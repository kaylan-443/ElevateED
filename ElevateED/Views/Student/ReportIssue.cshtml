@model ElevateED.ViewModels.CreateIssueViewModel

@{
    ViewBag.Title = "Report an Issue";
}

<style>
    .issue-container {
        max-width: 700px;
        margin: 0 auto;
        padding: 20px;
    }

    .issue-card {
        background: white;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

    .issue-header {
        text-align: center;
        margin-bottom: 30px;
    }

        .issue-header h2 {
            color: #1e3c72;
            margin-bottom: 10px;
        }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        display: block;
    }

    .form-control {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 10px 15px;
        width: 100%;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #1e3c72;
            outline: none;
            box-shadow: 0 0 0 3px rgba(30, 60, 114, 0.1);
        }

    textarea.form-control {
        resize: vertical;
        min-height: 120px;
    }

    .btn-submit {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
        padding: 12px 30px;
        border-radius: 25px;
        border: none;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        width: 100%;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(220, 53, 69, 0.3);
        }

    .btn-cancel {
        background: #6c757d;
        color: white;
        padding: 12px 30px;
        border-radius: 25px;
        border: none;
        font-size: 16px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        text-align: center;
        width: 100%;
        transition: all 0.3s ease;
    }

        .btn-cancel:hover {
            background: #5a6268;
            color: white;
            text-decoration: none;
        }

    .anonymous-check {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 15px;
        background: #f8f9fa;
        border-radius: 10px;
        margin-bottom: 20px;
    }

        .anonymous-check input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }

    .info-box {
        background: #e7f3ff;
        border-left: 4px solid #1e3c72;
        padding: 15px;
        margin-bottom: 20px;
        border-radius: 5px;
        font-size: 14px;
    }

    .required::after {
        content: " *";
        color: #dc3545;
    }
</style>

<div class="container issue-container">
    <div class="issue-card">
        <div class="issue-header">
            <h2><i class="fas fa-exclamation-circle text-danger"></i> Report an Issue</h2>
            <p class="text-muted">Report problems, concerns, or incidents to school administration</p>
        </div>

        <div class="info-box">
            <i class="fas fa-shield-alt"></i>
            <strong>Your safety matters.</strong> If this is an emergency or involves immediate danger,
            please contact a teacher or staff member directly or call the emergency number.
        </div>

        <form id="issueForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label required">Issue Title</label>
                <input type="text" name="Title" class="form-control" required
                       placeholder="Brief summary of the issue (e.g., 'Bullying in Grade 10A')" />
            </div>

            <div class="form-group">
                <label class="form-label required">Category</label>
                <select name="Category" class="form-control" required>
                    <option value="">-- Select Category --</option>
                    <option value="Academic">Academic (Grades, Exams, Homework)</option>
                    <option value="Technical">Technical (Computer, Website, App)</option>
                    <option value="Bullying">Bullying or Harassment</option>
                    <option value="Facility">Facility (Classroom, Bathroom, Equipment)</option>
                    <option value="Discipline">Discipline (Behavior, Rules)</option>
                    <option value="Other">Other</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label required">Description</label>
                <textarea name="Description" class="form-control" required
                          placeholder="Please provide detailed information about the issue. Include dates, times, locations, and any people involved."></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">Attachment (Optional)</label>
                <input type="file" name="Attachment" class="form-control" accept=".jpg,.jpeg,.png,.pdf,.doc,.docx" />
                <small class="text-muted">Max file size: 5MB. Images or documents only.</small>
            </div>

            <div class="anonymous-check">
                <input type="checkbox" name="IsAnonymous" id="IsAnonymous" value="true" />
                <label for="IsAnonymous" style="margin: 0; cursor: pointer;">
                    <strong>Report Anonymously</strong><br />
                    <small class="text-muted">Your name will not be visible to other students. Admin can still see your identity for safety reasons.</small>
                </label>
            </div>

            <div id="message" class="alert" style="display: none;"></div>

            <div class="row mt-4">
                <div class="col-md-6 mb-2">
                    <a href="@Url.Action("Dashboard", "Student")" class="btn-cancel">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
                <div class="col-md-6">
                    <button type="button" class="btn-submit" onclick="submitIssue()">
                        <i class="fas fa-paper-plane"></i> Submit Report
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<script>
    function submitIssue() {
        var form = document.getElementById('issueForm');
        var formData = new FormData(form);
        var title = $('input[name="Title"]').val();
        var category = $('select[name="Category"]').val();
        var description = $('textarea[name="Description"]').val();

        if (!title || !category || !description) {
            alert('Please fill in all required fields');
            return;
        }

        $('#message').hide();

        $.ajax({
            url: '@Url.Action("ReportIssue", "Student")',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            success: function(response) {
                if (response.success) {
                    $('#message').removeClass('alert-danger').addClass('alert-success')
                        .html('<i class="fas fa-check-circle"></i> ' + response.message).show();
                    setTimeout(function() {
                        window.location.href = '@Url.Action("MyIssues", "Student")';
                    }, 2000);
                } else {
                    $('#message').removeClass('alert-success').addClass('alert-danger')
                        .html('<i class="fas fa-exclamation-circle"></i> ' + response.message).show();
                }
            },
            error: function() {
                $('#message').removeClass('alert-success').addClass('alert-danger')
                    .html('<i class="fas fa-exclamation-circle"></i> An error occurred').show();
            }
        });
    }
</script>