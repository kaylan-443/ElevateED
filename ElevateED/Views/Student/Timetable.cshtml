@model ElevateED.ViewModels.StudentTimetableViewModel

@{
    ViewBag.Title = "My Timetable - ElevateED";
}

<style>
    .timetable-container {
        padding: 20px 0 40px 0;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 15px;
        border-bottom: 2px solid #e0e0e0;
        flex-wrap: wrap;
        gap: 15px;
    }

    .header-left h2 {
        margin: 0;
        color: #1e3c72;
        font-weight: 700;
    }

        .header-left h2 i {
            color: #d4af37;
            margin-right: 10px;
        }

    .header-left p {
        margin: 5px 0 0 0;
        color: #666;
    }

    .btn-back {
        background: #6c757d;
        color: white;
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        text-decoration: none;
        display: inline-block;
    }

        .btn-back:hover {
            background: #5a6268;
            color: white;
            transform: translateY(-2px);
            text-decoration: none;
        }

    .class-info-card {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        padding: 20px;
        border-radius: 15px;
        margin-bottom: 30px;
    }

        .class-info-card h3 {
            margin: 0 0 10px 0;
        }

        .class-info-card p {
            margin: 0;
            opacity: 0.9;
        }

    .timetable-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .timetable-header {
        background: #f8f9fa;
        padding: 20px;
        border-bottom: 1px solid #e0e0e0;
    }

        .timetable-header h4 {
            margin: 0;
            color: #1e3c72;
        }

    .timetable-body {
        padding: 20px;
    }

    .pdf-viewer {
        width: 100%;
        height: 600px;
        border: 1px solid #ddd;
        border-radius: 8px;
    }

    .no-timetable {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

        .no-timetable i {
            font-size: 64px;
            color: #ddd;
            margin-bottom: 20px;
        }

        .no-timetable h4 {
            color: #666;
            margin-bottom: 10px;
        }

        .no-timetable p {
            color: #999;
        }

    .btn-download {
        background: #28a745;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 15px;
        transition: all 0.3s ease;
    }

        .btn-download:hover {
            background: #218838;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }

    .info-text {
        background: #e3f2fd;
        padding: 15px;
        border-radius: 8px;
        margin-top: 20px;
        font-size: 14px;
        color: #1e3c72;
    }
</style>

<div class="container timetable-container">
    <div class="page-header">
        <div class="header-left">
            <h2>
                <i class="fas fa-calendar-alt"></i> My Timetable
            </h2>
            <p>View your weekly class schedule</p>
        </div>
        <div>
            <a href="@Url.Action("Dashboard", "Student")" class="btn-back">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <!-- Class Information -->
    <div class="class-info-card">
        <h3><i class="fas fa-graduation-cap"></i> @Model.StudentName</h3>
        <p><strong>Student Number:</strong> @Model.StudentNumber | <strong>Class:</strong> @Model.ClassName | <strong>Grade:</strong> @Model.Grade</p>
    </div>

    @if (Model.HasTimetable && !string.IsNullOrEmpty(Model.TimetableFilePath))
    {
        <div class="timetable-card">
            <div class="timetable-header">
                <h4><i class="fas fa-table"></i> @Model.TimetableTitle</h4>
                @if (!string.IsNullOrEmpty(Model.TimetableDescription))
                {
                    <p class="mb-0 mt-2 text-muted">@Model.TimetableDescription</p>
                }
                @if (Model.UploadedDate.HasValue)
                {
                    <small class="text-muted">Last updated: @Model.UploadedDate.Value.ToString("dd MMM yyyy")</small>
                }
            </div>
            <div class="timetable-body">
                @if (Model.TimetableFilePath.ToLower().EndsWith(".pdf"))
                {
                    <embed src="@Model.TimetableFilePath" type="application/pdf" class="pdf-viewer" />
                }
                else if (Model.TimetableFilePath.ToLower().EndsWith(".jpg") || Model.TimetableFilePath.ToLower().EndsWith(".jpeg") || Model.TimetableFilePath.ToLower().EndsWith(".png"))
                {
                    <img src="@Model.TimetableFilePath" alt="Timetable" style="width: 100%; border-radius: 8px;" />
                }
                else
                {
                    <div class="text-center">
                        <p>Click the button below to view/download your timetable.</p>
                        <a href="@Model.TimetableFilePath" target="_blank" class="btn-download">
                            <i class="fas fa-download"></i> Download Timetable
                        </a>
                    </div>
                }
            </div>
        </div>

        <div class="info-text">
            <i class="fas fa-info-circle"></i>
            <strong>Note:</strong> This timetable is for <strong>@Model.ClassName</strong> only. Please check with your class teacher if you notice any discrepancies.
        </div>
    }
    else
    {
        <div class="no-timetable">
            <i class="fas fa-calendar-times"></i>
            <h4>No Timetable Available</h4>
            <p>Your class timetable has not been uploaded yet.</p>
            <p>Please check back later or contact your class teacher.</p>
            <div class="info-text" style="margin-top: 20px; display: inline-block; text-align: left;">
                <strong>Class Information:</strong><br />
                Class: @Model.ClassName<br />
                Grade: @Model.Grade<br />
                Student Number: @Model.StudentNumber
            </div>
        </div>
    }
</div>