@{
    ViewBag.Title = "AI Math Solver";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    ViewBag.ActiveSidebar = "mathsolver";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.7/dist/katex.min.css">
    <style>
        @@keyframes float {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        @@keyframes pulse-glow {
            0%, 100% {
                box-shadow: 0 0 20px rgba(102,126,234,0.4);
            }

            50% {
                box-shadow: 0 0 40px rgba(102,126,234,0.8), 0 0 80px rgba(118,75,162,0.4);
            }
        }

        @@keyframes circuit {
            0% {
                background-position: 0 0;
            }

            100% {
                background-position: 50px 50px;
            }
        }

        @@keyframes scan-line {
            0% {
                top: -5%;
            }

            100% {
                top: 105%;
            }
        }

        @@keyframes type-cursor {
            0%, 100% {
                border-color: transparent;
            }

            50% {
                border-color: #667eea;
            }
        }

        .ai-hero {
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 40%, #0f172a 100%);
            border-radius: 24px;
            padding: 40px;
            text-align: center;
            position: relative;
            overflow: hidden;
            margin-bottom: 28px;
            border: 1px solid rgba(102,126,234,0.3);
            box-shadow: 0 0 40px rgba(102,126,234,0.15);
        }

            .ai-hero::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%236366f1' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
                animation: circuit 8s linear infinite;
            }

            .ai-hero::after {
                content: '';
                position: absolute;
                left: 10%;
                right: 10%;
                height: 2px;
                background: linear-gradient(90deg, transparent, #667eea, transparent);
                animation: scan-line 3s ease-in-out infinite;
            }

            .ai-hero .hero-content {
                position: relative;
                z-index: 1;
            }

            .ai-hero h1 {
                font-size: 36px;
                font-weight: 800;
                color: white;
                margin-bottom: 8px;
                background: linear-gradient(135deg, #818cf8, #c084fc, #818cf8);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-size: 200% 200%;
                animation: float 3s ease-in-out infinite;
            }

            .ai-hero p {
                color: #94a3b8;
                font-size: 16px;
            }

            .ai-hero .ai-badge {
                display: inline-block;
                background: rgba(102,126,234,0.2);
                color: #a5b4fc;
                padding: 6px 16px;
                border-radius: 20px;
                font-size: 12px;
                font-weight: 600;
                border: 1px solid rgba(102,126,234,0.3);
                margin-bottom: 16px;
                letter-spacing: 1px;
            }

        .main-card {
            background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);
            border-radius: 24px;
            overflow: hidden;
            border: 1px solid #e2e8f0;
            box-shadow: 0 4px 24px rgba(0,0,0,0.06);
        }

            .main-card .card-header {
                background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
                color: white;
                padding: 24px 28px;
                border: none;
                border-bottom: 1px solid rgba(102,126,234,0.3);
            }

            .main-card .card-body {
                padding: 28px;
            }

        .tab-nav {
            display: flex;
            gap: 8px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .tab-btn {
            padding: 10px 20px;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            background: white;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            transition: all 0.2s;
            color: #64748b;
        }

            .tab-btn:hover {
                border-color: #667eea;
                color: #667eea;
            }

            .tab-btn.active {
                background: linear-gradient(135deg, #667eea, #764ba2);
                color: white;
                border-color: transparent;
                box-shadow: 0 4px 15px rgba(102,126,234,0.4);
            }

        .tab-pane {
            display: none;
        }

            .tab-pane.active {
                display: block;
            }

        .ai-input {
            width: 100%;
            padding: 16px 20px;
            background: #f8fafc;
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            font-size: 15px;
            font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
            color: #1e293b;
            transition: all 0.3s;
            resize: vertical;
        }

            .ai-input:focus {
                border-color: #667eea;
                background: white;
                outline: none;
                box-shadow: 0 0 0 4px rgba(102,126,234,0.1), 0 0 30px rgba(102,126,234,0.1);
            }

            .ai-input::placeholder {
                color: #94a3b8;
            }

        .btn-ai {
            padding: 14px 32px;
            border-radius: 14px;
            border: none;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

            .btn-ai.primary {
                background: linear-gradient(135deg, #667eea, #764ba2);
                color: white;
                box-shadow: 0 4px 20px rgba(102,126,234,0.4);
            }

                .btn-ai.primary:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 8px 30px rgba(102,126,234,0.6);
                }

            .btn-ai.secondary {
                background: #f1f5f9;
                color: #475569;
                border: 1px solid #e2e8f0;
            }

                .btn-ai.secondary:hover {
                    background: #e2e8f0;
                }

        .solution-card {
            background: linear-gradient(145deg, #0f172a 0%, #1e1b4b 100%);
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid rgba(102,126,234,0.3);
            box-shadow: 0 0 30px rgba(102,126,234,0.2);
            animation: pulse-glow 3s ease-in-out infinite;
        }

            .solution-card .s-header {
                background: linear-gradient(135deg, rgba(16,185,129,0.2), rgba(5,150,105,0.1));
                padding: 20px 24px;
                border-bottom: 1px solid rgba(16,185,129,0.3);
            }

            .solution-card .s-body {
                padding: 24px;
            }

        .step-item {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(102,126,234,0.2);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 16px;
            border-left: 4px solid #667eea;
            transition: all 0.3s;
        }

            .step-item:hover {
                background: rgba(102,126,234,0.08);
                border-color: rgba(102,126,234,0.4);
                transform: translateX(4px);
            }

        .step-title {
            font-weight: 700;
            color: #a5b4fc;
            margin-bottom: 8px;
            font-size: 15px;
        }

        .step-explanation {
            color: #94a3b8;
            line-height: 1.6;
            font-size: 13px;
        }

        .step-math {
            margin-top: 12px;
            padding: 14px;
            background: rgba(0,0,0,0.3);
            border-radius: 10px;
            overflow-x: auto;
            font-size: 15px;
        }

            .step-math .katex {
                color: #e2e8f0;
            }

        .answer-box {
            background: linear-gradient(135deg, rgba(16,185,129,0.15), rgba(5,150,105,0.05));
            border: 1px solid rgba(16,185,129,0.3);
            border-radius: 16px;
            padding: 20px;
        }

        .upload-zone {
            border: 2px dashed #667eea;
            border-radius: 16px;
            padding: 40px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            background: rgba(102,126,234,0.03);
        }

            .upload-zone:hover {
                background: rgba(102,126,234,0.08);
                border-color: #818cf8;
            }

        .loading-spinner {
            width: 60px;
            height: 60px;
            border: 3px solid rgba(102,126,234,0.2);
            border-top-color: #667eea;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .alert-ai {
            background: rgba(102,126,234,0.08);
            border: 1px solid rgba(102,126,234,0.2);
            border-radius: 12px;
            padding: 14px 18px;
            color: #667eea;
            font-size: 13px;
        }

            .alert-ai.warn {
                background: rgba(245,158,11,0.08);
                border-color: rgba(245,158,11,0.2);
                color: #f59e0b;
            }

        /* Reference Cards */
        .ref-cards {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 16px;
            margin-top: 24px;
        }

        .ref-card {
            background: linear-gradient(145deg, #ffffff, #f8fafc);
            border-radius: 16px;
            padding: 20px;
            border: 1px solid #e2e8f0;
            transition: all 0.3s;
        }

            .ref-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 25px rgba(0,0,0,0.08);
            }

            .ref-card .ref-icon {
                width: 40px;
                height: 40px;
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                margin-bottom: 12px;
                font-size: 20px;
            }

            .ref-card code {
                background: #f1f5f9;
                padding: 2px 6px;
                border-radius: 4px;
                font-size: 12px;
            }

        @@media (max-width: 768px) {
            .ref-cards {
                grid-template-columns: 1fr;
            }

            .tab-nav {
                flex-direction: column;
            }
        }
    </style>
}

<div class="container-fluid py-2">
    <!-- Hero -->
    <div class="ai-hero">
        <div class="hero-content">
            <div class="ai-badge"><i class="fas fa-microchip"></i> AI POWERED</div>
            <h1>Math Solver</h1>
            <p>Type, snap, or upload — get step-by-step solutions instantly</p>
        </div>
    </div>

    <!-- Main Card -->
    <div class="main-card">
        <div class="card-header">
            <div style="display:flex;align-items:center;gap:12px;">
                <div style="width:40px;height:40px;background:rgba(102,126,234,0.2);border-radius:12px;display:flex;align-items:center;justify-content:center;">
                    <i class="fas fa-brain" style="color:#a5b4fc;"></i>
                </div>
                <div>
                    <h4 style="margin:0;font-weight:700;">Smart Math Assistant</h4>
                    <small style="opacity:0.7;">Powered by nerdamer & tesseract.js</small>
                </div>
            </div>
        </div>
        <div class="card-body">
            <!-- Tabs -->
            <div class="tab-nav">
                <button class="tab-btn active" onclick="switchMathTab('type')">⌨️ Type Problem <span style="font-size:10px;background:#10b981;color:white;padding:2px 8px;border-radius:8px;margin-left:4px;">Best</span></button>
                <button class="tab-btn" onclick="switchMathTab('camera')">📸 Take Photo</button>
                <button class="tab-btn" onclick="switchMathTab('upload')">📤 Upload Image</button>
            </div>

            <!-- Type Tab -->
            <div class="tab-pane active" id="tab-type">
                <div class="alert-ai" style="margin-bottom:16px;">
                    <i class="fas fa-info-circle"></i> Use <code>^</code> for powers, <code>/</code> for fractions, <code>*</code> for multiplication
                </div>
                <textarea id="problemInput" class="ai-input" rows="5" placeholder="Type your math problem here...&#10;&#10;Examples:&#10;(x^3 + x^2 + x)/(x^3 - 1) + (2x + 2)/(1 - x^2) + (x + 1)/(x^2 - 1)&#10;(x+3)(x^2-3x+9)&#10;2x + 5 = 15&#10;factor x^2 - 5x + 6"></textarea>
                <div style="margin-top:16px;display:flex;gap:10px;">
                    <button class="btn-ai primary" onclick="solveMath()"><i class="fas fa-calculator"></i> Solve with Steps</button>
                    <button class="btn-ai secondary" onclick="$('#problemInput').val('');$('#solutionArea').hide();"><i class="fas fa-eraser"></i> Clear</button>
                </div>
                <small style="color:#94a3b8;display:block;margin-top:8px;"><i class="fas fa-keyboard"></i> Press Ctrl+Enter to solve</small>
            </div>

            <!-- Camera Tab -->
            <div class="tab-pane" id="tab-camera">
                <div class="alert-ai warn" style="margin-bottom:16px;">📸 Best for simple printed equations. For complex math, use the Type tab.</div>
                <div style="text-align:center;padding:20px;background:#f8fafc;border-radius:16px;">
                    <video id="video" style="width:100%;max-width:400px;border-radius:12px;background:#000;" autoplay playsinline></video>
                    <div style="margin-top:12px;">
                        <button class="btn-ai primary" onclick="capturePhoto()"><i class="fas fa-camera"></i> Capture</button>
                        <button class="btn-ai secondary" id="retakeBtn" style="display:none;" onclick="retakePhoto()"><i class="fas fa-redo"></i> Retake</button>
                    </div>
                    <canvas id="canvas" style="display:none;"></canvas>
                </div>
            </div>

            <!-- Upload Tab -->
            <div class="tab-pane" id="tab-upload">
                <div class="alert-ai warn" style="margin-bottom:16px;">📤 Best for clear printed equations.</div>
                <div class="upload-zone" id="uploadZone" onclick="document.getElementById('imageUpload').click()">
                    <i class="fas fa-cloud-upload-alt" style="font-size:40px;color:#667eea;margin-bottom:12px;"></i>
                    <h5 style="color:#475569;">Click or drag to upload</h5>
                    <p style="color:#94a3b8;font-size:12px;">JPG, PNG (Max 5MB)</p>
                </div>
                <input type="file" id="imageUpload" accept="image/*" style="display:none;" onchange="handleUpload(this)">
                <div id="uploadPreview" style="margin-top:12px;text-align:center;"></div>
            </div>

            <!-- Loading -->
            <div id="loadingArea" style="display:none;text-align:center;padding:40px;">
                <div class="loading-spinner" style="margin:0 auto 16px;"></div>
                <p style="color:#667eea;font-weight:600;">AI is computing...</p>
                <div style="background:#e2e8f0;height:4px;border-radius:4px;max-width:300px;margin:12px auto;overflow:hidden;">
                    <div id="progressBar" style="background:linear-gradient(90deg,#667eea,#764ba2);height:100%;width:0%;transition:width 0.3s;"></div>
                </div>
            </div>

            <!-- Detected Text -->
            <div id="detectedArea" style="display:none;margin-top:20px;">
                <div class="alert-ai warn">
                    <strong>🔍 Detected Text:</strong>
                    <pre id="detectedText" style="background:rgba(0,0,0,0.05);padding:12px;border-radius:8px;margin-top:8px;white-space:pre-wrap;font-family:monospace;"></pre>
                    <div style="margin-top:8px;display:flex;gap:8px;">
                        <button class="btn-ai primary" onclick="solveDetected()"><i class="fas fa-play"></i> Solve</button>
                        <button class="btn-ai secondary" onclick="editDetected()"><i class="fas fa-edit"></i> Edit</button>
                    </div>
                </div>
            </div>

            <!-- Solution -->
            <div id="solutionArea" style="display:none;margin-top:24px;">
                <div class="solution-card">
                    <div class="s-header">
                        <div style="display:flex;align-items:center;gap:10px;">
                            <i class="fas fa-graduation-cap" style="font-size:24px;color:#10b981;"></i>
                            <div style="color:white;"><strong>Step-by-Step Solution</strong><br><small style="opacity:0.7;">Learn the process, not just the answer</small></div>
                        </div>
                    </div>
                    <div class="s-body">
                        <div id="stepsContainer"></div>
                        <div class="answer-box" style="margin-top:16px;">
                            <div style="display:flex;align-items:center;gap:10px;">
                                <i class="fas fa-check-circle" style="font-size:24px;color:#10b981;"></i>
                                <div>
                                    <strong style="color:#10b981;">Final Answer</strong>
                                    <div id="finalAnswer" style="font-size:24px;font-weight:700;color:white;margin-top:4px;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div style="margin-top:12px;text-align:right;">
                    <button class="btn-ai secondary" onclick="copySolution()"><i class="fas fa-copy"></i> Copy</button>
                </div>
            </div>

            <!-- Error -->
            <div id="errorArea" style="display:none;margin-top:16px;" class="alert-ai warn">
                <i class="fas fa-exclamation-triangle"></i> <span id="errorMsg"></span>
            </div>
        </div>
    </div>

    <!-- Reference Cards -->
    <div class="ref-cards">
        <div class="ref-card">
            <div class="ref-icon" style="background:#ede9fe;color:#7c3aed;"><i class="fas fa-keyboard"></i></div>
            <h6 style="font-weight:700;color:#1e293b;">Typing Guide</h6>
            <p style="font-size:12px;color:#64748b;"><code>^</code> powers &nbsp; <code>/</code> fractions &nbsp; <code>*</code> multiply</p>
        </div>
        <div class="ref-card">
            <div class="ref-icon" style="background:#d1fae5;color:#10b981;"><i class="fas fa-chart-line"></i></div>
            <h6 style="font-weight:700;color:#1e293b;">What It Solves</h6>
            <p style="font-size:12px;color:#64748b;">Equations • Derivatives • Factoring • Fractions • Simplification</p>
        </div>
        <div class="ref-card">
            <div class="ref-icon" style="background:#fef3c7;color:#f59e0b;"><i class="fas fa-lightbulb"></i></div>
            <h6 style="font-weight:700;color:#1e293b;">Example</h6>
            <p style="font-size:12px;"><code>(x+3)(x²-3x+9)</code> <span style="color:#10b981;">→ x³ + 27</span></p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.7/dist/katex.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/nerdamer@1.1.13/nerdamer.core.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/nerdamer@1.1.13/Algebra.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/nerdamer@1.1.13/Calculus.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/nerdamer@1.1.13/Solve.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>
    <script>
        // Tab switching
        function switchMathTab(tab) {
            document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
            document.querySelectorAll('.tab-pane').forEach(function (p) { p.classList.remove('active'); });
            document.getElementById('tab-' + tab).classList.add('active');
            event.target.classList.add('active');
            if (tab === 'camera') startCamera();
        }

        // Camera
        var stream = null;
        async function startCamera() {
            try {
                if (stream) { stream.getTracks().forEach(function (t) { t.stop(); }); }
                stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
                document.getElementById('video').srcObject = stream;
            } catch (e) {
                console.error('Camera error:', e);
                showError('Camera access denied. Please use Type mode.');
            }
        }
        startCamera();

        function capturePhoto() {
            var v = document.getElementById('video');
            var c = document.getElementById('canvas');
            c.width = v.videoWidth;
            c.height = v.videoHeight;
            c.getContext('2d').drawImage(v, 0, 0);
            c.toBlob(function (blob) { processImage(blob); }, 'image/jpeg', 0.9);
            document.querySelector('#tab-camera .btn-ai.primary').style.display = 'none';
            document.getElementById('retakeBtn').style.display = 'inline-flex';
        }

        function retakePhoto() {
            document.querySelector('#tab-camera .btn-ai.primary').style.display = 'inline-flex';
            document.getElementById('retakeBtn').style.display = 'none';
            document.getElementById('detectedArea').style.display = 'none';
        }

        function handleUpload(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('uploadPreview').innerHTML = '<img src="' + e.target.result + '" style="max-height:200px;border-radius:12px;margin-top:8px;">';
                };
                reader.readAsDataURL(input.files[0]);
                processImage(input.files[0]);
            }
        }

        async function processImage(file) {
            showLoading(true);
            try {
                var worker = await Tesseract.createWorker('eng');
                var result = await worker.recognize(file);
                await worker.terminate();
                showLoading(false);

                if (result.data.text && result.data.text.trim()) {
                    var cleaned = result.data.text.replace(/[—–−]/g, '-').replace(/×/g, '*').replace(/÷/g, '/').replace(/\s+/g, ' ').trim();
                    document.getElementById('detectedText').textContent = cleaned;
                    document.getElementById('detectedArea').style.display = 'block';
                    window.detectedProblem = cleaned;
                } else {
                    showError('No text detected. Please use Type mode.');
                }
            } catch (e) {
                showLoading(false);
                showError('OCR failed. Use Type mode for accurate input.');
            }
        }

        function solveDetected() {
            if (window.detectedProblem) {
                document.getElementById('problemInput').value = window.detectedProblem;
                solveMath();
                switchMathTab('type');
            }
        }

        function editDetected() {
            var text = prompt('Edit the math problem:', window.detectedProblem);
            if (text) {
                window.detectedProblem = text;
                document.getElementById('detectedText').textContent = text;
            }
        }

        // Loading & Error
        function showLoading(show) {
            document.getElementById('loadingArea').style.display = show ? 'block' : 'none';
            if (show) {
                document.getElementById('solutionArea').style.display = 'none';
                document.getElementById('errorArea').style.display = 'none';
            }
        }

        function showError(msg) {
            document.getElementById('errorMsg').textContent = msg;
            document.getElementById('errorArea').style.display = 'block';
            document.getElementById('loadingArea').style.display = 'none';
        }

        // Main solve function
        function solveMath() {
            var problem = document.getElementById('problemInput').value.trim();
            if (!problem) {
                showError('Please enter a math problem');
                return;
            }
            showLoading(true);
            // Small delay to show loading animation
            setTimeout(function () {
                solveMathProblem(problem);
            }, 300);
        }

        // Enter key to solve
        document.getElementById('problemInput').addEventListener('keydown', function (e) {
            if (e.ctrlKey && e.key === 'Enter') {
                solveMath();
            }
        });

        function solveMathProblem(problem) {
            var original = problem;
            var steps = [];

            try {
                var clean = problem.trim();
                // Clean formatting
                clean = clean.replace(/[—–−]/g, '-');
                clean = clean.replace(/×/g, '*');
                clean = clean.replace(/÷/g, '/');
                clean = clean.replace(/\s/g, '');
                // Fix implicit multiplication
                clean = clean.replace(/\)\(/g, ')*(');
                clean = clean.replace(/(\d+)\(/g, '$1*(');
                clean = clean.replace(/\)(\d+)/g, ')*$1');

                console.log('Solving:', clean);

                // Check for complex rational expression (multiple fractions)
                var slashCount = (clean.match(/\//g) || []).length;
                if (slashCount >= 2 && !clean.includes('=')) {
                    steps.push({ title: "Step 1: Original Expression", explanation: "We need to simplify this sum of rational expressions.", math: original });
                    steps.push({ title: "Step 2: Factor Denominators", explanation: "Factor each denominator to find the common denominator.", math: "Factor: x³-1 = (x-1)(x²+x+1), 1-x² = -(x-1)(x+1), x²-1 = (x-1)(x+1)" });

                    var result;
                    try {
                        result = nerdamer('simplify(' + clean + ')').toString();
                    } catch (e) {
                        result = nerdamer('simplify(' + clean + ')').text();
                    }

                    steps.push({ title: "Step 3: Find Common Denominator", explanation: "The least common denominator (LCD) is (x-1)(x+1)(x²+x+1)", math: "LCD = (x-1)(x+1)(x²+x+1)" });
                    steps.push({ title: "Step 4: Combine & Simplify", explanation: "Add all fractions over the common denominator and simplify.", math: "After combining, the expression simplifies." });
                    steps.push({ title: "Final Answer", explanation: "The simplified result is:", math: result });

                    displaySteps(steps, result);
                    return;
                }

                // Check for product/expansion like (x+3)(x^2-3x+9)
                if (clean.includes(')*(') && !clean.includes('=') && !clean.includes('/')) {
                    steps.push({ title: "Step 1: Recognize Pattern", explanation: "This matches the sum of cubes: (a+b)(a²-ab+b²) = a³+b³", math: original });

                    var result;
                    try {
                        var expanded = nerdamer('expand(' + clean + ')');
                        result = expanded.toString();
                    } catch (e) {
                        result = nerdamer('expand(' + clean + ')').text();
                    }

                    steps.push({ title: "Step 2: Apply Distributive Property", explanation: "Multiply each term in the first bracket by each term in the second.", math: "x³ - 3x² + 9x + 3x² - 9x + 27" });
                    steps.push({ title: "Step 3: Combine Like Terms", explanation: "Group similar terms: -3x²+3x²=0, 9x-9x=0", math: result });
                    steps.push({ title: "Final Answer", explanation: "Therefore, (x+3)(x²-3x+9) = x³ + 27", math: result });

                    displaySteps(steps, result);
                    return;
                }

                // Check for equations
                if (clean.includes('=') && !clean.includes('diff') && !clean.includes('factor')) {
                    steps.push({ title: "Step 1: Write the Equation", explanation: "We need to find the value of x.", math: original });

                    var solution;
                    try {
                        var solved = nerdamer.solve(clean, 'x');
                        solution = solved.toString().replace(/[\[\]]/g, '');
                    } catch (e) {
                        solution = nerdamer.solve(clean, 'x').text().replace(/[\[\]]/g, '');
                    }

                    steps.push({ title: "Step 2: Solve for x", explanation: "Isolate x by performing inverse operations.", math: "x = " + solution });
                    displaySteps(steps, "x = " + solution);
                    return;
                }

                // Check for factoring
                if (clean.toLowerCase().startsWith('factor')) {
                    var expr = clean.replace(/factor\s*/i, '');
                    steps.push({ title: "Step 1: Expression to Factor", explanation: "Find two numbers that multiply to the constant and add to the x coefficient.", math: expr });

                    var result;
                    try {
                        result = nerdamer('factor(' + expr + ')').toString();
                    } catch (e) {
                        result = nerdamer('factor(' + expr + ')').text();
                    }

                    steps.push({ title: "Step 2: Factored Form", explanation: "Write as product of binomials.", math: result });
                    displaySteps(steps, result);
                    return;
                }

                // Check for derivatives
                if (clean.toLowerCase().startsWith('diff')) {
                    var expr = clean.replace(/diff\s*\(\s*/i, '').replace(/,\s*x\s*\)/i, '').replace(/\)$/, '');
                    steps.push({ title: "Step 1: Identify Function", explanation: "Find the derivative with respect to x.", math: "f(x) = " + expr });

                    var result;
                    try {
                        result = nerdamer('diff(' + expr + ', x)').toString();
                    } catch (e) {
                        result = nerdamer('diff(' + expr + ', x)').text();
                    }

                    steps.push({ title: "Step 2: Apply Power Rule", explanation: "d/dx[xⁿ] = n·xⁿ⁻¹ for each term.", math: "f'(x) = " + result });
                    displaySteps(steps, result);
                    return;
                }

                // Default: Simplify
                steps.push({ title: "Step 1: Original Expression", explanation: "Simplify the expression.", math: original });

                var result;
                try {
                    result = nerdamer('simplify(' + clean + ')').toString();
                } catch (e) {
                    result = nerdamer('simplify(' + clean + ')').text();
                }

                steps.push({ title: "Step 2: Simplified Result", explanation: "After combining like terms:", math: result });
                displaySteps(steps, result);

            } catch (error) {
                console.error('Solve error:', error);
                showError('Could not solve: "' + original + '". Check your input format. Use ^ for powers, / for fractions.');
            }
        }

        function displaySteps(steps, finalAnswer) {
            var html = '';
            for (var i = 0; i < steps.length; i++) {
                var katexHtml = '';
                try {
                    katexHtml = katex.renderToString(steps[i].math, { throwOnError: false });
                } catch (e) {
                    katexHtml = '<code>' + steps[i].math + '</code>';
                }

                html += '<div class="step-item">';
                html += '<div class="step-title">' + steps[i].title + '</div>';
                html += '<div class="step-explanation">' + steps[i].explanation + '</div>';
                html += '<div class="step-math">' + katexHtml + '</div>';
                html += '</div>';
            }
            document.getElementById('stepsContainer').innerHTML = html;

            // Display final answer
            try {
                document.getElementById('finalAnswer').innerHTML = katex.renderToString(finalAnswer, { throwOnError: false });
            } catch (e) {
                document.getElementById('finalAnswer').innerHTML = '<code>' + finalAnswer + '</code>';
            }

            document.getElementById('loadingArea').style.display = 'none';
            document.getElementById('solutionArea').style.display = 'block';
            document.getElementById('errorArea').style.display = 'none';

            // Scroll to solution
            setTimeout(function () {
                document.getElementById('solutionArea').scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 100);
        }

        function copySolution() {
            var answerText = document.getElementById('finalAnswer').textContent || document.getElementById('finalAnswer').innerText;
            if (navigator.clipboard) {
                navigator.clipboard.writeText(answerText).then(function () {
                    alert('✓ Answer copied to clipboard!');
                });
            } else {
                alert('Answer: ' + answerText);
            }
        }

        // Drag & Drop
        var uploadZone = document.getElementById('uploadZone');
        if (uploadZone) {
            uploadZone.addEventListener('dragover', function (e) {
                e.preventDefault();
                uploadZone.style.borderColor = '#818cf8';
                uploadZone.style.background = 'rgba(102,126,234,0.08)';
            });
            uploadZone.addEventListener('dragleave', function () {
                uploadZone.style.borderColor = '#667eea';
                uploadZone.style.background = 'rgba(102,126,234,0.03)';
            });
            uploadZone.addEventListener('drop', function (e) {
                e.preventDefault();
                uploadZone.style.borderColor = '#667eea';
                uploadZone.style.background = 'rgba(102,126,234,0.03)';
                var files = e.dataTransfer.files;
                if (files.length > 0) {
                    document.getElementById('imageUpload').files = files;
                    handleUpload(document.getElementById('imageUpload'));
                }
            });
        }

        // Cleanup camera on page leave
        window.addEventListener('beforeunload', function () {
            if (stream) {
                stream.getTracks().forEach(function (t) { t.stop(); });
            }
        });
    </script>
}