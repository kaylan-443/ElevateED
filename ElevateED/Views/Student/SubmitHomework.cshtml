@model ElevateED.ViewModels.SubmitHomeworkViewModel

@{
    ViewBag.Title = "Submit Homework - ElevateED";
}

<style>
    .submit-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px 0 40px 0;
    }

    .homework-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .homework-header {
        background: linear-gradient(135deg, #16a085, #1abc9c);
        color: white;
        padding: 25px;
    }

        .homework-header h2 {
            margin: 0 0 10px 0;
            font-weight: 700;
        }

        .homework-header p {
            margin: 0;
            opacity: 0.9;
        }

    .homework-body {
        padding: 30px;
    }

    .info-section {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 25px;
        border-left: 4px solid #16a085;
    }

        .info-section h4 {
            color: #16a085;
            margin-bottom: 15px;
            font-weight: 700;
        }

        .info-section p {
            margin-bottom: 8px;
            color: #555;
        }

        .info-section strong {
            color: #333;
        }

    .late-badge {
        background: #dc3545;
        color: white;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        display: inline-block;
    }

    .form-group {
        margin-bottom: 25px;
    }

    .form-label {
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        display: block;
    }

    .required::after {
        content: " *";
        color: #dc3545;
    }

    .file-drop-zone {
        border: 3px dashed #ddd;
        border-radius: 10px;
        padding: 60px 40px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
        background: #fafafa;
    }

        .file-drop-zone:hover {
            border-color: #16a085;
            background: #f0faf8;
        }

        .file-drop-zone.has-file {
            border-color: #16a085;
            background: #f0faf8;
        }

        .file-drop-zone.has-error {
            border-color: #dc3545;
            background: #fff0f0;
        }

    .file-input {
        display: none;
    }

    .file-name {
        margin-top: 15px;
        font-weight: 500;
        color: #16a085;
        font-size: 14px;
    }

    .file-hint {
        color: #999;
        font-size: 12px;
        margin-top: 10px;
    }

    .btn-submit {
        background: linear-gradient(135deg, #16a085, #1abc9c);
        color: white;
        padding: 14px 30px;
        border-radius: 25px;
        border: none;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        width: 100%;
        transition: all 0.3s ease;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(22, 160, 133, 0.3);
        }

        .btn-submit:disabled {
            background: #6c757d;
            cursor: not-allowed;
            transform: none;
        }

    .btn-cancel {
        background: #6c757d;
        color: white;
        padding: 14px 30px;
        border-radius: 25px;
        border: none;
        text-decoration: none;
        display: inline-block;
        text-align: center;
        width: 100%;
        transition: all 0.3s ease;
    }

        .btn-cancel:hover {
            background: #5a6268;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }

    .alert-warning {
        background: #fff3cd;
        border: 1px solid #ffc107;
        color: #856404;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    .error-message {
        color: #dc3545;
        font-size: 13px;
        margin-top: 5px;
        display: none;
    }

    .spinner {
        display: inline-block;
        width: 18px;
        height: 18px;
        border: 2px solid #fff;
        border-top-color: transparent;
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
        margin-right: 8px;
        vertical-align: middle;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="container submit-container">
    <div class="homework-card">
        <div class="homework-header">
            <h2><i class="fas fa-home"></i> Submit Homework</h2>
            <p>Complete and submit your homework assignment</p>
        </div>

        <div class="homework-body">
            <!-- Homework Information -->
            <div class="info-section">
                <h4><i class="fas fa-info-circle"></i> Assignment Details</h4>
                <p><strong>Title:</strong> @Model.Title</p>
                <p><strong>Subject:</strong> @Model.Subject</p>
                <p><strong>Due Date:</strong> @Model.DueDate.ToString("dd MMM yyyy, hh:mm tt")</p>
                @if (Model.IsLate)
                {
                    <p><span class="late-badge"><i class="fas fa-exclamation-triangle"></i> LATE SUBMISSION</span></p>
                }
                <hr />
                <p><strong>Instructions:</strong></p>
                <p style="white-space: pre-wrap;">@Model.Instructions</p>
            </div>

            @if (Model.IsResubmission)
            {
                <div class="alert-warning">
                    <i class="fas fa-info-circle"></i>
                    <strong>Note:</strong> You have already submitted this homework. Submitting again will replace your previous submission.
                </div>
            }

            <!-- Upload Form -->
            <form id="submitForm" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="HomeworkId" value="@Model.HomeworkId" />

                <div class="form-group">
                    <label class="form-label required">Upload Your Homework</label>
                    <div class="file-drop-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
                        <i class="fas fa-cloud-upload-alt fa-4x text-muted mb-3"></i>
                        <h5>Click to browse or drag & drop your file here</h5>
                        <p class="file-hint">Supported formats: PDF, Word, Excel, PowerPoint, Images (Max 10MB)</p>
                        <div id="fileName" class="file-name"></div>
                    </div>
                    <input type="file" id="fileInput" name="SubmissionFile" class="file-input"
                           accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.jpg,.jpeg,.png" required />
                    <div id="fileError" class="error-message"></div>
                </div>

                @if (!string.IsNullOrEmpty(Model.ExistingSubmission?.FilePath))
                {
                    <div class="alert alert-info" style="background: #e3f2fd; border-left: 4px solid #17a2b8; padding: 12px; border-radius: 8px; margin-bottom: 20px;">
                        <i class="fas fa-paperclip"></i>
                        <strong>Previously uploaded:</strong> @Model.ExistingSubmission.FileName
                        <br /><small class="text-muted">Upload a new file to replace your previous submission.</small>
                    </div>
                }

                <div id="message" class="alert" style="display: none;"></div>

                <div class="row mt-4">
                    <div class="col-md-6 mb-2">
                        <a href="@Url.Action("Homework", "Student")" class="btn-cancel">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                    <div class="col-md-6">
                        <button type="button" class="btn-submit" id="submitBtn" onclick="submitHomework()">
                            <i class="fas fa-paper-plane"></i> Submit Homework
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
<script>
    function handleFileSelect() {
        var input = document.getElementById('fileInput');
        var fileName = document.getElementById('fileName');
        var dropZone = document.getElementById('dropZone');
        var fileError = document.getElementById('fileError');

        if (input.files && input.files[0]) {
            var file = input.files[0];
            var maxSize = 10 * 1024 * 1024;
            var allowedExtensions = ['.pdf', '.doc', '.docx', '.xls', '.xlsx', '.ppt', '.pptx', '.jpg', '.jpeg', '.png'];
            var fileExt = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();

            if (file.size > maxSize) {
                dropZone.classList.add('has-error');
                fileError.textContent = 'File size exceeds 10MB limit. Please choose a smaller file.';
                fileError.style.display = 'block';
                fileName.textContent = '';
                return false;
            }

            if (allowedExtensions.indexOf(fileExt) === -1) {
                dropZone.classList.add('has-error');
                fileError.textContent = 'Invalid file type. Please upload PDF, Word, Excel, PowerPoint, or image files.';
                fileError.style.display = 'block';
                fileName.textContent = '';
                return false;
            }

            dropZone.classList.add('has-file');
            dropZone.classList.remove('has-error');
            fileError.style.display = 'none';
            fileName.textContent = '✓ Selected: ' + file.name;
        } else {
            dropZone.classList.remove('has-file');
            dropZone.classList.remove('has-error');
            fileName.textContent = '';
        }
        return true;
    }

    document.getElementById('fileInput').addEventListener('change', handleFileSelect);

    var dropZone = document.getElementById('dropZone');
    dropZone.addEventListener('dragover', function(e) {
        e.preventDefault();
        dropZone.style.borderColor = '#16a085';
        dropZone.style.background = '#f0faf8';
    });

    dropZone.addEventListener('dragleave', function(e) {
        e.preventDefault();
        dropZone.style.borderColor = '#ddd';
        dropZone.style.background = '#fafafa';
    });

    dropZone.addEventListener('drop', function(e) {
        e.preventDefault();
        var files = e.dataTransfer.files;
        document.getElementById('fileInput').files = files;
        handleFileSelect();
    });

    function submitHomework() {
        var fileInput = document.getElementById('fileInput');
        var file = fileInput.files[0];
        var fileError = document.getElementById('fileError');

        fileError.style.display = 'none';
        document.getElementById('dropZone').classList.remove('has-error');

        if (!file) {
            fileError.textContent = 'Please select a file to upload';
            fileError.style.display = 'block';
            document.getElementById('dropZone').classList.add('has-error');
            document.getElementById('dropZone').scrollIntoView({ behavior: 'smooth', block: 'center' });
            return;
        }

        var formData = new FormData(document.getElementById('submitForm'));
        var submitBtn = document.getElementById('submitBtn');
        var messageDiv = document.getElementById('message');

        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner"></span> Submitting...';
        messageDiv.style.display = 'none';

        $.ajax({
            url: '@Url.Action("SubmitHomework", "Student")',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            success: function(response) {
                if (response.success) {
                    messageDiv.className = 'alert alert-success';
                    messageDiv.innerHTML = '<i class="fas fa-check-circle"></i> ' + response.message;
                    messageDiv.style.display = 'block';

                    setTimeout(function() {
                        window.location.href = '@Url.Action("Homework", "Student")';
                    }, 2000);
                } else {
                    messageDiv.className = 'alert alert-danger';
                    messageDiv.innerHTML = '<i class="fas fa-exclamation-circle"></i> ' + response.message;
                    messageDiv.style.display = 'block';
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Submit Homework';
                }
            },
            error: function(xhr) {
                var errorMsg = 'An error occurred. Please try again.';
                if (xhr.responseJSON && xhr.responseJSON.message) {
                    errorMsg = xhr.responseJSON.message;
                }
                messageDiv.className = 'alert alert-danger';
                messageDiv.innerHTML = '<i class="fas fa-exclamation-circle"></i> ' + errorMsg;
                messageDiv.style.display = 'block';
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Submit Homework';
            }
        });
    }
</script>