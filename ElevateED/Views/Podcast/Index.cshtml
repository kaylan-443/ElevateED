@model ElevateED.ViewModels.PodcastIndexViewModel
@{
    ViewBag.Title = "AI Podcast Generator";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    ViewBag.ActiveSidebar = "podcast";
}

@section Styles {
    <style>
        @@keyframes float {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        @@keyframes pulse-glow {
            0%, 100% {
                box-shadow: 0 0 20px rgba(139,92,246,0.4);
            }

            50% {
                box-shadow: 0 0 40px rgba(139,92,246,0.8), 0 0 80px rgba(236,72,153,0.4);
            }
        }

        @@keyframes sound-wave {
            0% {
                height: 4px;
            }

            50% {
                height: 20px;
            }

            100% {
                height: 4px;
            }
        }

        @@keyframes circuit {
            0% {
                background-position: 0 0;
            }

            100% {
                background-position: 50px 50px;
            }
        }

        .pod-hero {
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 40%, #0f172a 100%);
            border-radius: 24px;
            padding: 40px;
            text-align: center;
            position: relative;
            overflow: hidden;
            margin-bottom: 28px;
            border: 1px solid rgba(139,92,246,0.3);
            box-shadow: 0 0 40px rgba(139,92,246,0.15);
        }

            .pod-hero::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%238b5cf6' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
                animation: circuit 8s linear infinite;
            }

            .pod-hero .hero-content {
                position: relative;
                z-index: 1;
            }

            .pod-hero h1 {
                font-size: 36px;
                font-weight: 800;
                color: white;
                margin-bottom: 8px;
                background: linear-gradient(135deg, #c084fc, #e879f9, #c084fc);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-size: 200% 200%;
                animation: float 3s ease-in-out infinite;
            }

            .pod-hero p {
                color: #94a3b8;
                font-size: 16px;
            }

            .pod-hero .ai-badge {
                display: inline-block;
                background: rgba(139,92,246,0.2);
                color: #c4b5fd;
                padding: 6px 16px;
                border-radius: 20px;
                font-size: 12px;
                font-weight: 600;
                border: 1px solid rgba(139,92,246,0.3);
                margin-bottom: 16px;
                letter-spacing: 1px;
            }

            .pod-hero .sound-bars {
                display: flex;
                gap: 3px;
                justify-content: center;
                align-items: flex-end;
                height: 30px;
                margin-top: 16px;
            }

            .pod-hero .sound-bar {
                width: 4px;
                background: linear-gradient(180deg, #c084fc, #e879f9);
                border-radius: 2px;
                animation: sound-wave 1.2s ease-in-out infinite;
            }

                .pod-hero .sound-bar:nth-child(1) {
                    animation-delay: 0s;
                }

                .pod-hero .sound-bar:nth-child(2) {
                    animation-delay: 0.2s;
                }

                .pod-hero .sound-bar:nth-child(3) {
                    animation-delay: 0.4s;
                }

                .pod-hero .sound-bar:nth-child(4) {
                    animation-delay: 0.6s;
                }

                .pod-hero .sound-bar:nth-child(5) {
                    animation-delay: 0.8s;
                }

                .pod-hero .sound-bar:nth-child(6) {
                    animation-delay: 1s;
                }

                .pod-hero .sound-bar:nth-child(7) {
                    animation-delay: 1.2s;
                }

        .main-card {
            background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);
            border-radius: 24px;
            overflow: hidden;
            border: 1px solid #e2e8f0;
            box-shadow: 0 4px 24px rgba(0,0,0,0.06);
        }

            .main-card .card-header {
                background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
                color: white;
                padding: 24px 28px;
                border: none;
                border-bottom: 1px solid rgba(139,92,246,0.3);
            }

            .main-card .card-body {
                padding: 28px;
            }

        .tab-nav {
            display: flex;
            gap: 8px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .tab-btn {
            padding: 10px 20px;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            background: white;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            transition: all 0.2s;
            color: #64748b;
        }

            .tab-btn:hover {
                border-color: #8b5cf6;
                color: #8b5cf6;
            }

            .tab-btn.active {
                background: linear-gradient(135deg, #8b5cf6, #6366f1);
                color: white;
                border-color: transparent;
                box-shadow: 0 4px 15px rgba(139,92,246,0.4);
            }

        .tab-pane {
            display: none;
        }

            .tab-pane.active {
                display: block;
            }

        .btn-ai {
            padding: 14px 32px;
            border-radius: 14px;
            border: none;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            width: 100%;
            justify-content: center;
        }

            .btn-ai.primary {
                background: linear-gradient(135deg, #8b5cf6, #6366f1);
                color: white;
                box-shadow: 0 4px 20px rgba(139,92,246,0.4);
            }

                .btn-ai.primary:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 8px 30px rgba(139,92,246,0.6);
                }

                .btn-ai.primary:disabled {
                    opacity: 0.5;
                    cursor: not-allowed;
                    transform: none;
                }

            .btn-ai.play {
                background: linear-gradient(135deg, #10b981, #059669);
            }

            .btn-ai.pause {
                background: linear-gradient(135deg, #f59e0b, #d97706);
            }

            .btn-ai.stop {
                background: linear-gradient(135deg, #ef4444, #dc2626);
            }

        .ai-input {
            width: 100%;
            padding: 14px 18px;
            background: #f8fafc;
            border: 2px solid #e2e8f0;
            border-radius: 14px;
            font-size: 14px;
            color: #1e293b;
            transition: all 0.3s;
        }

            .ai-input:focus {
                border-color: #8b5cf6;
                background: white;
                outline: none;
                box-shadow: 0 0 0 4px rgba(139,92,246,0.1);
            }

        textarea.ai-input {
            resize: vertical;
            min-height: 140px;
        }

        .upload-zone {
            border: 2px dashed #8b5cf6;
            border-radius: 16px;
            padding: 40px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            background: rgba(139,92,246,0.03);
        }

            .upload-zone:hover {
                background: rgba(139,92,246,0.08);
                border-color: #a78bfa;
            }

        .loading-spinner {
            width: 60px;
            height: 60px;
            border: 3px solid rgba(139,92,246,0.2);
            border-top-color: #8b5cf6;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .script-box {
            background: #0f172a;
            color: #e2e8f0;
            padding: 20px;
            border-radius: 14px;
            font-size: 14px;
            line-height: 1.7;
            white-space: pre-wrap;
            max-height: 300px;
            overflow-y: auto;
            font-family: 'Georgia', serif;
            border: 1px solid rgba(139,92,246,0.3);
        }

        .history-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px;
            border-bottom: 1px solid #f1f5f9;
            border-radius: 10px;
            transition: all 0.2s;
        }

            .history-item:hover {
                background: rgba(139,92,246,0.04);
            }

        .history-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 18px;
            flex-shrink: 0;
            background: linear-gradient(135deg, #8b5cf6, #6366f1);
        }

        .history-info {
            flex: 1;
        }

            .history-info strong {
                color: #1e293b;
            }

            .history-info span {
                color: #94a3b8;
                font-size: 12px;
            }

        .badge {
            padding: 4px 10px;
            border-radius: 8px;
            font-size: 10px;
            font-weight: 600;
        }

        .badge-success {
            background: #d1fae5;
            color: #065f46;
        }

        .badge-warn {
            background: #fef3c7;
            color: #92400e;
        }

        .audio-card {
            background: #0f172a;
            border-radius: 16px;
            padding: 20px;
            border: 1px solid rgba(139,92,246,0.3);
            margin-top: 12px;
        }

            .audio-card .controls {
                display: flex;
                gap: 10px;
                justify-content: center;
                flex-wrap: wrap;
                margin-top: 12px;
            }

            .audio-card select {
                padding: 8px 14px;
                border-radius: 10px;
                border: 1px solid rgba(139,92,246,0.3);
                background: rgba(255,255,255,0.05);
                color: #cbd5e1;
                font-size: 12px;
            }

        @@media (max-width: 768px) {
            .tab-nav {
                flex-direction: column;
            }
        }
    </style>
}

<div class="container-fluid py-2">
    <!-- Hero -->
    <div class="pod-hero">
        <div class="hero-content">
            <div class="ai-badge"><i class="fas fa-microchip"></i> AI POWERED</div>
            <h1>Podcast Generator</h1>
            <p>Turn your notes into engaging audio podcasts</p>
            <div class="sound-bars">
                <div class="sound-bar"></div><div class="sound-bar"></div><div class="sound-bar"></div>
                <div class="sound-bar"></div><div class="sound-bar"></div><div class="sound-bar"></div>
                <div class="sound-bar"></div>
            </div>
        </div>
    </div>

    <!-- Main Card -->
    <div class="main-card">
        <div class="card-header">
            <div style="display:flex;align-items:center;gap:12px;">
                <div style="width:40px;height:40px;background:rgba(139,92,246,0.2);border-radius:12px;display:flex;align-items:center;justify-content:center;">
                    <i class="fas fa-podcast" style="color:#c4b5fd;"></i>
                </div>
                <div>
                    <h4 style="margin:0;font-weight:700;">Podcast Studio</h4>
                    <small style="opacity:0.7;">Upload, paste, or revisit your podcasts</small>
                </div>
            </div>
        </div>
        <div class="card-body">
            <!-- Tabs -->
            <div class="tab-nav">
                <button class="tab-btn active" onclick="switchPodTab('upload')">📄 Upload Notes</button>
                <button class="tab-btn" onclick="switchPodTab('paste')">📝 Paste Text</button>
                <button class="tab-btn" onclick="switchPodTab('history')">📚 History (@Model.PodcastHistory?.Count ?? 0)</button>
            </div>

            <!-- Upload Tab -->
            <div class="tab-pane active" id="pod-upload">
                <div class="upload-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
                    <i class="fas fa-cloud-upload-alt" style="font-size:40px;color:#8b5cf6;margin-bottom:12px;"></i>
                    <h5 style="color:#475569;">Click or drag to upload</h5>
                    <p style="color:#94a3b8;font-size:12px;">PDF files (max 20MB)</p>
                    <p id="fileName" style="color:#8b5cf6;font-weight:500;margin-top:8px;"></p>
                </div>
                <input type="file" id="fileInput" accept=".pdf,.txt" style="display:none;" onchange="handleFile(this)" />
                <button class="btn-ai primary" onclick="uploadFile()" style="margin-top:16px;">🤖 Generate Podcast</button>
            </div>

            <!-- Paste Tab -->
            <div class="tab-pane" id="pod-paste">
                <div style="margin-bottom:12px;">
                    <input type="text" id="pasteTitle" class="ai-input" placeholder="Title (optional)">
                </div>
                <textarea id="pasteText" class="ai-input" placeholder="Paste your study notes or material here..."></textarea>
                <button class="btn-ai primary" onclick="generateFromText()" style="margin-top:16px;">🤖 Generate Podcast</button>
            </div>

            <!-- Loading -->
            <div id="loadingSection" style="display:none;text-align:center;padding:40px;">
                <div class="loading-spinner" style="margin:0 auto 16px;"></div>
                <p style="color:#8b5cf6;font-weight:600;">AI is creating your podcast...</p>
                <p style="color:#94a3b8;font-size:13px;">Extracting text, generating script, preparing audio...</p>
            </div>

            <!-- Result -->
            <div id="resultSection" style="display:none;margin-top:20px;">
                <h5 id="resultTitle" style="color:#1e293b;margin-bottom:12px;">🎙️ Your Podcast is Ready!</h5>
                <div class="script-box" id="scriptBox"></div>
                <div class="audio-card" id="audioPlayer" style="display:none;">
                    <p style="color:white;font-weight:600;text-align:center;margin-bottom:12px;">🔊 Listen to Your Podcast</p>
                    <div class="controls" id="audioControls"></div>
                    <div style="margin-top:12px;display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
                        <select id="voiceSelect" onchange="changeVoice()"><option>Loading...</option></select>
                        <select id="speedSelect" onchange="changeSpeed()">
                            <option value="0.75">0.75x</option>
                            <option value="0.9">0.9x</option>
                            <option value="1" selected>1x</option>
                            <option value="1.25">1.25x</option>
                            <option value="1.5">1.5x</option>
                        </select>
                    </div>
                    <div id="audioStatus" style="margin-top:8px;font-size:12px;color:#94a3b8;text-align:center;"></div>
                </div>
            </div>

            <!-- History Tab -->
            <div class="tab-pane" id="pod-history">
                @if (Model.PodcastHistory != null && Model.PodcastHistory.Any())
                {
                    foreach (var podcast in Model.PodcastHistory)
                    {
                        <div class="history-item">
                            <div class="history-icon"><i class="fas fa-headphones"></i></div>
                            <div class="history-info">
                                <strong>@podcast.Title</strong><br>
                                <span>@podcast.CreatedAt.ToString("dd MMM yyyy, HH:mm")</span>
                            </div>
                            <span class="badge @(podcast.Status == "Completed" ? "badge-success" : "badge-warn")">@podcast.Status</span>
                            <button class="btn-ai" style="width:auto;padding:8px 16px;font-size:12px;" onclick="loadPodcast(@podcast.PodcastHistoryId)">▶️</button>
                            <button onclick="deletePodcast(@podcast.PodcastHistoryId)" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:16px;">🗑️</button>
                        </div>
                    }
                }
                else
                {
                    <p style="text-align:center;color:#94a3b8;padding:30px;">No podcasts yet. Upload your notes to get started!</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var currentPodcastId = null, currentScript = null, speechSynth = window.speechSynthesis, currentUtterance = null, isPlaying = false, isPaused = false;

        function switchPodTab(tab) {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
            document.getElementById('pod-' + tab).classList.add('active');
            document.querySelector(`button[onclick="switchPodTab('${tab}')"]`).classList.add('active');
        }

        function handleFile(input) { if (input.files[0]) document.getElementById('fileName').textContent = '📎 ' + input.files[0].name; }

        var dz = document.getElementById('dropZone');
        dz.addEventListener('dragover', e => { e.preventDefault(); dz.style.borderColor = '#a78bfa'; });
        dz.addEventListener('dragleave', () => { dz.style.borderColor = '#8b5cf6'; });
        dz.addEventListener('drop', e => { e.preventDefault(); document.getElementById('fileInput').files = e.dataTransfer.files; handleFile(document.getElementById('fileInput')); });

        function uploadFile() {
            var f = document.getElementById('fileInput').files[0];
            if (!f) { alert('Please select a file'); return; }
            if (f.size > 20*1024*1024) { alert('File too large (max 20MB)'); return; }
            var fd = new FormData(); fd.append('file', f);
            processReq('@Url.Action("UploadNotes","Podcast")', fd);
        }

        function generateFromText() {
            var t = document.getElementById('pasteText').value;
            if (!t) { alert('Please paste some text'); return; }
            var fd = new FormData(); fd.append('notesText', t); fd.append('title', document.getElementById('pasteTitle').value || 'Study Notes');
            processReq('@Url.Action("GenerateFromText","Podcast")', fd);
        }

        function processReq(url, fd) {
            document.getElementById('loadingSection').style.display = 'block';
            document.getElementById('resultSection').style.display = 'none';
            $.ajax({
                url: url, type: 'POST', data: fd, processData: false, contentType: false,
                success: function(r) {
                    document.getElementById('loadingSection').style.display = 'none';
                    if (r.success) {
                        currentPodcastId = r.podcastId; currentScript = r.script;
                        document.getElementById('scriptBox').textContent = r.script;
                        document.getElementById('resultTitle').textContent = '🎙️ ' + (r.title || 'Your Podcast');
                        document.getElementById('resultSection').style.display = 'block';
                        document.getElementById('resultSection').scrollIntoView({behavior:'smooth'});
                        updateAudioControls();
                    } else { alert('Error: ' + (r.message || 'Failed')); }
                },
                error: function() { document.getElementById('loadingSection').style.display = 'none'; alert('An error occurred'); }
            });
        }

        function updateAudioControls() {
            document.getElementById('audioPlayer').style.display = 'block';
            document.getElementById('audioControls').innerHTML = `
                <button class="btn-ai play" onclick="playPodcast()" style="width:auto;padding:10px 20px;">▶️ Play</button>
                <button class="btn-ai pause" onclick="pausePodcast()" style="width:auto;padding:10px 20px;display:none;">⏸️ Pause</button>
                <button class="btn-ai stop" onclick="stopPodcast()" style="width:auto;padding:10px 20px;">⏹️ Stop</button>
            `;
            loadVoices();
        }

        function loadVoices() {
            var voices = speechSynth.getVoices(), select = document.getElementById('voiceSelect');
            if (!select) return;
            select.innerHTML = '';
            var ev = voices.filter(v => v.lang.startsWith('en'));
            if (!ev.length) ev = voices;
            ev.forEach(function(v, i) {
                var o = document.createElement('option'); o.value = i; o.textContent = v.name + ' (' + v.lang + ')';
                if (v.name.includes('Female') || v.name.includes('Samantha') || v.name.includes('Karen')) o.selected = true;
                select.appendChild(o);
            });
        }

        function getSelectedVoice() {
            var voices = speechSynth.getVoices(), ev = voices.filter(v => v.lang.startsWith('en'));
            if (!ev.length) ev = voices; if (!ev.length) return null;
            return ev[parseInt(document.getElementById('voiceSelect').value) || 0];
        }

        function playPodcast() {
            if (!currentScript) return;
            speechSynth.cancel(); isPlaying = true; isPaused = false;
            var clean = currentScript.replace(/\[.*?\]/g,'').replace(/\*\*.*?\*\*/g,'').replace(/\*.*?\*/g,'').replace(/\(.*?music.*?\)/gi,'').substring(0,5000);
            currentUtterance = new SpeechSynthesisUtterance(clean);
            var v = getSelectedVoice(); if (v) currentUtterance.voice = v;
            currentUtterance.rate = parseFloat(document.getElementById('speedSelect').value);
            currentUtterance.onstart = function() {
                document.querySelector('#audioControls .play').style.display = 'none';
                document.querySelector('#audioControls .pause').style.display = 'inline-flex';
                document.getElementById('audioStatus').textContent = '🔊 Playing...';
            };
            currentUtterance.onend = function() { resetAudio(); document.getElementById('audioStatus').textContent = '✅ Finished!'; };
            currentUtterance.onpause = function() { document.getElementById('audioStatus').textContent = '⏸️ Paused'; isPaused = true; };
            currentUtterance.onresume = function() { document.getElementById('audioStatus').textContent = '🔊 Playing...'; isPaused = false; };
            speechSynth.speak(currentUtterance);
        }

        function pausePodcast() { if (isPlaying) speechSynth.pause(); }
        function stopPodcast() { speechSynth.cancel(); isPlaying = false; isPaused = false; resetAudio(); document.getElementById('audioStatus').textContent = '⏹️ Stopped'; }
        function resetAudio() {
            document.querySelector('#audioControls .play').style.display = 'inline-flex';
            document.querySelector('#audioControls .pause').style.display = 'none';
        }
        function changeVoice() { if (isPlaying) { speechSynth.cancel(); playPodcast(); } }
        function changeSpeed() { if (isPlaying) { speechSynth.cancel(); playPodcast(); } }
        speechSynth.onvoiceschanged = loadVoices;

        function loadPodcast(id) {
            $.get('@Url.Action("GetPodcast","Podcast")', {id:id}, function(r) {
                if (r.success) {
                    currentPodcastId = r.podcastId; currentScript = r.script;
                    document.getElementById('scriptBox').textContent = r.script;
                    document.getElementById('resultTitle').textContent = '🎙️ ' + r.title;
                    document.getElementById('resultSection').style.display = 'block';
                    document.getElementById('resultSection').scrollIntoView({behavior:'smooth'});
                    updateAudioControls(); switchPodTab('upload');
                }
            });
        }

        function deletePodcast(id) {
            if (!confirm('Delete this podcast?')) return;
            $.post('@Url.Action("DeletePodcast","Podcast")', {id:id}, function(r) { if (r.success) location.reload(); });
        }
    </script>
}