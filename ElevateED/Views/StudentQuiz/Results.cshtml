@model ElevateED.ViewModels.QuizResultViewModel
@{
    ViewBag.Title = "Quiz Results";
}

<style>
    .results-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
    }

    .score-card {
        background: white;
        border-radius: 20px;
        padding: 30px;
        text-align: center;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        margin-bottom: 30px;
    }

    .score-circle {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 48px;
        font-weight: 700;
    }

    .score-high {
        background: #d4edda;
        color: #155724;
        border: 6px solid #28a745;
    }

    .score-medium {
        background: #fff3cd;
        color: #856404;
        border: 6px solid #ffc107;
    }

    .score-low {
        background: #f8d7da;
        color: #721c24;
        border: 6px solid #dc3545;
    }

    .result-item {
        background: white;
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 15px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

        .result-item.correct {
            border-left: 4px solid #28a745;
        }

        .result-item.incorrect {
            border-left: 4px solid #dc3545;
        }

    .question-text {
        font-weight: 600;
        margin-bottom: 10px;
    }

    .answer-row {
        display: flex;
        gap: 20px;
        font-size: 14px;
    }

    .your-answer {
        color: #dc3545;
    }

    .correct-answer {
        color: #28a745;
        font-weight: 600;
    }

    .btn-back {
        background: #1e3c72;
        color: white;
        padding: 10px 25px;
        border-radius: 25px;
        border: none;
        text-decoration: none;
        display: inline-block;
    }

        .btn-back:hover {
            background: #2a5298;
            color: white;
            text-decoration: none;
        }
</style>

<div class="container results-container">
    @{
        var scoreClass = Model.Score >= 70 ? "score-high" : Model.Score >= 50 ? "score-medium" : "score-low";
    }

    <div class="score-card">
        <h2>Quiz Results</h2>
        <p class="text-muted">@Model.SubjectName</p>

        <div class="score-circle @scoreClass">@Model.Score%</div>

        <h4>@Model.CorrectAnswers / @Model.TotalQuestions correct</h4>
        <p class="text-muted">Attempted: @Model.AttemptedAt.ToString("dd MMM yyyy, HH:mm")</p>

        <a href="@Url.Action("Index", "StudentQuiz")" class="btn-back mt-3">
            <i class="fas fa-arrow-left"></i> Back to Quizzes
        </a>
    </div>

    <h4 class="mb-3">Review Answers</h4>

    @foreach (var answer in Model.Answers)
    {
        <div class="result-item @(answer.IsCorrect ? "correct" : "incorrect")">
            <div class="question-text">
                @(answer.IsCorrect ? "✅" : "❌") @answer.QuestionText
            </div>
            <div class="answer-row">
                <span class="your-answer">
                    <strong>Your answer:</strong> @answer.SelectedAnswer
                </span>
                @if (!answer.IsCorrect)
                {
                    <span class="correct-answer">
                        <strong>Correct answer:</strong> @answer.CorrectAnswer
                    </span>
                }
            </div>
        </div>
    }
</div>