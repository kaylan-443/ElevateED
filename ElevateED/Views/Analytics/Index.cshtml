@model ElevateED.Models.ViewModels.AnalyticsViewModel

@{
    ViewBag.Title = "Attendance Analytics";
}

<div class="container-fluid mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-chart-bar"></i> Attendance Analytics
                    </h5>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("Index", "Analytics", FormMethod.Get, new { @class = "form-inline" }))
                    {
                        <div class="form-group mr-3">
                            @Html.LabelFor(m => m.Filter, new { @class = "mr-2" })
                            @Html.DropDownListFor(m => m.Filter,
                                new List<SelectListItem>
                                {
                                    new SelectListItem { Text = "Daily", Value = "daily", Selected = Model.Filter == "daily" },
                                    new SelectListItem { Text = "Weekly", Value = "weekly", Selected = Model.Filter == "weekly" },
                                    new SelectListItem { Text = "Monthly", Value = "monthly", Selected = Model.Filter == "monthly" }
                                },
                                new { @class = "form-control" })
                        </div>
                        <div class="form-group mr-3">
                            @Html.LabelFor(m => m.ClassId, new { @class = "mr-2" })
                            @Html.DropDownListFor(m => m.ClassId,
                                Model.AvailableClasses ?? new List<SelectListItem>(),
                                "-- Select Class --",
                                new { @class = "form-control" })
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-filter"></i> Filter
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Total Sessions</h6>
                    <h3 class="text-primary">@Model.TotalSessions</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Overall Attendance Rate</h6>
                    <h3 class="text-success">@Model.OverallAttendanceRate.ToString("F1")%</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted mb-2">At-Risk Students</h6>
                    <h3 class="text-danger">@Model.AtRiskCount</h3>
                </div>
            </div>
        </div>
    </div>

    @if (Model.ClassStats != null && Model.ClassStats.Count > 0)
    {
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">Attendance Rate by Class</h6>
                    </div>
                    <div class="card-body">
                        <canvas id="attendanceChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">Attendance Trend</h6>
                    </div>
                    <div class="card-body">
                        <canvas id="trendChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">Detailed Attendance Records</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Student Name</th>
                                        <th>Class</th>
                                        <th>Present</th>
                                        <th>Absent</th>
                                        <th>Attendance %</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var classStats in Model.ClassStats)
                                    {
                                        if (classStats.AllLearnerStats != null)
                                        {
                                            foreach (var student in classStats.AllLearnerStats.OrderBy(s => s.AttendancePercent))
                                            {
                                                var rowClass = student.IsAtRisk ? "table-danger" : "";
                                                <tr class="@rowClass">
                                                    <td>
                                                        <strong>@student.FullName</strong>
                                                        @if (student.IsAtRisk)
                                                        {
                                                            <span class="badge badge-danger ml-2">At Risk</span>
                                                        }
                                                    </td>
                                                    <td>@classStats.ClassName</td>
                                                    <td>@student.PresentCount</td>
                                                    <td>@student.AbsentCount</td>
                                                    <td>
                                                        <div class="progress" style="height: 20px;">
                                                            @{
                                                                var progressColor = student.AttendancePercent >= 75 ? "bg-success" : "bg-danger";
                                                            }
                                                            <div class="progress-bar @progressColor" style="width: @(student.AttendancePercent)">
                                                                @student.AttendancePercent.ToString("F1")%
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No attendance data available.
        </div>
    }
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

@if (Model.ClassStats != null && Model.ClassStats.Count > 0)
{
    <script>
        var classNames = @Html.Raw(Json.Encode(Model.ClassStats.Select(c => c.ClassName).ToList()));
        var attendanceRates = @Html.Raw(Json.Encode(Model.ClassStats.Select(c => c.AttendanceRate).ToList()));

        var ctxAttendance = document.getElementById("attendanceChart").getContext("2d");
        var attendanceChart = new Chart(ctxAttendance, {
            type: "bar",
            data: {
                labels: classNames,
                datasets: [{
                    label: "Attendance Rate (%)",
                    data: attendanceRates,
                    backgroundColor: "rgba(75, 192, 192, 0.5)",
                    borderColor: "rgba(75, 192, 192, 1)",
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 100
                    }
                }
            }
        });

        var ctxTrend = document.getElementById("trendChart").getContext("2d");
        var trendChart = new Chart(ctxTrend, {
            type: "line",
            data: {
                labels: ["Week 1", "Week 2", "Week 3", "Week 4"],
                datasets: [{
                    label: "Average Attendance (%)",
                    data: [@Model.OverallAttendanceRate, @Model.OverallAttendanceRate, @Model.OverallAttendanceRate, @Model.OverallAttendanceRate],
                    borderColor: "rgba(54, 162, 235, 1)",
                    backgroundColor: "rgba(54, 162, 235, 0.1)",
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 100
                    }
                }
            }
        });
    </script>
}
