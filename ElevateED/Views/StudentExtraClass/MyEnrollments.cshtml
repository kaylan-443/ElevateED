@model List<ElevateED.Models.ExtraClassAttendanceRecord>
@using ElevateED.Models

@{
    ViewBag.Title = "My Attendance History";
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        color: #1e3c72;
    }

        .page-title i {
            color: #d4af37;
            margin-right: 10px;
        }

    .attendance-card {
        background: white;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        border-left: 4px solid #ddd;
    }

        .attendance-card.present {
            border-left-color: #10b981;
        }

        .attendance-card.absent {
            border-left-color: #ef4444;
        }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 20px;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        padding: 20px;
        border-radius: 16px;
        text-align: center;
        box-shadow: 0 3px 15px rgba(0,0,0,0.08);
    }

    .stat-number {
        font-size: 32px;
        font-weight: 700;
        color: #1e3c72;
    }

    .stat-label {
        font-size: 12px;
        color: #666;
        text-transform: uppercase;
    }

    .badge {
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-success {
        background: #d1fae5;
        color: #065f46;
    }

    .badge-danger {
        background: #fee2e2;
        color: #991b1b;
    }
</style>

<div class="container py-4">
    <div class="page-header">
        <div>
            <h2 class="page-title">
                <i class="fas fa-calendar-check"></i> My Attendance History
            </h2>
            <p class="text-muted">Track your attendance for extra classes</p>
        </div>
        <div>
            <a href="@Url.Action("Index", "StudentExtraClass")" class="btn btn-outline-primary">
                <i class="fas fa-search"></i> Browse Classes
            </a>
            <a href="@Url.Action("MyEnrollments", "StudentExtraClass")" class="btn btn-outline-secondary ml-2">
                <i class="fas fa-list"></i> My Enrollments
            </a>
        </div>
    </div>

    @{
        var presentCount = Model.Count(r => r.IsPresent);
        var absentCount = Model.Count(r => !r.IsPresent);
        var total = Model.Count;
        var percentage = total > 0 ? Math.Round((double)presentCount / total * 100, 1) : 0;
    }

    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-number">@total</div>
            <div class="stat-label">Total Sessions</div>
        </div>
        <div class="stat-card">
            <div class="stat-number" style="color: #10b981;">@presentCount</div>
            <div class="stat-label">Present</div>
        </div>
        <div class="stat-card">
            <div class="stat-number" style="color: #ef4444;">@absentCount</div>
            <div class="stat-label">Absent</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@percentage%</div>
            <div class="stat-label">Attendance Rate</div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-calendar-times"></i>
            <h4>No Attendance Records</h4>
            <p>You haven't attended any extra class sessions yet.</p>
        </div>
    }
    else
    {
        foreach (var record in Model.OrderByDescending(r => r.AttendanceSession.SessionDate))
        {
            var presentClass = record.IsPresent ? "present" : "absent";
            <div class="attendance-card @presentClass">
                <div>
                    <strong>@(record.AttendanceSession?.ExtraClass?.Name ?? "Class")</strong>
                    <br />
                    <small class="text-muted">@(record.AttendanceSession?.ExtraClass?.Subject?.Name ?? "N/A")</small>
                </div>
                <div class="text-center">
                    <strong>Session @(record.AttendanceSession?.SessionNumber ?? 0)</strong>
                    <br />
                    <small>@(record.AttendanceSession?.SessionDate.ToString("dd MMM yyyy") ?? "N/A")</small>
                </div>
                <div>
                    @if (record.IsPresent)
                    {
                        <span class="badge badge-success"><i class="fas fa-check-circle"></i> Present</span>
                    }
                    else
                    {
                        <span class="badge badge-danger"><i class="fas fa-times-circle"></i> Absent</span>
                    }
                    <br />
                    <small>@record.ScanTime.ToString("HH:mm")</small>
                </div>
            </div>
        }
    }
</div>