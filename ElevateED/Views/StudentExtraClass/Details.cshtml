@model ElevateED.ViewModels.StudentExtraClassDetailViewModel
@using ElevateED.Models

@{
    ViewBag.Title = Model.ExtraClass?.Name ?? "Class Details";
}

<style>
    :root {
        --primary: #4f46e5;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
    }

    .page-header {
        margin-bottom: 30px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        color: #1e3c72;
    }

        .page-title i {
            color: #d4af37;
            margin-right: 10px;
        }

    .class-header {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: white;
        padding: 30px;
        border-radius: 20px;
        margin-bottom: 30px;
    }

        .class-header h2 {
            margin: 0 0 10px 0;
            font-weight: 700;
        }

    .info-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: 0 3px 15px rgba(0,0,0,0.08);
    }

    .info-title {
        font-size: 18px;
        font-weight: 700;
        color: #1e3c72;
        margin-bottom: 15px;
        padding-bottom: 10px;
        border-bottom: 2px solid #d4af37;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .info-item i {
            width: 35px;
            height: 35px;
            background: #e0e7ff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #1e3c72;
        }

    .progress-circle {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        position: relative;
    }

        .progress-circle .inner {
            width: 90px;
            height: 90px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            font-weight: 700;
            color: var(--success);
        }

    .rating-stars {
        color: #fbbf24;
        font-size: 18px;
    }

    .feedback-card {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 10px;
    }

    .btn-feedback {
        background: var(--primary);
        color: white;
        padding: 10px 25px;
        border-radius: 25px;
        border: none;
        font-weight: 600;
        cursor: pointer;
    }

    .star-rating {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin-bottom: 20px;
    }

        .star-rating i {
            font-size: 32px;
            cursor: pointer;
            color: #ddd;
            transition: all 0.2s;
        }

            .star-rating i:hover,
            .star-rating i.active {
                color: #fbbf24;
            }

    textarea {
        resize: vertical;
        border-radius: 12px;
        border: 2px solid #e0e0e0;
        padding: 12px;
        width: 100%;
    }

    .alert {
        padding: 15px 20px;
        border-radius: 12px;
        margin-bottom: 20px;
    }

    .btn-pay {
        background: linear-gradient(135deg, var(--success), #059669);
        color: white;
        padding: 10px 25px;
        border-radius: 25px;
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: none;
        cursor: pointer;
    }

        .btn-pay:hover {
            transform: translateY(-2px);
            color: white;
            text-decoration: none;
        }

    .btn-enroll {
        background: var(--success);
        color: white;
        padding: 10px 25px;
        border-radius: 25px;
        border: none;
        font-weight: 600;
        cursor: pointer;
    }
</style>

<div class="container py-4">
    <div class="page-header">
        <div>
            <h2 class="page-title">
                <i class="fas fa-info-circle"></i> Class Details
            </h2>
        </div>
        <div>
            <a href="@Url.Action("Index", "StudentExtraClass")" class="btn btn-outline-primary">
                <i class="fas fa-search"></i> Browse Classes
            </a>
            <a href="@Url.Action("MyEnrollments", "StudentExtraClass")" class="btn btn-outline-secondary ml-2">
                <i class="fas fa-list"></i> My Enrollments
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="class-header">
        <h2><i class="fas fa-chalkboard-teacher"></i> @Model.ExtraClass?.Name</h2>
        <p>@(Model.ExtraClass?.Description ?? "No description available")</p>
    </div>

    <div class="row">
        <div class="col-md-8">
            <!-- Class Information -->
            <div class="info-card">
                <div class="info-title"><i class="fas fa-info-circle"></i> Class Information</div>
                <div class="info-grid">
                    <div class="info-item"><i class="fas fa-book"></i> <strong>Subject:</strong> @(Model.ExtraClass?.Subject?.Name ?? "N/A")</div>
                    <div class="info-item"><i class="fas fa-graduation-cap"></i> <strong>Grade:</strong> @(Model.ExtraClass?.Grade?.Name ?? "N/A")</div>
                    <div class="info-item"><i class="fas fa-user-tie"></i> <strong>Teacher:</strong> @(Model.ExtraClass?.Teacher?.FullName ?? "To be assigned")</div>
                    <div class="info-item"><i class="fas fa-calendar"></i> <strong>Start Date:</strong> @(Model.ExtraClass?.StartDate.ToString("dd MMM yyyy") ?? "N/A")</div>
                    <div class="info-item"><i class="fas fa-clock"></i> <strong>Schedule:</strong> @(Model.ExtraClass?.Schedule ?? "N/A")</div>
                    <div class="info-item"><i class="fas fa-map-marker-alt"></i> <strong>Venue:</strong> @(Model.ExtraClass?.Venue ?? "To be announced")</div>
                    <div class="info-item"><i class="fas fa-users"></i> <strong>Enrollment:</strong> @(Model.ExtraClass?.CurrentEnrollment ?? 0)/@(Model.ExtraClass?.Capacity ?? 0)</div>
                    <div class="info-item"><i class="fas fa-tag"></i> <strong>Price:</strong> @(Model.ExtraClass?.Price == 0 ? "FREE" : $"R {Model.ExtraClass?.Price:F2}")</div>
                </div>
            </div>

            <!-- Attendance Progress -->
            @if (Model.IsEnrolled && Model.TotalSessions > 0)
            {
                <div class="info-card">
                    <div class="info-title"><i class="fas fa-calendar-check"></i> Your Attendance Progress</div>
                    <div class="text-center">
                        <div class="progress-circle">
                            <div class="inner">@Model.AttendancePercentage%</div>
                        </div>
                        <p>Attended @Model.PresentCount out of @Model.TotalSessions sessions</p>
                    </div>
                </div>
            }

            <!-- Attendance History -->
            @if (Model.AttendanceRecords != null && Model.AttendanceRecords.Any())
            {
                <div class="info-card">
                    <div class="info-title"><i class="fas fa-history"></i> Your Attendance History</div>
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr><th>Date</th><th>Session</th><th>Status</th><th>Time</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var record in Model.AttendanceRecords.OrderByDescending(r => r.AttendanceSession.SessionDate))
                                {
                                    <tr>
                                        <td>@record.AttendanceSession.SessionDate.ToString("dd MMM yyyy")</td>
                                        <td>Session @record.AttendanceSession.SessionNumber</td>
                                        <td>@(record.IsPresent ? "✅ Present" : "❌ Absent")</td>
                                        <td>@record.ScanTime.ToString("HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- Feedback Section -->
            @if (Model.CanProvideFeedback)
            {
                <div class="info-card">
                    <div class="info-title"><i class="fas fa-star"></i> Rate This Class</div>
                    <div class="text-center">
                        <div class="star-rating" id="starRating">
                            <i class="far fa-star" data-rating="1"></i>
                            <i class="far fa-star" data-rating="2"></i>
                            <i class="far fa-star" data-rating="3"></i>
                            <i class="far fa-star" data-rating="4"></i>
                            <i class="far fa-star" data-rating="5"></i>
                        </div>
                        <textarea id="feedbackComment" rows="3" placeholder="Share your experience... (Optional)" class="mt-3"></textarea>
                        <button class="btn-feedback mt-3" onclick="submitFeedback()">
                            <i class="fas fa-paper-plane"></i> Submit Feedback
                        </button>
                    </div>
                </div>
            }
            else if (Model.MyFeedback != null)
            {
                <div class="info-card">
                    <div class="info-title"><i class="fas fa-star"></i> Your Feedback</div>
                    <div class="text-center">
                        <div class="rating-stars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= Model.MyFeedback.Rating)
                                {
                                    <i class="fas fa-star"></i>
                                }
                                else
                                {
                                    <i class="far fa-star"></i>
                                }
                            }
                        </div>
                        <p class="mt-2">@(Model.MyFeedback.Comment ?? "No comment provided")</p>
                        <small class="text-muted">Submitted on @Model.MyFeedback.DateSubmitted.ToString("dd MMM yyyy")</small>
                    </div>
                </div>
            }
        </div>

        <div class="col-md-4">
            <!-- Enrollment Status -->
            <div class="info-card">
                <div class="info-title"><i class="fas fa-user-check"></i> Your Status</div>
                @if (Model.IsEnrolled)
                {
                    <div class="text-center">
                        <i class="fas fa-check-circle" style="font-size: 48px; color: var(--success);"></i>
                        <h4 class="mt-2">You are enrolled!</h4>
                        @if (Model.IsPaid)
                        {
                            <p class="text-success"><i class="fas fa-check"></i> Payment confirmed</p>
                        }
                        else if (Model.ExtraClass != null && Model.ExtraClass.Price > 0)
                        {
                            <p class="text-warning"><i class="fas fa-clock"></i> Payment pending</p>
                            <a href="@Url.Action("PayNow", "StudentExtraClass", new { enrollmentId = Model.Enrollment?.Id })" class="btn-pay mt-2">
                                <i class="fas fa-credit-card"></i> Complete Payment
                            </a>
                        }
                        else
                        {
                            <p class="text-success"><i class="fas fa-gift"></i> Free class</p>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center">
                        <i class="fas fa-user-plus" style="font-size: 48px; color: var(--warning);"></i>
                        <h4 class="mt-2">Not Enrolled Yet</h4>
                        @if (Model.ExtraClass != null && Model.ExtraClass.CurrentEnrollment >= Model.ExtraClass.Capacity)
                        {
                            <p class="text-danger">This class is full</p>
                        }
                        else
                        {
                            <button class="btn-enroll mt-2" onclick="enrollInClass()">
                                <i class="fas fa-plus-circle"></i> Enroll Now
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    // Star rating
    var selectedRating = 0;
    var stars = document.querySelectorAll('#starRating i');

    for (var i = 0; i < stars.length; i++) {
        stars[i].addEventListener('mouseenter', (function(index) {
            return function() { highlightStars(index + 1); };
        })(i));

        stars[i].addEventListener('click', (function(index) {
            return function() {
                selectedRating = index + 1;
                highlightStars(selectedRating);
            };
        })(i));
    }

    function highlightStars(rating) {
        for (var i = 0; i < stars.length; i++) {
            if (i < rating) {
                stars[i].classList.remove('far');
                stars[i].classList.add('fas');
            } else {
                stars[i].classList.remove('fas');
                stars[i].classList.add('far');
            }
        }
    }

    function submitFeedback() {
        if (selectedRating === 0) {
            alert('Please select a rating');
            return;
        }

        $.ajax({
            url: '@Url.Action("SubmitFeedback", "StudentExtraClass")',
            type: 'POST',
            data: {
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val(),
                classId: @(Model.ExtraClass?.Id ?? 0),
                rating: selectedRating,
                comment: $('#feedbackComment').val()
            },
            success: function(response) {
                if (response.success) {
                    alert(response.message);
                    location.reload();
                } else {
                    alert(response.message);
                }
            }
        });
    }

    function enrollInClass() {
        if (!confirm('Enroll in this class?')) return;

        $.ajax({
            url: '@Url.Action("Join", "StudentExtraClass")',
            type: 'POST',
            data: {
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val(),
                classId: @(Model.ExtraClass?.Id ?? 0)
            },
            success: function(response) {
                if (response.success) {
                    if (response.requiresPayment && @(Model.ExtraClass?.Price ?? 0) > 0) {
                        alert(response.message);
                        window.location.href = '@Url.Action("MyEnrollments", "StudentExtraClass")';
                    } else {
                        alert(response.message);
                        location.reload();
                    }
                } else {
                    alert(response.message);
                }
            }
        });
    }
</script>