@model List<ElevateED.Models.ExtraClass>
@using ElevateED.Models

@{
    ViewBag.Title = "Available Extra Classes";
    var myEnrollments = ViewBag.MyEnrollments as List<int> ?? new List<int>();
    var studentId = ViewBag.StudentId as int?;
}

<style>
    :root {
        --primary: #4f46e5;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        color: #1e3c72;
    }

        .page-title i {
            color: #d4af37;
            margin-right: 10px;
        }

    .class-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: 0 3px 15px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        border-left: 4px solid var(--primary);
    }

        .class-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.12);
        }

        .class-card.enrolled {
            border-left-color: var(--success);
            background: linear-gradient(to right, white, #f0fdf4);
        }

        .class-card.full {
            border-left-color: var(--danger);
            opacity: 0.8;
        }

    .class-title {
        font-size: 20px;
        font-weight: 700;
        color: #1e3c72;
        margin-bottom: 8px;
    }

    .class-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        font-size: 13px;
        color: #666;
        margin-bottom: 15px;
    }

        .class-meta span {
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .class-meta span i {
                width: 18px;
                color: var(--primary);
            }

    .class-description {
        color: #555;
        font-size: 14px;
        margin-bottom: 15px;
        line-height: 1.5;
    }

    .price-badge {
        display: inline-block;
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: white;
        padding: 6px 16px;
        border-radius: 25px;
        font-weight: 700;
        font-size: 16px;
    }

    .free-badge {
        background: linear-gradient(135deg, var(--success), #059669);
    }

    .capacity-badge {
        background: #e0e7ff;
        color: #1e3c72;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .btn-enroll {
        background: var(--success);
        color: white;
        padding: 10px 25px;
        border-radius: 25px;
        border: none;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

        .btn-enroll:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(16,185,129,0.3);
        }

    .btn-enrolled {
        background: #e0e7ff;
        color: #1e3c72;
        padding: 10px 25px;
        border-radius: 25px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

        .btn-enrolled:hover {
            background: #c7d2fe;
            text-decoration: none;
            color: #1e3c72;
        }

    .btn-full {
        background: #e5e7eb;
        color: #6b7280;
        padding: 10px 25px;
        border-radius: 25px;
        font-weight: 600;
        cursor: not-allowed;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 20px;
    }

        .empty-state i {
            font-size: 64px;
            color: #ddd;
            margin-bottom: 20px;
        }

    .alert {
        padding: 15px 20px;
        border-radius: 12px;
        margin-bottom: 20px;
    }
</style>

<div class="container py-4">
    <div class="page-header">
        <div>
            <h2 class="page-title">
                <i class="fas fa-chalkboard-teacher"></i> Available Extra Classes
            </h2>
            <p class="text-muted">Browse and enroll in extra classes to boost your performance</p>
        </div>
        <div>
            <a href="@Url.Action("MyEnrollments", "StudentExtraClass")" class="btn btn-outline-primary">
                <i class="fas fa-list"></i> My Enrollments
            </a>
            <a href="@Url.Action("Dashboard", "Student")" class="btn btn-outline-secondary ml-2">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-calendar-times"></i>
            <h4>No Extra Classes Available</h4>
            <p>There are no extra classes available for your grade at the moment.</p>
            <p>Check back later for new classes!</p>
        </div>
    }
    else
    {
        foreach (var extraClass in Model)
        {
            bool isEnrolled = myEnrollments.Contains(extraClass.Id);
            bool isFull = extraClass.CurrentEnrollment >= extraClass.Capacity;
            string priceClass = extraClass.Price == 0 ? "free-badge" : "";

            <div class="class-card @(isEnrolled ? "enrolled" : "") @(isFull ? "full" : "")">
                <div class="class-title">@extraClass.Name</div>
                <div class="class-meta">
                    <span><i class="fas fa-book"></i> @(extraClass.Subject?.Name ?? "N/A")</span>
                    <span><i class="fas fa-graduation-cap"></i> @(extraClass.Grade?.Name ?? "N/A")</span>
                    <span><i class="fas fa-calendar"></i> Starts: @extraClass.StartDate.ToString("dd MMM yyyy")</span>
                    <span><i class="fas fa-clock"></i> @extraClass.Schedule</span>
                    <span><i class="fas fa-map-marker-alt"></i> @(extraClass.Venue ?? "TBA")</span>
                    <span><i class="fas fa-users"></i> @extraClass.CurrentEnrollment/@extraClass.Capacity enrolled</span>
                </div>
                @if (!string.IsNullOrEmpty(extraClass.Description))
                {
                    <div class="class-description">@extraClass.Description</div>
                }
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <span class="price-badge @priceClass">
                            @if (extraClass.Price == 0)
                            {
                                <i class="fas fa-gift"></i> @:FREE
                            }
                            else
                            {
                                <i class="fas fa-rand"></i> @:R @extraClass.Price.ToString("0.00")
                            }
                        </span>
                        @if (isFull)
                        {
                            <span class="capacity-badge ml-2"><i class="fas fa-ban"></i> Class Full</span>
                        }
                    </div>
                    <div>
                        @if (isEnrolled)
                        {
                            <a href="@Url.Action("Details", "StudentExtraClass", new { id = extraClass.Id })" class="btn-enrolled">
                                <i class="fas fa-check-circle"></i> Enrolled - View Details
                            </a>
                        }
                        else if (isFull)
                        {
                            <button class="btn-full" disabled>
                                <i class="fas fa-ban"></i> Class Full
                            </button>
                        }
                        else
                        {
                            <button class="btn-enroll" onclick="enrollClass(@extraClass.Id, '@extraClass.Name.Replace("'", "\\'")', @extraClass.Price)">
                                <i class="fas fa-plus-circle"></i> Enroll Now
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

<script>
    function enrollClass(classId, className, price) {
        var message = 'Enroll in "' + className + '"?';
        if (price > 0) {
            message += '\n\nFee: R ' + price.toFixed(2) + '\nYou will need to pay to confirm your spot.';
        } else {
            message += '\n\nThis is a FREE class!';
        }

        if (!confirm(message)) return;

        $.ajax({
            url: '@Url.Action("Join", "StudentExtraClass")',
            type: 'POST',
            data: {
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val(),
                classId: classId
            },
            success: function(response) {
                if (response.success) {
                    if (response.requiresPayment && price > 0) {
                        alert(response.message + '\n\nYou will be redirected to payment.');
                        window.location.href = '@Url.Action("MyEnrollments", "StudentExtraClass")';
                    } else {
                        alert(response.message);
                        location.reload();
                    }
                } else {
                    alert(response.message);
                }
            },
            error: function() {
                alert('An error occurred. Please try again.');
            }
        });
    }
</script>