@model ElevateED.Models.ExtraClassEnrollment

@{
    ViewBag.Title = "Card Payment";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Secure Payment - ElevateED</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #1a1a2e 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        .payment-container {
            max-width: 900px;
            width: 100%;
            display: flex;
            gap: 30px;
            align-items: flex-start;
        }

        /* Credit Card Styling */
        .card-wrapper {
            flex: 1;
            perspective: 1000px;
            min-width: 380px;
        }

        .credit-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 20px;
            padding: 30px;
            color: white;
            box-shadow: 0 20px 60px rgba(102, 126, 234, 0.4);
            position: relative;
            overflow: hidden;
            transition: transform 0.6s;
            transform-style: preserve-3d;
        }

        .credit-card::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
        }

        .credit-card::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -30%;
            width: 150px;
            height: 150px;
            background: rgba(255,255,255,0.03);
            border-radius: 50%;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .card-chip {
            width: 50px;
            height: 40px;
            background: linear-gradient(135deg, #ffd700, #ffb800);
            border-radius: 8px;
            position: relative;
            overflow: hidden;
        }

        .card-chip::before,
        .card-chip::after {
            content: '';
            position: absolute;
        }

        .card-chip::before {
            top: 8px;
            left: 8px;
            right: 8px;
            bottom: 8px;
            border: 1px solid rgba(0,0,0,0.2);
            border-radius: 3px;
        }

        .card-chip::after {
            top: 50%;
            left: 15px;
            right: 15px;
            height: 1px;
            background: rgba(0,0,0,0.2);
        }

        .card-type {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: 2px;
            opacity: 0.8;
        }

        .card-number-display {
            font-size: 26px;
            letter-spacing: 4px;
            margin-bottom: 25px;
            font-family: 'Courier New', monospace;
            word-spacing: 8px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.2);
        }

        .card-details {
            display: flex;
            justify-content: space-between;
            gap: 20px;
        }

        .card-label {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 2px;
            opacity: 0.7;
            margin-bottom: 5px;
        }

        .card-value {
            font-size: 16px;
            font-weight: 500;
            letter-spacing: 1px;
            font-family: 'Courier New', monospace;
        }

        .card-brand {
            position: absolute;
            bottom: 25px;
            right: 25px;
            font-size: 32px;
            font-weight: 900;
            opacity: 0.3;
            letter-spacing: 2px;
        }

        /* Payment Form Styling */
        .payment-form-wrapper {
            flex: 1;
            min-width: 380px;
        }

        .payment-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }

        .payment-header {
            text-align: center;
            margin-bottom: 25px;
        }

        .payment-header h2 {
            color: #1e3a5f;
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 5px;
        }

        .payment-header .lock-icon {
            color: #10b981;
            margin-right: 5px;
        }

        .order-summary {
            background: #f8fafc;
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 25px;
            border: 1px solid #e2e8f0;
        }

        .order-summary h5 {
            color: #1e3a5f;
            font-weight: 700;
            margin-bottom: 15px;
            font-size: 15px;
        }

        .order-item {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            font-size: 14px;
        }

        .order-item:not(:last-child) {
            border-bottom: 1px solid #e2e8f0;
        }

        .order-item .label {
            color: #64748b;
        }

        .order-item .value {
            color: #334155;
            font-weight: 500;
        }

        .order-total {
            display: flex;
            justify-content: space-between;
            padding: 15px 0 0 0;
            margin-top: 10px;
            border-top: 2px solid #e2e8f0;
            font-size: 18px;
            font-weight: 700;
        }

        .order-total .label {
            color: #1e3a5f;
        }

        .order-total .value {
            color: #059669;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            font-weight: 600;
            color: #475569;
            margin-bottom: 6px;
            display: block;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .input-with-icon {
            position: relative;
        }

        .input-with-icon .icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 16px;
        }

        .input-with-icon .form-control {
            padding-left: 45px;
        }

        .form-control {
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px 15px;
            width: 100%;
            font-size: 15px;
            transition: all 0.3s;
            background: #f8fafc;
        }

        .form-control:focus {
            border-color: #667eea;
            background: white;
            outline: none;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.1);
        }

        .card-icons {
            display: flex;
            gap: 10px;
            margin-top: 8px;
        }

        .card-icon {
            font-size: 24px;
            opacity: 0.3;
            transition: all 0.3s;
        }

        .card-icon.active {
            opacity: 1;
        }

        .btn-pay {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            padding: 16px;
            border-radius: 12px;
            border: none;
            font-size: 16px;
            font-weight: 600;
            width: 100%;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 4px 15px rgba(102,126,234,0.4);
        }

        .btn-pay:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102,126,234,0.6);
        }

        .btn-pay:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        .alert {
            padding: 12px 15px;
            border-radius: 10px;
            margin-bottom: 15px;
            display: none;
            font-size: 14px;
            font-weight: 500;
        }

        .alert-danger {
            background: #fef2f2;
            color: #dc2626;
            border: 1px solid #fecaca;
        }

        .alert-success {
            background: #f0fdf4;
            color: #16a34a;
            border: 1px solid #bbf7d0;
        }

        .secure-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 20px;
            color: #94a3b8;
            font-size: 12px;
        }

        .secure-badge i {
            color: #10b981;
        }

        .btn-cancel {
            display: block;
            text-align: center;
            color: #64748b;
            text-decoration: none;
            padding: 12px;
            margin-top: 10px;
            font-weight: 500;
            transition: all 0.3s;
            border-radius: 10px;
        }

        .btn-cancel:hover {
            background: #f1f5f9;
            color: #334155;
            text-decoration: none;
        }

        @@media (max-width: 800px) {
            .payment-container {
                flex-direction: column;
                align-items: center;
            }

            .card-wrapper,
            .payment-form-wrapper {
                min-width: 100%;
                max-width: 450px;
            }
        }
    </style>
</head>
<body>
    <div class="payment-container">
        <!-- Credit Card Preview -->
        <div class="card-wrapper">
            <div class="credit-card" id="creditCard">
                <div class="card-header">
                    <div class="card-chip"></div>
                    <div class="card-type">PLATINUM</div>
                </div>
                <div class="card-number-display" id="cardNumberDisplay">•••• •••• •••• ••••</div>
                <div class="card-details">
                    <div>
                        <div class="card-label">Card Holder</div>
                        <div class="card-value" id="cardHolderDisplay">YOUR NAME</div>
                    </div>
                    <div>
                        <div class="card-label">Expires</div>
                        <div class="card-value" id="expiryDisplay">MM/YY</div>
                    </div>
                    <div>
                        <div class="card-label">CVV</div>
                        <div class="card-value" id="cvvDisplay">•••</div>
                    </div>
                </div>
                <div class="card-brand">ELEVATE</div>
            </div>
        </div>

        <!-- Payment Form -->
        <div class="payment-form-wrapper">
            <div class="payment-card">
                <div class="payment-header">
                    <h2><i class="fas fa-lock lock-icon"></i> Secure Payment</h2>
                    <p class="text-muted">Complete your payment to confirm enrollment</p>
                </div>

                <div class="order-summary">
                    <h5><i class="fas fa-receipt"></i> Order Summary</h5>
                    <div class="order-item">
                        <span class="label">Class</span>
                        <span class="value">@(Model?.ExtraClass?.Name ?? "N/A")</span>
                    </div>
                    <div class="order-item">
                        <span class="label">Subject</span>
                        <span class="value">@(Model?.ExtraClass?.Subject?.Name ?? "N/A")</span>
                    </div>
                    <div class="order-item">
                        <span class="label">Grade</span>
                        <span class="value">@(Model?.ExtraClass?.Grade?.Name ?? "N/A")</span>
                    </div>
                    <div class="order-item">
                        <span class="label">Schedule</span>
                        <span class="value">@(Model?.ExtraClass?.Schedule ?? "N/A")</span>
                    </div>
                    <div class="order-total">
                        <span class="label">Total</span>
                        <span class="value">R @(Model?.ExtraClass?.Price.ToString("0.00") ?? "0.00")</span>
                    </div>
                </div>

                <form id="paymentForm" autocomplete="off">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="enrollmentId" value="@Model?.Id" />

                    <div class="form-group">
                        <label>Card Number</label>
                        <div class="input-with-icon">
                            <i class="fas fa-credit-card icon"></i>
                            <input type="text" name="cardNumber" id="cardNumber" class="form-control"
                                   placeholder="4111 1111 1111 1111" maxlength="19" />
                        </div>
                        <div class="card-icons">
                            <i class="fab fa-cc-visa card-icon" id="visaIcon"></i>
                            <i class="fab fa-cc-mastercard card-icon" id="mastercardIcon"></i>
                            <i class="fab fa-cc-amex card-icon" id="amexIcon"></i>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Card Holder Name</label>
                        <div class="input-with-icon">
                            <i class="fas fa-user icon"></i>
                            <input type="text" name="cardHolder" id="cardHolder" class="form-control"
                                   placeholder="JOHN DOE" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-6">
                            <div class="form-group">
                                <label>Expiry Date</label>
                                <div class="d-flex" style="gap:8px;">
                                    <select name="expiryMonth" id="expiryMonth" class="form-control" style="width:50%;">
                                        <option value="">MM</option>
                                        @for (int i = 1; i <= 12; i++)
                                        {
                                            <option value="@i.ToString("D2")">@i.ToString("D2")</option>
                                        }
                                    </select>
                                    <select name="expiryYear" id="expiryYear" class="form-control" style="width:50%;">
                                        <option value="">YY</option>
                                        @for (int i = DateTime.Now.Year; i <= DateTime.Now.Year + 10; i++)
                                        {
                                            <option value="@i">@(i.ToString().Substring(2))</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label>CVV</label>
                                <div class="input-with-icon">
                                    <i class="fas fa-shield-alt icon"></i>
                                    <input type="password" name="cvv" id="cvv" class="form-control"
                                           placeholder="123" maxlength="4" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="message" class="alert"></div>

                    <button type="button" class="btn-pay" onclick="processPayment()" id="payBtn">
                        <i class="fas fa-lock"></i> Pay R @(Model?.ExtraClass?.Price.ToString("0.00") ?? "0.00")
                    </button>

                    <div class="secure-badge">
                        <i class="fas fa-shield-alt"></i>
                        <span>Secured by 256-bit SSL Encryption</span>
                    </div>
                </form>

                <a href="@Url.Action("MyEnrollments", "StudentExtraClass")" class="btn-cancel">
                    <i class="fas fa-arrow-left"></i> Cancel and go back
                </a>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script>
        // Live card preview updates
        $('#cardNumber').on('input', function() {
            var value = $(this).val().replace(/\D/g, '').substring(0, 16);
            var formatted = value.replace(/(\d{4})(?=\d)/g, '$1 ');
            $(this).val(formatted);

            // Update card display
            var display = value.replace(/(\d{4})(?=\d)/g, '$1 ');
            if (display) {
                $('#cardNumberDisplay').text(display.padEnd(19, '•'));
            } else {
                $('#cardNumberDisplay').text('•••• •••• •••• ••••');
            }

            // Detect card type
            $('#visaIcon, #mastercardIcon, #amexIcon').removeClass('active');
            if (value.startsWith('4')) {
                $('#visaIcon').addClass('active');
            } else if (value.startsWith('5')) {
                $('#mastercardIcon').addClass('active');
            } else if (value.startsWith('3')) {
                $('#amexIcon').addClass('active');
            }
        });

        $('#cardHolder').on('input', function() {
            var value = $(this).val().toUpperCase() || 'YOUR NAME';
            $('#cardHolderDisplay').text(value);
        });

        $('#expiryMonth, #expiryYear').on('change', function() {
            var month = $('#expiryMonth').val() || 'MM';
            var year = $('#expiryYear').val() || 'YY';
            if (year.length === 4) year = year.substring(2);
            $('#expiryDisplay').text(month + '/' + year);
        });

        $('#cvv').on('focus', function() {
            $('.credit-card').css('transform', 'rotateY(180deg)');
            setTimeout(function() {
                $('#cardNumberDisplay').text('•••• •••• •••• ••••');
                $('#cardHolderDisplay').text('SECURITY CODE');
                $('#expiryDisplay').text('•••');
            }, 300);
        }).on('blur', function() {
            $('.credit-card').css('transform', 'rotateY(0deg)');
            setTimeout(function() {
                // Restore values
                var cardNum = $('#cardNumber').val() || '•••• •••• •••• ••••';
                $('#cardNumberDisplay').text(cardNum.padEnd(19, '•'));
                $('#cardHolderDisplay').text($('#cardHolder').val().toUpperCase() || 'YOUR NAME');
                var month = $('#expiryMonth').val() || 'MM';
                var year = $('#expiryYear').val() || 'YY';
                if (year.length === 4) year = year.substring(2);
                $('#expiryDisplay').text(month + '/' + year);
            }, 300);
        });

        $('#cvv').on('input', function() {
            var value = $(this).val() || '•••';
            $('#cvvDisplay').text(value.replace(/./g, '•'));
        });

        function processPayment() {
            var cardNum = $('#cardNumber').val().replace(/\s/g, '');
            var holder = $('#cardHolder').val();
            var month = $('#expiryMonth').val();
            var year = $('#expiryYear').val();
            var cvv = $('#cvv').val();

            if (!cardNum || cardNum.length < 13) {
                showError('Please enter a valid card number');
                return;
            }
            if (!holder) {
                showError('Please enter card holder name');
                return;
            }
            if (!month || !year) {
                showError('Please select expiry date');
                return;
            }
            if (!cvv || cvv.length < 3) {
                showError('Please enter a valid CVV');
                return;
            }

            var btn = $('#payBtn');
            btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Processing Payment...');

            $.ajax({
                url: '@Url.Action("ProcessCardPayment", "StudentExtraClass")',
                type: 'POST',
                data: {
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val(),
                    enrollmentId: @(Model?.Id ?? 0),
                    cardNumber: cardNum,
                    cardHolder: holder,
                    expiryMonth: month,
                    expiryYear: year,
                    cvv: cvv
                },
                success: function(res) {
                    if (res.success) {
                        showSuccess(res.message);
                        btn.html('<i class="fas fa-check-circle"></i> Payment Successful!');
                        setTimeout(function() {
                            window.location.href = '@Url.Action("MyEnrollments", "StudentExtraClass")';
                        }, 2000);
                    } else {
                        showError(res.message);
                        btn.prop('disabled', false).html('<i class="fas fa-lock"></i> Pay R @(Model?.ExtraClass?.Price.ToString("0.00") ?? "0.00")');
                    }
                },
                error: function(xhr) {
                    var errorMsg = 'Payment failed. Please try again.';
                    try {
                        var response = JSON.parse(xhr.responseText);
                        if (response.message) errorMsg = response.message;
                    } catch(e) {}
                    showError(errorMsg);
                    btn.prop('disabled', false).html('<i class="fas fa-lock"></i> Pay R @(Model?.ExtraClass?.Price.ToString("0.00") ?? "0.00")');
                }
            });
        }

        function showError(msg) {
            var msgDiv = $('#message');
            msgDiv.removeClass('alert-success').addClass('alert-danger').html('<i class="fas fa-exclamation-circle"></i> ' + msg).show();
            setTimeout(function() { msgDiv.fadeOut(); }, 5000);
        }

        function showSuccess(msg) {
            var msgDiv = $('#message');
            msgDiv.removeClass('alert-danger').addClass('alert-success').html('<i class="fas fa-check-circle"></i> ' + msg).show();
        }
    </script>
</body>
</html>