@model ElevateED.ViewModels.ActiveAttendanceSessionViewModel

@{
    ViewBag.Title = "Active Session - " + Model.ClassName;
}

<style>
    .qr-container {
        text-align: center;
        padding: 30px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 3px 15px rgba(0,0,0,0.08);
        max-width: 500px;
        margin: 0 auto;
    }

    .qr-code {
        background: white;
        padding: 20px;
        border-radius: 16px;
        display: inline-block;
        margin: 20px 0;
    }

        .qr-code img {
            width: 250px;
            height: 250px;
        }

    .qr-code-simple {
        font-size: 32px;
        font-family: monospace;
        background: #f8f9fa;
        padding: 20px;
        border-radius: 12px;
        letter-spacing: 2px;
    }

    .expiry-timer {
        font-size: 24px;
        font-weight: 700;
        color: var(--warning);
    }

    .stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        margin-top: 20px;
    }

    .stat-item {
        text-align: center;
        padding: 15px;
        background: #f8f9fa;
        border-radius: 12px;
    }

    .stat-number {
        font-size: 28px;
        font-weight: 700;
    }

    .btn-refresh {
        background: var(--primary);
        color: white;
        padding: 10px 25px;
        border-radius: 25px;
        border: none;
        margin-top: 20px;
    }
</style>

<div class="container py-4">
    <div class="qr-container">
        <h3><i class="fas fa-qrcode"></i> Active Session</h3>
        <p class="text-muted">@Model.ClassName - @Model.SessionDate.ToString("dd MMM yyyy")</p>

        @if (!Model.IsExpired)
        {
            <div class="qr-code">
                <div class="qr-code-simple">
                    <strong>@Model.QRCode</strong>
                </div>
                <p class="mt-2 small text-muted">QR Code Text: @Model.QRCode</p>
            </div>

            <div class="expiry-timer" id="timer">
                Time Remaining: @Model.TimeRemaining
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                <i class="fas fa-clock"></i> This session has expired.
            </div>
        }

        <div class="stats">
            <div class="stat-item">
                <div class="stat-number">@Model.TotalStudents</div>
                <div>Total Students</div>
            </div>
            <div class="stat-item">
                <div class="stat-number" style="color: #10b981;">@Model.PresentCount</div>
                <div>Present</div>
            </div>
            <div class="stat-item">
                <div class="stat-number" style="color: #ef4444;">@Model.AbsentCount</div>
                <div>Absent</div>
            </div>
        </div>

        <div class="mt-3">
            <a href="@Url.Action("MarkAttendance", new { sessionId = Model.SessionId })" class="btn btn-primary">
                <i class="fas fa-edit"></i> Mark Attendance Manually
            </a>
            <button class="btn btn-secondary" onclick="location.reload()">
                <i class="fas fa-sync-alt"></i> Refresh
            </button>
        </div>
    </div>
</div>

<script>
    @if (!Model.IsExpired)
    {
        <text>
        function updateTimer() {
            location.reload();
        }
        setTimeout(updateTimer, 30000);
        </text>
    }
</script>