@model ElevateED.ViewModels.ActiveAttendanceSessionViewModel

@{
    ViewBag.Title = "Active Session - " + Model.ClassName;
}

<style>
    .qr-container {
        text-align: center;
        padding: 30px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 3px 15px rgba(0,0,0,0.08);
        max-width: 500px;
        margin: 0 auto;
    }

    .qr-code {
        background: white;
        padding: 20px;
        border-radius: 16px;
        display: inline-block;
        margin: 20px 0;
    }

        .qr-code img {
            width: 250px;
            height: 250px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
        }

    .qr-code-simple {
        font-size: 20px;
        font-family: monospace;
        background: #f8f9fa;
        padding: 15px;
        border-radius: 12px;
        letter-spacing: 2px;
        word-break: break-all;
    }

    .expiry-timer {
        font-size: 24px;
        font-weight: 700;
        color: #f59e0b;
        margin: 15px 0;
    }

    .stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        margin-top: 20px;
    }

    .stat-item {
        text-align: center;
        padding: 15px;
        background: #f8f9fa;
        border-radius: 12px;
    }

    .stat-number {
        font-size: 28px;
        font-weight: 700;
    }

    .btn-refresh {
        background: #4f46e5;
        color: white;
        padding: 10px 25px;
        border-radius: 25px;
        border: none;
        margin-top: 20px;
    }

    .alert {
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 20px;
    }

    .alert-warning {
        background: #fef3c7;
        color: #92400e;
        border: 1px solid #fcd34d;
    }
</style>

<div class="container py-4">
    <div class="qr-container">
        <h3><i class="fas fa-qrcode"></i> Active Session</h3>
        <p class="text-muted">@Model.ClassName - @Model.SessionDate.ToString("dd MMM yyyy")</p>

        @if (!Model.IsExpired)
        {
            <div class="qr-code">
                <img src="https://chart.googleapis.com/chart?cht=qr&chs=250x250&chl=@Model.QRCode&choe=UTF-8"
                     alt="QR Code"
                     onerror="this.onerror=null; this.src='https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=@Model.QRCode';" />
            </div>

            <div class="qr-code-simple mt-3">
                <strong>QR Code Text: @Model.QRCode</strong>
            </div>

            <div class="expiry-timer" id="timer">
                <i class="fas fa-hourglass-half"></i> Time Remaining: <span id="timeRemaining">@Model.TimeRemaining</span>
            </div>

            <div class="alert alert-warning">
                <i class="fas fa-info-circle"></i>
                <strong>Instructions for students:</strong><br />
                1. Open your Student Portal<br />
                2. Go to Extra Classes → My Enrollments<br />
                3. Click on this class and select "Mark Attendance"<br />
                4. Scan this QR code using your device's camera
            </div>

            <div class="stats">
                <div class="stat-item">
                    <div class="stat-number">@Model.TotalStudents</div>
                    <div>Total Students</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number" style="color: #10b981;">@Model.PresentCount</div>
                    <div>Present</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number" style="color: #ef4444;">@Model.AbsentCount</div>
                    <div>Absent</div>
                </div>
            </div>

            <div class="mt-3">
                <a href="@Url.Action("MarkAttendance", new { sessionId = Model.SessionId })" class="btn btn-primary">
                    <i class="fas fa-edit"></i> Mark Attendance Manually
                </a>
                <button class="btn btn-secondary" onclick="location.reload()">
                    <i class="fas fa-sync-alt"></i> Refresh
                </button>
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                <i class="fas fa-clock"></i> This session has expired.
            </div>
            <a href="@Url.Action("Index", "TeacherExtraClass")" class="btn btn-primary">
                <i class="fas fa-arrow-left"></i> Back to Classes
            </a>
        }
    </div>
</div>

<script>
    @if (!Model.IsExpired)
    {
        @:var expiryTime = new Date('@Model.QRCodeExpiry.ToString("yyyy-MM-ddTHH:mm:ss")');
        @:
        @:function updateTimer() {
        @:    var now = new Date();
        @:    var diff = expiryTime - now;
        @:
        @:    if (diff <= 0) {
        @:        document.getElementById('timer').innerHTML = '<i class="fas fa-clock"></i> Session Expired';
        @:        location.reload();
        @:        return;
        @:    }
        @:
        @:    var minutes = Math.floor(diff / 60000);
        @:    var seconds = Math.floor((diff % 60000) / 1000);
        @:
        @:    document.getElementById('timeRemaining').innerHTML = minutes + 'm ' + seconds + 's remaining';
        @:}
        @:
        @:setInterval(updateTimer, 1000);
    }
</script>