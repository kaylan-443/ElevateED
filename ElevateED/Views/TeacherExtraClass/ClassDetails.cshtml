@model ElevateED.ViewModels.TeacherClassDetailsViewModel
@using ElevateED.Models

@{
    ViewBag.Title = Model.ExtraClass?.Name ?? "Class Details";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        color: #1e3c72;
    }

    .class-header {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: white;
        padding: 25px;
        border-radius: 20px;
        margin-bottom: 30px;
    }

    .info-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: 0 3px 15px rgba(0,0,0,0.08);
    }

    .info-title {
        font-size: 18px;
        font-weight: 700;
        color: #1e3c72;
        margin-bottom: 15px;
        padding-bottom: 10px;
        border-bottom: 2px solid #d4af37;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 15px;
        margin-bottom: 20px;
    }

    .stat-card {
        text-align: center;
        padding: 15px;
        background: #f8f9fa;
        border-radius: 12px;
    }

    .stat-number {
        font-size: 24px;
        font-weight: 700;
    }

    .ai-card {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .topic-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
    }

    .topic-badge {
        background: rgba(255,255,255,0.2);
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
    }

    .btn-apply {
        background: rgba(255,255,255,0.2);
        border: 1px solid white;
        color: white;
        padding: 8px 20px;
        border-radius: 25px;
        cursor: pointer;
    }

    .btn-sm {
        padding: 5px 10px;
        font-size: 12px;
        border-radius: 5px;
    }

    .badge {
        padding: 5px 10px;
        border-radius: 5px;
        font-size: 12px;
    }
</style>

<div class="container py-4">
    <div class="page-header">
        <div>
            <h2 class="page-title">
                <i class="fas fa-info-circle"></i> @Model.ExtraClass?.Name
            </h2>
        </div>
        <div>
            <a href="@Url.Action("Index", "TeacherExtraClass")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <div class="class-header">
        <h3>@Model.ExtraClass?.Name</h3>
        <p>@(Model.ExtraClass?.Description ?? "No description")</p>
        <div class="mt-2">
            <span class="badge bg-light text-dark">@Model.ExtraClass?.Status</span>
            <span class="badge bg-light text-dark ms-2">@Model.TotalEnrolled Enrolled | @Model.TotalPaid Paid</span>
            <span class="badge bg-light text-dark ms-2">⭐ @Model.AverageRating</span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <!-- Class Information -->
            <div class="info-card">
                <div class="info-title"><i class="fas fa-info-circle"></i> Class Information</div>
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Subject:</strong> @(Model.ExtraClass?.Subject?.Name ?? "N/A")</p>
                        <p><strong>Grade:</strong> @(Model.ExtraClass?.Grade?.Name ?? "N/A")</p>
                        <p><strong>Schedule:</strong> @(Model.ExtraClass?.Schedule ?? "N/A")</p>
                        <p><strong>Venue:</strong> @(Model.ExtraClass?.Venue ?? "TBA")</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Start Date:</strong> @(Model.ExtraClass?.StartDate.ToString("dd MMM yyyy") ?? "N/A")</p>
                        <p><strong>End Date:</strong> @(Model.ExtraClass?.EndDate.ToString("dd MMM yyyy") ?? "N/A")</p>
                        <p><strong>Price:</strong> R @(Model.ExtraClass?.Price.ToString("0.00") ?? "0.00")</p>
                        <p><strong>Capacity:</strong> @(Model.ExtraClass?.CurrentEnrollment ?? 0)/@(Model.ExtraClass?.Capacity ?? 0)</p>
                    </div>
                </div>
            </div>

            <!-- AI Recommendations -->
            @if (Model.AIRecommendation != null)
            {
                <div class="ai-card">
                    <h5><i class="fas fa-robot"></i> AI Teaching Assistant</h5>
                    <p><strong>Predicted Improvement:</strong> +@Model.AIRecommendation.PredictedImprovement%</p>

                    @if (ViewBag.EasyTopics != null && ((List<string>)ViewBag.EasyTopics).Any())
                    {
                        <div>
                            <strong>Easy Win Topics (Start Here):</strong>
                            <div class="topic-list">
                                @foreach (var topic in ViewBag.EasyTopics)
                                {
                                    <span class="topic-badge">✅ @topic</span>
                                }
                            </div>
                        </div>
                    }

                    @if (ViewBag.DifficultTopics != null && ((List<string>)ViewBag.DifficultTopics).Any())
                    {
                        <div class="mt-2">
                            <strong>Difficult Topics (Need Extra Attention):</strong>
                            <div class="topic-list">
                                @foreach (var topic in ViewBag.DifficultTopics)
                                {
                                    <span class="topic-badge">⚠️ @topic</span>
                                }
                            </div>
                        </div>
                    }

                    @if (ViewBag.SuggestedOrder != null && ((List<string>)ViewBag.SuggestedOrder).Any())
                    {
                        <div class="mt-2">
                            <strong>Suggested Teaching Order:</strong>
                            <div class="topic-list">
                                @foreach (var topic in ViewBag.SuggestedOrder)
                                {
                                    <span class="topic-badge">📚 @topic</span>
                                }
                            </div>
                        </div>
                    }

                    @if (ViewBag.CommonMistakes != null && ((List<string>)ViewBag.CommonMistakes).Any())
                    {
                        <div class="mt-2">
                            <strong>Common Mistakes to Watch For:</strong>
                            <div class="topic-list">
                                @foreach (var mistake in ViewBag.CommonMistakes)
                                {
                                    <span class="topic-badge">❗ @mistake</span>
                                }
                            </div>
                        </div>
                    }

                    @if (!Model.AIRecommendation.IsApplied)
                    {
                        <div class="mt-3">
                            <button class="btn-apply" onclick="applyRecommendation(@Model.ExtraClass.Id, @Model.AIRecommendation.Id)">
                                <i class="fas fa-check"></i> Apply Recommendation
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="mt-3">
                            <span class="badge bg-success">✓ Recommendation Applied</span>
                        </div>
                    }
                </div>
            }

            <!-- Attendance Sessions -->
            @if (Model.AttendanceSessions != null && Model.AttendanceSessions.Any())
            {
                <div class="info-card">
                    <div class="info-title"><i class="fas fa-calendar-check"></i> Attendance Sessions</div>
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Session</th>
                                    <th>Present/Absent</th>
                                    <th>Attendance %</th>
                                    <th>Topics Covered</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var session in Model.AttendanceSessions.OrderByDescending(s => s.SessionDate))
                                {
                                    var total = session.AttendanceRecords?.Count ?? 0;
                                    var present = session.AttendanceRecords?.Count(r => r.IsPresent) ?? 0;
                                    var percent = total > 0 ? Math.Round((double)present / total * 100, 1) : 0;

                                    <tr>
                                        <td>@session.SessionDate.ToString("dd MMM yyyy")</td>
                                        <td>Session @session.SessionNumber</td>
                                        <td>@present/@total</td>
                                        <td>@percent%</td>
                                        <td>@(session.TopicsCovered ?? "-")</td>
                                        <td>
                                            <a href="@Url.Action("MarkAttendance", new { sessionId = session.Id })" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-edit"></i> Mark
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

        <div class="col-md-4">
            <!-- Quick Stats -->
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-number">@Model.TotalEnrolled</div>
                    <div>Enrolled</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">@Model.TotalPaid</div>
                    <div>Paid</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">@(Model.AttendanceSessions?.Count ?? 0)</div>
                    <div>Sessions</div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="info-card">
                <div class="info-title"><i class="fas fa-bolt"></i> Quick Actions</div>
                <div class="d-grid gap-2">
                    <a href="@Url.Action("StartSession", new { classId = Model.ExtraClass?.Id })" class="btn btn-success">
                        <i class="fas fa-play"></i> Start New Session
                    </a>
                    <a href="@Url.Action("EnrolledStudents", new { classId = Model.ExtraClass?.Id })" class="btn btn-primary">
                        <i class="fas fa-users"></i> View Students
                    </a>
                    <a href="@Url.Action("SessionHistory", new { classId = Model.ExtraClass?.Id })" class="btn btn-info">
                        <i class="fas fa-history"></i> Session History
                    </a>
                    <a href="@Url.Action("ViewFeedback", new { classId = Model.ExtraClass?.Id })" class="btn btn-secondary">
                        <i class="fas fa-star"></i> View Feedback
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function applyRecommendation(classId, recommendationId) {
        $.ajax({
            url: '@Url.Action("ApplyAIRecommendation", "TeacherExtraClass")',
            type: 'POST',
            data: {
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val(),
                classId: classId,
                recommendationId: recommendationId
            },
            success: function(response) {
                if (response.success) {
                    alert(response.message);
                    location.reload();
                } else {
                    alert(response.message);
                }
            }
        });
    }
</script>