@model ElevateED.ViewModels.ApplicationStatusViewModel
@using ElevateED.Models

@{
    ViewBag.Title = "Application Status - Rejected";
}

<style>
    .status-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        padding: 40px;
    }

    .status-card {
        background: white;
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        text-align: center;
        max-width: 600px;
        width: 100%;
    }

    .status-icon {
        width: 100px;
        height: 100px;
        background: #dc3545;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
    }

    .status-badge {
        display: inline-block;
        padding: 8px 20px;
        border-radius: 20px;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 14px;
        letter-spacing: 1px;
    }

    .status-rejected {
        background: #f8d7da;
        color: #721c24;
        border: 2px solid #dc3545;
    }

    .info-box {
        background: #fff5f5;
        border-left: 4px solid #dc3545;
        padding: 20px;
        margin: 20px 0;
        border-radius: 8px;
        text-align: left;
    }

        .info-box h5 {
            color: #dc3545;
            margin-bottom: 10px;
        }

        .info-box p {
            margin-bottom: 5px;
            color: #555;
        }

        .info-box strong {
            color: #dc3545;
        }

    .rejection-box {
        background: #f8f9fa;
        border: 2px solid #dc3545;
        padding: 20px;
        margin: 20px 0;
        border-radius: 8px;
        text-align: left;
    }

        .rejection-box h5 {
            color: #dc3545;
            margin-bottom: 10px;
        }

    .btn-logout {
        background: transparent;
        color: #6c757d;
        border: 2px solid #6c757d;
        padding: 10px 30px;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-logout:hover {
            background: #6c757d;
            color: white;
        }

    .btn-contact {
        background: #1e3c72;
        color: white;
        border: none;
        padding: 10px 30px;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s ease;
        margin-right: 10px;
    }

        .btn-contact:hover {
            background: #2a5298;
            transform: translateY(-2px);
        }
</style>

<div class="status-container">
    <div class="status-card">
        <div class="status-icon">
            <i class="fas fa-times-circle fa-3x text-white"></i>
        </div>

        <h2 class="mb-3 text-danger">Application Not Approved</h2>

        <div class="status-badge status-rejected mb-4">
            <i class="fas fa-ban"></i> @Model.Status
        </div>

        <p class="lead">Hello <strong>@Model.ApplicantName</strong>,</p>

        <p>We regret to inform you that your application for <strong>@Model.GradeApplyingFor</strong> has been reviewed and could not be approved at this time.</p>

        @if (!string.IsNullOrEmpty(Model.RejectionReason))
        {
            <div class="rejection-box">
                <h5><i class="fas fa-exclamation-triangle"></i> Reason for Rejection</h5>
                <p>@Model.RejectionReason</p>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.AdminNotes))
        {
            <div class="alert alert-secondary" role="alert">
                <strong>Additional Notes:</strong> @Model.AdminNotes
            </div>
        }

        <div class="info-box">
            <h5><i class="fas fa-info-circle"></i> Application Details</h5>
            <p><strong>Student Number:</strong> @Model.StudentNumber</p>
            <p><strong>Status:</strong> <span style="color: #dc3545; font-weight: 600;">@Model.Status</span></p>
            <p><strong>Applied On:</strong> @Model.ApplicationDate.ToString("dd MMMM yyyy")</p>
            <p><strong>Grade Applied For:</strong> @Model.GradeApplyingFor</p>
        </div>

        <div class="alert alert-warning" role="alert">
            <i class="fas fa-phone"></i>
            <strong>Need Help?</strong> If you believe this decision was made in error or would like to discuss your application,
            please contact our admissions office at <strong>(031) 123-4567</strong> or email <strong>admissions@mpiyakhehigh.co.za</strong>
        </div>

        <div class="mt-4">
            <a href="mailto:admissions@mpiyakhehigh.co.za" class="btn btn-contact">
                <i class="fas fa-envelope"></i> Contact Admissions
            </a>
            <form action="@Url.Action("LogOff", "Account")" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-logout">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </form>
        </div>
    </div>
</div>