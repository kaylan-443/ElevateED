@model ElevateED.Models.ViewModels.EditAttendanceViewModel

@{
    ViewBag.Title = "Edit Attendance";
}

<div class="container-fluid mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-edit"></i> Edit Attendance (Session #@Model.SessionId)
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Class:</strong> @Model.ClassName
                        </div>
                        <div class="col-md-6">
                            <strong>Date:</strong> @Model.SessionDate.ToString("MMM dd, yyyy HH:mm")
                        </div>
                    </div>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["Success"]
                            <button type="button" class="close" data-dismiss="alert"></button>
                        </div>
                    }

                    @using (Html.BeginForm("EditAttendance", "Attendance", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.SessionId)

                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Student Name</th>
                                        <th style="width: 200px;">Present</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Records != null && Model.Records.Count > 0)
                                    {
                                        for (int i = 0; i < Model.Records.Count; i++)
                                        {
                                            <tr>
                                                <td>
                                                    @Html.HiddenFor(m => m.Records[i].RecordId)
                                                    @Html.HiddenFor(m => m.Records[i].StudentId)
                                                    <strong>@Model.Records[i].FullName</strong>
                                                </td>
                                                <td>
                                                    <div class="custom-control custom-checkbox">
                                                        @Html.CheckBoxFor(m => m.Records[i].IsPresent, new { @class = "custom-control-input" })
                                                        <label class="custom-control-label" for="Records_@(i)__IsPresent">Mark Present</label>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="2" class="text-center text-muted">No records found</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                            <a href="@Url.Action("StartSession", "Attendance")" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
