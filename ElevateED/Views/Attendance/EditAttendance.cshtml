@model ElevateED.ViewModels.EditAttendanceViewModel

@{
    ViewBag.Title = "Edit Attendance - " + Model.ClassName;
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --primary: #4f46e5;
        --accent: #fbbf24;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --sidebar-width: 280px;
        --header-height: 70px;
    }

    body {
        font-family: 'Inter', -apple-system, sans-serif;
        background: var(--gray-50);
    }

    .app-container {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: var(--sidebar-width);
        background: linear-gradient(180deg, #1e1b4b 0%, #2e1065 100%);
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        z-index: 100;
        overflow-y: auto;
    }

    .sidebar-header {
        padding: 24px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .logo-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--accent), #f59e0b);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e1b4b;
        font-size: 20px;
    }

    .logo-text {
        font-size: 20px;
        font-weight: 700;
        color: white;
    }

        .logo-text span {
            color: var(--accent);
        }

    .sidebar-nav {
        flex: 1;
        padding: 24px 16px;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        margin-bottom: 8px;
        border-radius: 12px;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        transition: all 0.2s;
        font-size: 14px;
        font-weight: 500;
    }

        .nav-item:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        .nav-item.active {
            background: linear-gradient(135deg, var(--accent), #f59e0b);
            color: #1e1b4b;
        }

    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width);
        min-height: 100vh;
    }

    .top-header {
        height: var(--header-height);
        background: white;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: flex-end;
        align-items: center;
        padding: 0 32px;
        position: sticky;
        top: 0;
        z-index: 99;
    }

    .profile-trigger {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 50px;
        background: none;
        border: none;
    }

    .avatar {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg, var(--primary), #4338ca);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 15px;
    }

    .content-area {
        padding: 32px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 15px;
    }

        .page-header h1 {
            font-size: 26px;
            font-weight: 700;
            color: var(--gray-900);
        }

    .btn-back {
        background: white;
        color: var(--gray-700);
        padding: 10px 20px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 500;
        border: 1px solid var(--gray-200);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-back:hover {
            background: var(--gray-100);
            text-decoration: none;
        }

    .info-card {
        background: linear-gradient(135deg, var(--primary), #4338ca);
        color: white;
        padding: 24px;
        border-radius: 16px;
        margin-bottom: 24px;
    }

        .info-card h3 {
            font-size: 20px;
            margin-bottom: 5px;
        }

    .stats-row {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
        margin-top: 14px;
    }

    .stat-item {
        text-align: center;
    }

    .stat-num {
        font-size: 26px;
        font-weight: 700;
    }

    .stat-lbl {
        font-size: 11px;
        text-transform: uppercase;
        opacity: 0.8;
    }

    .alert-success {
        background: #d1fae5;
        color: #065f46;
        padding: 12px 16px;
        border-radius: 10px;
        margin-bottom: 20px;
    }

    .table-wrap {
        background: white;
        border-radius: 16px;
        border: 1px solid var(--gray-200);
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    th {
        background: var(--gray-800);
        color: white;
        padding: 11px 16px;
        text-align: left;
        font-weight: 500;
        font-size: 12px;
    }

    td {
        padding: 11px 16px;
        border-bottom: 1px solid var(--gray-100);
        vertical-align: middle;
    }

    .present-row {
        background: #f0fdf4;
    }

    .absent-row {
        background: #fef2f2;
    }

    tr:hover td {
        background: var(--gray-50);
    }

    .student-name {
        font-weight: 500;
        color: var(--gray-800);
    }

    .badge {
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 600;
        display: inline-block;
    }

    .badge-present {
        background: #d1fae5;
        color: #065f46;
    }

    .badge-absent {
        background: #fee2e2;
        color: #991b1b;
    }

    .checkbox {
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .btn-save {
        background: var(--success);
        color: white;
        padding: 12px 28px;
        border-radius: 12px;
        border: none;
        font-size: 15px;
        font-weight: 500;
        cursor: pointer;
    }

        .btn-save:hover {
            background: #059669;
        }

    @@media (max-width: 1024px) {
        .sidebar {
            transform: translateX(-100%);
        }

        .main-content {
            margin-left: 0;
        }
    }

    @@media (max-width: 768px) {
        .content-area {
            padding: 20px;
        }
    }
</style>

<div class="app-container">
    <aside class="sidebar">
        <div class="sidebar-header"><div class="logo"><div class="logo-icon"><i class="fas fa-graduation-cap"></i></div><div class="logo-text">Elevate<span>ED</span></div></div></div>
        <nav class="sidebar-nav">
            <div class="nav-section">Main</div>
            <a href="@Url.Action("Dashboard","Teacher")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
            <a href="@Url.Action("StartSession","Attendance")" class="nav-item"><i class="fas fa-user-check"></i><span>Take Attendance</span></a>
            <a href="@Url.Action("ActiveSessions","Teacher")" class="nav-item active"><i class="fas fa-list-alt"></i><span>Active Sessions</span></a>
        </nav>
    </aside>
    <main class="main-content">
        <header class="top-header"><div class="header-right"><div class="profile-container" style="position:relative;"><button class="profile-trigger" onclick="toggleDropdown()"><div class="avatar">T</div></button></div></div></header>
        <div class="content-area">
            <div class="page-header">
                <div><h1><i class="fas fa-edit" style="color:var(--primary);"></i> Edit Attendance</h1><p style="color:var(--gray-500);">Manually mark students as present or absent</p></div>
                <a href="@Url.Action("ActiveSessions","Teacher")" class="btn-back"><i class="fas fa-arrow-left"></i> Back to Sessions</a>
            </div>

            @if (TempData["Success"] != null)
            {<div class="alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>}

            <div class="info-card">
                <h3><i class="fas fa-users"></i> @Model.ClassName</h3>
                <p>Session: @Model.SessionDate.ToString("dd MMMM yyyy, hh:mm tt")</p>
                <div class="stats-row">
                    <div class="stat-item"><div class="stat-num">@Model.Records.Count</div><div class="stat-lbl">Total</div></div>
                    <div class="stat-item"><div class="stat-num" style="color:#2ecc71;">@Model.Records.Count(r => r.IsPresent)</div><div class="stat-lbl">Present</div></div>
                    <div class="stat-item"><div class="stat-num" style="color:#e74c3c;">@Model.Records.Count(r => !r.IsPresent)</div><div class="stat-lbl">Absent</div></div>
                </div>
            </div>

            <div class="table-wrap">
                @using (Html.BeginForm("EditAttendance", "Attendance", FormMethod.Post, new { id = "editForm" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.SessionId)@Html.HiddenFor(m => m.ClassName)@Html.HiddenFor(m => m.SessionDate)
                    <table>
                        <thead><tr><th width="40">#</th><th>Student Name</th><th width="100">Status</th><th width="100">Present</th></tr></thead>
                        <tbody>
                            @for (int i = 0; i < Model.Records.Count; i++)
                            {
                                <tr class="@(Model.Records[i].IsPresent?"present-row":"absent-row")">
                                    <td>@(i+1)</td>
                                    <td class="student-name">@Model.Records[i].FullName</td>
                                    <td><span class="badge @(Model.Records[i].IsPresent?"badge-present":"badge-absent")">@(Model.Records[i].IsPresent?"Present":"Absent")</span></td>
                                    <td style="text-align:center;">@Html.HiddenFor(m => m.Records[i].RecordId)@Html.HiddenFor(m => m.Records[i].StudentId)@Html.HiddenFor(m => m.Records[i].FullName)@Html.CheckBoxFor(m => m.Records[i].IsPresent, new { @class = "checkbox", onchange = "updateRow(this)" })</td>
                                </tr>
}
                        </tbody>
                    </table>
                    <div style="padding:16px 20px;text-align:right;border-top:1px solid var(--gray-200);"><button type="submit" class="btn-save"><i class="fas fa-save"></i> Save Changes</button></div>}
            </div>
        </div>
    </main>
</div>
<script>
    function toggleDropdown() { document.getElementById('profileDropdown').classList.toggle('show'); }
    document.addEventListener('click', function (e) { var c = document.querySelector('.profile-container'); var d = document.getElementById('profileDropdown'); if (c && !c.contains(e.target)) d.classList.remove('show'); });
    function updateRow(cb) {
        var row = cb.closest('tr'); var badge = row.querySelector('.badge');
        if (cb.checked) { row.classList.remove('absent-row'); row.classList.add('present-row'); badge.classList.remove('badge-absent'); badge.classList.add('badge-present'); badge.textContent = 'Present'; }
        else { row.classList.remove('present-row'); row.classList.add('absent-row'); badge.classList.remove('badge-present'); badge.classList.add('badge-absent'); badge.textContent = 'Absent'; }
    }
</script>