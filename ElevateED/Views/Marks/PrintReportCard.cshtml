@model ElevateED.ViewModels.ReportCardViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Report Card - @Model.StudentName</title>
    <style>
        body { font-family: Arial, sans-serif; color: #111827; margin: 30px; }
        .toolbar { margin-bottom: 20px; }
        .btn { display: inline-block; padding: 10px 16px; background: #2563eb; color: white; text-decoration: none; border-radius: 6px; border: 0; cursor: pointer; }
        .report { border: 1px solid #d1d5db; padding: 24px; }
        .header { display: flex; justify-content: space-between; border-bottom: 2px solid #111827; padding-bottom: 12px; margin-bottom: 18px; }
        h1, h2, h3 { margin: 0; }
        .muted { color: #6b7280; }
        .summary { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin: 18px 0; }
        .box { border: 1px solid #e5e7eb; padding: 12px; text-align: center; }
        .label { font-size: 12px; color: #6b7280; }
        .value { font-size: 20px; font-weight: bold; margin-top: 4px; }
        table { width: 100%; border-collapse: collapse; margin-top: 16px; }
        th, td { border: 1px solid #d1d5db; padding: 8px; text-align: left; font-size: 13px; }
        th { background: #f3f4f6; }
        .signatures { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 50px; }
        .line { border-top: 1px solid #111827; padding-top: 8px; }
        @@media print {
            .toolbar { display: none; }
            body { margin: 0; }
            .report { border: 0; }
        }
    </style>
</head>
<body>
    <div class="toolbar">
        <button class="btn" onclick="window.print()">Export / Save as PDF</button>
    </div>

    <div class="report">
        <div class="header">
            <div>
                <h1>ElevateED</h1>
                <div class="muted">Learner Academic Report</div>
            </div>
            <div>
                <h3>@Model.Term @Model.AcademicYear</h3>
                <div class="muted">Generated @Model.GeneratedAt.ToString("dd MMM yyyy")</div>
            </div>
        </div>

        <p><strong>Learner:</strong> @Model.StudentName</p>
        <p><strong>Class:</strong> @Model.ClassName</p>

        <div class="summary">
            <div class="box"><div class="label">Term Mark</div><div class="value">@Model.TermMark%</div></div>
            <div class="box"><div class="label">Exam Mark</div><div class="value">@Model.ExamMark%</div></div>
            <div class="box"><div class="label">Final Mark</div><div class="value">@Model.FinalMark%</div></div>
            <div class="box"><div class="label">Decision</div><div class="value">@Model.PromotionDecision</div></div>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Subject</th>
                    <th>Term</th>
                    <th>Exam</th>
                    <th>Final</th>
                    <th>Status</th>
                    <th>Class Avg</th>
                    <th>Trend</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var subject in Model.Subjects)
                {
                    <tr>
                        <td>@subject.SubjectName</td>
                        <td>@subject.TermMark%</td>
                        <td>@subject.ExamMark%</td>
                        <td>@subject.FinalMark%</td>
                        <td>@subject.PassFailStatus</td>
                        <td>@subject.ClassAverage%</td>
                        <td>@subject.PerformanceTrend</td>
                    </tr>
                }
            </tbody>
        </table>

        <p><strong>Overall status:</strong> @Model.PassFailStatus</p>
        <p><strong>Promotion decision:</strong> @Model.PromotionDecision</p>
        <p>@Model.ImprovementComment</p>

        @if (!string.IsNullOrWhiteSpace(Model.ClassTeacherComment))
        {
            <div style="margin-top:22px;padding:14px 16px;border:1px solid #e5e7eb;background:#fafafa;border-radius:6px;">
                <div style="font-weight:bold;margin-bottom:6px;">Class Teacher's Comment</div>
                <div style="white-space:pre-wrap;font-size:13px;">@Model.ClassTeacherComment</div>
                @if (!string.IsNullOrWhiteSpace(Model.ClassTeacherName))
                {
                    <div class="muted" style="margin-top:8px;font-size:12px;">— @Model.ClassTeacherName@(Model.ClassTeacherCommentedAt.HasValue ? $", {Model.ClassTeacherCommentedAt.Value:dd MMM yyyy}" : "")</div>
                }
            </div>
        }

        @if (Model.IsPublished)
        {
            <p class="muted" style="margin-top:18px;font-size:12px;">Published @(Model.PublishedAt?.ToString("dd MMM yyyy") ?? "")</p>
        }
        else
        {
            <p class="muted" style="margin-top:18px;font-size:12px;color:#b76e00;"><strong>Draft</strong> — this report has not yet been published by the principal.</p>
        }

        <div class="signatures">
            <div class="line">Class Teacher Signature</div>
            <div class="line">Principal / HOD Signature</div>
        </div>
    </div>
</body>
</html>
