@model List<ElevateED.Models.ExtraClass>
@using ElevateED.Models

@{
    ViewBag.Title = "Extra Classes Management - ElevateED";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section SidebarNav {
    <div class="nav-section">Main</div>
    <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
    <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
    <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
    <div class="nav-section">Management</div>
    <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
    <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
    <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
    <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
    <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
    <div class="nav-section">Extra</div>
    <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item active"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
    <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
    <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
    <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
}

@section Styles {
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            flex-wrap: wrap;
            gap: 15px;
        }

            .page-header h1 {
                font-size: 24px;
                font-weight: 700;
                color: var(--gray-900);
            }

        .btn-success {
            background: linear-gradient(135deg, var(--success), #059669);
            color: white;
            padding: 10px 20px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-back {
            background: white;
            color: var(--gray-700);
            padding: 10px 20px;
            border-radius: 10px;
            text-decoration: none;
            border: 1px solid var(--gray-200);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .class-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 16px;
            border: 1px solid var(--gray-200);
            border-left: 4px solid var(--primary);
            transition: all 0.3s;
        }

            .class-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            }

        .class-title {
            font-size: 17px;
            font-weight: 600;
            color: var(--gray-900);
            margin-bottom: 12px;
        }

        .class-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            font-size: 13px;
            color: var(--gray-500);
            margin-bottom: 16px;
        }

            .class-meta span {
                display: inline-flex;
                align-items: center;
                gap: 6px;
            }

        .badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-count {
            background: var(--primary);
            color: white;
        }

        .badge-paid {
            background: var(--success);
            color: white;
        }

        .badge-fee {
            background: var(--accent);
            color: #1e1b4b;
        }

        .btn-sm {
            padding: 7px 14px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 500;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
        }

        .btn-book {
            background: var(--info);
            color: white;
        }

        .btn-delete {
            background: var(--danger);
            color: white;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: white;
            border-radius: 20px;
            border: 2px dashed var(--gray-200);
        }

            .empty-state i {
                font-size: 64px;
                color: var(--gray-200);
                margin-bottom: 20px;
            }

        @@media (max-width: 768px) {
            .class-meta {
                flex-direction: column;
                gap: 8px;
            }
        }
    </style>
}

<div class="page-header">
    <div>
        <h1>📚 Extra Classes</h1>
        <p style="color:var(--gray-500);">Manage extra classes and student bookings</p>
    </div>
    <div style="display:flex;gap:10px;">
        <a href="@Url.Action("Create","AdminExtraClass")" class="btn-success">
            <i class="fas fa-plus"></i> Create Class
        </a>
        <a href="@Url.Action("Dashboard","Admin")" class="btn-back">
            <i class="fas fa-arrow-left"></i> Back
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-calendar-plus"></i>
        <h4>No Extra Classes</h4>
        <p style="color:var(--gray-500);">Get started by creating your first extra class</p>
        <a href="@Url.Action("Create","AdminExtraClass")" class="btn-success" style="display:inline-flex;margin-top:15px;">
            <i class="fas fa-plus"></i> Create Your First Class
        </a>
    </div>
}
else
{
    foreach (var cls in Model)
    {
        var bookedCount = cls.Bookings?.Count(b => b.Status != BookingStatus.Cancelled) ?? 0;
        var paidCount = cls.Bookings?.Count(b => b.Status == BookingStatus.Paid) ?? 0;

        <div class="class-card" id="class-@cls.Id">
            <div class="class-title"><i class="fas fa-book-open"></i> @cls.Title</div>
            <div class="class-meta">
                <span><i class="fas fa-book"></i> @(cls.Subject?.Name ?? "N/A")</span>
                <span><i class="fas fa-graduation-cap"></i> @(cls.Grade?.Name ?? "N/A")</span>
                <span><i class="fas fa-calendar"></i> @cls.ClassDate.ToString("dd MMM yyyy")</span>
                <span><i class="fas fa-clock"></i> @(cls.StartTime.ToString(@"hh\:mm")) - @(cls.EndTime.ToString(@"hh\:mm"))</span>
                <span><i class="fas fa-map-marker-alt"></i> @(cls.Location ?? "TBA")</span>
                <span class="badge badge-fee">R @cls.Fee.ToString("0.00")</span>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;">
                <div>
                    <span class="badge badge-count">@bookedCount/@cls.MaxStudents Booked</span>
                    <span class="badge badge-paid">@paidCount Paid</span>
                </div>
                <div style="display:flex;gap:8px;">
                    <a href="@Url.Action("Bookings", new { classId = cls.Id })" class="btn-sm btn-book">
                        <i class="fas fa-list"></i> Bookings
                    </a>
                    <button class="btn-sm btn-delete" onclick="deleteClass(@cls.Id)">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    }
}

@section Scripts {
    <script>
        function deleteClass(id) {
            if (!confirm('Delete this extra class?')) return;
            fetch('@Url.Action("Delete","AdminExtraClass")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + id
            }).then(r => r.json()).then(r => {
                if (r.success) {
                    document.getElementById('class-' + id).style.display = 'none';
                    alert('Class deleted!');
                } else alert(r.message);
            });
        }
    </script>
}