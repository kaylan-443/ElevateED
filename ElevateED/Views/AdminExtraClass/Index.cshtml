@model ElevateED.ViewModels.AdminExtraClassDashboardViewModel
@using ElevateED.Models

@{
    ViewBag.Title = "Extra Classes Management";
}

<style>
    :root {
        --primary: #4f46e5;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        color: #1e3c72;
    }

        .page-title i {
            color: #d4af37;
            margin-right: 10px;
        }

    /* Stats Cards */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 3px 15px rgba(0,0,0,0.08);
        transition: all 0.3s;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.12);
        }

    .stat-number {
        font-size: 32px;
        font-weight: 700;
        color: #1e3c72;
    }

    .stat-label {
        font-size: 12px;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* AI Recommendation Card */
    .ai-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
    }

        .ai-card::before {
            content: '🤖';
            position: absolute;
            right: 20px;
            top: 20px;
            font-size: 60px;
            opacity: 0.2;
        }

        .ai-card h3 {
            margin: 0 0 10px 0;
            font-weight: 700;
        }

    .btn-ai-create {
        background: rgba(255,255,255,0.2);
        color: white;
        border: 2px solid white;
        padding: 10px 25px;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-ai-create:hover {
            background: white;
            color: #764ba2;
            text-decoration: none;
        }

    /* Struggling Subjects */
    .struggling-card {
        background: #fff7ed;
        border-left: 4px solid #f97316;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 10px;
        transition: all 0.3s;
    }

        .struggling-card:hover {
            transform: translateX(5px);
            background: #fffbeb;
        }

    .progress-bar-custom {
        height: 8px;
        border-radius: 4px;
        background: #e5e7eb;
        margin: 10px 0;
    }

    .progress-fill {
        height: 8px;
        border-radius: 4px;
        background: #f97316;
    }

        .progress-fill.low {
            width: 25%;
            background: #ef4444;
        }

        .progress-fill.medium {
            width: 50%;
            background: #f59e0b;
        }

        .progress-fill.high {
            width: 75%;
            background: #10b981;
        }

    /* Class Cards */
    .class-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: 0 3px 15px rgba(0,0,0,0.08);
        transition: all 0.3s;
        border-left: 4px solid var(--primary);
    }

        .class-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.12);
        }

        .class-card.upcoming {
            border-left-color: var(--info);
        }

        .class-card.inprogress {
            border-left-color: var(--warning);
        }

        .class-card.completed {
            border-left-color: var(--success);
        }

        .class-card.cancelled {
            border-left-color: var(--danger);
            opacity: 0.7;
        }

    .class-title {
        font-size: 18px;
        font-weight: 700;
        color: #1e3c72;
        margin-bottom: 8px;
    }

    .class-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        font-size: 13px;
        color: #666;
        margin-bottom: 15px;
    }

        .class-meta span {
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

    .btn-sm {
        padding: 6px 15px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        margin: 2px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 20px;
    }

    .alert {
        padding: 15px 20px;
        border-radius: 12px;
        margin-bottom: 20px;
    }
</style>

<div class="container py-4">
    <div class="page-header">
        <div>
            <h2 class="page-title">
                <i class="fas fa-chalkboard-teacher"></i> Extra Classes Management
            </h2>
            <p class="text-muted">Manage extra classes, monitor performance, and get AI recommendations</p>
        </div>
        <div>
            <a href="@Url.Action("Create", "AdminExtraClass")" class="btn btn-primary">
                <i class="fas fa-plus"></i> Create Extra Class
            </a>
            <a href="@Url.Action("Analytics", "AdminExtraClass")" class="btn btn-outline-info ml-2">
                <i class="fas fa-chart-line"></i> Analytics
            </a>
            <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-outline-secondary ml-2">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <!-- Stats Row -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-number">@Model.TotalClasses</div>
            <div class="stat-label">Total Classes</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@Model.TotalEnrollments</div>
            <div class="stat-label">Total Enrollments</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">R @Model.TotalRevenue.ToString("N0")</div>
            <div class="stat-label">Total Revenue</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">⭐ @Model.AverageRating.ToString("0.0")</div>
            <div class="stat-label">Average Rating</div>
        </div>
    </div>

    <!-- AI Recommendation -->
    @if (Model.AIRecommendation != null)
    {
        <div class="ai-card">
            <h3><i class="fas fa-robot"></i> AI Recommendation</h3>
            <p>Students in <strong>@Model.AIRecommendation.GradeName @Model.AIRecommendation.SubjectName</strong> are struggling with an average mark of <strong>@Model.AIRecommendation.AverageMark%</strong>.</p>
            <p>@Model.AIRecommendation.RecommendedAction</p>
            <div class="mt-3">
                <a href="@Url.Action("Create", new { strugglingSubjectId = Model.StrugglingSubjects.FirstOrDefault()?.SubjectId, strugglingGradeId = Model.StrugglingSubjects.FirstOrDefault()?.GradeId })" class="btn-ai-create">
                    <i class="fas fa-magic"></i> Create AI-Assisted Class
                </a>
            </div>
        </div>
    }

    <!-- Struggling Subjects -->
    @if (Model.StrugglingSubjects != null && Model.StrugglingSubjects.Any())
    {
        <div class="card mb-4">
            <div class="card-header bg-warning text-white">
                <i class="fas fa-exclamation-triangle"></i> Struggling Subjects - Needs Intervention
            </div>
            <div class="card-body">
                @foreach (var subject in Model.StrugglingSubjects)
                {
                    <div class="struggling-card">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div>
                                <strong>@subject.GradeName @subject.SubjectName</strong>
                                <br />
                                <small>@subject.StudentCount students | Pass Rate: @subject.PassRate%</small>
                            </div>
                            <div class="text-end">
                                <span class="badge bg-danger">Avg: @subject.AverageMark%</span>
                                <a href="@Url.Action("Create", new { strugglingSubjectId = subject.SubjectId, strugglingGradeId = subject.GradeId })" class="btn btn-sm btn-warning ms-2">
                                    <i class="fas fa-plus"></i> Create Class
                                </a>
                            </div>
                        </div>
                        <div class="progress-bar-custom">
                            <div class="progress-fill @(subject.AverageMark < 40 ? "low" : subject.AverageMark < 55 ? "medium" : "high")" style="width: @subject.AverageMark%"></div>
                        </div>
                        <small class="text-muted">@subject.Recommendation</small>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Extra Classes List -->
    <h4 class="mb-3"><i class="fas fa-list"></i> All Extra Classes</h4>

    @if (!Model.ExtraClasses.Any())
    {
        <div class="empty-state">
            <i class="fas fa-calendar-plus"></i>
            <h4>No Extra Classes Created</h4>
            <p>Get started by creating your first extra class.</p>
            <a href="@Url.Action("Create", "AdminExtraClass")" class="btn btn-primary mt-3">
                <i class="fas fa-plus"></i> Create Extra Class
            </a>
        </div>
    }
    else
    {
        foreach (var cls in Model.ExtraClasses.OrderByDescending(c => c.StartDate))
        {
            var statusClass = cls.Status.ToString().ToLower();
            var enrolledCount = cls.Enrollments?.Count(e => e.IsActive) ?? 0;
            var paidCount = cls.Enrollments?.Count(e => e.IsPaid) ?? 0;

            <div class="class-card @statusClass">
                <div class="class-title">@cls.Name</div>
                <div class="class-meta">
                    <span><i class="fas fa-book"></i> @(cls.Subject?.Name ?? "N/A")</span>
                    <span><i class="fas fa-graduation-cap"></i> @(cls.Grade?.Name ?? "N/A")</span>
                    <span><i class="fas fa-user-tie"></i> @(cls.Teacher?.FullName ?? "Unassigned")</span>
                    <span><i class="fas fa-calendar"></i> @cls.StartDate.ToString("dd MMM yyyy")</span>
                    <span><i class="fas fa-clock"></i> @cls.Schedule</span>
                    <span><i class="fas fa-map-marker-alt"></i> @(cls.Venue ?? "TBA")</span>
                    <span><i class="fas fa-users"></i> @enrolledCount/@cls.Capacity enrolled</span>
                    <span><i class="fas fa-rand"></i> R @cls.Price.ToString("0.00")</span>
                </div>
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <span class="badge @(statusClass == "upcoming" ? "bg-info" : statusClass == "inprogress" ? "bg-warning" : statusClass == "completed" ? "bg-success" : "bg-secondary")">
                            @cls.Status
                        </span>
                        <span class="badge bg-success ms-1">@paidCount Paid</span>
                    </div>
                    <div>
                        <a href="@Url.Action("Details", new { id = cls.Id })" class="btn btn-sm btn-info">
                            <i class="fas fa-eye"></i> Details
                        </a>
                        <a href="@Url.Action("Enrollments", new { id = cls.Id })" class="btn btn-sm btn-primary">
                            <i class="fas fa-users"></i> Enrollments (@enrolledCount)
                        </a>
                        @if (cls.TeacherId == null)
                        {
                            <a href="@Url.Action("Details", new { id = cls.Id })" class="btn btn-sm btn-warning">
                                <i class="fas fa-user-plus"></i> Assign Teacher
                            </a>
                        }
                        <button class="btn btn-sm btn-danger" onclick="deleteClass(@cls.Id, '@cls.Name')">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>

<script>
    function deleteClass(id, name) {
        if (confirm('Delete "' + name + '"? This action cannot be undone.')) {
            $.ajax({
                url: '@Url.Action("Delete", "AdminExtraClass")',
                type: 'POST',
                data: {
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val(),
                    id: id
                },
                success: function(response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        alert(response.message);
                    }
                }
            });
        }
    }
</script>