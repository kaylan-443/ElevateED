@model List<ElevateED.Models.ExtraClass>
@using ElevateED.Models

@{
    ViewBag.Title = "Extra Classes Management - ElevateED";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --primary: #4f46e5;
        --primary-dark: #4338ca;
        --accent: #fbbf24;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --purple: #8b5cf6;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-900: #111827;
        --sidebar-width: 280px;
        --header-height: 70px;
    }

    body {
        font-family: 'Inter', -apple-system, sans-serif;
        background: var(--gray-50);
    }

    .app-container {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: var(--sidebar-width);
        background: linear-gradient(180deg, #1e1b4b 0%, #2e1065 100%);
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        z-index: 100;
        overflow-y: auto;
    }

    .sidebar-header {
        padding: 24px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .logo-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--accent), #f59e0b);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e1b4b;
        font-size: 20px;
    }

    .logo-text {
        font-size: 20px;
        font-weight: 700;
        color: white;
    }

        .logo-text span {
            color: var(--accent);
        }

    .sidebar-nav {
        flex: 1;
        padding: 24px 16px;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        margin-bottom: 8px;
        border-radius: 12px;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
    }

        .nav-item:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        .nav-item.active {
            background: linear-gradient(135deg, var(--accent), #f59e0b);
            color: #1e1b4b;
        }

        .nav-item i {
            width: 20px;
            font-size: 18px;
        }

    .nav-section {
        margin-top: 24px;
        margin-bottom: 12px;
        padding: 0 16px;
        font-size: 11px;
        font-weight: 600;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width);
        min-height: 100vh;
    }

    .top-header {
        height: var(--header-height);
        background: white;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: flex-end;
        align-items: center;
        padding: 0 32px;
        position: sticky;
        top: 0;
        z-index: 99;
    }

    .content-area {
        padding: 32px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
        flex-wrap: wrap;
        gap: 15px;
    }

        .page-header h1 {
            font-size: 24px;
            font-weight: 700;
            color: var(--gray-900);
        }

    .btn-success {
        background: linear-gradient(135deg, var(--success), #059669);
        color: white;
        padding: 10px 20px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-back {
        background: white;
        color: var(--gray-700);
        padding: 10px 20px;
        border-radius: 10px;
        text-decoration: none;
        border: 1px solid var(--gray-200);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .class-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 16px;
        border: 1px solid var(--gray-200);
        border-left: 4px solid var(--primary);
        transition: all 0.3s;
    }

        .class-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        }

    .class-title {
        font-size: 17px;
        font-weight: 600;
        color: var(--gray-900);
        margin-bottom: 12px;
    }

    .class-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        font-size: 13px;
        color: var(--gray-500);
        margin-bottom: 16px;
    }

        .class-meta span {
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

    .badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 600;
    }

    .badge-count {
        background: var(--primary);
        color: white;
    }

    .badge-paid {
        background: var(--success);
        color: white;
    }

    .badge-fee {
        background: var(--accent);
        color: #1e1b4b;
    }

    .btn-sm {
        padding: 7px 14px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
    }

    .btn-book {
        background: var(--info);
        color: white;
    }

    .btn-delete {
        background: var(--danger);
        color: white;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 20px;
        border: 2px dashed var(--gray-200);
    }

        .empty-state i {
            font-size: 64px;
            color: var(--gray-200);
            margin-bottom: 20px;
        }

    .profile-container {
        position: relative;
    }

    .profile-trigger {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 50px;
        background: none;
        border: none;
    }

    .avatar {
        width: 40px;
        height: 40px;
        background: var(--primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
    }

    .dropdown-menu {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        width: 240px;
        display: none;
        z-index: 1000;
    }

        .dropdown-menu.show {
            display: block;
        }

    .dropdown-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        text-decoration: none;
        color: var(--gray-700);
        cursor: pointer;
        background: none;
        border: none;
        width: 100%;
        text-align: left;
    }

        .dropdown-item:hover {
            background: var(--gray-100);
        }

    .dropdown-divider {
        height: 1px;
        background: var(--gray-200);
        margin: 8px 0;
    }

    @@media (max-width: 768px) {
        .content-area {
            padding: 20px;
        }

        .class-meta {
            flex-direction: column;
            gap: 8px;
        }
    }
</style>

<div class="app-container">
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="logo"><div class="logo-icon"><i class="fas fa-graduation-cap"></i></div><div class="logo-text">Elevate<span>ED</span></div></div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section">Main</div>
            <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
            <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
            <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
            <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
            <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
            <div class="nav-section">Management</div>
            <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
            <a href="@Url.Action("CreateWizard","AdminAnnouncement")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
            <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
            <div class="nav-section">Extra</div>
            <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item active"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
            <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
        </nav>
    </aside>

    <main class="main-content">
        <header class="top-header">
            <div class="header-right">
                <div class="profile-container">
                    <button class="profile-trigger" onclick="toggleDropdown()"><div class="avatar">A</div><span>Admin</span></button>
                    <div class="dropdown-menu" id="profileDropdown">
                        <div class="dropdown-header" style="padding:16px;"><strong>Administrator</strong></div>
                        <div class="dropdown-divider"></div>
                        <form action="@Url.Action("LogOff","Account")" method="post">@Html.AntiForgeryToken()<button type="submit" class="dropdown-item" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i>Logout</button></form>
                    </div>
                </div>
            </div>
        </header>

        <div class="content-area">
            <div class="page-header">
                <div><h1>📚 Extra Classes</h1><p style="color:var(--gray-500);">Manage extra classes and student bookings</p></div>
                <div style="display:flex;gap:10px;">
                    <a href="@Url.Action("Create","AdminExtraClass")" class="btn-success"><i class="fas fa-plus"></i> Create Class</a>
                    <a href="@Url.Action("Dashboard","Admin")" class="btn-back"><i class="fas fa-arrow-left"></i> Back</a>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="fas fa-calendar-plus"></i>
                    <h4>No Extra Classes</h4>
                    <p style="color:var(--gray-500);">Get started by creating your first extra class</p>
                    <a href="@Url.Action("Create","AdminExtraClass")" class="btn-success" style="display:inline-flex;margin-top:15px;"><i class="fas fa-plus"></i> Create Your First Class</a>
                </div>
            }
            else
            {
                foreach (var cls in Model)
                {
                    var bookedCount = cls.Bookings?.Count(b => b.Status != BookingStatus.Cancelled) ?? 0;
                    var paidCount = cls.Bookings?.Count(b => b.Status == BookingStatus.Paid) ?? 0;

                    <div class="class-card" id="class-@cls.Id">
                        <div class="class-title"><i class="fas fa-book-open"></i> @cls.Title</div>
                        <div class="class-meta">
                            <span><i class="fas fa-book"></i> @(cls.Subject?.Name ?? "N/A")</span>
                            <span><i class="fas fa-graduation-cap"></i> @(cls.Grade?.Name ?? "N/A")</span>
                            <span><i class="fas fa-calendar"></i> @cls.ClassDate.ToString("dd MMM yyyy")</span>
                            <span><i class="fas fa-clock"></i> @(cls.StartTime.ToString(@"hh\:mm")) - @(cls.EndTime.ToString(@"hh\:mm"))</span>
                            <span><i class="fas fa-map-marker-alt"></i> @(cls.Location ?? "TBA")</span>
                            <span class="badge badge-fee">R @cls.Fee.ToString("0.00")</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;align-items:center;">
                            <div>
                                <span class="badge badge-count">@bookedCount/@cls.MaxStudents Booked</span>
                                <span class="badge badge-paid">@paidCount Paid</span>
                            </div>
                            <div style="display:flex;gap:8px;">
                                <a href="@Url.Action("Bookings",new{classId=cls.Id})" class="btn-sm btn-book"><i class="fas fa-list"></i> Bookings</a>
                                <button class="btn-sm btn-delete" onclick="deleteClass(@cls.Id)"><i class="fas fa-trash"></i> Delete</button>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </main>
</div>

<script>
    function toggleDropdown(){document.getElementById('profileDropdown').classList.toggle('show');}
    document.addEventListener('click',function(e){var c=document.querySelector('.profile-container'),d=document.getElementById('profileDropdown');if(c&&!c.contains(e.target))d.classList.remove('show');});
    function deleteClass(id){if(!confirm('Delete this extra class?'))return;fetch('@Url.Action("Delete","AdminExtraClass")',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'id='+id}).then(r=>r.json()).then(r=>{if(r.success){document.getElementById('class-'+id).style.display='none';alert('Class deleted!')}else alert(r.message)})}
</script>