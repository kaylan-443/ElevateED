@model ElevateED.ViewModels.CreateExtraClassViewModel
@using ElevateED.Models

@{
    ViewBag.Title = Model.IsAIGenerated ? "AI-Assisted Create Extra Class" : "Create Extra Class";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        color: #1e3c72;
    }

        .page-title i {
            color: #d4af37;
            margin-right: 10px;
        }

    .form-card {
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 3px 15px rgba(0,0,0,0.08);
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        display: block;
    }

    .form-control, select {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 10px 15px;
        width: 100%;
        transition: all 0.3s;
    }

        .form-control:focus, select:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79,70,229,0.1);
            outline: none;
        }

    .required::after {
        content: " *";
        color: #ef4444;
    }

    .ai-badge {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        padding: 8px 16px;
        border-radius: 25px;
        font-size: 12px;
        display: inline-block;
        margin-bottom: 20px;
    }

    .btn-submit {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        padding: 14px 30px;
        border-radius: 25px;
        border: none;
        font-weight: 600;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.3s;
        width: 100%;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(16,185,129,0.3);
        }

    .btn-cancel {
        background: #6b7280;
        color: white;
        padding: 14px 30px;
        border-radius: 25px;
        border: none;
        font-weight: 600;
        font-size: 16px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        text-align: center;
        width: 100%;
    }

        .btn-cancel:hover {
            background: #5a6268;
            color: white;
            text-decoration: none;
        }

    .button-row {
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e5e7eb;
    }

    .text-danger {
        color: #ef4444;
        font-size: 12px;
        margin-top: 5px;
    }
</style>

<div class="container py-4">
    <div class="page-header">
        <div>
            <h2 class="page-title">
                <i class="fas @(Model.IsAIGenerated ? "fa-robot" : "fa-plus-circle")"></i> @(Model.IsAIGenerated ? "AI-Assisted" : "Create") Extra Class
            </h2>
            <p class="text-muted">@(Model.IsAIGenerated ? "AI has pre-filled recommended details based on student performance" : "Fill in the details to create a new extra class")</p>
        </div>
        <div>
            <a href="@Url.Action("Index", "AdminExtraClass")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    @if (Model.IsAIGenerated)
    {
        <div class="ai-badge">
            <i class="fas fa-robot"></i> AI-Generated Recommendation
        </div>
    }

    <div class="form-card">
        @using (Html.BeginForm("Create", "AdminExtraClass", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="row">
                <div class="col-md-8">
                    <div class="form-group">
                        <label class="form-label required">Class Name</label>
                        @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "e.g., Grade 10 Mathematics Intervention" })
                        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label required">Price (R)</label>
                        @Html.TextBoxFor(m => m.Price, new { @class = "form-control", type = "number", step = "0.01", min = "0", placeholder = "0.00" })
                        @Html.ValidationMessageFor(m => m.Price, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Description</label>
                @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = 3, placeholder = "Describe what this class will cover..." })
                @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-danger" })
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label required">Subject</label>
                        <select name="SubjectId" class="form-control" required>
                            <option value="">-- Select Subject --</option>
                            @if (ViewBag.Subjects != null)
                            {
                                foreach (var subject in ViewBag.Subjects)
                                {
                                    <option value="@subject.Id" @(Model.SubjectId == subject.Id ? "selected" : "")>@subject.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label required">Grade</label>
                        <select name="GradeId" class="form-control" required>
                            <option value="">-- Select Grade --</option>
                            @if (ViewBag.Grades != null)
                            {
                                foreach (var grade in ViewBag.Grades)
                                {
                                    <option value="@grade.Id" @(Model.GradeId == grade.Id ? "selected" : "")>@grade.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Assigned Teacher (Optional)</label>
                        <select name="TeacherId" class="form-control">
                            <option value="">-- Assign Later --</option>
                            @if (ViewBag.Teachers != null)
                            {
                                foreach (var teacher in ViewBag.Teachers)
                                {
                                    <option value="@teacher.Id" @(Model.TeacherId == teacher.Id ? "selected" : "")>@teacher.FullName (@teacher.User?.StudentNumber)</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label required">Schedule</label>
                        @Html.TextBoxFor(m => m.Schedule, new { @class = "form-control", placeholder = "e.g., Saturdays 09:00-11:00" })
                        @Html.ValidationMessageFor(m => m.Schedule, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label required">Start Date</label>
                        @Html.TextBoxFor(m => m.StartDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                        @Html.ValidationMessageFor(m => m.StartDate, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label required">End Date</label>
                        @Html.TextBoxFor(m => m.EndDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                        @Html.ValidationMessageFor(m => m.EndDate, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Venue / Location</label>
                        @Html.TextBoxFor(m => m.Venue, new { @class = "form-control", placeholder = "e.g., Room 101, Online (Zoom link)" })
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label required">Capacity</label>
                        @Html.TextBoxFor(m => m.Capacity, new { @class = "form-control", type = "number", min = "1", max = "100", placeholder = "25" })
                        @Html.ValidationMessageFor(m => m.Capacity, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            <!-- BUTTON ROW - Clearly visible -->
            <div class="row button-row">
                <div class="col-md-6">
                    <a href="@Url.Action("Index", "AdminExtraClass")" class="btn-cancel">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
                <div class="col-md-6">
                    <button type="submit" class="btn-submit">
                        <i class="fas fa-save"></i> Create Extra Class
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<script>
    // Set default dates if not already set
    document.addEventListener('DOMContentLoaded', function() {
        var startDate = document.querySelector('input[name="StartDate"]');
        var endDate = document.querySelector('input[name="EndDate"]');

        if (startDate && !startDate.value) {
            var today = new Date();
            var nextWeek = new Date(today);
            nextWeek.setDate(today.getDate() + 7);
            startDate.value = nextWeek.toISOString().split('T')[0];
        }

        if (endDate && !endDate.value && startDate && startDate.value) {
            var end = new Date(startDate.value);
            end.setDate(end.getDate() + 42); // 6 weeks later
            endDate.value = end.toISOString().split('T')[0];
        }
    });
</script>