@model List<ElevateED.Models.TransportRoute>
@{
    ViewBag.Title = "Driver Dashboard";
    Layout = "~/Views/Shared/_DriverLayout.cshtml";
}

<style>
    :root {
        --primary: #1e3c72;
        --secondary: #2a5298;
        --gold: #d4af37;
        --success: #28a745;
        --danger: #dc3545;
        --warning: #ffc107;
        --info: #17a2b8;
    }

    body {
        background: #f5f6fa;
    }

    .dashboard-container {
        padding: 20px 0 40px 0;
    }

    .welcome-card {
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        padding: 25px 30px;
        border-radius: 15px;
        margin-bottom: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
    }

        .welcome-card h3 {
            margin: 0;
            font-weight: 700;
        }

    .driver-info {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        font-size: 14px;
        opacity: 0.9;
    }

        .driver-info span {
            display: flex;
            align-items: center;
            gap: 5px;
        }

    .btn-logout {
        background: rgba(255,255,255,0.15);
        color: white;
        border: 1px solid rgba(255,255,255,0.3);
        padding: 8px 20px;
        border-radius: 25px;
        text-decoration: none;
    }

    .route-card {
        background: white;
        border-radius: 15px;
        padding: 25px;
        margin-bottom: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border-left: 5px solid #ddd;
    }

        .route-card.pending {
            border-left-color: var(--warning);
        }

        .route-card.active {
            border-left-color: #28a745;
            background: #f9fff9;
        }

        .route-card.outbound-complete {
            border-left-color: #6366f1;
            background: #f5f3ff;
        }

        .route-card.return-active {
            border-left-color: #8b5cf6;
            background: #faf5ff;
        }

        .route-card.completed {
            border-left-color: #6c757d;
            opacity: 0.7;
        }

    .route-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .route-title {
        font-size: 20px;
        font-weight: 700;
        color: var(--primary);
    }

    .route-details {
        display: flex;
        gap: 25px;
        flex-wrap: wrap;
        margin-bottom: 15px;
        color: #555;
        font-size: 14px;
    }

        .route-details div {
            display: flex;
            align-items: center;
            gap: 6px;
        }

    .action-buttons {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 10px 22px;
        border-radius: 25px;
        border: none;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
    }

    .btn-start {
        background: var(--success);
        color: white;
    }

    .btn-end {
        background: var(--warning);
        color: #333;
    }

    .btn-return {
        background: #8b5cf6;
        color: white;
    }

    .btn-list {
        background: #6c757d;
        color: white;
    }

    .status-badge {
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .trip-badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 600;
        margin-left: 8px;
    }

    .trip-outbound {
        background: #e0e7ff;
        color: #4338ca;
    }

    .trip-return {
        background: #ede9fe;
        color: #6d28d9;
    }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
        background: white;
        border-radius: 15px;
    }

    .roll-call-table {
        width: 100%;
        border-collapse: collapse;
    }

        .roll-call-table th {
            background: #f8f9fa;
            padding: 12px;
            text-align: left;
            font-weight: 600;
            border-bottom: 2px solid #e0e0e0;
        }

        .roll-call-table td {
            padding: 10px 12px;
            border-bottom: 1px solid #f0f0f0;
        }

    .modal-content {
        border-radius: 15px;
        border: none;
    }

    .modal-header {
        border-radius: 15px 15px 0 0;
        padding: 18px 25px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
    }

    .card {
        border-radius: 10px;
    }
</style>

<div class="container dashboard-container">
    <div class="welcome-card">
        <div>
            <h3><i class="fas fa-bus"></i> Driver Dashboard</h3>
            <p class="mb-0 mt-2">Welcome, <strong>@ViewBag.DriverName</strong></p>
        </div>
        <div class="driver-info">
            <span><i class="fas fa-phone"></i> @ViewBag.DriverPhone</span>
            <span><i class="fas fa-car"></i> @ViewBag.DriverVehicle</span>
        </div>
        <a href="@Url.Action("Logout", "Driver")" class="btn-logout" onclick="return confirm('Logout?')"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state"><i class="fas fa-route"></i><h4>No Routes Assigned</h4></div>
    }
    else
    {
        foreach (var route in Model)
        {
            var ec = route.ExtraClass;

            string sc = route.Status == "Active" ? "active" :
                        route.Status == "Emergency" ? "emergency" :
                        route.Status == "Outbound_Complete" ? "outbound-complete" :
                        route.Status == "Return_Active" ? "return-active" :
                        route.Status == "Completed" ? "completed" : "pending";

            string bc = route.Status == "Active" ? "success" :
                        route.Status == "Emergency" ? "danger" :
                        route.Status == "Outbound_Complete" ? "info" :
                        route.Status == "Return_Active" ? "purple" :
                        route.Status == "Completed" ? "secondary" : "warning";

            string statusText = route.Status == "Active" ? "Outbound" :
                               route.Status == "Return_Active" ? "Return" :
                               route.Status == "Outbound_Complete" ? "Venue Reached" :
                               route.Status;

            <div class="route-card @sc" id="route-@route.Id">
                <div class="route-header">
                    <div class="route-title">
                        @(ec?.Title ?? "Route #"+route.Id)
                        @if (route.Status == "Active")
                        {<span class="trip-badge trip-outbound">🚐 Outbound Trip</span>}
                        @if (route.Status == "Return_Active")
                        {<span class="trip-badge trip-return">🏫 Return Trip</span>}
                        @if (route.Status == "Outbound_Complete")
                        {<span class="trip-badge trip-outbound">✅ Outbound Done</span>}
                    </div>
                    <span class="badge badge-@bc status-badge">@statusText</span>
                </div>
                <div class="route-details">
                    <div><i class="fas fa-graduation-cap"></i>@(ec?.Grade?.Name??"N/A")</div>
                    <div><i class="fas fa-book"></i>@(ec?.Subject?.Name??"N/A")</div>
                    <div><i class="fas fa-calendar"></i>@(ec?.ClassDate.ToString("dd MMM yyyy")??"N/A")</div>
                    <div><i class="fas fa-clock"></i>@(ec?.StartTime.ToString(@"hh\:mm")??"N/A")-@(ec?.EndTime.ToString(@"hh\:mm")??"N/A")</div>
                    <div><i class="fas fa-map-marker-alt"></i>@(ec?.Location??"TBA")</div>
                </div>
                <div class="action-buttons">
                    @if (route.Status == "Pending")
                    {<button class="btn-action btn-start" onclick="startTripWithRollCall(@route.Id,'Outbound')"><i class="fas fa-play-circle"></i>Start Outbound Trip</button>}

                    @if (route.Status == "Active")
                    {<button class="btn-action btn-end" onclick="endOutboundTrip(@route.Id)"><i class="fas fa-flag-checkered"></i>Arrived at Venue</button>}

                    @if (route.Status == "Outbound_Complete")
                    {<button class="btn-action btn-return" onclick="startTripWithRollCall(@route.Id,'Return')"><i class="fas fa-play-circle"></i>Start Return Trip</button>}

                    @if (route.Status == "Return_Active")
                    {<button class="btn-action btn-end" onclick="endTrip(@route.Id)"><i class="fas fa-flag-checkered"></i>Arrived at School</button>}

                    <a class="btn-action btn-list" href="@Url.Action("TransportList","Driver",new{routeId=route.Id})"><i class="fas fa-list"></i>View Students</a>
                </div>
            </div>
        }
    }
</div>

<!-- ROLL CALL MODAL -->
<div class="modal fade" id="rollCallModal" tabindex="-1" data-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="rollCallTitle"><i class="fas fa-clipboard-check"></i> Student Roll Call</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body" id="rollCallBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" id="startTripBtn" onclick="confirmStartTrip()">
                    <i class="fas fa-play-circle"></i> Start Trip
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    var currentRouteId = null;
    var currentTripType = null;

    function startTripWithRollCall(routeId, tripType) {
        currentRouteId = routeId;
        currentTripType = tripType;
        var title = tripType === 'Outbound' ? 'Outbound Trip Roll Call (School → Venue)' : 'Return Trip Roll Call (Venue → School)';
        $('#rollCallTitle').html('<i class="fas fa-clipboard-check"></i> ' + title);
        $('#rollCallBody').html('<div class="text-center py-4"><i class="fas fa-spinner fa-spin"></i> Loading students...</div>');
        $('#rollCallModal').modal('show');

        $.get('@Url.Action("GetStudentsForRollCall","Driver")', { routeId: routeId }, function(r) {
            if (r.success) {
                var h = '<p class="text-muted mb-3"><i class="fas fa-info-circle"></i> Check off each student as they board the vehicle.</p>';
                h += '<table class="roll-call-table"><thead><tr><th>✓</th><th>#</th><th>Student</th><th>Class</th></tr></thead><tbody>';
                r.students.forEach(function(s, i) {
                    h += '<tr><td><input type="checkbox" class="sc" checked data-id="' + s.bookingId + '"></td><td>' + (i + 1) + '</td><td><strong>' + s.fullName + '</strong></td><td>' + (s.className || '') + '</td></tr>';
                });
                h += '</tbody></table>';
                h += '<div class="text-right mt-3"><button class="btn btn-outline-secondary btn-sm" onclick="$(\'.sc\').prop(\'checked\',true)">Select All</button></div>';
                $('#rollCallBody').html(h);
            } else {
                $('#rollCallBody').html('<div class="alert alert-warning">No students found for this route.</div>');
            }
        });
    }

    function confirmStartTrip() {
        var ids = [];
        $('.sc:checked').each(function() { ids.push(parseInt($(this).data('id'))); });
        if (ids.length === 0) { alert('Please select at least one student!'); return; }

        $('#startTripBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Starting...');

        $.post('@Url.Action("SaveRollCall","Driver")', {
            routeId: currentRouteId,
            tripType: currentTripType,
            presentStudentIds: ids
        }, function(r) {
            if (r.success) {
                // Now start the trip
                $.post('@Url.Action("StartTrip","Driver")', {
                    routeId: currentRouteId,
                    tripType: currentTripType
                }, function(r2) {
                    if (r2.success) {
                        $('#rollCallModal').modal('hide');
                        alert('✅ ' + currentTripType + ' trip started!');
                        location.reload();
                    } else {
                        alert(r2.message);
                        $('#startTripBtn').prop('disabled', false).html('<i class="fas fa-play-circle"></i> Start Trip');
                    }
                });
            } else {
                alert(r.message);
                $('#startTripBtn').prop('disabled', false).html('<i class="fas fa-play-circle"></i> Start Trip');
            }
        });
    }

    function endOutboundTrip(id) {
        if (!confirm('Confirm arrival at venue? This will complete the outbound trip.')) return;
        $.post('@Url.Action("EndOutboundTrip","Driver")', { routeId: id }, function(r) {
            if (r.success) { alert('✅ Outbound trip complete!'); location.reload(); }
        });
    }

    function endTrip(id) {
        if (!confirm('Confirm arrival at school? This will complete the entire trip.')) return;
        $.post('@Url.Action("EndRoute","Driver")', { routeId: id }, function(r) {
            if (r.success) { alert('✅ All trips completed!'); location.reload(); }
        });
    }

    // Reset when modal closes
    $('#rollCallModal').on('hidden.bs.modal', function() {
        currentRouteId = null;
        currentTripType = null;
        $('#startTripBtn').prop('disabled', false).html('<i class="fas fa-play-circle"></i> Start Trip');
    });
</script>