@model List<string>

@{
    ViewBag.Title = ViewBag.Grade + " - Select Class";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section SidebarNav {
    <div class="nav-section">Main</div>
    <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
    <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
    <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
    <div class="nav-section">Management</div>
    <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
    <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
    <a href="@Url.Action("ClassRegister","Admin")" class="nav-item active"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
    <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
    <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
    <div class="nav-section">Extra</div>
    <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
    <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
    <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
    <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
}

@section Styles {
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 15px;
        }

            .page-header h1 {
                font-size: 26px;
                font-weight: 700;
                color: var(--gray-900);
            }

        .btn-back {
            background: white;
            color: var(--gray-700);
            padding: 10px 20px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 500;
            border: 1px solid var(--gray-200);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-back:hover {
                background: var(--gray-100);
                text-decoration: none;
            }

        .info-banner {
            background: linear-gradient(135deg, var(--primary), #4338ca);
            color: white;
            padding: 24px;
            border-radius: 16px;
            margin-bottom: 24px;
            text-align: center;
        }

            .info-banner h2 {
                font-size: 22px;
                margin-bottom: 5px;
            }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 16px;
        }

        .card {
            background: white;
            border-radius: 16px;
            padding: 28px;
            text-align: center;
            border: 1px solid var(--gray-200);
            cursor: pointer;
            transition: all 0.3s;
        }

            .card:hover {
                transform: translateY(-4px);
                box-shadow: 0 15px 30px rgba(0,0,0,0.08);
                border-color: var(--success);
            }

        .card-icon {
            width: 65px;
            height: 65px;
            border-radius: 50%;
            background: var(--success);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            font-size: 30px;
            color: white;
        }

        .card h3 {
            font-size: 22px;
            font-weight: 700;
            color: var(--gray-900);
            margin-bottom: 12px;
        }

        .card .btns {
            display: flex;
            gap: 8px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-upload {
            background: var(--success);
            color: white;
            padding: 8px 18px;
            border-radius: 10px;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
        }

            .btn-upload:hover {
                background: #059669;
                color: white;
                text-decoration: none;
            }

        .btn-view {
            background: var(--info);
            color: white;
            padding: 8px 18px;
            border-radius: 10px;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
        }

            .btn-view:hover {
                background: #2563eb;
                color: white;
                text-decoration: none;
            }
    </style>
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-clipboard-list" style="color:var(--info);"></i> Class Register</h1>
        <p style="color:var(--gray-500);">@ViewBag.Grade - Select a class</p>
    </div>
    <a href="@Url.Action("ClassRegister","Admin")" class="btn-back">
        <i class="fas fa-arrow-left"></i> Back to Grades
    </a>
</div>

<div class="info-banner">
    <h2><i class="fas fa-graduation-cap"></i> @ViewBag.Grade</h2>
    <p>Select a class to upload or view the register</p>
</div>

<div class="grid">
    @foreach (var c in Model)
    {
        <div class="card">
            <div class="card-icon"><i class="fas fa-users"></i></div>
            <h3>@c</h3>
            <div class="btns">
                <a href="@Url.Action("UploadClassRegister","Admin", new { grade = ViewBag.Grade, className = c })" class="btn-upload">
                    <i class="fas fa-upload"></i> Upload
                </a>
                <a href="@Url.Action("ViewClassRegisters","Admin", new { grade = ViewBag.Grade, className = c })" class="btn-view">
                    <i class="fas fa-eye"></i> View
                </a>
            </div>
        </div>
    }
</div>