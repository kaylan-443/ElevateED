@{
    ViewBag.Title = "Time Table - Admin";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section SidebarNav {
    <div class="nav-section">Main</div>
    <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
    <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
    <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
    <div class="nav-section">Management</div>
    <a href="@Url.Action("TimeTable","Admin")" class="nav-item active"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
    <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
    <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
    <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
    <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
    <div class="nav-section">Extra</div>
    <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
    <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
    <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
    <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
}

@section Styles {
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            flex-wrap: wrap;
            gap: 15px;
        }

            .page-header h1 {
                font-size: 26px;
                font-weight: 700;
                color: var(--gray-900);
            }

        .btn-back {
            background: white;
            color: var(--gray-700);
            padding: 10px 20px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 500;
            border: 1px solid var(--gray-200);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-back:hover {
                background: var(--gray-100);
                text-decoration: none;
            }

        .options-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            max-width: 800px;
            margin: 0 auto;
        }

        .option-card {
            background: white;
            border-radius: 20px;
            padding: 40px 30px;
            text-align: center;
            border: 1px solid var(--gray-200);
            cursor: pointer;
            transition: all 0.3s;
        }

            .option-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            }

        .option-icon {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 42px;
            color: white;
        }

            .option-icon.teachers {
                background: linear-gradient(135deg, var(--success), #34d399);
            }

            .option-icon.learners {
                background: linear-gradient(135deg, var(--info), #60a5fa);
            }

        .option-card h2 {
            font-size: 22px;
            font-weight: 700;
            color: var(--gray-900);
            margin-bottom: 12px;
        }

        .option-card p {
            color: var(--gray-500);
            font-size: 14px;
            line-height: 1.6;
        }

            .option-card p i {
                margin-right: 6px;
            }

        @@media (max-width: 768px) {
            .options-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-calendar-alt" style="color:var(--info);"></i> Time Table Management</h1>
        <p style="color:var(--gray-500);">Upload and manage school timetables</p>
    </div>
    <a href="@Url.Action("Dashboard","Admin")" class="btn-back">
        <i class="fas fa-arrow-left"></i> Back
    </a>
</div>

<div class="options-grid">
    <div class="option-card" onclick="location.href='@Url.Action("ManageTimeTable","Admin", new { type = "Teachers" })'">
        <div class="option-icon teachers"><i class="fas fa-chalkboard-teacher"></i></div>
        <h2>Teachers Timetable</h2>
        <p>
            <i class="fas fa-calendar-check" style="color:var(--success);"></i> View & manage<br />
            <i class="fas fa-upload" style="color:var(--info);"></i> Upload new<br />
            <i class="fas fa-download" style="color:var(--primary);"></i> Download current
        </p>
    </div>
    <div class="option-card" onclick="location.href='@Url.Action("ManageTimeTable","Admin", new { type = "Learners" })'">
        <div class="option-icon learners"><i class="fas fa-user-graduate"></i></div>
        <h2>Learners Timetable</h2>
        <p>
            <i class="fas fa-calendar-check" style="color:var(--success);"></i> View & manage<br />
            <i class="fas fa-upload" style="color:var(--info);"></i> Upload new<br />
            <i class="fas fa-download" style="color:var(--primary);"></i> Download current
        </p>
    </div>
</div>