@model List<ElevateED.Models.Teacher>

@{
    ViewBag.Title = "Register Teacher - Admin";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var subjects = ViewBag.Subjects as List<ElevateED.Models.Subject>;
    var grades = ViewBag.Grades as List<ElevateED.Models.Grade>;
}

@section SidebarNav {
    <div class="nav-section">Main</div>
    <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
    <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
    <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item active"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
    <div class="nav-section">Management</div>
    <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
    <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
    <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
    <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
    <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
    <div class="nav-section">Extra</div>
    <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
    <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
    <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
    <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
}

@section Styles {
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 15px;
        }

            .page-header h1 {
                font-size: 26px;
                font-weight: 700;
                color: var(--gray-900);
            }

        .btn-primary {
            background: var(--success);
            color: white;
            padding: 10px 20px;
            border-radius: 12px;
            border: none;
            font-weight: 500;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-back {
            background: white;
            color: var(--gray-700);
            padding: 10px 20px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 500;
            border: 1px solid var(--gray-200);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-back:hover {
                background: var(--gray-100);
                text-decoration: none;
            }

        .table-wrap {
            background: white;
            border-radius: 16px;
            border: 1px solid var(--gray-200);
            overflow: hidden;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th {
            background: var(--gray-800);
            color: white;
            padding: 11px 14px;
            text-align: left;
            font-weight: 500;
            font-size: 12px;
            white-space: nowrap;
        }

        td {
            padding: 11px 14px;
            border-bottom: 1px solid var(--gray-100);
        }

        tr:hover td {
            background: var(--gray-50);
        }

        .staff-badge {
            font-family: monospace;
            background: var(--accent);
            color: #1e1b4b;
            padding: 4px 10px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 600;
        }

        .tag {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 8px;
            font-size: 10px;
            font-weight: 500;
            margin: 2px;
        }

        .tag-subject {
            background: #e0e7ff;
            color: #3730a3;
        }

        .tag-grade {
            background: #d1fae5;
            color: #065f46;
        }

        .tag-more {
            background: var(--gray-200);
            color: var(--gray-600);
        }

        .btn-sm {
            padding: 5px 10px;
            border-radius: 8px;
            font-size: 11px;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            margin: 0 2px;
        }

        .btn-edit {
            background: var(--info);
            color: white;
        }

        .btn-del {
            background: var(--danger);
            color: white;
        }

        .empty-state {
            text-align: center;
            padding: 60px;
        }

        .empty-icon {
            width: 80px;
            height: 80px;
            background: var(--gray-100);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 36px;
            color: var(--primary);
        }

        .btn-floating {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: var(--success);
            color: white;
            border: none;
            font-size: 24px;
            cursor: pointer;
            box-shadow: 0 8px 25px rgba(16,185,129,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 50;
        }

            .btn-floating:hover {
                transform: scale(1.1);
            }

        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 1050;
            align-items: center;
            justify-content: center;
        }

            .modal-overlay.show {
                display: flex;
            }

        .modal-box {
            background: white;
            border-radius: 16px;
            width: 90%;
            max-width: 800px;
            max-height: 85vh;
            overflow-y: auto;
        }

        .modal-header {
            padding: 18px 24px;
            border-bottom: 1px solid var(--gray-200);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--primary);
            color: white;
            border-radius: 16px 16px 0 0;
            position: sticky;
            top: 0;
            z-index: 1;
        }

        .modal-body {
            padding: 24px;
        }

        .form-section {
            font-size: 14px;
            font-weight: 600;
            color: var(--primary);
            margin: 20px 0 12px;
            padding-bottom: 8px;
            border-bottom: 2px solid var(--accent);
        }

        .form-group {
            margin-bottom: 14px;
        }

            .form-group label {
                font-weight: 600;
                font-size: 12px;
                color: var(--gray-700);
                display: block;
                margin-bottom: 4px;
            }

            .form-group input, .form-group textarea {
                width: 100%;
                padding: 9px 12px;
                border: 2px solid var(--gray-200);
                border-radius: 10px;
                font-size: 13px;
            }

                .form-group input:focus, .form-group textarea:focus {
                    border-color: var(--primary);
                    outline: none;
                }

        .required::after {
            content: " *";
            color: var(--danger);
        }

        .checkbox-group {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            max-height: 180px;
            overflow-y: auto;
            padding: 10px;
            border: 1px solid var(--gray-200);
            border-radius: 10px;
            background: var(--gray-50);
        }

        .checkbox-item input {
            display: none;
        }

        .checkbox-item label {
            display: block;
            padding: 7px 14px;
            background: white;
            border: 2px solid var(--gray-200);
            border-radius: 20px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.2s;
        }

        .checkbox-item input:checked + label {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .btn-save {
            background: var(--success);
            color: white;
            padding: 12px 30px;
            border-radius: 12px;
            border: none;
            font-weight: 500;
            cursor: pointer;
        }

        @@media (max-width: 768px) {
            .modal-box {
                max-width: 95%;
            }
        }
    </style>
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-chalkboard-teacher" style="color:var(--success);"></i> Teacher Management</h1>
        <p style="color:var(--gray-500);">Register and manage teaching staff</p>
    </div>
    <div style="display:flex;gap:10px;">
        <button class="btn-primary" onclick="openAddModal()">
            <i class="fas fa-plus"></i> Add Teacher
        </button>
        <a href="@Url.Action("Dashboard","Admin")" class="btn-back">
            <i class="fas fa-arrow-left"></i> Back
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-icon"><i class="fas fa-user-plus"></i></div>
        <h3>No Teachers Registered Yet</h3>
        <p style="color:var(--gray-500);">Get started by adding your first teacher.</p>
        <button class="btn-primary mt-3" onclick="openAddModal()">
            <i class="fas fa-plus"></i> Add First Teacher
        </button>
    </div>
}
else
{
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Staff Number</th>
                    <th>Full Name</th>
                    <th>Contact</th>
                    <th>Subjects</th>
                    <th>Grades</th>
                    <th>Qualification</th>
                    <th>Joined</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="teacherTableBody">
                @foreach (var t in Model)
                {
                    var ts = t.SubjectQualifications?.Where(sq => sq.Subject != null).Select(sq => sq.Subject.Name).ToList() ?? new List<string>();
                    var tg = t.GradeAssignments?.Where(ga => ga.Grade != null).Select(ga => ga.Grade.Name).ToList() ?? new List<string>();
                    <tr data-id="@t.Id">
                        <td><span class="staff-badge">@(t.User?.StudentNumber ?? "—")</span></td>
                        <td><strong style="color:var(--gray-800);">@t.FullName</strong></td>
                        <td>
                            <div style="font-size:12px;">@(t.User?.Email ?? "—")</div>
                            <div style="font-size:12px;color:var(--gray-500);">@t.PhoneNumber</div>
                        </td>
                        <td>
                            @if (ts.Any())
                            {
                                foreach (var s in ts.Take(3))
                                {<span class="tag tag-subject">@s</span>}
                            if (ts.Count > 3)
                            {<span class="tag tag-more">+@(ts.Count-3)</span>}
                        }
                        else
                        {<span style="color:var(--gray-400);">-</span>}
                        </td>
                        <td>
                            @if (tg.Any())
                            {
                                foreach (var g in tg)
                                {<span class="tag tag-grade">@g</span>}
                        }
                        else
                        {<span style="color:var(--gray-400);">-</span>}
                        </td>
                        <td>@t.Qualification</td>
                        <td>@t.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <button class="btn-sm btn-edit" onclick="location.href='@Url.Action("RegisterTeacher","Admin")?editId=@t.Id'">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn-sm btn-del" onclick="delTeacher(@t.Id)">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <button class="btn-floating" onclick="openAddModal()">
        <i class="fas fa-plus"></i>
    </button>
}

<!-- Add Teacher Modal -->
<div class="modal-overlay" id="addTeacherModal">
    <div class="modal-box">
        <div class="modal-header">
            <h4><i class="fas fa-user-plus"></i> Register New Teacher</h4>
            <button onclick="closeAddModal()" style="background:none;border:none;color:white;font-size:22px;cursor:pointer;">&times;</button>
        </div>
        <div class="modal-body">
            <form id="teacherForm">
                @Html.AntiForgeryToken()
                <div class="form-section"><i class="fas fa-user"></i> Personal Information</div>
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;">
                    <div class="form-group"><label class="required">First Name</label><input type="text" name="FirstName" required /></div>
                    <div class="form-group"><label>Middle Name</label><input type="text" name="MiddleName" /></div>
                    <div class="form-group"><label class="required">Last Name</label><input type="text" name="LastName" required /></div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
                    <div class="form-group"><label class="required">ID Number</label><input type="text" name="IdentityNumber" required maxlength="13" /></div>
                    <div class="form-group"><label class="required">Date of Birth</label><input type="date" name="DateOfBirth" required /></div>
                </div>
                <div class="form-section"><i class="fas fa-address-card"></i> Contact</div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
                    <div class="form-group"><label class="required">Email</label><input type="email" name="Email" required /></div>
                    <div class="form-group"><label class="required">Phone</label><input type="tel" name="PhoneNumber" required /></div>
                    <div class="form-group"><label>Alt Phone</label><input type="tel" name="AlternativePhone" /></div>
                    <div class="form-group"><label>Address</label><textarea name="Address" rows="2"></textarea></div>
                </div>
                <div class="form-section"><i class="fas fa-chalkboard"></i> Teaching Assignment</div>
                <div class="form-group">
                    <label class="required">Subjects</label>
                    <div class="checkbox-group">
                        @if (subjects != null)
                        {
                            foreach (var s in subjects)
                            {
                                <div class="checkbox-item"><input type="checkbox" id="s_@s.Id" name="SubjectIds" value="@s.Id" /><label for="s_@s.Id">@s.Name</label></div>
                            }
                        }
                    </div>
                </div>
                <div class="form-group">
                    <label class="required">Grades</label>
                    <div class="checkbox-group">
                        @if (grades != null)
                        {
                            foreach (var g in grades)
                            {
                                <div class="checkbox-item"><input type="checkbox" id="g_@g.Id" name="GradeIds" value="@g.Id" /><label for="g_@g.Id">@g.Name</label></div>
                            }
                        }
                    </div>
                </div>
                <div class="form-section"><i class="fas fa-graduation-cap"></i> Qualifications</div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
                    <div class="form-group"><label class="required">Highest Qualification</label><input type="text" name="Qualification" required /></div>
                    <div class="form-group"><label>Years Experience</label><input type="number" name="YearsOfExperience" min="0" max="50" value="0" /></div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
                    <div class="form-group"><label>Emergency Contact</label><input type="text" name="EmergencyContactName" /></div>
                    <div class="form-group"><label>Emergency Phone</label><input type="tel" name="EmergencyContactPhone" /></div>
                </div>
                <div id="modalMsg" style="display:none;padding:10px;border-radius:8px;margin-top:10px;"></div>
            </form>
        </div>
        <div style="padding:16px 24px;border-top:1px solid var(--gray-200);display:flex;justify-content:flex-end;gap:10px;">
            <button onclick="closeAddModal()" style="padding:10px 20px;border-radius:10px;border:1px solid var(--gray-200);background:white;cursor:pointer;">Cancel</button>
            <button class="btn-save" onclick="saveTeacher()"><i class="fas fa-save"></i> Register Teacher</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openAddModal() {
            document.getElementById('addTeacherModal').classList.add('show');
            document.getElementById('teacherForm').reset();
        }

        function closeAddModal() {
            document.getElementById('addTeacherModal').classList.remove('show');
        }

        document.getElementById('addTeacherModal').addEventListener('click', function(e) {
            if (e.target === this) closeAddModal();
        });

        function saveTeacher() {
            var f = document.getElementById('teacherForm');
            var fn = f.querySelector('[name="FirstName"]').value,
                ln = f.querySelector('[name="LastName"]').value,
                em = f.querySelector('[name="Email"]').value;
            if (!fn || !ln || !em) { alert('Please fill required fields'); return; }
            var si = [];
            f.querySelectorAll('[name="SubjectIds"]:checked').forEach(c => si.push(parseInt(c.value)));
            var gi = [];
            f.querySelectorAll('[name="GradeIds"]:checked').forEach(c => gi.push(parseInt(c.value)));
            if (!si.length || !gi.length) { alert('Select at least one subject and grade'); return; }
            var d = new URLSearchParams();
            d.append('__RequestVerificationToken', f.querySelector('[name="__RequestVerificationToken"]').value);
            ['FirstName','MiddleName','LastName','IdentityNumber','DateOfBirth','Email','PhoneNumber','AlternativePhone','Address','Qualification','EmergencyContactName','EmergencyContactPhone'].forEach(n =>
                d.append(n, f.querySelector('[name="' + n + '"]')?.value || ''));
            d.append('YearsOfExperience', parseInt(f.querySelector('[name="YearsOfExperience"]').value) || 0);
            si.forEach(v => d.append('SubjectIds', v));
            gi.forEach(v => d.append('GradeIds', v));
            fetch('@Url.Action("AddTeacher","Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: d
            }).then(r => r.json()).then(r => {
                if (r.success) { closeAddModal(); alert('Teacher registered!'); location.reload(); }
                else alert(r.message);
            });
        }

        function delTeacher(id) {
            if (!confirm('Delete this teacher?')) return;
            var t = document.querySelector('input[name="__RequestVerificationToken"]').value;
            fetch('@Url.Action("DeleteTeacher","Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: '__RequestVerificationToken=' + t + '&id=' + id
            }).then(r => r.json()).then(r => {
                if (r.success) {
                    var tr = document.querySelector('tr[data-id="' + id + '"]');
                    if (tr) tr.remove();
                    if (!document.querySelectorAll('#teacherTableBody tr').length) location.reload();
                } else alert(r.message);
            });
        }
    </script>
}