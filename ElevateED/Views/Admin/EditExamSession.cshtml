@model ElevateED.ViewModels.EditExamSessionViewModel

@{
    ViewBag.Title = "Edit Exam Session - Admin";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var minDate = ViewBag.MinDate;
    var maxDate = ViewBag.MaxDate;
}

@section SidebarNav {
    <div class="nav-section">Main</div>
    <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
    <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
    <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
    <div class="nav-section">Management</div>
    <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
    <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item active"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
    <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
    <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
    <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
    <div class="nav-section">Extra</div>
    <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
    <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
    <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
    <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
}

@section Styles {
    <style>
        .form-card {
            background: white;
            border-radius: 16px;
            padding: 32px;
            border: 1px solid var(--gray-200);
            max-width: 700px;
            margin: 0 auto;
        }

        .form-header {
            text-align: center;
            margin-bottom: 28px;
            padding-bottom: 20px;
            border-bottom: 2px solid var(--gray-200);
        }

            .form-header h2 {
                font-size: 24px;
                font-weight: 700;
                color: var(--gray-900);
                margin-bottom: 8px;
            }

            .form-header i {
                color: var(--accent);
                font-size: 40px;
                margin-bottom: 12px;
            }

        .session-info {
            background: #d1fae5;
            padding: 16px;
            border-radius: 10px;
            margin-bottom: 24px;
            border-left: 4px solid var(--success);
        }

            .session-info p {
                margin-bottom: 6px;
                font-size: 14px;
            }

            .session-info strong {
                color: var(--gray-800);
            }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            font-weight: 600;
            font-size: 13px;
            color: var(--gray-700);
            margin-bottom: 6px;
            display: block;
        }

        .form-control {
            width: 100%;
            padding: 10px 14px;
            border: 2px solid var(--gray-200);
            border-radius: 10px;
            font-size: 14px;
        }

            .form-control:focus {
                border-color: var(--primary);
                outline: none;
            }

        .required::after {
            content: " *";
            color: var(--danger);
        }

        .time-hint {
            font-size: 12px;
            color: var(--gray-500);
            margin-top: 4px;
        }

        .btn-submit {
            background: var(--success);
            color: white;
            padding: 14px 30px;
            border-radius: 12px;
            border: none;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            width: 100%;
        }

            .btn-submit:hover {
                background: #059669;
            }

        .btn-cancel {
            background: var(--gray-200);
            color: var(--gray-700);
            padding: 14px 30px;
            border-radius: 12px;
            border: none;
            font-size: 16px;
            font-weight: 500;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            width: 100%;
        }

            .btn-cancel:hover {
                background: var(--gray-300);
                color: var(--gray-900);
                text-decoration: none;
            }

        .alert-danger {
            background: #fee2e2;
            color: #991b1b;
            padding: 14px;
            border-radius: 10px;
            margin-bottom: 20px;
        }

        .alert-success {
            background: #d1fae5;
            color: #065f46;
            padding: 14px;
            border-radius: 10px;
            margin-bottom: 20px;
        }
    </style>
}

<div class="form-card">
    <div class="form-header">
        <i class="fas fa-edit"></i>
        <h2>Edit Exam Session</h2>
        <p style="color:var(--gray-500);">@ViewBag.TimetableName</p>
    </div>

    <div class="session-info">
        <p><strong><i class="fas fa-book"></i> Subject:</strong> @Model.SubjectName</p>
        <p><strong><i class="fas fa-graduation-cap"></i> Grade:</strong> @Model.GradeName</p>
        <p><strong><i class="fas fa-layer-group"></i> Stream:</strong> @Model.StreamName</p>
        <p><strong><i class="fas fa-file-alt"></i> Paper:</strong> @Model.PaperNumber</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }

    @using (Html.BeginForm("EditExamSession", "Admin", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)
        @Html.HiddenFor(m => m.ExamTimetableId)

        if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-danger">
                @Html.ValidationSummary(true, "Please correct the following errors:", new { @class = "text-danger" })
            </div>
        }

        <div class="form-group">
            <label class="form-label required">Exam Date</label>
            <input type="date" name="ExamDate" class="form-control"
                   value="@Model.ExamDate.ToString("yyyy-MM-dd")"
                   min="@minDate" max="@maxDate" required />
            <div class="time-hint">Exam date must be within the timetable period</div>
            @Html.ValidationMessageFor(m => m.ExamDate, "", new { @class = "text-danger" })
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div class="form-group">
                <label class="form-label required">Start Time</label>
                <input type="time" name="StartTime" class="form-control"
                       value="@Model.StartTime.ToString(@"hh\:mm")" required />
                <div class="time-hint">Minimum: 09:00</div>
                @Html.ValidationMessageFor(m => m.StartTime, "", new { @class = "text-danger" })
            </div>
            <div class="form-group">
                <label class="form-label required">End Time</label>
                <input type="time" name="EndTime" class="form-control"
                       value="@Model.EndTime.ToString(@"hh\:mm")" required />
                <div class="time-hint">Maximum: 14:15</div>
                @Html.ValidationMessageFor(m => m.EndTime, "", new { @class = "text-danger" })
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div class="form-group">
                <label class="form-label required">Duration (Hours)</label>
                <input type="number" name="DurationHours" class="form-control"
                       value="@Model.DurationHours" step="0.5" min="1" max="3" required />
                <div class="time-hint">Between 1 and 3 hours</div>
                @Html.ValidationMessageFor(m => m.DurationHours, "", new { @class = "text-danger" })
            </div>
            <div class="form-group">
                <label class="form-label">Venue</label>
                <input type="text" name="Venue" class="form-control"
                       value="@Model.Venue" placeholder="e.g., Main Hall, Room 101" />
                @Html.ValidationMessageFor(m => m.Venue, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Invigilator</label>
            <input type="text" name="Invigilator" class="form-control"
                   value="@Model.Invigilator" placeholder="e.g., Mr. Smith" />
            @Html.ValidationMessageFor(m => m.Invigilator, "", new { @class = "text-danger" })
        </div>

        <div style="display:flex;gap:14px;margin-top:24px;">
            <a href="@Url.Action("ViewExamTimetable","Admin",new{id=Model.ExamTimetableId})" class="btn-cancel">
                <i class="fas fa-times"></i> Cancel
            </a>
            <button type="submit" class="btn-submit">
                <i class="fas fa-save"></i> Save Changes
            </button>
        </div>
    }
</div>