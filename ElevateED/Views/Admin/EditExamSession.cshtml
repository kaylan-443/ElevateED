@model ElevateED.ViewModels.EditExamSessionViewModel

@{
    ViewBag.Title = "Edit Exam Session - Admin";
    var minDate = ViewBag.MinDate;
    var maxDate = ViewBag.MaxDate;
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --primary: #4f46e5;
        --primary-light: #6366f1;
        --primary-dark: #4338ca;
        --primary-bg: #f5f3ff;
        --primary-soft: #ede9fe;
        --primary-hover: #e0e7ff;
        --accent: #fbbf24;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --sidebar-width: 280px;
        --header-height: 70px;
    }

    body {
        font-family: 'Inter', -apple-system, sans-serif;
        background: var(--gray-50);
        overflow-x: hidden;
    }

    .app-container {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: var(--sidebar-width);
        background: linear-gradient(180deg, #1e1b4b 0%, #2e1065 100%);
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        transition: all 0.3s ease;
        z-index: 100;
        overflow-y: auto;
    }

    .sidebar-header {
        padding: 24px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .logo-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--accent), #f59e0b);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e1b4b;
        font-size: 20px;
    }

    .logo-text {
        font-size: 20px;
        font-weight: 700;
        color: white;
    }

        .logo-text span {
            color: var(--accent);
        }

    .sidebar-nav {
        flex: 1;
        padding: 24px 16px;
    }

    .nav-section {
        margin-top: 24px;
        margin-bottom: 12px;
        padding: 0 16px;
        font-size: 11px;
        font-weight: 600;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        margin-bottom: 8px;
        border-radius: 12px;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .nav-item:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        .nav-item.active {
            background: linear-gradient(135deg, var(--accent), #f59e0b);
            color: #1e1b4b;
        }

        .nav-item i {
            width: 20px;
            font-size: 18px;
        }

        .nav-item span {
            font-size: 14px;
            font-weight: 500;
        }

    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width);
        min-height: 100vh;
    }

    .top-header {
        height: var(--header-height);
        background: white;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: flex-end;
        align-items: center;
        padding: 0 32px;
        position: sticky;
        top: 0;
        z-index: 99;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .notification-btn {
        position: relative;
        background: none;
        border: none;
        font-size: 20px;
        color: var(--gray-500);
        cursor: pointer;
        padding: 8px;
        border-radius: 10px;
        transition: all 0.2s;
    }

        .notification-btn:hover {
            background: var(--gray-100);
        }

    .notification-badge {
        position: absolute;
        top: 2px;
        right: 2px;
        width: 8px;
        height: 8px;
        background: var(--danger);
        border-radius: 50%;
    }

    .profile-container {
        position: relative;
    }

    .profile-trigger {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 50px;
        transition: all 0.2s;
        background: none;
        border: none;
    }

        .profile-trigger:hover {
            background: var(--gray-100);
        }

    .avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 16px;
        text-transform: uppercase;
    }

    .profile-name {
        font-size: 14px;
        font-weight: 500;
        color: var(--gray-700);
    }

    .dropdown-icon {
        font-size: 12px;
        color: var(--gray-400);
    }

    .dropdown-menu {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        width: 240px;
        overflow: hidden;
        display: none;
        z-index: 1000;
    }

        .dropdown-menu.show {
            display: block;
            animation: fadeInDown 0.2s ease;
        }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .dropdown-header {
        padding: 16px;
        border-bottom: 1px solid var(--gray-200);
        background: linear-gradient(135deg, var(--primary-bg), var(--primary-soft));
    }

        .dropdown-header .user-name {
            font-weight: 600;
            color: var(--gray-900);
            margin-bottom: 4px;
        }

        .dropdown-header .user-email {
            font-size: 12px;
            color: var(--gray-500);
        }

    .dropdown-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        text-decoration: none;
        color: var(--gray-700);
        transition: all 0.2s;
        cursor: pointer;
        background: none;
        border: none;
        width: 100%;
        text-align: left;
    }

        .dropdown-item:hover {
            background: var(--primary-hover);
            color: var(--primary);
        }

        .dropdown-item i {
            width: 20px;
            font-size: 16px;
            color: var(--gray-500);
        }

    .dropdown-divider {
        height: 1px;
        background: var(--gray-200);
        margin: 8px 0;
    }

    .dashboard-content {
        padding: 32px;
    }

    .form-card {
        background: white;
        border-radius: 16px;
        padding: 32px;
        border: 1px solid var(--gray-200);
        max-width: 700px;
        margin: 0 auto;
    }

    .form-header {
        text-align: center;
        margin-bottom: 28px;
        padding-bottom: 20px;
        border-bottom: 2px solid var(--gray-200);
    }

        .form-header h2 {
            font-size: 24px;
            font-weight: 700;
            color: var(--gray-900);
            margin-bottom: 8px;
        }

        .form-header i {
            color: var(--accent);
            font-size: 40px;
            margin-bottom: 12px;
        }

    .session-info {
        background: #d1fae5;
        padding: 16px;
        border-radius: 10px;
        margin-bottom: 24px;
        border-left: 4px solid var(--success);
    }

        .session-info p {
            margin-bottom: 6px;
            font-size: 14px;
        }

        .session-info strong {
            color: var(--gray-800);
        }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        font-size: 13px;
        color: var(--gray-700);
        margin-bottom: 6px;
        display: block;
    }

    .form-control {
        width: 100%;
        padding: 10px 14px;
        border: 2px solid var(--gray-200);
        border-radius: 10px;
        font-size: 14px;
    }

        .form-control:focus {
            border-color: var(--primary);
            outline: none;
        }

    .required::after {
        content: " *";
        color: var(--danger);
    }

    .time-hint {
        font-size: 12px;
        color: var(--gray-500);
        margin-top: 4px;
    }

    .btn-submit {
        background: var(--success);
        color: white;
        padding: 14px 30px;
        border-radius: 12px;
        border: none;
        font-size: 16px;
        font-weight: 500;
        cursor: pointer;
        width: 100%;
    }

        .btn-submit:hover {
            background: #059669;
        }

    .btn-cancel {
        background: var(--gray-200);
        color: var(--gray-700);
        padding: 14px 30px;
        border-radius: 12px;
        border: none;
        font-size: 16px;
        font-weight: 500;
        text-decoration: none;
        display: inline-block;
        text-align: center;
        width: 100%;
    }

        .btn-cancel:hover {
            background: var(--gray-300);
            color: var(--gray-900);
            text-decoration: none;
        }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
        padding: 14px;
        border-radius: 10px;
        margin-bottom: 20px;
    }

    .alert-success {
        background: #d1fae5;
        color: #065f46;
        padding: 14px;
        border-radius: 10px;
        margin-bottom: 20px;
    }

    @@media (max-width: 1024px) {
        .sidebar {
            transform: translateX(-100%);
        }

        .main-content {
            margin-left: 0;
        }
    }

    @@media (max-width: 768px) {
        .dashboard-content {
            padding: 20px;
        }
    }
</style>

<div class="app-container">
    <aside class="sidebar">
        <div class="sidebar-header"><div class="logo"><div class="logo-icon"><i class="fas fa-graduation-cap"></i></div><div class="logo-text">Elevate<span>ED</span></div></div></div>
        <nav class="sidebar-nav">
            <div class="nav-section">Main</div>
            <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
            <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
            <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
            <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
            <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
            <div class="nav-section">Management</div>
            <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
            <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item active"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
            <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
            <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
            <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
            <div class="nav-section">Extra</div>
            <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
            <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
            <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
            <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
        </nav>
    </aside>
    <main class="main-content">
        <header class="top-header">
            <div class="header-right">
                <button class="notification-btn"><i class="far fa-bell"></i><span class="notification-badge"></span></button>
                <div class="profile-container">
                    <button class="profile-trigger" onclick="toggleDropdown()"><div class="avatar">A</div><span class="profile-name">Admin</span><i class="fas fa-chevron-down dropdown-icon"></i></button>
                    <div class="dropdown-menu" id="profileDropdown">
                        <div class="dropdown-header"><div class="user-name">Administrator</div><div class="user-email">admin@mpiyakhehs.co.za</div></div>
                        <a href="@Url.Action("ManageUsers","Admin")" class="dropdown-item"><i class="fas fa-users"></i><span>Manage Users</span></a>
                        <div class="dropdown-divider"></div>
                        <form action="@Url.Action("LogOff","Account")" method="post" id="logoutForm">
                            @Html.AntiForgeryToken()
                            <button type="button" class="dropdown-item" onclick="confirmLogout(event)" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i><span>Logout</span></button>
                        </form>
                    </div>
                </div>
            </div>
        </header>
        <div class="dashboard-content">
            <div class="form-card">
                <div class="form-header"><i class="fas fa-edit"></i><h2>Edit Exam Session</h2><p style="color:var(--gray-500);">@ViewBag.TimetableName</p></div>
                <div class="session-info"><p><strong><i class="fas fa-book"></i> Subject:</strong> @Model.SubjectName</p><p><strong><i class="fas fa-graduation-cap"></i> Grade:</strong> @Model.GradeName</p><p><strong><i class="fas fa-layer-group"></i> Stream:</strong> @Model.StreamName</p><p><strong><i class="fas fa-file-alt"></i> Paper:</strong> @Model.PaperNumber</p></div>
                @if (TempData["SuccessMessage"] != null)
                {<div class="alert-success"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>}
                @using (Html.BeginForm("EditExamSession", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.Id)@Html.HiddenFor(m => m.ExamTimetableId)
                    if (!ViewData.ModelState.IsValid)
                    {<div class="alert-danger">@Html.ValidationSummary(true, "Please correct the following errors:", new { @class = "text-danger" })</div>}
                <div class="form-group"><label class="form-label required">Exam Date</label><input type="date" name="ExamDate" class="form-control" value="@Model.ExamDate.ToString("yyyy-MM-dd")" min="@minDate" max="@maxDate" required /><div class="time-hint">Exam date must be within the timetable period</div>@Html.ValidationMessageFor(m => m.ExamDate, "", new { @class = "text-danger" })</div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;"><div class="form-group"><label class="form-label required">Start Time</label><input type="time" name="StartTime" class="form-control" value="@Model.StartTime.ToString(@"hh\:mm")" required /><div class="time-hint">Minimum: 09:00</div>@Html.ValidationMessageFor(m => m.StartTime, "", new { @class = "text-danger" })</div><div class="form-group"><label class="form-label required">End Time</label><input type="time" name="EndTime" class="form-control" value="@Model.EndTime.ToString(@"hh\:mm")" required /><div class="time-hint">Maximum: 14:15</div>@Html.ValidationMessageFor(m => m.EndTime, "", new { @class = "text-danger" })</div></div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;"><div class="form-group"><label class="form-label required">Duration (Hours)</label><input type="number" name="DurationHours" class="form-control" value="@Model.DurationHours" step="0.5" min="1" max="3" required /><div class="time-hint">Between 1 and 3 hours</div>@Html.ValidationMessageFor(m => m.DurationHours, "", new { @class = "text-danger" })</div><div class="form-group"><label class="form-label">Venue</label><input type="text" name="Venue" class="form-control" value="@Model.Venue" placeholder="e.g., Main Hall, Room 101" />@Html.ValidationMessageFor(m => m.Venue, "", new { @class = "text-danger" })</div></div>
                <div class="form-group"><label class="form-label">Invigilator</label><input type="text" name="Invigilator" class="form-control" value="@Model.Invigilator" placeholder="e.g., Mr. Smith" />@Html.ValidationMessageFor(m => m.Invigilator, "", new { @class = "text-danger" })</div>
                <div style="display:flex;gap:14px;margin-top:24px;"><a href="@Url.Action("ViewExamTimetable","Admin",new{id=Model.ExamTimetableId})" class="btn-cancel"><i class="fas fa-times"></i> Cancel</a><button type="submit" class="btn-submit"><i class="fas fa-save"></i> Save Changes</button></div>}
            </div>
        </div>
    </main>
</div>
<script>
    function toggleDropdown() { document.getElementById('profileDropdown').classList.toggle('show'); }
    document.addEventListener('click', function (e) { var c = document.querySelector('.profile-container'); var d = document.getElementById('profileDropdown'); if (c && !c.contains(e.target)) d.classList.remove('show'); });
    function confirmLogout(e) { e.preventDefault(); if (confirm('Are you sure you want to logout?')) { document.getElementById('logoutForm').submit(); } }
</script>