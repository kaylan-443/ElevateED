@model ElevateED.ViewModels.AdminAnalyticsViewModel
@{
    ViewBag.Title = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section SidebarNav {
    @Html.Partial("_AdminSidebar")
}

@section Styles {
    <style>
        .welcome-banner {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 50%, #a78bfa 100%);
            border-radius: 20px;
            padding: 32px 36px;
            margin-bottom: 28px;
            color: white;
            position: relative;
            overflow: hidden;
        }

            .welcome-banner::after {
                content: '';
                position: absolute;
                top: -50%;
                right: -10%;
                width: 300px;
                height: 300px;
                background: rgba(255,255,255,0.05);
                border-radius: 50%;
            }

            .welcome-banner h1 {
                font-size: 26px;
                font-weight: 700;
                position: relative;
                z-index: 1;
            }

            .welcome-banner p {
                opacity: 0.85;
                position: relative;
                z-index: 1;
                margin-top: 4px;
                font-size: 14px;
            }

            .welcome-banner .date-badge {
                position: absolute;
                top: 20px;
                right: 24px;
                background: rgba(255,255,255,0.15);
                backdrop-filter: blur(10px);
                padding: 8px 16px;
                border-radius: 10px;
                font-size: 13px;
                z-index: 1;
            }

        .stat-cards {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: white;
            border-radius: 16px;
            padding: 22px 20px;
            border: 1px solid #e2e8f0;
            box-shadow: var(--shadow);
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 16px;
        }

            .stat-card:hover {
                transform: translateY(-3px);
                box-shadow: var(--shadow-lg);
            }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            color: white;
            flex-shrink: 0;
        }

            .stat-icon.blue {
                background: linear-gradient(135deg, #3b82f6, #6366f1);
            }

            .stat-icon.green {
                background: linear-gradient(135deg, #10b981, #34d399);
            }

            .stat-icon.orange {
                background: linear-gradient(135deg, #f59e0b, #f97316);
            }

            .stat-icon.purple {
                background: linear-gradient(135deg, #8b5cf6, #a78bfa);
            }

        .stat-info {
            flex: 1;
        }

        .stat-label {
            font-size: 12px;
            color: #94a3b8;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stat-value {
            font-size: 28px;
            font-weight: 700;
            color: #1e293b;
            margin: 2px 0;
        }

        .stat-change {
            font-size: 11px;
            font-weight: 600;
        }

            .stat-change.up {
                color: #10b981;
            }

            .stat-change.down {
                color: #ef4444;
            }

        .chart-row {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
            margin-bottom: 28px;
        }

        .chart-box {
            background: white;
            border-radius: 16px;
            padding: 24px;
            border: 1px solid #e2e8f0;
            box-shadow: var(--shadow);
        }

            .chart-box h3 {
                font-size: 15px;
                font-weight: 600;
                color: #1e293b;
                margin-bottom: 20px;
            }

        canvas {
            max-height: 280px;
        }

        .quick-actions h3 {
            font-size: 15px;
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 16px;
        }

        .actions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 12px;
        }

        .action-card {
            background: white;
            border-radius: 14px;
            padding: 18px 16px;
            text-align: center;
            text-decoration: none;
            border: 1px solid #e2e8f0;
            transition: all 0.25s;
            color: inherit;
            box-shadow: var(--shadow-sm);
        }

            .action-card:hover {
                transform: translateY(-3px);
                box-shadow: var(--shadow-md);
                border-color: #6366f1;
            }

        .action-icon-sm {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
            font-size: 18px;
            color: white;
        }

        .action-card h4 {
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 2px;
        }

        .action-card p {
            font-size: 11px;
            color: #94a3b8;
        }

        .recent-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 28px;
        }

        .list-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            border: 1px solid #e2e8f0;
            box-shadow: var(--shadow);
        }

            .list-card h3 {
                font-size: 15px;
                font-weight: 600;
                margin-bottom: 16px;
            }

        .list-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 0;
            border-bottom: 1px solid #f1f5f9;
        }

            .list-item:last-child {
                border-bottom: none;
            }

        .list-avatar {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            color: white;
            flex-shrink: 0;
        }

        .list-info {
            flex: 1;
            font-size: 13px;
        }

            .list-info strong {
                color: #1e293b;
            }

            .list-info span {
                color: #94a3b8;
                font-size: 11px;
            }

        .badge {
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: 600;
        }

        .badge-warn {
            background: #fef3c7;
            color: #92400e;
        }

        .badge-success {
            background: #d1fae5;
            color: #065f46;
        }

        .badge-info {
            background: #dbeafe;
            color: #1e40af;
        }

        .badge-danger {
            background: #fee2e2;
            color: #991b1b;
        }

        @@media (max-width: 1024px) {
            .stat-cards {
                grid-template-columns: repeat(2, 1fr);
            }

            .chart-row {
                grid-template-columns: 1fr;
            }

            .recent-row {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 640px) {
            .stat-cards {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="welcome-banner">
    <h1>Welcome back, Administrator 👋</h1>
    <p>Here's your school overview for today</p>
    <div class="date-badge">📅 @DateTime.Now.ToString("dddd, dd MMMM yyyy")</div>
</div>

<!-- Stats -->
<div class="stat-cards">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fas fa-user-graduate"></i></div>
        <div class="stat-info">
            <div class="stat-label">Total Students</div>
            <div class="stat-value">@Model.TotalStudents.ToString("N0")</div>
            <div class="stat-change up">↑ @Math.Abs(Model.StudentGrowth)% this year</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-chalkboard-teacher"></i></div>
        <div class="stat-info">
            <div class="stat-label">Total Teachers</div>
            <div class="stat-value">@Model.TotalTeachers</div>
            <div class="stat-change up">↑ @Math.Abs(Model.TeacherGrowth)% this year</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon orange"><i class="fas fa-school"></i></div>
        <div class="stat-info">
            <div class="stat-label">Active Classes</div>
            <div class="stat-value">@Model.TotalClasses</div>
            <div class="stat-change">Across 5 grades</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple"><i class="fas fa-chart-line"></i></div>
        <div class="stat-info">
            <div class="stat-label">Approval Rate</div>
            <div class="stat-value">@Model.ApprovalRate%</div>
            <div class="stat-change up">Application success</div>
        </div>
    </div>
</div>

<!-- Charts -->
<div class="chart-row">
    <div class="chart-box">
        <h3>📊 Student Distribution by Grade</h3>
        <canvas id="gradeChart"></canvas>
    </div>
    <div class="chart-box">
        <h3>📋 Application Status</h3>
        <canvas id="appChart" style="max-height:240px;"></canvas>
        <div style="display:flex;justify-content:center;gap:20px;margin-top:12px;">
            @foreach (var item in Model.ApplicationBreakdown)
            {
                <div style="text-align:center;"><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:@item.Color;margin-right:4px;"></span>@item.Status: <strong>@item.Count</strong></div>
            }
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="quick-actions">
    <h3>⚡ Quick Actions</h3>
    <div class="actions-grid">
        <a href="@Url.Action("EvaluateApplications", "Admin")" class="action-card">
            <div class="action-icon-sm" style="background:linear-gradient(135deg,#f59e0b,#f97316);"><i class="fas fa-clipboard-check"></i></div>
            <h4>Review Applications</h4><p>@Model.ApplicationStats.Pending pending</p>
        </a>
        <a href="@Url.Action("CreateWizard", "AdminAnnouncement")" class="action-card">
            <div class="action-icon-sm" style="background:linear-gradient(135deg,#8b5cf6,#6366f1);"><i class="fas fa-robot"></i></div>
            <h4>AI Announcement</h4><p>Create with AI</p>
        </a>
        <a href="@Url.Action("ExamTimetables", "Admin")" class="action-card">
            <div class="action-icon-sm" style="background:linear-gradient(135deg,#3b82f6,#06b6d4);"><i class="fas fa-calendar-check"></i></div>
            <h4>Exam Management</h4><p>Timetables</p>
        </a>
        <a href="@Url.Action("RegisterTeacher", "Admin")" class="action-card">
            <div class="action-icon-sm" style="background:linear-gradient(135deg,#10b981,#34d399);"><i class="fas fa-user-plus"></i></div>
            <h4>Register Teacher</h4><p>Add staff</p>
        </a>
        <a href="@Url.Action("ManageUsers", "Admin")" class="action-card">
            <div class="action-icon-sm" style="background:linear-gradient(135deg,#6366f1,#4f46e5);"><i class="fas fa-users-cog"></i></div>
            <h4>Manage Users</h4><p>All users</p>
        </a>
        <a href="@Url.Action("TimeTable", "Admin")" class="action-card">
            <div class="action-icon-sm" style="background:linear-gradient(135deg,#64748b,#94a3b8);"><i class="fas fa-calendar-alt"></i></div>
            <h4>Timetable</h4><p>Schedules</p>
        </a>
        <a href="@Url.Action("Index", "AdminExtraClass")" class="action-card">
            <div class="action-icon-sm" style="background:linear-gradient(135deg,#ec4899,#f472b6);"><i class="fas fa-chalkboard"></i></div>
            <h4>Extra Classes</h4><p>Manage</p>
        </a>
        <a href="@Url.Action("Issues", "Admin")" class="action-card">
            <div class="action-icon-sm" style="background:linear-gradient(135deg,#ef4444,#f87171);"><i class="fas fa-exclamation-triangle"></i></div>
            <h4>View Issues</h4><p>@Model.PendingIssuesCount open</p>
        </a>
    </div>
</div>

<!-- Recent & Tasks -->
<div class="recent-row">
    <div class="list-card">
        <h3>🕐 Recent Applications</h3>
        @if (Model.RecentApplications.Any())
        {
            foreach (var app in Model.RecentApplications)
            {
                var bg = app.Status == "Approved" ? "#10b981" : app.Status == "Pending" ? "#f59e0b" : app.Status == "Rejected" ? "#ef4444" : "#3b82f6";
                var badge = app.Status == "Pending" ? "badge-warn" : app.Status == "Approved" ? "badge-success" : app.Status == "UnderReview" ? "badge-info" : "badge-danger";
                <div class="list-item">
                    <div class="list-avatar" style="background:@bg;">@app.FullName[0]</div>
                    <div class="list-info"><strong>@app.FullName</strong><br /><span>@app.GradeApplyingFor</span></div>
                    <span class="badge @badge">@app.Status</span>
                    <span style="font-size:11px;color:#94a3b8;">@app.DaysAgo d</span>
                </div>
            }
        }
        else
        {
            <div style="text-align:center;padding:30px;color:#94a3b8;">No recent applications</div>
        }
    </div>
    <div class="list-card">
        <h3>📌 Pending Tasks</h3>
        <div class="list-item">
            <div class="list-avatar" style="background:#f59e0b;"><i class="fas fa-exclamation"></i></div>
            <div class="list-info"><strong>@Model.PendingIssuesCount Unresolved Issues</strong><br /><span>Needs attention</span></div>
        </div>
        <div class="list-item">
            <div class="list-avatar" style="background:#ef4444;"><i class="fas fa-chalkboard"></i></div>
            <div class="list-info"><strong>@Model.UnassignedClassesCount Classes Without Teacher</strong><br /><span>Needs assignment</span></div>
        </div>
        <div class="list-item">
            <div class="list-avatar" style="background:#3b82f6;"><i class="fas fa-user"></i></div>
            <div class="list-info"><strong>@Model.PendingTeacherAssignments Unassigned Teachers</strong><br /><span>Needs scheduling</span></div>
        </div>
        <div class="list-item">
            <div class="list-avatar" style="background:#10b981;"><i class="fas fa-file-alt"></i></div>
            <div class="list-info"><strong>@Model.ApplicationStats.Pending Pending Applications</strong><br /><span>Awaiting review</span></div>
        </div>
    </div>
</div>

<script>
    function toggleDropdown() { document.getElementById('profileDropdown').classList.toggle('show'); }
    document.addEventListener('click', function (e) { var c = document.querySelector('.profile-container'); var d = document.getElementById('profileDropdown'); if (c && !c.contains(e.target)) d.classList.remove('show'); });
    function confirmLogout(e) { e.preventDefault(); if (confirm('Are you sure you want to logout?')) { document.getElementById('logoutForm').submit(); } }
</script>