@model ElevateED.ViewModels.ClassAllocationViewModel

@{
    ViewBag.Title = "Allocate Students - Admin";
}

<style>
    .allocate-container {
        padding: 20px 0 40px 0;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid #e0e0e0;
        flex-wrap: wrap;
        gap: 15px;
    }

    .header-left h2 {
        margin: 0;
        color: #1e3c72;
        font-weight: 700;
    }

    .stats-bar {
        background: white;
        padding: 15px 20px;
        border-radius: 10px;
        margin-bottom: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        display: flex;
        gap: 30px;
        flex-wrap: wrap;
    }

    .stat-item {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .stat-value {
        font-size: 24px;
        font-weight: 700;
        color: #1e3c72;
    }

    .filter-section {
        background: white;
        padding: 15px 20px;
        border-radius: 10px;
        margin-bottom: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .students-section, .classes-section {
        background: white;
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        color: #1e3c72;
    }

    .student-table, .class-table {
        width: 100%;
    }

        .student-table th, .class-table th {
            background: #f8f9fa;
            padding: 10px 15px;
            font-weight: 600;
            color: #555;
            border-bottom: 2px solid #e0e0e0;
        }

        .student-table td, .class-table td {
            padding: 10px 15px;
            border-bottom: 1px solid #e0e0e0;
            vertical-align: middle;
        }

    .class-card {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 15px;
        background: #fafafa;
    }

    .class-name {
        font-size: 16px;
        font-weight: 700;
        color: #1e3c72;
    }

    .class-capacity {
        font-size: 13px;
        color: #666;
    }

    .progress {
        height: 8px;
        margin: 10px 0;
    }

    .btn-auto {
        background: #28a745;
        color: white;
        border: none;
        padding: 10px 25px;
        border-radius: 25px;
        font-weight: 600;
    }

        .btn-auto:hover {
            background: #218838;
        }

    .badge-grade {
        background: #1e3c72;
        color: white;
        padding: 4px 10px;
        border-radius: 15px;
        font-size: 11px;
    }

    .empty-state {
        text-align: center;
        padding: 40px;
        color: #999;
    }
</style>

<div class="container allocate-container">
    <div class="page-header">
        <div class="header-left">
            <h2>
                <i class="fas fa-users-cog"></i> Allocate Students to Classes
            </h2>
            <p class="text-muted">Assign approved students to their classes</p>
        </div>
        <div>
            <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <div class="stats-bar">
        <div class="stat-item">
            <i class="fas fa-user-graduate fa-2x text-primary"></i>
            <div>
                <div class="stat-value">@(Model.UnallocatedStudents?.Count ?? 0)</div>
                <div class="text-muted">Unallocated Students</div>
            </div>
        </div>
        <div class="stat-item">
            <i class="fas fa-door-open fa-2x text-success"></i>
            <div>
                <div class="stat-value">@(Model.AvailableClasses?.Count ?? 0)</div>
                <div class="text-muted">Available Classes</div>
            </div>
        </div>
    </div>

    <div class="filter-section">
        <form method="get" class="form-inline">
            <label class="mr-2"><i class="fas fa-filter"></i> Filter by Grade:</label>
            <select name="gradeId" class="form-control mr-2" onchange="this.form.submit()">
                <option value="">All Grades</option>
                @if (Model.Grades != null)
                {
                    foreach (var grade in Model.Grades)
                    {
                        <option value="@grade.Id" selected="@(Model.SelectedGradeId == grade.Id)">@grade.Name</option>
                    }
                }
            </select>
            <button type="button" class="btn-auto" onclick="autoAllocate()">
                <i class="fas fa-magic"></i> Auto Allocate @(Model.SelectedGradeId.HasValue ? "This Grade" : "All")
            </button>
        </form>
    </div>

    <div class="row">
        <div class="col-md-7">
            <div class="students-section">
                <div class="section-header">
                    <span class="section-title">
                        <i class="fas fa-users"></i> Unallocated Students
                    </span>
                    <span class="badge badge-primary">@(Model.UnallocatedStudents?.Count ?? 0) students</span>
                </div>

                @if (Model.UnallocatedStudents == null || !Model.UnallocatedStudents.Any())
                {
                    <div class="empty-state">
                        <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
                        <h5>All students have been allocated!</h5>
                        <p>No unallocated students found.</p>
                    </div>
                }
                else
                {
                    <div style="max-height: 500px; overflow-y: auto;">
                        <table class="student-table">
                            <thead>
                                <tr>
                                    <th>Student</th>
                                    <th>Grade</th>
                                    <th>Stream</th>
                                    <th>Average</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var student in Model.UnallocatedStudents)
                                {
                                    <tr>
                                        <td>
                                            <strong>@student.FullName</strong><br />
                                            <small>@student.User?.StudentNumber</small>
                                        </td>
                                        <td>@(student.GradeApplyingFor?.Name ?? "—")</td>
                                        <td>@(student.Stream?.Name ?? "—")</td>
                                        <td>@(student.Applicant?.AcademicAverage?.ToString("0.0") ?? "—")%</td>
                                        <td>
                                            <select class="form-control form-control-sm class-select" data-student-id="@student.Id" style="width: 150px;">
                                                <option value="">-- Select Class --</option>
                                                @foreach (var cls in Model.AvailableClasses.Where(c => c.GradeId == student.GradeApplyingForId))
                                                {
                                                    var currentCount = Model.ClassStudentCounts != null && Model.ClassStudentCounts.ContainsKey(cls.Id)
                                                        ? Model.ClassStudentCounts[cls.Id]
                                                        : 0;
                                                    <option value="@cls.Id" @(currentCount >= cls.Capacity ? "disabled" : "")>
                                                        @cls.FullName (@currentCount/@cls.Capacity)
                                                    </option>
                                                }
                                            </select>
                                            <button class="btn btn-sm btn-outline-success mt-1 allocate-btn" data-student-id="@student.Id">
                                                Allocate
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-5">
            <div class="classes-section">
                <div class="section-header">
                    <span class="section-title">
                        <i class="fas fa-chalkboard"></i> Class Capacities
                    </span>
                </div>

                @if (Model.AvailableClasses != null)
                {
                    foreach (var cls in Model.AvailableClasses.OrderBy(c => c.Grade?.Level).ThenBy(c => c.Name))
                    {
                        var studentCount = Model.ClassStudentCounts != null && Model.ClassStudentCounts.ContainsKey(cls.Id)
                            ? Model.ClassStudentCounts[cls.Id]
                            : 0;
                        var percentage = cls.Capacity > 0 ? (studentCount * 100 / cls.Capacity) : 0;
                        var progressColor = percentage >= 90 ? "bg-danger" : percentage >= 70 ? "bg-warning" : "bg-success";

                        <div class="class-card">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="class-name">@cls.FullName</span>
                                    <span class="badge-grade ml-2">@cls.Grade?.Name</span>
                                    @if (cls.ClassTeacher != null)
                                    {
                                        <br /><small><i class="fas fa-user-tie"></i> @cls.ClassTeacher.FullName</small>
                                    }
                                </div>
                                <div class="class-capacity">
                                    <strong>@studentCount / @cls.Capacity</strong>
                                </div>
                            </div>
                            <div class="progress">
                                <div class="progress-bar @progressColor" style="width: @percentage%"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var context = {
            allocateUrl: '@Url.Action("ManuallyAllocateStudent", "Admin")',
            autoAllocateUrl: '@Url.Action("AutoAllocateStudents", "Admin")'
        };

        $('.allocate-btn').on('click', function() {
            var studentId = $(this).data('student-id');
            var select = $('.class-select[data-student-id="' + studentId + '"]');
            var classId = select.val();

            if (!classId) {
                alert('Please select a class');
                return;
            }

            var btn = $(this);
            btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>');

            $.ajax({
                url: context.allocateUrl,
                type: 'POST',
                data: { studentId: studentId, classId: classId },
                success: function(response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        alert(response.message);
                        btn.prop('disabled', false).text('Allocate');
                    }
                },
                error: function() {
                    alert('An error occurred');
                    btn.prop('disabled', false).text('Allocate');
                }
            });
        });

        function autoAllocate() {
            if (confirm('Auto-allocate students to classes? This will distribute students evenly across available classes.')) {
                var gradeId = '@(Model.SelectedGradeId)';
                var url = context.autoAllocateUrl;
                if (gradeId) {
                    url += '?gradeId=' + gradeId;
                }

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: { __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert(response.message);
                        }
                    }
                });
            }
        }
    </script>
}