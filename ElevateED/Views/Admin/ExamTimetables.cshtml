@model List<ElevateED.ViewModels.ExamTimetableViewModel>
@using ElevateED.Models

@{
    ViewBag.Title = "Exam Timetables - Admin";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --primary: #4f46e5;
        --primary-light: #6366f1;
        --primary-dark: #4338ca;
        --primary-bg: #f5f3ff;
        --primary-soft: #ede9fe;
        --primary-hover: #e0e7ff;
        --accent: #fbbf24;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --sidebar-width: 280px;
        --header-height: 70px;
    }

    body {
        font-family: 'Inter', -apple-system, sans-serif;
        background: var(--gray-50);
        overflow-x: hidden;
    }

    .app-container {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: var(--sidebar-width);
        background: linear-gradient(180deg, #1e1b4b 0%, #2e1065 100%);
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        transition: all 0.3s ease;
        z-index: 100;
        overflow-y: auto;
    }

    .sidebar-header {
        padding: 24px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .logo-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--accent), #f59e0b);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e1b4b;
        font-size: 20px;
    }

    .logo-text {
        font-size: 20px;
        font-weight: 700;
        color: white;
    }

        .logo-text span {
            color: var(--accent);
        }

    .sidebar-nav {
        flex: 1;
        padding: 24px 16px;
    }

    .nav-section {
        margin-top: 24px;
        margin-bottom: 12px;
        padding: 0 16px;
        font-size: 11px;
        font-weight: 600;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        margin-bottom: 8px;
        border-radius: 12px;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .nav-item:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        .nav-item.active {
            background: linear-gradient(135deg, var(--accent), #f59e0b);
            color: #1e1b4b;
        }

        .nav-item i {
            width: 20px;
            font-size: 18px;
        }

        .nav-item span {
            font-size: 14px;
            font-weight: 500;
        }

    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width);
        min-height: 100vh;
    }

    .top-header {
        height: var(--header-height);
        background: white;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: flex-end;
        align-items: center;
        padding: 0 32px;
        position: sticky;
        top: 0;
        z-index: 99;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .notification-btn {
        position: relative;
        background: none;
        border: none;
        font-size: 20px;
        color: var(--gray-500);
        cursor: pointer;
        padding: 8px;
        border-radius: 10px;
        transition: all 0.2s;
    }

        .notification-btn:hover {
            background: var(--gray-100);
        }

    .notification-badge {
        position: absolute;
        top: 2px;
        right: 2px;
        width: 8px;
        height: 8px;
        background: var(--danger);
        border-radius: 50%;
    }

    .profile-container {
        position: relative;
    }

    .profile-trigger {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 50px;
        transition: all 0.2s;
        background: none;
        border: none;
    }

        .profile-trigger:hover {
            background: var(--gray-100);
        }

    .avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 16px;
        text-transform: uppercase;
    }

    .profile-name {
        font-size: 14px;
        font-weight: 500;
        color: var(--gray-700);
    }

    .dropdown-icon {
        font-size: 12px;
        color: var(--gray-400);
    }

    .dropdown-menu {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        width: 240px;
        overflow: hidden;
        display: none;
        z-index: 1000;
    }

        .dropdown-menu.show {
            display: block;
            animation: fadeInDown 0.2s ease;
        }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .dropdown-header {
        padding: 16px;
        border-bottom: 1px solid var(--gray-200);
        background: linear-gradient(135deg, var(--primary-bg), var(--primary-soft));
    }

        .dropdown-header .user-name {
            font-weight: 600;
            color: var(--gray-900);
            margin-bottom: 4px;
        }

        .dropdown-header .user-email {
            font-size: 12px;
            color: var(--gray-500);
        }

    .dropdown-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        text-decoration: none;
        color: var(--gray-700);
        transition: all 0.2s;
        cursor: pointer;
        background: none;
        border: none;
        width: 100%;
        text-align: left;
    }

        .dropdown-item:hover {
            background: var(--primary-hover);
            color: var(--primary);
        }

        .dropdown-item i {
            width: 20px;
            font-size: 16px;
            color: var(--gray-500);
        }

    .dropdown-divider {
        height: 1px;
        background: var(--gray-200);
        margin: 8px 0;
    }

    .dashboard-content {
        padding: 32px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 15px;
    }

        .page-header h1 {
            font-size: 26px;
            font-weight: 700;
            color: var(--gray-900);
        }

    .btn-create {
        background: var(--success);
        color: white;
        padding: 10px 22px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-create:hover {
            background: #059669;
            color: white;
            text-decoration: none;
        }

    .timetable-card {
        background: white;
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 16px;
        border: 1px solid var(--gray-200);
        transition: all 0.3s;
        border-left: 4px solid var(--gray-300);
    }

        .timetable-card:hover {
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        }

        .timetable-card.status-draft {
            border-left-color: #6c757d;
        }

        .timetable-card.status-awaitingteacherinput {
            border-left-color: var(--warning);
        }

        .timetable-card.status-generated {
            border-left-color: var(--info);
        }

        .timetable-card.status-distributed {
            border-left-color: var(--success);
        }

    .card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 14px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .card-title {
        font-size: 19px;
        font-weight: 600;
        color: var(--gray-900);
    }

    .card-subtitle {
        font-size: 12px;
        color: var(--gray-500);
    }

    .status-badge {
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
    }

    .badge-draft {
        background: var(--gray-200);
        color: var(--gray-600);
    }

    .badge-awaiting {
        background: #fef3c7;
        color: #92400e;
    }

    .badge-generated {
        background: #dbeafe;
        color: #1e40af;
    }

    .badge-distributed {
        background: #d1fae5;
        color: #065f46;
    }

    .card-dates {
        display: flex;
        gap: 20px;
        margin-bottom: 12px;
        font-size: 13px;
        color: var(--gray-600);
        flex-wrap: wrap;
    }

        .card-dates span {
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

    .stats-row {
        display: flex;
        gap: 14px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .stat {
        background: var(--gray-50);
        padding: 6px 14px;
        border-radius: 10px;
        font-size: 12px;
        color: var(--gray-600);
    }

        .stat strong {
            color: var(--gray-800);
        }

    .btn-sm {
        padding: 7px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        margin-right: 6px;
    }

    .btn-view {
        background: var(--info);
        color: white;
    }

        .btn-view:hover {
            background: #2563eb;
            color: white;
            text-decoration: none;
        }

    .btn-notify {
        background: var(--warning);
        color: #1e1b4b;
    }

        .btn-notify:hover {
            background: #e0a800;
        }

    .btn-generate {
        background: var(--info);
        color: white;
    }

        .btn-generate:hover {
            background: #2563eb;
        }

    .btn-distribute {
        background: var(--success);
        color: white;
    }

        .btn-distribute:hover {
            background: #059669;
        }

    .btn-delete {
        background: var(--danger);
        color: white;
    }

        .btn-delete:hover {
            background: #dc2626;
        }

    .empty-state {
        text-align: center;
        padding: 60px;
        background: white;
        border-radius: 16px;
        border: 1px solid var(--gray-200);
    }

        .empty-state i {
            font-size: 48px;
            color: var(--gray-400);
            margin-bottom: 15px;
        }

    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 9999;
        display: none;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

        .loading-overlay .spinner {
            width: 50px;
            height: 50px;
            border: 5px solid #fff;
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        .loading-overlay p {
            color: white;
            margin-top: 15px;
            font-size: 16px;
        }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    @@media (max-width: 1024px) {
        .sidebar {
            transform: translateX(-100%);
        }

        .main-content {
            margin-left: 0;
        }
    }

    @@media (max-width: 768px) {
        .dashboard-content {
            padding: 20px;
        }
    }
</style>

<div class="app-container">
    <aside class="sidebar">
        <div class="sidebar-header"><div class="logo"><div class="logo-icon"><i class="fas fa-graduation-cap"></i></div><div class="logo-text">Elevate<span>ED</span></div></div></div>
        <nav class="sidebar-nav">
            <div class="nav-section">Main</div>
            <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
            <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
            <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
            <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
            <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
            <div class="nav-section">Management</div>
            <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
            <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item active"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
            <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
            <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
            <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
            <div class="nav-section">Extra</div>
            <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
            <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
            <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
            <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
        </nav>
    </aside>
    <main class="main-content">
        <header class="top-header">
            <div class="header-right">
                <button class="notification-btn"><i class="far fa-bell"></i><span class="notification-badge"></span></button>
                <div class="profile-container">
                    <button class="profile-trigger" onclick="toggleDropdown()"><div class="avatar">A</div><span class="profile-name">Admin</span><i class="fas fa-chevron-down dropdown-icon"></i></button>
                    <div class="dropdown-menu" id="profileDropdown">
                        <div class="dropdown-header"><div class="user-name">Administrator</div><div class="user-email">admin@mpiyakhehs.co.za</div></div>
                        <a href="@Url.Action("ManageUsers","Admin")" class="dropdown-item"><i class="fas fa-users"></i><span>Manage Users</span></a>
                        <div class="dropdown-divider"></div>
                        <form action="@Url.Action("LogOff","Account")" method="post" id="logoutForm">
                            @Html.AntiForgeryToken()
                            <button type="button" class="dropdown-item" onclick="confirmLogout(event)" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i><span>Logout</span></button>
                        </form>
                    </div>
                </div>
            </div>
        </header>
        <div class="dashboard-content">
            <div class="page-header"><div><h1><i class="fas fa-calendar-alt" style="color:var(--info);"></i> Exam Timetables</h1><p style="color:var(--gray-500);">Create and manage examination schedules</p></div><a href="@Url.Action("CreateExamTimetable","Admin")" class="btn-create"><i class="fas fa-plus"></i> Create New Timetable</a></div>
            @if (!Model.Any())
            {<div class="empty-state"><i class="fas fa-calendar-plus"></i><h4>No Exam Timetables</h4><p style="color:var(--gray-500);">Create your first exam timetable to get started.</p><a href="@Url.Action("CreateExamTimetable","Admin")" class="btn-create" style="display:inline-flex;margin-top:12px;"><i class="fas fa-plus"></i> Create Timetable</a></div>}
            else
            {
                foreach (var timetable in Model)
                {<div class="timetable-card status-@timetable.Status.ToString().ToLower()" id="timetable-@timetable.Id">
                        <div class="card-top"><div><div class="card-title">@timetable.Name</div><div class="card-subtitle">Academic Year @timetable.AcademicYear</div></div><span class="status-badge @timetable.StatusBadgeClass">@timetable.StatusDisplay</span></div>
                        <div class="card-dates"><span><i class="fas fa-calendar"></i> Start: @timetable.StartDate.ToString("dd MMM yyyy")</span><span><i class="fas fa-calendar-check"></i> End: @timetable.EndDate.ToString("dd MMM yyyy")</span><span><i class="fas fa-clock"></i> @timetable.NumberOfWeeks Week(s)</span></div>
                        <div class="stats-row"><div class="stat"><strong>Sessions:</strong> @timetable.TotalSessions</div><div class="stat"><strong>Created:</strong> @timetable.CreatedAt.ToString("dd MMM yyyy")</div>@if (timetable.GeneratedAt.HasValue)
                        {<div class="stat"><strong>Generated:</strong> @timetable.GeneratedAt.Value.ToString("dd MMM yyyy")</div>}@if (timetable.DistributedAt.HasValue)
                        {<div class="stat"><strong>Distributed:</strong> @timetable.DistributedAt.Value.ToString("dd MMM yyyy")</div>}</div>
                        <div style="display:flex;gap:8px;flex-wrap:wrap;">
                            <a href="@Url.Action("ViewExamTimetable","Admin",new{id=timetable.Id})" class="btn-sm btn-view"><i class="fas fa-eye"></i> View</a>
                            @if (timetable.Status == ExamTimetableStatus.Draft)
                            {<button class="btn-sm btn-notify" onclick="sendNotifications(@timetable.Id)"><i class="fas fa-bell"></i> Notify Teachers</button>}
                            @if (timetable.Status == ExamTimetableStatus.AwaitingTeacherInput)
                            {<button class="btn-sm btn-generate" onclick="generateTimetable(@timetable.Id)" @(timetable.CanGenerate ? "" : "disabled")><i class="fas fa-cogs"></i> Generate</button>}
                            @if (timetable.Status == ExamTimetableStatus.Generated)
                            {<button class="btn-sm btn-distribute" onclick="distributeTimetable(@timetable.Id)"><i class="fas fa-share-alt"></i> Distribute</button>}
                            <button class="btn-sm btn-delete" onclick="deleteTimetable(@timetable.Id,'@timetable.Name')"><i class="fas fa-trash"></i> Delete</button>
                        </div>
                    </div>}
            }
        </div>
    </main>
</div>

<div id="loadingOverlay" class="loading-overlay"><div class="spinner"></div><p>Processing... Please wait</p></div>

<script>
    function toggleDropdown(){document.getElementById('profileDropdown').classList.toggle('show');}
    document.addEventListener('click',function(e){var c=document.querySelector('.profile-container');var d=document.getElementById('profileDropdown');if(c&&!c.contains(e.target))d.classList.remove('show');});
    function confirmLogout(e){e.preventDefault();if(confirm('Are you sure you want to logout?')){document.getElementById('logoutForm').submit();}}
    function showLoading(){document.getElementById('loadingOverlay').style.display='flex';}
    function hideLoading(){document.getElementById('loadingOverlay').style.display='none';}
    function getToken(){return document.querySelector('input[name="__RequestVerificationToken"]').value;}
    function sendNotifications(id){if(!confirm('Send notifications to all teachers?'))return;showLoading();fetch('@Url.Action("SendTeacherNotifications","Admin")',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'__RequestVerificationToken='+getToken()+'&id='+id}).then(r=>r.json()).then(r=>{hideLoading();alert(r.message);if(r.success)location.reload();});}
    function generateTimetable(id){if(!confirm('Generate exam timetable?'))return;showLoading();fetch('@Url.Action("GenerateExamTimetable","Admin")',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'__RequestVerificationToken='+getToken()+'&id='+id}).then(r=>r.json()).then(r=>{hideLoading();var m=r.message;if(r.warnings&&r.warnings.length)m+='\n\nWarnings:\n'+r.warnings.join('\n');alert(m);if(r.success)location.reload();});}
    function distributeTimetable(id){if(!confirm('Distribute to all students and teachers?'))return;showLoading();fetch('@Url.Action("DistributeExamTimetable","Admin")',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'__RequestVerificationToken='+getToken()+'&id='+id}).then(r=>r.json()).then(r=>{hideLoading();alert(r.message);if(r.success)location.reload();});}
    function deleteTimetable(id,name){if(!confirm('Delete "'+name+'"?'))return;showLoading();fetch('@Url.Action("DeleteExamTimetable","Admin")',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'__RequestVerificationToken='+getToken()+'&id='+id}).then(r=>r.json()).then(r=>{hideLoading();if(r.success){var c=document.getElementById('timetable-'+id);if(c)c.style.display='none';if(!document.querySelectorAll('.timetable-card:not([style*="display:none"])').length)location.reload();}else alert(r.message);});}
</script>