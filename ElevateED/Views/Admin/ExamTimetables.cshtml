@model List<ElevateED.ViewModels.ExamTimetableViewModel>
@using ElevateED.Models

@{
    ViewBag.Title = "Exam Timetables - Admin";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section SidebarNav {
    <div class="nav-section">Main</div>
    <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
    <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
    <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
    <div class="nav-section">Management</div>
    <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
    <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item active"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
    <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
    <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
    <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
    <div class="nav-section">Extra</div>
    <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
    <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
    <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
    <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
}

@section Styles {
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 15px;
        }

            .page-header h1 {
                font-size: 26px;
                font-weight: 700;
                color: var(--gray-900);
            }

        .btn-create {
            background: var(--success);
            color: white;
            padding: 10px 22px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-create:hover {
                background: #059669;
                color: white;
                text-decoration: none;
            }

        .timetable-card {
            background: white;
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 16px;
            border: 1px solid var(--gray-200);
            transition: all 0.3s;
            border-left: 4px solid var(--gray-300);
        }

            .timetable-card:hover {
                box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            }

            .timetable-card.status-draft {
                border-left-color: #6c757d;
            }

            .timetable-card.status-awaitingteacherinput {
                border-left-color: var(--warning);
            }

            .timetable-card.status-generated {
                border-left-color: var(--info);
            }

            .timetable-card.status-distributed {
                border-left-color: var(--success);
            }

        .card-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 14px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .card-title {
            font-size: 19px;
            font-weight: 600;
            color: var(--gray-900);
        }

        .card-subtitle {
            font-size: 12px;
            color: var(--gray-500);
        }

        .status-badge {
            padding: 5px 14px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-draft {
            background: var(--gray-200);
            color: var(--gray-600);
        }

        .badge-awaiting {
            background: #fef3c7;
            color: #92400e;
        }

        .badge-generated {
            background: #dbeafe;
            color: #1e40af;
        }

        .badge-distributed {
            background: #d1fae5;
            color: #065f46;
        }

        .card-dates {
            display: flex;
            gap: 20px;
            margin-bottom: 12px;
            font-size: 13px;
            color: var(--gray-600);
            flex-wrap: wrap;
        }

            .card-dates span {
                display: inline-flex;
                align-items: center;
                gap: 5px;
            }

        .stats-row {
            display: flex;
            gap: 14px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .stat {
            background: var(--gray-50);
            padding: 6px 14px;
            border-radius: 10px;
            font-size: 12px;
            color: var(--gray-600);
        }

            .stat strong {
                color: var(--gray-800);
            }

        .btn-sm {
            padding: 7px 16px;
            border-radius: 10px;
            font-size: 12px;
            font-weight: 500;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
            margin-right: 6px;
        }

        .btn-view {
            background: var(--info);
            color: white;
        }

            .btn-view:hover {
                background: #2563eb;
                color: white;
                text-decoration: none;
            }

        .btn-notify {
            background: var(--warning);
            color: #1e1b4b;
        }

            .btn-notify:hover {
                background: #e0a800;
            }

        .btn-generate {
            background: var(--info);
            color: white;
        }

            .btn-generate:hover {
                background: #2563eb;
            }

        .btn-distribute {
            background: var(--success);
            color: white;
        }

            .btn-distribute:hover {
                background: #059669;
            }

        .btn-delete {
            background: var(--danger);
            color: white;
        }

            .btn-delete:hover {
                background: #dc2626;
            }

        .empty-state {
            text-align: center;
            padding: 60px;
            background: white;
            border-radius: 16px;
            border: 1px solid var(--gray-200);
        }

            .empty-state i {
                font-size: 48px;
                color: var(--gray-400);
                margin-bottom: 15px;
            }

        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 9999;
            display: none;
            justify-content: center;
            align-items: center;
            flex-direction: column;
        }

            .loading-overlay .spinner {
                width: 50px;
                height: 50px;
                border: 5px solid #fff;
                border-top-color: var(--accent);
                border-radius: 50%;
                animation: spin 1s linear infinite;
            }

            .loading-overlay p {
                color: white;
                margin-top: 15px;
                font-size: 16px;
            }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>
}

<div class="page-header">
    <div>
        <h1>
            <i class="fas fa-calendar-alt" style="color:var(--info);"></i>
            Exam Timetables
        </h1>
        <p style="color:var(--gray-500);">Create and manage examination schedules</p>
    </div>
    <a href="@Url.Action("CreateExamTimetable","Admin")" class="btn-create">
        <i class="fas fa-plus"></i> Create New Timetable
    </a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-calendar-plus"></i>
        <h4>No Exam Timetables</h4>
        <p style="color:var(--gray-500);">Create your first exam timetable to get started.</p>
        <a href="@Url.Action("CreateExamTimetable","Admin")" class="btn-create" style="display:inline-flex;margin-top:12px;">
            <i class="fas fa-plus"></i> Create Timetable
        </a>
    </div>
}
else
{
    foreach (var timetable in Model)
    {
        <div class="timetable-card status-@timetable.Status.ToString().ToLower()" id="timetable-@timetable.Id">
            <div class="card-top">
                <div>
                    <div class="card-title">@timetable.Name</div>
                    <div class="card-subtitle">Academic Year @timetable.AcademicYear</div>
                </div>
                <span class="status-badge @timetable.StatusBadgeClass">@timetable.StatusDisplay</span>
            </div>
            <div class="card-dates">
                <span><i class="fas fa-calendar"></i> Start: @timetable.StartDate.ToString("dd MMM yyyy")</span>
                <span><i class="fas fa-calendar-check"></i> End: @timetable.EndDate.ToString("dd MMM yyyy")</span>
                <span><i class="fas fa-clock"></i> @timetable.NumberOfWeeks Week(s)</span>
            </div>
            <div class="stats-row">
                <div class="stat"><strong>Sessions:</strong> @timetable.TotalSessions</div>
                <div class="stat"><strong>Created:</strong> @timetable.CreatedAt.ToString("dd MMM yyyy")</div>
                @if (timetable.GeneratedAt.HasValue)
                {
                    <div class="stat"><strong>Generated:</strong> @timetable.GeneratedAt.Value.ToString("dd MMM yyyy")</div>
                }
                @if (timetable.DistributedAt.HasValue)
                {
                    <div class="stat"><strong>Distributed:</strong> @timetable.DistributedAt.Value.ToString("dd MMM yyyy")</div>
                }
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
                <a href="@Url.Action("ViewExamTimetable","Admin",new{id=timetable.Id})" class="btn-sm btn-view">
                    <i class="fas fa-eye"></i> View
                </a>
                @if (timetable.Status == ExamTimetableStatus.Draft)
                {
                    <button class="btn-sm btn-notify" onclick="sendNotifications(@timetable.Id)">
                        <i class="fas fa-bell"></i> Notify Teachers
                    </button>
                }
                @if (timetable.Status == ExamTimetableStatus.AwaitingTeacherInput)
                {
                    <button class="btn-sm btn-generate" onclick="generateTimetable(@timetable.Id)"
                            @(timetable.CanGenerate ? "" : "disabled")>
                        <i class="fas fa-cogs"></i> Generate
                    </button>
                }
                @if (timetable.Status == ExamTimetableStatus.Generated)
                {
                    <button class="btn-sm btn-distribute" onclick="distributeTimetable(@timetable.Id)">
                        <i class="fas fa-share-alt"></i> Distribute
                    </button>
                }
                <button class="btn-sm btn-delete" onclick="deleteTimetable(@timetable.Id,'@timetable.Name')">
                    <i class="fas fa-trash"></i> Delete
                </button>
            </div>
        </div>
    }
}

<div id="loadingOverlay" class="loading-overlay">
    <div class="spinner"></div>
    <p>Processing... Please wait</p>
</div>

@section Scripts {
    <script>
        function showLoading() {
            document.getElementById('loadingOverlay').style.display = 'flex';
        }

        function hideLoading() {
            document.getElementById('loadingOverlay').style.display = 'none';
        }

        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function sendNotifications(id) {
            if (!confirm('Send notifications to all teachers?')) return;
            showLoading();
            fetch('@Url.Action("SendTeacherNotifications","Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: '__RequestVerificationToken=' + getToken() + '&id=' + id
            }).then(r => r.json()).then(r => {
                hideLoading();
                alert(r.message);
                if (r.success) location.reload();
            });
        }

        function generateTimetable(id) {
            if (!confirm('Generate exam timetable?')) return;
            showLoading();
            fetch('@Url.Action("GenerateExamTimetable","Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: '__RequestVerificationToken=' + getToken() + '&id=' + id
            }).then(r => r.json()).then(r => {
                hideLoading();
                var m = r.message;
                if (r.warnings && r.warnings.length) m += '\n\nWarnings:\n' + r.warnings.join('\n');
                alert(m);
                if (r.success) location.reload();
            });
        }

        function distributeTimetable(id) {
            if (!confirm('Distribute to all students and teachers?')) return;
            showLoading();
            fetch('@Url.Action("DistributeExamTimetable","Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: '__RequestVerificationToken=' + getToken() + '&id=' + id
            }).then(r => r.json()).then(r => {
                hideLoading();
                alert(r.message);
                if (r.success) location.reload();
            });
        }

        function deleteTimetable(id, name) {
            if (!confirm('Delete "' + name + '"?')) return;
            showLoading();
            fetch('@Url.Action("DeleteExamTimetable","Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: '__RequestVerificationToken=' + getToken() + '&id=' + id
            }).then(r => r.json()).then(r => {
                hideLoading();
                if (r.success) {
                    var c = document.getElementById('timetable-' + id);
                    if (c) c.style.display = 'none';
                    if (!document.querySelectorAll('.timetable-card:not([style*="display:none"])').length)
                        location.reload();
                } else {
                    alert(r.message);
                }
            });
        }
    </script>
}