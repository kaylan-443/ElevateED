@model List<ElevateED.ViewModels.ExamTimetableViewModel>
@using ElevateED.Models

@{
    ViewBag.Title = "Exam Cycles - Admin";
}

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
        --primary: #4f46e5;
        --primary-light: #6366f1;
        --primary-dark: #4338ca;
        --primary-bg: #f5f3ff;
        --primary-soft: #ede9fe;
        --primary-hover: #e0e7ff;
        --accent: #fbbf24;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --sidebar-width: 280px;
        --header-height: 70px;
    }

    body {
        font-family: 'Inter', -apple-system, sans-serif;
        background: var(--gray-50);
        overflow-x: hidden;
    }

    .app-container { display: flex; min-height: 100vh; }

    .sidebar {
        width: var(--sidebar-width);
        background: linear-gradient(180deg, #1e1b4b 0%, #2e1065 100%);
        position: fixed; left: 0; top: 0; bottom: 0;
        display: flex; flex-direction: column;
        z-index: 100; overflow-y: auto;
    }
    .sidebar-header { padding: 24px; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .logo { display: flex; align-items: center; gap: 12px; }
    .logo-icon {
        width: 40px; height: 40px;
        background: linear-gradient(135deg, var(--accent), #f59e0b);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        color: #1e1b4b; font-size: 20px;
    }
    .logo-text { font-size: 20px; font-weight: 700; color: white; }
    .logo-text span { color: var(--accent); }
    .sidebar-nav { flex: 1; padding: 24px 16px; }
    .nav-section {
        margin-top: 24px; margin-bottom: 12px; padding: 0 16px;
        font-size: 11px; font-weight: 600;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase; letter-spacing: 1px;
    }
    .nav-item {
        display: flex; align-items: center; gap: 12px;
        padding: 12px 16px; margin-bottom: 8px;
        border-radius: 12px;
        color: rgba(255,255,255,0.7); text-decoration: none;
        transition: all 0.2s ease;
    }
    .nav-item:hover { background: rgba(255,255,255,0.1); color: white; }
    .nav-item.active { background: linear-gradient(135deg, var(--accent), #f59e0b); color: #1e1b4b; }
    .nav-item i { width: 20px; font-size: 18px; }
    .nav-item span { font-size: 14px; font-weight: 500; }

    .main-content { flex: 1; margin-left: var(--sidebar-width); min-height: 100vh; }
    .top-header {
        height: var(--header-height);
        background: white;
        border-bottom: 1px solid var(--gray-200);
        display: flex; justify-content: flex-end; align-items: center;
        padding: 0 32px; position: sticky; top: 0; z-index: 99;
    }
    .header-right { display: flex; align-items: center; gap: 24px; }
    .avatar {
        width: 40px; height: 40px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        color: white; font-weight: 600; font-size: 16px;
    }

    .dashboard-content { padding: 32px; }

    .page-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 14px; flex-wrap: wrap; gap: 15px;
    }
    .page-header h1 { font-size: 26px; font-weight: 700; color: var(--gray-900); }
    .page-header p { color: var(--gray-500); font-size: 14px; margin-top: 4px; }

    .actions-bar {
        display: flex; gap: 10px; flex-wrap: wrap;
        margin-bottom: 24px;
    }
    .btn-create {
        background: var(--success); color: white;
        padding: 10px 22px; border-radius: 12px;
        text-decoration: none; font-weight: 500;
        display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-create:hover { background: #059669; color: white; text-decoration: none; }
    .btn-link-outline {
        background: white; color: var(--primary);
        padding: 10px 22px; border-radius: 12px;
        text-decoration: none; font-weight: 500;
        border: 1.5px solid var(--primary);
        display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-link-outline:hover { background: var(--primary); color: white; text-decoration: none; }

    .info-banner {
        background: var(--primary-bg);
        border: 1px solid var(--primary-soft);
        color: var(--primary-dark);
        border-radius: 12px;
        padding: 14px 18px;
        margin-bottom: 22px;
        font-size: 13px;
    }
    .info-banner i { margin-right: 6px; }

    .timetable-card {
        background: white;
        border-radius: 16px;
        padding: 22px 24px;
        margin-bottom: 16px;
        border: 1px solid var(--gray-200);
        border-left: 4px solid var(--gray-300);
        transition: all 0.25s;
    }
    .timetable-card:hover { box-shadow: 0 10px 25px rgba(0,0,0,0.08); }
    .timetable-card.status-draft { border-left-color: #6c757d; }
    .timetable-card.status-awaitingteacherinput { border-left-color: var(--warning); }
    .timetable-card.status-generated { border-left-color: var(--info); }
    .timetable-card.status-distributed { border-left-color: var(--success); }
    .timetable-card.status-archived { border-left-color: var(--gray-400); }

    .card-top {
        display: flex; justify-content: space-between; align-items: flex-start;
        margin-bottom: 14px; flex-wrap: wrap; gap: 10px;
    }
    .card-title { font-size: 19px; font-weight: 600; color: var(--gray-900); }
    .card-subtitle { font-size: 12px; color: var(--gray-500); margin-top: 2px; }

    .status-badge {
        padding: 5px 14px; border-radius: 20px;
        font-size: 11px; font-weight: 600;
    }
    .badge-draft { background: var(--gray-200); color: var(--gray-600); }
    .badge-awaiting { background: #fef3c7; color: #92400e; }
    .badge-generated { background: #dbeafe; color: #1e40af; }
    .badge-distributed { background: #d1fae5; color: #065f46; }

    .card-dates {
        display: flex; gap: 20px; margin-bottom: 12px;
        font-size: 13px; color: var(--gray-600); flex-wrap: wrap;
    }
    .card-dates span { display: inline-flex; align-items: center; gap: 5px; }

    .stats-row {
        display: flex; gap: 14px; margin-bottom: 16px; flex-wrap: wrap;
    }
    .stat {
        background: var(--gray-50);
        padding: 6px 14px;
        border-radius: 10px;
        font-size: 12px;
        color: var(--gray-600);
    }
    .stat strong { color: var(--gray-800); }

    .card-actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .btn-sm {
        padding: 7px 16px; border-radius: 10px;
        font-size: 12px; font-weight: 500;
        border: none; cursor: pointer;
        display: inline-flex; align-items: center; gap: 6px;
        text-decoration: none;
    }
    .btn-review {
        background: var(--primary); color: white;
    }
    .btn-review:hover { background: var(--primary-dark); color: white; text-decoration: none; }
    .btn-delete { background: var(--danger); color: white; }
    .btn-delete:hover { background: #dc2626; }

    .empty-state {
        text-align: center; padding: 60px;
        background: white; border-radius: 16px;
        border: 1px solid var(--gray-200);
    }
    .empty-state i { font-size: 48px; color: var(--gray-400); margin-bottom: 15px; }

    .alert-flash {
        border-radius: 12px; padding: 14px 18px; margin-bottom: 18px;
    }
    .alert-flash-success { background: #d1fae5; color: #065f46; border: 1px solid #a7f3d0; }
    .alert-flash-error { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }

    @@media (max-width: 1024px) {
        .sidebar { transform: translateX(-100%); }
        .main-content { margin-left: 0; }
    }
</style>

<div class="app-container">
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <div class="logo-icon"><i class="fas fa-graduation-cap"></i></div>
                <div class="logo-text">Elevate<span>ED</span></div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section">Main</div>
            <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
            <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
            <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
            <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
            <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
            <div class="nav-section">Management</div>
            <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
            <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item active"><i class="fas fa-calendar-check"></i><span>Exam Cycles</span></a>
            <a href="@Url.Action("Index","ExamApproval")" class="nav-item"><i class="fas fa-clipboard-check"></i><span>Exam Proposals</span></a>
            <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
            <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
            <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
            <div class="nav-section">Extra</div>
            <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
            <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
        </nav>
    </aside>

    <main class="main-content">
        <header class="top-header">
            <div class="header-right">
                <div class="avatar">A</div>
            </div>
        </header>

        <div class="dashboard-content">
            <div class="page-header">
                <div>
                    <h1><i class="fas fa-calendar-alt" style="color:var(--info);"></i> Exam Cycles</h1>
                    <p>Create exam cycles (e.g. "June Exams 2026"). Teachers propose individual sessions; the principal approves and publishes them.</p>
                </div>
            </div>

            <div class="info-banner">
                <i class="fas fa-info-circle"></i>
                <strong>New flow:</strong> Create a cycle here, then teachers propose their own exam sessions at <em>Propose Exam</em>. Review and publish via <a href="@Url.Action("Index","ExamApproval")" style="color:var(--primary-dark);font-weight:600;">Exam Proposals</a>.
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert-flash alert-flash-success"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert-flash alert-flash-error"><i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]</div>
            }

            <div class="actions-bar">
                <a href="@Url.Action("CreateExamTimetable","Admin")" class="btn-create"><i class="fas fa-plus"></i> Create Cycle</a>
                <a href="@Url.Action("Index","ExamApproval")" class="btn-link-outline"><i class="fas fa-clipboard-check"></i> Review Proposals</a>
            </div>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="fas fa-calendar-plus"></i>
                    <h4>No exam cycles yet</h4>
                    <p style="color:var(--gray-500);">Create your first exam cycle (e.g. "June Exams 2026") so teachers can start proposing exam sessions for it.</p>
                    <a href="@Url.Action("CreateExamTimetable","Admin")" class="btn-create" style="display:inline-flex;margin-top:14px;"><i class="fas fa-plus"></i> Create Cycle</a>
                </div>
            }
            else
            {
                foreach (var timetable in Model)
                {
                    <div class="timetable-card status-@timetable.Status.ToString().ToLower()" id="timetable-@timetable.Id">
                        <div class="card-top">
                            <div>
                                <div class="card-title">@timetable.Name</div>
                                <div class="card-subtitle">Academic Year @timetable.AcademicYear</div>
                            </div>
                            <span class="status-badge @timetable.StatusBadgeClass">@timetable.StatusDisplay</span>
                        </div>
                        <div class="card-dates">
                            <span><i class="fas fa-calendar"></i> Start: @timetable.StartDate.ToString("dd MMM yyyy")</span>
                            <span><i class="fas fa-calendar-check"></i> End: @timetable.EndDate.ToString("dd MMM yyyy")</span>
                            <span><i class="fas fa-clock"></i> @timetable.NumberOfWeeks Week(s)</span>
                        </div>
                        <div class="stats-row">
                            <div class="stat"><strong>Sessions:</strong> @timetable.TotalSessions</div>
                            <div class="stat"><strong>Created:</strong> @timetable.CreatedAt.ToString("dd MMM yyyy")</div>
                            @if (timetable.DistributedAt.HasValue)
                            {
                                <div class="stat"><strong>Published:</strong> @timetable.DistributedAt.Value.ToString("dd MMM yyyy")</div>
                            }
                        </div>
                        <div class="card-actions">
                            <a href="@Url.Action("Index","ExamApproval", new { cycleId = timetable.Id })" class="btn-sm btn-review"><i class="fas fa-clipboard-check"></i> Review Proposals</a>
                            <button class="btn-sm btn-delete" onclick="deleteTimetable(@timetable.Id,'@timetable.Name')"><i class="fas fa-trash"></i> Delete</button>
                        </div>
                    </div>
                }
            }
        </div>
    </main>
</div>

@Html.AntiForgeryToken()
<script>
    function getToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]').value;
    }
    function deleteTimetable(id, name) {
        if (!confirm('Delete the cycle "' + name + '"? All sessions in it will be removed.')) return;
        fetch('@Url.Action("DeleteExamTimetable","Admin")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: '__RequestVerificationToken=' + getToken() + '&id=' + id
        }).then(r => r.json()).then(r => {
            if (r.success) {
                var c = document.getElementById('timetable-' + id);
                if (c) c.style.display = 'none';
            } else {
                alert(r.message);
            }
        });
    }
</script>
