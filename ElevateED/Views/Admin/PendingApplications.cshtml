@model IEnumerable<ElevateED.Models.Applicant>
@using ElevateED.Models

@{
    ViewBag.Title = "Pending Applications";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var pendingCount = Model.Count(a => a.Status == ApplicationStatus.Pending);
    var underReviewCount = Model.Count(a => a.Status == ApplicationStatus.UnderReview);
}

@section SidebarNav {
    <div class="nav-section">Main</div>
    <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="@Url.Action("PendingApplications","Admin")" class="nav-item active"><i class="fas fa-file-alt"></i><span>Applications</span></a>
    <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
    <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
    <div class="nav-section">Management</div>
    <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
    <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
    <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
    <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
    <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
    <div class="nav-section">Extra</div>
    <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
    <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
    <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
    <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
}

@section Styles {
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 15px;
        }

            .page-header h1 {
                font-size: 26px;
                font-weight: 700;
                color: var(--gray-900);
            }

        .btn-primary {
            background: var(--primary);
            color: white;
            padding: 10px 20px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-primary:hover {
                background: #4338ca;
                color: white;
                text-decoration: none;
            }

        .btn-back {
            background: white;
            color: var(--gray-700);
            padding: 10px 20px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 500;
            border: 1px solid var(--gray-200);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-back:hover {
                background: var(--gray-100);
                text-decoration: none;
            }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .stat-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            border: 1px solid var(--gray-200);
        }

        .stat-num {
            font-size: 30px;
            font-weight: 700;
        }

        .stat-lbl {
            font-size: 12px;
            color: var(--gray-500);
            text-transform: uppercase;
            margin-top: 4px;
        }

        .filter-bar {
            background: white;
            border-radius: 16px;
            padding: 16px 20px;
            border: 1px solid var(--gray-200);
            margin-bottom: 20px;
        }

            .filter-bar select, .filter-bar input {
                padding: 9px 14px;
                border: 2px solid var(--gray-200);
                border-radius: 10px;
                font-size: 13px;
            }

        .btn-filter {
            background: var(--primary);
            color: white;
            padding: 9px 18px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-weight: 500;
        }

        .btn-reset {
            padding: 9px 18px;
            border-radius: 10px;
            border: 1px solid var(--gray-200);
            background: white;
            cursor: pointer;
            text-decoration: none;
            color: var(--gray-700);
            font-size: 13px;
            display: inline-block;
        }

        .table-wrap {
            background: white;
            border-radius: 16px;
            border: 1px solid var(--gray-200);
            overflow: hidden;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th {
            background: var(--gray-800);
            color: white;
            padding: 11px 14px;
            text-align: left;
            font-weight: 500;
            font-size: 12px;
        }

        td {
            padding: 11px 14px;
            border-bottom: 1px solid var(--gray-100);
            vertical-align: middle;
        }

        tr:hover td {
            background: var(--gray-50);
        }

        .badge {
            padding: 4px 10px;
            border-radius: 10px;
            font-size: 10px;
            font-weight: 600;
        }

        .badge-pending {
            background: #fef3c7;
            color: #92400e;
        }

        .badge-review {
            background: #dbeafe;
            color: #1e40af;
        }

        .badge-grade {
            background: #e0e7ff;
            color: #3730a3;
            padding: 4px 10px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 500;
            display: inline-block;
        }

        .avg-badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 10px;
            font-size: 12px;
            font-weight: 600;
        }

        .avg-high {
            background: #d1fae5;
            color: #065f46;
        }

        .avg-med {
            background: #fef3c7;
            color: #92400e;
        }

        .avg-low {
            background: #fee2e2;
            color: #991b1b;
        }

        .btn-sm {
            padding: 5px 12px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 500;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            text-decoration: none;
        }

        .btn-rev {
            background: #f97316;
            color: white;
        }

        .btn-det {
            background: var(--info);
            color: white;
        }

            .btn-det:hover {
                background: #2563eb;
                color: white;
                text-decoration: none;
            }

        .alert-success {
            background: #d1fae5;
            color: #065f46;
            padding: 12px 16px;
            border-radius: 10px;
            margin-bottom: 20px;
        }

        .empty-state {
            text-align: center;
            padding: 60px;
            color: var(--gray-400);
        }

        @@media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-clipboard-list" style="color:var(--warning);"></i> Pending Applications</h1>
        <p style="color:var(--gray-500);">Review and manage student applications</p>
    </div>
    <div style="display:flex;gap:10px;">
        <a href="@Url.Action("EvaluateApplications","Admin")" class="btn-primary" style="background:var(--success);">
            <i class="fas fa-star"></i> Bulk Evaluate
        </a>
        <a href="@Url.Action("Dashboard","Admin")" class="btn-back">
            <i class="fas fa-arrow-left"></i> Back
        </a>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-num" style="color:var(--warning);">@pendingCount</div>
        <div class="stat-lbl">Pending</div>
    </div>
    <div class="stat-card">
        <div class="stat-num" style="color:var(--info);">@underReviewCount</div>
        <div class="stat-lbl">Under Review</div>
    </div>
    <div class="stat-card">
        <div class="stat-num" style="color:var(--primary);">@(pendingCount+underReviewCount)</div>
        <div class="stat-lbl">Total to Review</div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
}

<div class="filter-bar">
    <form method="get" action="@Url.Action("PendingApplications")" style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
        <select name="status">
            <option value="">All Statuses</option>
            <option value="Pending">Pending</option>
            <option value="UnderReview">Under Review</option>
        </select>
        <input type="text" name="search" placeholder="Search name..." />
        <select name="grade">
            <option value="">All Grades</option>
            <option value="Grade 8">Grade 8</option>
            <option value="Grade 9">Grade 9</option>
            <option value="Grade 10">Grade 10</option>
            <option value="Grade 11">Grade 11</option>
            <option value="Grade 12">Grade 12</option>
        </select>
        <button type="submit" class="btn-filter"><i class="fas fa-filter"></i> Apply</button>
        <a href="@Url.Action("PendingApplications")" class="btn-reset"><i class="fas fa-redo"></i> Reset</a>
    </form>
</div>

<div class="table-wrap">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-inbox" style="font-size:40px;display:block;margin-bottom:10px;"></i>
            <p>No applications found.</p>
        </div>
    }
    else
    {
        <table>
            <thead>
                <tr><th>Applicant</th><th>Student #</th><th>Grade</th><th>Average</th><th>Applied</th><th>Status</th><th>Parent</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    string sn = item.User?.StudentNumber ?? "—";
                    string sc = item.Status == ApplicationStatus.Pending ? "badge-pending" : "badge-review";
                    string ac = item.AcademicAverage >= 80 ? "avg-high" : item.AcademicAverage >= 60 ? "avg-med" : "avg-low";
                    <tr>
                        <td>
                            <strong style="color:var(--gray-800);">@item.FullName</strong><br />
                            <small style="color:var(--gray-500);">@item.PreviousSchool</small>
                        </td>
                        <td>@sn</td>
                        <td>
                            <span class="badge-grade"><i class="fas fa-graduation-cap"></i> @(item.GradeApplyingForDisplay ?? "—")</span>
                        </td>
                        <td>
                            <span class="avg-badge @ac">@(item.AcademicAverage?.ToString("0.0") ?? "—")%</span>
                        </td>
                        <td>@item.ApplicationDate.ToString("dd MMM yyyy")</td>
                        <td><span class="badge @sc">@item.Status</span></td>
                        <td>
                            <div><i class="fas fa-phone-alt" style="color:var(--gray-400);font-size:10px;margin-right:4px;"></i>@item.ParentCellPhone</div>
                            <small style="color:var(--gray-500);">@item.ParentEmail</small>
                        </td>
                        <td style="display:flex;gap:6px;">
                            @if (item.Status == ApplicationStatus.Pending)
                            {
                                using (Html.BeginForm("SetUnderReview", "Admin", new { id = item.Id }, FormMethod.Post, new { style = "display:inline;" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-sm btn-rev"><i class="fas fa-eye"></i> Review</button>
                                }
                            }
                            <a href="@Url.Action("ViewApplication", new { id = item.Id })" class="btn-sm btn-det">
                                <i class="fas fa-info-circle"></i> Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var p = new URLSearchParams(window.location.search);
            if (p.get('status')) document.querySelector('[name="status"]').value = p.get('status');
            if (p.get('search')) document.querySelector('[name="search"]').value = p.get('search');
            if (p.get('grade')) document.querySelector('[name="grade"]').value = p.get('grade');
        });
    </script>
}