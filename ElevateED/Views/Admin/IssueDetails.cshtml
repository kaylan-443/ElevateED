@model ElevateED.ViewModels.IssueDetailViewModel
@using ElevateED.Models

@{
    ViewBag.Title = "Issue Details";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --primary: #4f46e5;
        --primary-light: #6366f1;
        --primary-dark: #4338ca;
        --primary-bg: #f5f3ff;
        --primary-soft: #ede9fe;
        --primary-hover: #e0e7ff;
        --accent: #fbbf24;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --sidebar-width: 280px;
        --header-height: 70px;
    }

    body {
        font-family: 'Inter', -apple-system, sans-serif;
        background: var(--gray-50);
        overflow-x: hidden;
    }

    .app-container {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: var(--sidebar-width);
        background: linear-gradient(180deg, #1e1b4b 0%, #2e1065 100%);
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        transition: all 0.3s ease;
        z-index: 100;
        overflow-y: auto;
    }

    .sidebar-header {
        padding: 24px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .logo-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--accent), #f59e0b);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e1b4b;
        font-size: 20px;
    }

    .logo-text {
        font-size: 20px;
        font-weight: 700;
        color: white;
    }

        .logo-text span {
            color: var(--accent);
        }

    .sidebar-nav {
        flex: 1;
        padding: 24px 16px;
    }

    .nav-section {
        margin-top: 24px;
        margin-bottom: 12px;
        padding: 0 16px;
        font-size: 11px;
        font-weight: 600;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        margin-bottom: 8px;
        border-radius: 12px;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .nav-item:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        .nav-item.active {
            background: linear-gradient(135deg, var(--accent), #f59e0b);
            color: #1e1b4b;
        }

        .nav-item i {
            width: 20px;
            font-size: 18px;
        }

        .nav-item span {
            font-size: 14px;
            font-weight: 500;
        }

    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width);
        min-height: 100vh;
    }

    .top-header {
        height: var(--header-height);
        background: white;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: flex-end;
        align-items: center;
        padding: 0 32px;
        position: sticky;
        top: 0;
        z-index: 99;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .notification-btn {
        position: relative;
        background: none;
        border: none;
        font-size: 20px;
        color: var(--gray-500);
        cursor: pointer;
        padding: 8px;
        border-radius: 10px;
        transition: all 0.2s;
    }

        .notification-btn:hover {
            background: var(--gray-100);
        }

    .notification-badge {
        position: absolute;
        top: 2px;
        right: 2px;
        width: 8px;
        height: 8px;
        background: var(--danger);
        border-radius: 50%;
    }

    .profile-container {
        position: relative;
    }

    .profile-trigger {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 50px;
        transition: all 0.2s;
        background: none;
        border: none;
    }

        .profile-trigger:hover {
            background: var(--gray-100);
        }

    .avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 16px;
        text-transform: uppercase;
    }

    .profile-name {
        font-size: 14px;
        font-weight: 500;
        color: var(--gray-700);
    }

    .dropdown-icon {
        font-size: 12px;
        color: var(--gray-400);
    }

    .dropdown-menu {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        width: 240px;
        overflow: hidden;
        display: none;
        z-index: 1000;
    }

        .dropdown-menu.show {
            display: block;
            animation: fadeInDown 0.2s ease;
        }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .dropdown-header {
        padding: 16px;
        border-bottom: 1px solid var(--gray-200);
        background: linear-gradient(135deg, var(--primary-bg), var(--primary-soft));
    }

        .dropdown-header .user-name {
            font-weight: 600;
            color: var(--gray-900);
            margin-bottom: 4px;
        }

        .dropdown-header .user-email {
            font-size: 12px;
            color: var(--gray-500);
        }

    .dropdown-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        text-decoration: none;
        color: var(--gray-700);
        transition: all 0.2s;
        cursor: pointer;
        background: none;
        border: none;
        width: 100%;
        text-align: left;
    }

        .dropdown-item:hover {
            background: var(--primary-hover);
            color: var(--primary);
        }

        .dropdown-item i {
            width: 20px;
            font-size: 16px;
            color: var(--gray-500);
        }

    .dropdown-divider {
        height: 1px;
        background: var(--gray-200);
        margin: 8px 0;
    }

    .dashboard-content {
        padding: 32px;
        max-width: 900px;
        margin: 0 auto;
    }

    .card {
        background: white;
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 20px;
        border: 1px solid var(--gray-200);
    }

        .card.status-pending {
            border-left: 4px solid var(--warning);
        }

        .card.status-underreview {
            border-left: 4px solid var(--info);
        }

        .card.status-resolved {
            border-left: 4px solid var(--success);
        }

        .card.status-closed {
            border-left: 4px solid var(--gray-400);
        }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 16px;
        flex-wrap: wrap;
        gap: 10px;
    }

        .card-header h2 {
            font-size: 22px;
            font-weight: 700;
            color: var(--gray-900);
        }

    .badge {
        padding: 5px 12px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 600;
        display: inline-block;
        margin-right: 6px;
    }

    .badge-warning {
        background: #fef3c7;
        color: #92400e;
    }

    .badge-info {
        background: #dbeafe;
        color: #1e40af;
    }

    .badge-success {
        background: #d1fae5;
        color: #065f46;
    }

    .badge-secondary {
        background: var(--gray-200);
        color: var(--gray-600);
    }

    .badge-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    .badge-dark {
        background: var(--gray-800);
        color: white;
    }

    .meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
        margin-top: 16px;
        padding: 16px;
        background: var(--gray-50);
        border-radius: 10px;
    }

    .meta-item label {
        font-size: 10px;
        color: var(--gray-500);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: block;
    }

    .meta-item span {
        font-weight: 600;
        color: var(--gray-800);
        font-size: 14px;
    }

    .desc-text {
        white-space: pre-wrap;
        line-height: 1.7;
        color: var(--gray-700);
    }

    .btn {
        padding: 10px 22px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

    .btn-review {
        background: var(--info);
        color: white;
    }

    .btn-resolve {
        background: var(--success);
        color: white;
    }

    .btn-back {
        background: white;
        color: var(--gray-700);
        border: 1px solid var(--gray-200);
    }

    textarea, select {
        width: 100%;
        padding: 10px 14px;
        border: 2px solid var(--gray-200);
        border-radius: 10px;
        font-size: 14px;
        margin-top: 6px;
    }

        textarea:focus, select:focus {
            border-color: var(--primary);
            outline: none;
        }

    .alert {
        padding: 12px 16px;
        border-radius: 10px;
        margin-top: 12px;
        display: none;
    }

    .alert-success {
        background: #d1fae5;
        color: #065f46;
    }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    @@media (max-width: 1024px) {
        .sidebar {
            transform: translateX(-100%);
        }

        .main-content {
            margin-left: 0;
        }
    }

    @@media (max-width: 768px) {
        .dashboard-content {
            padding: 20px;
        }
    }
</style>

<div class="app-container">
    <aside class="sidebar">
        <div class="sidebar-header"><div class="logo"><div class="logo-icon"><i class="fas fa-graduation-cap"></i></div><div class="logo-text">Elevate<span>ED</span></div></div></div>
        <nav class="sidebar-nav">
            <div class="nav-section">Main</div>
            <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
            <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
            <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
            <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
            <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
            <div class="nav-section">Management</div>
            <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
            <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
            <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
            <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
            <a href="@Url.Action("Issues","Admin")" class="nav-item active"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
            <div class="nav-section">Extra</div>
            <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
            <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
            <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
            <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
        </nav>
    </aside>
    <main class="main-content">
        <header class="top-header">
            <div class="header-right">
                <button class="notification-btn"><i class="far fa-bell"></i><span class="notification-badge"></span></button>
                <div class="profile-container">
                    <button class="profile-trigger" onclick="toggleDropdown()"><div class="avatar">A</div><span class="profile-name">Admin</span><i class="fas fa-chevron-down dropdown-icon"></i></button>
                    <div class="dropdown-menu" id="profileDropdown">
                        <div class="dropdown-header"><div class="user-name">Administrator</div><div class="user-email">admin@mpiyakhehs.co.za</div></div>
                        <a href="@Url.Action("ManageUsers","Admin")" class="dropdown-item"><i class="fas fa-users"></i><span>Manage Users</span></a>
                        <div class="dropdown-divider"></div>
                        <form action="@Url.Action("LogOff","Account")" method="post" id="logoutForm">
                            @Html.AntiForgeryToken()
                            <button type="button" class="dropdown-item" onclick="confirmLogout(event)" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i><span>Logout</span></button>
                        </form>
                    </div>
                </div>
            </div>
        </header>
        <div class="dashboard-content">
            <div class="card status-@Model.Status.ToString().ToLower()">
                <div class="card-header">
                    <div>
                        <h2><i class="fas fa-exclamation-circle"></i> @Model.Title</h2>
                        <div style="margin-top:8px;">
                            <span class="badge @(Model.Status==IssueStatus.Pending?"badge-warning":Model.Status==IssueStatus.UnderReview?"badge-info":Model.Status==IssueStatus.Resolved?"badge-success":"badge-secondary")">@Model.Status</span>
                            <span class="badge @(Model.Priority==IssuePriority.Critical?"badge-danger":Model.Priority==IssuePriority.High?"badge-warning":Model.Priority==IssuePriority.Medium?"badge-info":"badge-secondary")">@Model.Priority</span>
                            <span class="badge badge-secondary">@Model.Category</span>
                            @if (Model.IsAnonymous)
                            {<span class="badge badge-dark"><i class="fas fa-user-secret"></i> Anonymous</span>}
                        </div>
                    </div>
                    <div style="text-align:right;font-size:13px;color:var(--gray-500);">Issue #@Model.Id<br />@Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")</div>
                </div>
                <div class="meta-grid">
                    <div class="meta-item"><label>Reported By</label><span>@(Model.IsAnonymous?"Anonymous":Model.StudentName)</span></div>
                    @if (!Model.IsAnonymous)
                    {<div class="meta-item"><label>Student #</label><span>@Model.StudentNumber</span></div><div class="meta-item"><label>Grade & Class</label><span>@Model.Grade @Model.ClassName</span></div><div class="meta-item"><label>Email</label><span>@Model.StudentEmail</span></div>}
                    <div class="meta-item"><label>Category</label><span>@Model.Category</span></div>
                </div>
            </div>
            <div class="card"><h4 style="margin-bottom:12px;color:var(--primary);"><i class="fas fa-align-left"></i> Description</h4><p class="desc-text">@Model.Description</p>@if (Model.HasAttachment)
            {<div style="margin-top:12px;"><a href="@Model.AttachmentsPath" target="_blank" class="btn btn-back"><i class="fas fa-download"></i> View Attachment</a></div>}</div>
            @if (Model.Status == IssueStatus.Resolved || Model.Status == IssueStatus.Closed)
            {<div class="card" style="background:#f0fdf4;"><h4 style="color:var(--success);margin-bottom:12px;"><i class="fas fa-check-circle"></i> Resolution</h4><p><strong>Resolved By:</strong> @Model.ResolvedByName</p><p><strong>Resolved At:</strong> @(Model.ResolvedAt?.ToString("dd MMM yyyy, HH:mm")??"-")</p>@if (!string.IsNullOrEmpty(Model.ResolutionNotes))
            {<div style="margin-top:10px;"><strong>Notes:</strong><p style="background:white;padding:12px;border-radius:8px;margin-top:6px;">@Model.ResolutionNotes</p></div>}@if (!string.IsNullOrEmpty(Model.AdminResponse))
            {<div style="margin-top:10px;"><strong>Response:</strong><p style="background:white;padding:12px;border-radius:8px;margin-top:6px;">@Model.AdminResponse</p></div>}</div>}
        else
        {<div class="card"><h4 style="color:var(--primary);margin-bottom:16px;"><i class="fas fa-cogs"></i> Admin Actions</h4>@if (Model.Status == IssueStatus.Pending)
            {<button class="btn btn-review" onclick="setUnderReview(@Model.Id)"><i class="fas fa-clock"></i> Mark as Under Review</button>}<form id="resolveForm" style="margin-top:16px;">@Html.AntiForgeryToken()<input type="hidden" name="Id" value="@Model.Id" /><div style="margin-bottom:12px;"><label style="font-weight:600;">Resolution Notes *</label><textarea name="ResolutionNotes" rows="3" required placeholder="Describe action taken..."></textarea></div><div style="margin-bottom:12px;"><label style="font-weight:600;">Response to Student</label><textarea name="AdminResponse" rows="3" placeholder="Message visible to student..."></textarea></div><div style="margin-bottom:12px;"><label style="font-weight:600;">Mark as</label><select name="NewStatus" style="max-width:200px;"><option value="Resolved">Resolved</option><option value="Closed">Closed</option></select></div><div id="message" class="alert"></div><div style="display:flex;gap:10px;"><button type="button" class="btn btn-resolve" onclick="resolveIssue()"><i class="fas fa-check"></i> Submit Resolution</button><a href="@Url.Action("Issues","Admin")" class="btn btn-back"><i class="fas fa-arrow-left"></i> Back</a></div></form></div>}
        </div>
    </main>
</div>
<script>
    function toggleDropdown(){document.getElementById('profileDropdown').classList.toggle('show');}
    document.addEventListener('click',function(e){var c=document.querySelector('.profile-container');var d=document.getElementById('profileDropdown');if(c&&!c.contains(e.target))d.classList.remove('show');});
    function confirmLogout(e){e.preventDefault();if(confirm('Are you sure you want to logout?')){document.getElementById('logoutForm').submit();}}
    function setUnderReview(id){if(!confirm('Mark as under review?'))return;fetch('@Url.Action("SetIssueUnderReview","Admin")',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'id='+id}).then(r=>r.json()).then(r=>{alert(r.message);location.reload();});}
    function resolveIssue(){var f=document.getElementById('resolveForm');var n=f.querySelector('[name="ResolutionNotes"]').value;if(!n){alert('Enter resolution notes');return;}document.getElementById('message').style.display='none';fetch('@Url.Action("ResolveIssue","Admin")',{method:'POST',body:new FormData(f)}).then(r=>r.json()).then(r=>{var m=document.getElementById('message');if(r.success){m.className='alert alert-success';m.innerHTML='<i class="fas fa-check-circle"></i> '+r.message;m.style.display='block';setTimeout(function(){location.href='@Url.Action("Issues","Admin")';},2000);}else{m.className='alert alert-danger';m.innerHTML='<i class="fas fa-exclamation-circle"></i> '+r.message;m.style.display='block';}});}
</script>