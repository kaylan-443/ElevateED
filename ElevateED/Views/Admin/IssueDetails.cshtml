@model ElevateED.ViewModels.IssueDetailViewModel
@using ElevateED.Models

@{
    ViewBag.Title = "Issue Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section SidebarNav {
    <div class="nav-section">Main</div>
    <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
    <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
    <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
    <div class="nav-section">Management</div>
    <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
    <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
    <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
    <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
    <a href="@Url.Action("Issues","Admin")" class="nav-item active"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
    <div class="nav-section">Extra</div>
    <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
    <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
    <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
    <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
}

@section Styles {
    <style>
        .dashboard-content {
            max-width: 900px;
            margin: 0 auto;
        }

        .card {
            background: white;
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 20px;
            border: 1px solid var(--gray-200);
        }

            .card.status-pending {
                border-left: 4px solid var(--warning);
            }

            .card.status-underreview {
                border-left: 4px solid var(--info);
            }

            .card.status-resolved {
                border-left: 4px solid var(--success);
            }

            .card.status-closed {
                border-left: 4px solid var(--gray-400);
            }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 16px;
            flex-wrap: wrap;
            gap: 10px;
        }

            .card-header h2 {
                font-size: 22px;
                font-weight: 700;
                color: var(--gray-900);
            }

        .badge {
            padding: 5px 12px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
            display: inline-block;
            margin-right: 6px;
        }

        .badge-warning {
            background: #fef3c7;
            color: #92400e;
        }

        .badge-info {
            background: #dbeafe;
            color: #1e40af;
        }

        .badge-success {
            background: #d1fae5;
            color: #065f46;
        }

        .badge-secondary {
            background: var(--gray-200);
            color: var(--gray-600);
        }

        .badge-danger {
            background: #fee2e2;
            color: #991b1b;
        }

        .badge-dark {
            background: var(--gray-800);
            color: white;
        }

        .meta-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 12px;
            margin-top: 16px;
            padding: 16px;
            background: var(--gray-50);
            border-radius: 10px;
        }

        .meta-item label {
            font-size: 10px;
            color: var(--gray-500);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: block;
        }

        .meta-item span {
            font-weight: 600;
            color: var(--gray-800);
            font-size: 14px;
        }

        .desc-text {
            white-space: pre-wrap;
            line-height: 1.7;
            color: var(--gray-700);
        }

        .btn {
            padding: 10px 22px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .btn-review {
            background: var(--info);
            color: white;
        }

        .btn-resolve {
            background: var(--success);
            color: white;
        }

        .btn-back {
            background: white;
            color: var(--gray-700);
            border: 1px solid var(--gray-200);
        }

        textarea, select {
            width: 100%;
            padding: 10px 14px;
            border: 2px solid var(--gray-200);
            border-radius: 10px;
            font-size: 14px;
            margin-top: 6px;
        }

            textarea:focus, select:focus {
                border-color: var(--primary);
                outline: none;
            }

        .alert {
            padding: 12px 16px;
            border-radius: 10px;
            margin-top: 12px;
            display: none;
        }

        .alert-success {
            background: #d1fae5;
            color: #065f46;
        }

        .alert-danger {
            background: #fee2e2;
            color: #991b1b;
        }
    </style>
}

<div class="card status-@Model.Status.ToString().ToLower()">
    <div class="card-header">
        <div>
            <h2><i class="fas fa-exclamation-circle"></i> @Model.Title</h2>
            <div style="margin-top:8px;">
                <span class="badge @(Model.Status==IssueStatus.Pending?"badge-warning":Model.Status==IssueStatus.UnderReview?"badge-info":Model.Status==IssueStatus.Resolved?"badge-success":"badge-secondary")">@Model.Status</span>
                <span class="badge @(Model.Priority==IssuePriority.Critical?"badge-danger":Model.Priority==IssuePriority.High?"badge-warning":Model.Priority==IssuePriority.Medium?"badge-info":"badge-secondary")">@Model.Priority</span>
                <span class="badge badge-secondary">@Model.Category</span>
                @if (Model.IsAnonymous)
                {
                    <span class="badge badge-dark"><i class="fas fa-user-secret"></i> Anonymous</span>
                }
            </div>
        </div>
        <div style="text-align:right;font-size:13px;color:var(--gray-500);">
            Issue #@Model.Id<br />
            @Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")
        </div>
    </div>
    <div class="meta-grid">
        <div class="meta-item"><label>Reported By</label><span>@(Model.IsAnonymous?"Anonymous":Model.StudentName)</span></div>
        @if (!Model.IsAnonymous)
        {
            <div class="meta-item"><label>Student #</label><span>@Model.StudentNumber</span></div>
            <div class="meta-item"><label>Grade & Class</label><span>@Model.Grade @Model.ClassName</span></div>
            <div class="meta-item"><label>Email</label><span>@Model.StudentEmail</span></div>
        }
        <div class="meta-item"><label>Category</label><span>@Model.Category</span></div>
    </div>
</div>

<div class="card">
    <h4 style="margin-bottom:12px;color:var(--primary);">
        <i class="fas fa-align-left"></i> Description
    </h4>
    <p class="desc-text">@Model.Description</p>
    @if (Model.HasAttachment)
    {
        <div style="margin-top:12px;">
            <a href="@Model.AttachmentsPath" target="_blank" class="btn btn-back">
                <i class="fas fa-download"></i> View Attachment
            </a>
        </div>
    }
</div>

@if (Model.Status == IssueStatus.Resolved || Model.Status == IssueStatus.Closed)
{
    <div class="card" style="background:#f0fdf4;">
        <h4 style="color:var(--success);margin-bottom:12px;">
            <i class="fas fa-check-circle"></i> Resolution
        </h4>
        <p><strong>Resolved By:</strong> @Model.ResolvedByName</p>
        <p><strong>Resolved At:</strong> @(Model.ResolvedAt?.ToString("dd MMM yyyy, HH:mm") ?? "-")</p>
        @if (!string.IsNullOrEmpty(Model.ResolutionNotes))
        {
            <div style="margin-top:10px;">
                <strong>Notes:</strong>
                <p style="background:white;padding:12px;border-radius:8px;margin-top:6px;">@Model.ResolutionNotes</p>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.AdminResponse))
        {
            <div style="margin-top:10px;">
                <strong>Response:</strong>
                <p style="background:white;padding:12px;border-radius:8px;margin-top:6px;">@Model.AdminResponse</p>
            </div>
        }
    </div>
}
else
{
    <div class="card">
        <h4 style="color:var(--primary);margin-bottom:16px;">
            <i class="fas fa-cogs"></i> Admin Actions
        </h4>
        @if (Model.Status == IssueStatus.Pending)
        {
            <button class="btn btn-review" onclick="setUnderReview(@Model.Id)">
                <i class="fas fa-clock"></i> Mark as Under Review
            </button>
        }
        <form id="resolveForm" style="margin-top:16px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.Id" />
            <div style="margin-bottom:12px;">
                <label style="font-weight:600;">Resolution Notes *</label>
                <textarea name="ResolutionNotes" rows="3" required placeholder="Describe action taken..."></textarea>
            </div>
            <div style="margin-bottom:12px;">
                <label style="font-weight:600;">Response to Student</label>
                <textarea name="AdminResponse" rows="3" placeholder="Message visible to student..."></textarea>
            </div>
            <div style="margin-bottom:12px;">
                <label style="font-weight:600;">Mark as</label>
                <select name="NewStatus" style="max-width:200px;">
                    <option value="Resolved">Resolved</option>
                    <option value="Closed">Closed</option>
                </select>
            </div>
            <div id="message" class="alert"></div>
            <div style="display:flex;gap:10px;">
                <button type="button" class="btn btn-resolve" onclick="resolveIssue()">
                    <i class="fas fa-check"></i> Submit Resolution
                </button>
                <a href="@Url.Action("Issues","Admin")" class="btn btn-back">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </div>
        </form>
    </div>
}

@section Scripts {
    <script>
        function setUnderReview(id) {
            if (!confirm('Mark as under review?')) return;
            fetch('@Url.Action("SetIssueUnderReview","Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + id
            }).then(r => r.json()).then(r => {
                alert(r.message);
                location.reload();
            });
        }

        function resolveIssue() {
            var f = document.getElementById('resolveForm');
            var n = f.querySelector('[name="ResolutionNotes"]').value;
            if (!n) { alert('Enter resolution notes'); return; }
            document.getElementById('message').style.display = 'none';
            fetch('@Url.Action("ResolveIssue","Admin")', {
                method: 'POST',
                body: new FormData(f)
            }).then(r => r.json()).then(r => {
                var m = document.getElementById('message');
                if (r.success) {
                    m.className = 'alert alert-success';
                    m.innerHTML = '<i class="fas fa-check-circle"></i> ' + r.message;
                    m.style.display = 'block';
                    setTimeout(function() {
                        location.href = '@Url.Action("Issues","Admin")';
                    }, 2000);
                } else {
                    m.className = 'alert alert-danger';
                    m.innerHTML = '<i class="fas fa-exclamation-circle"></i> ' + r.message;
                    m.style.display = 'block';
                }
            });
        }
    </script>
}