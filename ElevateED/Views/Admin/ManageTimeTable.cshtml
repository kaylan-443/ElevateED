@model List<ElevateED.ViewModels.TimeTableViewModel>

@{
    ViewBag.Title = ViewBag.TypeName + " - Admin";
    var type = ViewBag.Type as string;
    var showGradeSelection = ViewBag.ShowGradeSelection as bool?;
    var showClassSelection = ViewBag.ShowClassSelection as bool?;
    var showTimetables = ViewBag.ShowTimetables as bool?;
    var showTeacherTimetable = ViewBag.ShowTeacherTimetable as bool?;
    var grades = ViewBag.Grades as List<string> ?? new List<string>();
    var classes = ViewBag.Classes as List<string> ?? new List<string>();
    var selectedGrade = ViewBag.Grade as string ?? "";
    var selectedClass = ViewBag.ClassName as string ?? "";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --primary: #4f46e5;
        --primary-light: #6366f1;
        --primary-dark: #4338ca;
        --primary-bg: #f5f3ff;
        --primary-soft: #ede9fe;
        --primary-hover: #e0e7ff;
        --accent: #fbbf24;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --sidebar-width: 280px;
        --header-height: 70px;
    }

    body {
        font-family: 'Inter', -apple-system, sans-serif;
        background: var(--gray-50);
        overflow-x: hidden;
    }

    .app-container {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: var(--sidebar-width);
        background: linear-gradient(180deg, #1e1b4b 0%, #2e1065 100%);
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        transition: all 0.3s ease;
        z-index: 100;
        overflow-y: auto;
    }

    .sidebar-header {
        padding: 24px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .logo-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--accent), #f59e0b);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e1b4b;
        font-size: 20px;
    }

    .logo-text {
        font-size: 20px;
        font-weight: 700;
        color: white;
    }

        .logo-text span {
            color: var(--accent);
        }

    .sidebar-nav {
        flex: 1;
        padding: 24px 16px;
    }

    .nav-section {
        margin-top: 24px;
        margin-bottom: 12px;
        padding: 0 16px;
        font-size: 11px;
        font-weight: 600;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        margin-bottom: 8px;
        border-radius: 12px;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .nav-item:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        .nav-item.active {
            background: linear-gradient(135deg, var(--accent), #f59e0b);
            color: #1e1b4b;
        }

        .nav-item i {
            width: 20px;
            font-size: 18px;
        }

        .nav-item span {
            font-size: 14px;
            font-weight: 500;
        }

    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width);
        min-height: 100vh;
    }

    .top-header {
        height: var(--header-height);
        background: white;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: flex-end;
        align-items: center;
        padding: 0 32px;
        position: sticky;
        top: 0;
        z-index: 99;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .notification-btn {
        position: relative;
        background: none;
        border: none;
        font-size: 20px;
        color: var(--gray-500);
        cursor: pointer;
        padding: 8px;
        border-radius: 10px;
        transition: all 0.2s;
    }

        .notification-btn:hover {
            background: var(--gray-100);
        }

    .notification-badge {
        position: absolute;
        top: 2px;
        right: 2px;
        width: 8px;
        height: 8px;
        background: var(--danger);
        border-radius: 50%;
    }

    .profile-container {
        position: relative;
    }

    .profile-trigger {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 50px;
        transition: all 0.2s;
        background: none;
        border: none;
    }

        .profile-trigger:hover {
            background: var(--gray-100);
        }

    .avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 16px;
        text-transform: uppercase;
    }

    .profile-name {
        font-size: 14px;
        font-weight: 500;
        color: var(--gray-700);
    }

    .dropdown-icon {
        font-size: 12px;
        color: var(--gray-400);
    }

    .dropdown-menu {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        width: 240px;
        overflow: hidden;
        display: none;
        z-index: 1000;
    }

        .dropdown-menu.show {
            display: block;
            animation: fadeInDown 0.2s ease;
        }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .dropdown-header {
        padding: 16px;
        border-bottom: 1px solid var(--gray-200);
        background: linear-gradient(135deg, var(--primary-bg), var(--primary-soft));
    }

        .dropdown-header .user-name {
            font-weight: 600;
            color: var(--gray-900);
            margin-bottom: 4px;
        }

        .dropdown-header .user-email {
            font-size: 12px;
            color: var(--gray-500);
        }

    .dropdown-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        text-decoration: none;
        color: var(--gray-700);
        transition: all 0.2s;
        cursor: pointer;
        background: none;
        border: none;
        width: 100%;
        text-align: left;
    }

        .dropdown-item:hover {
            background: var(--primary-hover);
            color: var(--primary);
        }

        .dropdown-item i {
            width: 20px;
            font-size: 16px;
            color: var(--gray-500);
        }

    .dropdown-divider {
        height: 1px;
        background: var(--gray-200);
        margin: 8px 0;
    }

    .dashboard-content {
        padding: 32px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 15px;
    }

        .page-header h1 {
            font-size: 26px;
            font-weight: 700;
            color: var(--gray-900);
        }

    .btn-back {
        background: white;
        color: var(--gray-700);
        padding: 10px 20px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 500;
        border: 1px solid var(--gray-200);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-back:hover {
            background: var(--gray-100);
            text-decoration: none;
        }

    .btn-upload {
        background: var(--success);
        color: white;
        padding: 10px 20px;
        border-radius: 12px;
        border: none;
        font-weight: 500;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .breadcrumb {
        padding: 10px 16px;
        background: white;
        border-radius: 10px;
        margin-bottom: 20px;
        font-size: 13px;
        color: var(--gray-500);
    }

        .breadcrumb a {
            color: var(--primary);
            text-decoration: none;
        }

            .breadcrumb a:hover {
                text-decoration: underline;
            }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
    }

    .card {
        background: white;
        border-radius: 16px;
        padding: 24px;
        text-align: center;
        border: 1px solid var(--gray-200);
        cursor: pointer;
        transition: all 0.3s;
    }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.08);
            border-color: var(--primary);
        }

    .card-icon {
        width: 55px;
        height: 55px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 12px;
        font-size: 24px;
        color: white;
    }

        .card-icon.blue {
            background: var(--primary);
        }

        .card-icon.green {
            background: var(--success);
        }

    .card h4 {
        font-size: 16px;
        font-weight: 600;
        color: var(--gray-800);
        margin-bottom: 4px;
    }

    .card p {
        font-size: 12px;
        color: var(--gray-500);
    }

    .tt-card {
        background: white;
        border-radius: 16px;
        border: 1px solid var(--gray-200);
        overflow: hidden;
        margin-bottom: 16px;
    }

    .tt-preview {
        padding: 24px;
        text-align: center;
        background: var(--gray-50);
    }

        .tt-preview i {
            font-size: 40px;
        }

    .tt-info {
        padding: 16px 20px;
    }

        .tt-info h4 {
            font-size: 16px;
            font-weight: 600;
            color: var(--gray-800);
            margin-bottom: 4px;
        }

        .tt-info p {
            font-size: 12px;
            color: var(--gray-500);
        }

    .btn-sm {
        padding: 6px 14px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        text-decoration: none;
    }

    .btn-view {
        background: var(--info);
        color: white;
    }

    .btn-dl {
        background: var(--success);
        color: white;
    }

    .btn-del {
        background: var(--danger);
        color: white;
    }

    .empty-state {
        text-align: center;
        padding: 60px;
        background: white;
        border-radius: 16px;
        border: 1px solid var(--gray-200);
        color: var(--gray-500);
    }

    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 1050;
        align-items: center;
        justify-content: center;
    }

        .modal-overlay.show {
            display: flex;
        }

    .modal-box {
        background: white;
        border-radius: 16px;
        width: 90%;
        max-width: 480px;
    }

    .modal-header {
        padding: 16px 20px;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--primary);
        color: white;
        border-radius: 16px 16px 0 0;
    }

    .modal-body {
        padding: 20px;
    }

        .modal-body input, .modal-body textarea {
            width: 100%;
            padding: 9px 12px;
            border: 2px solid var(--gray-200);
            border-radius: 10px;
            font-size: 13px;
            margin-bottom: 12px;
        }

        .modal-body label {
            font-weight: 600;
            font-size: 12px;
            color: var(--gray-700);
            display: block;
            margin-bottom: 4px;
        }

    @@media (max-width: 1024px) {
        .sidebar {
            transform: translateX(-100%);
        }

        .main-content {
            margin-left: 0;
        }
    }
</style>

<div class="app-container">
    <aside class="sidebar">
        <div class="sidebar-header"><div class="logo"><div class="logo-icon"><i class="fas fa-graduation-cap"></i></div><div class="logo-text">Elevate<span>ED</span></div></div></div>
        <nav class="sidebar-nav">
            <div class="nav-section">Main</div>
            <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
            <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
            <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
            <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
            <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
            <div class="nav-section">Management</div>
            <a href="@Url.Action("TimeTable","Admin")" class="nav-item active"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
            <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
            <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
            <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
            <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
            <div class="nav-section">Extra</div>
            <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
            <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
            <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
            <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
        </nav>
    </aside>
    <main class="main-content">
        <header class="top-header">
            <div class="header-right">
                <button class="notification-btn"><i class="far fa-bell"></i><span class="notification-badge"></span></button>
                <div class="profile-container">
                    <button class="profile-trigger" onclick="toggleDropdown()"><div class="avatar">A</div><span class="profile-name">Admin</span><i class="fas fa-chevron-down dropdown-icon"></i></button>
                    <div class="dropdown-menu" id="profileDropdown">
                        <div class="dropdown-header"><div class="user-name">Administrator</div><div class="user-email">admin@mpiyakhehs.co.za</div></div>
                        <a href="@Url.Action("ManageUsers","Admin")" class="dropdown-item"><i class="fas fa-users"></i><span>Manage Users</span></a>
                        <div class="dropdown-divider"></div>
                        <form action="@Url.Action("LogOff","Account")" method="post" id="logoutForm">
                            @Html.AntiForgeryToken()
                            <button type="button" class="dropdown-item" onclick="confirmLogout(event)" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i><span>Logout</span></button>
                        </form>
                    </div>
                </div>
            </div>
        </header>
        <div class="dashboard-content">
            <div class="page-header"><div><h1><i class="fas fa-calendar-alt" style="color:var(--info);"></i> @ViewBag.TypeName</h1><p style="color:var(--gray-500);">Upload and manage timetables</p></div><a href="@Url.Action("TimeTable","Admin")" class="btn-back"><i class="fas fa-arrow-left"></i> Back</a></div>
            @if (showTeacherTimetable == true)
            {
                <div style="text-align:right;margin-bottom:20px;"><button class="btn-upload" onclick="openUploadModal('','')"><i class="fas fa-upload"></i> Upload Teacher Timetable</button></div>
                if (!Model.Any())
                {<div class="empty-state"><i class="fas fa-calendar-times" style="font-size:40px;display:block;margin-bottom:10px;"></i><p>No teachers timetable uploaded yet.</p></div>}
                else
                {<div class="grid">@foreach (var t in Model)
                    {<div class="tt-card"><div class="tt-preview">@if (t.FilePath.EndsWith(".pdf"))
                        {<i class="fas fa-file-pdf" style="color:var(--danger);"></i>}
                        else if (t.FilePath.EndsWith(".jpg") || t.FilePath.EndsWith(".png"))
                        {<img src="@t.FilePath" style="max-width:100%;height:100px;object-fit:cover;border-radius:8px;" />}
                        else
                        {<i class="fas fa-file-alt" style="color:var(--info);"></i>}</div><div class="tt-info"><h4>@t.Title</h4><p>Uploaded: @t.UploadedAt.ToString("dd MMM yyyy")</p><div style="display:flex;gap:6px;margin-top:8px;"><a href="@t.FilePath" target="_blank" class="btn-sm btn-view"><i class="fas fa-eye"></i> View</a><a href="@t.FilePath" download class="btn-sm btn-dl"><i class="fas fa-download"></i></a><button class="btn-sm btn-del" onclick="deleteTT(@t.Id)"><i class="fas fa-trash"></i></button></div></div></div>}}</div>}
        }
        else if (showGradeSelection == true)
        {<div class="grid">@foreach (var g in grades)
            {<div class="card" onclick="location.href='@Url.Action("ManageTimeTable","Admin",new{type=type,grade=g})'"><div class="card-icon blue"><i class="fas fa-graduation-cap"></i></div><h4>@g</h4><p>View timetables</p></div>}</div>}
    else if (showClassSelection == true)
    {<div class="breadcrumb"><a href="@Url.Action("ManageTimeTable","Admin",new{type=type})">Grades</a> &gt; @selectedGrade</div><div class="grid">@foreach (var c in classes)
    {<div class="card" onclick="location.href='@Url.Action("ManageTimeTable","Admin",new{type=type,grade=selectedGrade,className=c})'"><div class="card-icon green"><i class="fas fa-chalkboard"></i></div><h4>@c</h4><p>View timetables</p></div>}</div>}
else if (showTimetables == true)
{<div class="breadcrumb"><a href="@Url.Action("ManageTimeTable","Admin",new{type=type})">Grades</a> &gt; <a href="@Url.Action("ManageTimeTable","Admin",new{type=type,grade=selectedGrade})">@selectedGrade</a> &gt; @selectedClass</div><div style="text-align:right;margin-bottom:20px;"><button class="btn-upload" onclick="openUploadModal('@selectedGrade','@selectedClass')"><i class="fas fa-upload"></i> Upload for @selectedClass</button></div>if (!Model.Any())
{<div class="empty-state"><i class="fas fa-calendar-times" style="font-size:40px;display:block;margin-bottom:10px;"></i><p>No timetables for @selectedClass yet.</p></div>}
else
{<div class="grid">@foreach (var t in Model)
{<div class="tt-card"><div class="tt-preview">@if (t.FilePath.EndsWith(".pdf"))
    {<i class="fas fa-file-pdf" style="color:var(--danger);"></i>}
    else if (t.FilePath.EndsWith(".jpg") || t.FilePath.EndsWith(".png"))
    {<img src="@t.FilePath" style="max-width:100%;height:100px;object-fit:cover;border-radius:8px;" />}
    else
    {<i class="fas fa-file-alt" style="color:var(--info);"></i>}</div><div class="tt-info"><h4>@t.Title</h4><p>@t.UploadedAt.ToString("dd MMM yyyy")</p><div style="display:flex;gap:6px;margin-top:8px;"><a href="@t.FilePath" target="_blank" class="btn-sm btn-view"><i class="fas fa-eye"></i></a><a href="@t.FilePath" download class="btn-sm btn-dl"><i class="fas fa-download"></i></a><button class="btn-sm btn-del" onclick="deleteTT(@t.Id)"><i class="fas fa-trash"></i></button></div></div></div>}}</div>}}
        </div>
    </main>
</div>
<div class="modal-overlay" id="uploadModal"><div class="modal-box"><div class="modal-header"><h4><i class="fas fa-upload"></i> Upload Timetable</h4><button onclick="closeUploadModal()" style="background:none;border:none;color:white;font-size:22px;cursor:pointer;">&times;</button></div><div class="modal-body"><form id="uploadForm" enctype="multipart/form-data">@Html.AntiForgeryToken()<input type="hidden" name="Type" value="@type" /><input type="hidden" name="Grade" id="modalGrade" /><input type="hidden" name="ClassName" id="modalClassName" /><label>Title <span style="color:var(--danger);">*</span></label><input type="text" name="Title" required placeholder="e.g., 2026 Term 1" /><label>Description</label><textarea name="Description" rows="2" placeholder="Optional"></textarea><label>File <span style="color:var(--danger);">*</span></label><input type="file" name="TimetableFile" accept=".pdf,.jpg,.jpeg,.png" required /><small style="color:var(--gray-500);">PDF, JPG, PNG - max 10MB</small><div id="uploadMessage" style="display:none;padding:10px;border-radius:8px;margin-top:10px;"></div></form></div><div style="padding:16px 20px;border-top:1px solid var(--gray-200);display:flex;justify-content:flex-end;gap:10px;"><button onclick="closeUploadModal()" style="padding:8px 20px;border-radius:10px;border:1px solid var(--gray-200);background:white;cursor:pointer;">Cancel</button><button onclick="submitUpload()" style="padding:8px 20px;border-radius:10px;background:var(--success);color:white;border:none;cursor:pointer;"><i class="fas fa-upload"></i> Upload</button></div></div></div>
<script>
    function toggleDropdown(){document.getElementById('profileDropdown').classList.toggle('show');}
    document.addEventListener('click',function(e){var c=document.querySelector('.profile-container');var d=document.getElementById('profileDropdown');if(c&&!c.contains(e.target))d.classList.remove('show');});
    function confirmLogout(e){e.preventDefault();if(confirm('Are you sure you want to logout?')){document.getElementById('logoutForm').submit();}}
    function openUploadModal(g,c){document.getElementById('modalGrade').value=g||'';document.getElementById('modalClassName').value=c||'';document.getElementById('uploadModal').classList.add('show');document.getElementById('uploadForm').reset();var m=document.getElementById('uploadMessage');if(m)m.style.display='none';}
    function closeUploadModal(){document.getElementById('uploadModal').classList.remove('show');}
    document.getElementById('uploadModal').addEventListener('click',function(e){if(e.target===this)closeUploadModal();});
    function submitUpload(){var f=document.getElementById('uploadForm');var t=f.querySelector('[name="Title"]').value;var fl=f.querySelector('[name="TimetableFile"]').files[0];if(!t||!fl){alert('Fill all required fields');return;}if(fl.size>10485760){alert('File too large');return;}var fd=new FormData(f);var m=document.getElementById('uploadMessage');m.style.display='block';m.style.background='#dbeafe';m.style.color='#1e40af';m.innerHTML='<i class="fas fa-spinner fa-spin"></i> Uploading...';fetch('@Url.Action("UploadTimeTable","Admin")',{method:'POST',body:fd}).then(r=>r.json()).then(r=>{if(r.success){m.style.background='#d1fae5';m.style.color='#065f46';m.innerHTML='<i class="fas fa-check-circle"></i> '+r.message;setTimeout(function(){closeUploadModal();location.reload();},1500);}else{m.style.background='#fee2e2';m.style.color='#991b1b';m.innerHTML='<i class="fas fa-exclamation-circle"></i> '+r.message;}});}
    function deleteTT(id){if(confirm('Delete this timetable?')){var t=document.querySelector('input[name="__RequestVerificationToken"]').value;fetch('@Url.Action("DeleteTimeTable","Admin")',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'__RequestVerificationToken='+t+'&id='+id}).then(r=>r.json()).then(r=>{alert(r.message);location.reload();});}}
</script>