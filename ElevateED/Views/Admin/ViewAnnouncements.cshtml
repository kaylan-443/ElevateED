@model List<ElevateED.ViewModels.AnnouncementListViewModel>

@{
    ViewBag.Title = "View Announcements - Admin";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section SidebarNav {
    <div class="nav-section">Main</div>
    <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
    <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
    <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
    <div class="nav-section">Management</div>
    <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
    <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
    <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
    <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item active"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
    <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
    <div class="nav-section">Extra</div>
    <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
    <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
    <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
    <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
}

@section Styles {
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 15px;
        }

            .page-header h1 {
                font-size: 26px;
                font-weight: 700;
                color: var(--gray-900);
            }

        .btn-primary {
            background: var(--success);
            color: white;
            padding: 10px 20px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-primary:hover {
                background: #059669;
                color: white;
                text-decoration: none;
            }

        .btn-back {
            background: white;
            color: var(--gray-700);
            padding: 10px 20px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 500;
            border: 1px solid var(--gray-200);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-back:hover {
                background: var(--gray-100);
                text-decoration: none;
            }

        .ann-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 16px;
            border: 1px solid var(--gray-200);
            border-left: 4px solid var(--primary);
            transition: all 0.3s;
        }

            .ann-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(0,0,0,0.06);
            }

        .ann-title {
            font-size: 17px;
            font-weight: 600;
            color: var(--gray-900);
            margin-bottom: 8px;
        }

        .ann-content {
            color: var(--gray-600);
            font-size: 14px;
            margin-bottom: 12px;
            line-height: 1.5;
        }

        .ann-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            font-size: 12px;
            color: var(--gray-500);
            margin-bottom: 12px;
        }

        .badge {
            padding: 4px 10px;
            border-radius: 10px;
            font-size: 10px;
            font-weight: 600;
            display: inline-block;
        }

        .badge-warning {
            background: #fef3c7;
            color: #92400e;
        }

        .badge-danger {
            background: #fee2e2;
            color: #991b1b;
        }

        .badge-info {
            background: #dbeafe;
            color: #1e40af;
        }

        .badge-secondary {
            background: var(--gray-200);
            color: var(--gray-600);
        }

        .badge-primary {
            background: #e0e7ff;
            color: #3730a3;
        }

        .badge-success {
            background: #d1fae5;
            color: #065f46;
        }

        .btn-del {
            background: var(--danger);
            color: white;
            padding: 6px 14px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-size: 12px;
        }

            .btn-del:hover {
                background: #dc2626;
            }

        .empty-state {
            text-align: center;
            padding: 60px;
            background: white;
            border-radius: 16px;
            border: 1px solid var(--gray-200);
        }

            .empty-state i {
                font-size: 48px;
                color: var(--gray-400);
                margin-bottom: 15px;
            }
    </style>
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-bullhorn" style="color:var(--accent);"></i> Announcements</h1>
        <p style="color:var(--gray-500);">View and manage all announcements</p>
    </div>
    <div style="display:flex;gap:10px;">
        <a href="@Url.Action("SendAnnouncement","Admin")" class="btn-primary">
            <i class="fas fa-plus"></i> New
        </a>
        <a href="@Url.Action("Dashboard","Admin")" class="btn-back">
            <i class="fas fa-arrow-left"></i> Back
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-bullhorn"></i>
        <h4>No Announcements</h4>
        <p style="color:var(--gray-500);">Create your first announcement.</p>
        <a href="@Url.Action("SendAnnouncement","Admin")" class="btn-primary mt-3" style="display:inline-flex;">Create First</a>
    </div>
}
else
{
    foreach (var item in Model)
    {
        <div class="ann-card">
            <div class="ann-title">
                @item.Title
                <span class="badge @item.TypeBadgeClass" style="margin-left:8px;">@item.AnnouncementType</span>
                <span class="badge @item.AudienceBadgeClass" style="margin-left:4px;">@item.TargetAudience</span>
                @if (!item.IsActive)
                {
                    <span class="badge badge-secondary" style="margin-left:4px;">Inactive</span>
                }
            </div>
            <div class="ann-content">@item.Content</div>
            <div class="ann-meta">
                <span><i class="fas fa-calendar"></i> @item.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</span>
                <span><i class="fas fa-users"></i> @item.TargetAudience</span>
                @if (item.TargetGrade != "All Grades" && !string.IsNullOrEmpty(item.TargetGrade))
                {
                    <span><i class="fas fa-graduation-cap"></i> @item.TargetGrade</span>
                }
                @if (item.TargetClass != "All Classes" && !string.IsNullOrEmpty(item.TargetClass))
                {
                    <span><i class="fas fa-users"></i> @item.TargetClass</span>
                }
                @if (item.ExpiryDate.HasValue)
                {
                    <span><i class="fas fa-hourglass-end"></i> Expires: @item.ExpiryDate.Value.ToString("dd MMM yyyy")</span>
                }
            </div>
            <button class="btn-del" onclick="delAnn(@item.Id)">
                <i class="fas fa-trash"></i> Delete
            </button>
        </div>
    }
}

@section Scripts {
    <script>
        function delAnn(id) {
            if (!confirm('Delete this announcement?')) return;
            var t = document.querySelector('input[name="__RequestVerificationToken"]').value;
            fetch('@Url.Action("DeleteAnnouncement","Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: '__RequestVerificationToken=' + t + '&id=' + id
            }).then(r => r.json()).then(r => {
                if (r.success) location.reload();
                else alert(r.message);
            });
        }
    </script>
}