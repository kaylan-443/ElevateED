@model ElevateED.ViewModels.ManageUsersViewModel

@{
    ViewBag.Title = "Manage Users - Admin";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section SidebarNav {
    <div class="nav-section">Main</div>
    <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
    <a href="@Url.Action("ManageUsers","Admin")" class="nav-item active"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
    <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
    <div class="nav-section">Management</div>
    <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
    <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
    <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
    <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
    <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
    <div class="nav-section">Extra</div>
    <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
    <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
    <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
    <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
}

@section Styles {
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 15px;
        }

            .page-header h1 {
                font-size: 26px;
                font-weight: 700;
                color: var(--gray-900);
            }

        .btn-back {
            background: white;
            color: var(--gray-700);
            padding: 10px 20px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 500;
            border: 1px solid var(--gray-200);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-back:hover {
                background: var(--gray-100);
                text-decoration: none;
            }

        .panel {
            background: white;
            border-radius: 16px;
            border: 1px solid var(--gray-200);
            margin-bottom: 24px;
            overflow: hidden;
        }

        .panel-header {
            padding: 16px 20px;
            background: var(--gray-800);
            color: white;
            font-size: 16px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .search-bar {
            padding: 14px 20px;
            border-bottom: 1px solid var(--gray-200);
            display: flex;
            gap: 10px;
        }

            .search-bar input {
                flex: 1;
                padding: 9px 14px;
                border: 2px solid var(--gray-200);
                border-radius: 10px;
                font-size: 13px;
            }

            .search-bar button {
                padding: 9px 16px;
                border-radius: 10px;
                border: 1px solid var(--gray-200);
                background: white;
                cursor: pointer;
                font-size: 13px;
            }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th {
            text-align: left;
            padding: 11px 16px;
            background: var(--gray-50);
            font-weight: 600;
            color: var(--gray-700);
            border-bottom: 2px solid var(--gray-200);
        }

        td {
            padding: 11px 16px;
            border-bottom: 1px solid var(--gray-100);
            vertical-align: middle;
        }

        tr:hover td {
            background: var(--gray-50);
        }

        .badge {
            padding: 4px 10px;
            border-radius: 10px;
            font-size: 10px;
            font-weight: 600;
        }

        .badge-active {
            background: #d1fae5;
            color: #065f46;
        }

        .badge-pending {
            background: #fef3c7;
            color: #92400e;
        }

        .badge-inactive {
            background: #fee2e2;
            color: #991b1b;
        }

        .tag {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 8px;
            font-size: 10px;
            font-weight: 500;
            margin: 2px;
        }

        .tag-subject {
            background: #e0e7ff;
            color: #3730a3;
        }

        .tag-grade {
            background: #d1fae5;
            color: #065f46;
        }

        .tag-more {
            background: var(--gray-200);
            color: var(--gray-600);
        }

        .btn-sm {
            padding: 5px 10px;
            border-radius: 8px;
            font-size: 11px;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            margin: 0 2px;
        }

        .btn-view {
            background: var(--info);
            color: white;
        }

        .btn-reset {
            background: var(--warning);
            color: #1e1b4b;
        }

        .btn-del {
            background: var(--danger);
            color: white;
        }

        .empty-row {
            text-align: center;
            padding: 30px;
            color: var(--gray-400);
        }

        .num-badge {
            font-family: monospace;
            font-size: 11px;
            background: var(--gray-100);
            padding: 3px 8px;
            border-radius: 8px;
            color: var(--gray-700);
        }
    </style>
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-users-cog" style="color:var(--primary);"></i> Manage Users</h1>
        <p style="color:var(--gray-500);">View and manage all users</p>
    </div>
    <a href="@Url.Action("Dashboard","Admin")" class="btn-back">
        <i class="fas fa-arrow-left"></i> Back
    </a>
</div>

<div class="panel">
    <div class="panel-header">
        <i class="fas fa-chalkboard-teacher"></i> Teachers (@Model.Teachers.Count)
    </div>
    <div class="search-bar">
        <input type="text" id="teacherSearch" placeholder="Search teachers..." />
        <button onclick="clearSearch('teacherSearch','teachersTable')">Clear</button>
    </div>
    <div style="overflow-x:auto;">
        <table id="teachersTable">
            <thead>
                <tr><th>Staff #</th><th>Teacher</th><th>Subjects</th><th>Grades</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Teachers)
                {
                    <tr>
                        <td><span class="num-badge">@t.StaffNumber</span></td>
                        <td>
                            <strong style="color:var(--gray-800);">@t.FullName</strong><br />
                            <small style="color:var(--gray-500);">@t.Email</small><br />
                            <small style="color:var(--gray-400);">@t.PhoneNumber</small>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(t.Subjects))
                            {
                                var sl = t.Subjects.Split(',');
                                foreach (var s in sl.Take(3))
                                {<span class="tag tag-subject">@s.Trim()</span>}
                            if (sl.Length > 3)
                            {<span class="tag tag-more">+@(sl.Length-3)</span>}
                        }
                        else
                        {<span style="color:var(--gray-400);">-</span>}
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(t.Grades))
                            {
                                foreach (var g in t.Grades.Split(','))
                                {<span class="tag tag-grade">@g.Trim()</span>}
                        }
                        else
                        {<span style="color:var(--gray-400);">-</span>}
                        </td>
                        <td><span class="badge badge-active">Active</span></td>
                        <td>
                            <button class="btn-sm btn-view" onclick="location.href='@Url.Action("RegisterTeacher","Admin")?editId=@t.Id'"><i class="fas fa-edit"></i></button>
                            <button class="btn-sm btn-reset" onclick="resetPass(@t.Id,'@t.FullName','teacher')"><i class="fas fa-key"></i></button>
                            <button class="btn-sm btn-del" onclick="delTeacher(@t.Id)"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                }
                @if (!Model.Teachers.Any())
                {
                    <tr><td colspan="6" class="empty-row">No teachers found</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="panel">
    <div class="panel-header">
        <i class="fas fa-user-graduate"></i> Students (@Model.Students.Count)
    </div>
    <div class="search-bar">
        <input type="text" id="studentSearch" placeholder="Search students..." />
        <button onclick="clearSearch('studentSearch','studentsTable')">Clear</button>
    </div>
    <div style="overflow-x:auto;">
        <table id="studentsTable">
            <thead>
                <tr><th>Student #</th><th>Student</th><th>Contact</th><th>Grade</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Students)
                {
                    var sc = s.Status == "Approved" ? "badge-active" : s.Status == "Pending" ? "badge-pending" : "badge-inactive";
                    <tr>
                        <td><span class="num-badge">@s.StudentNumber</span></td>
                        <td>
                            <strong style="color:var(--gray-800);">@s.FullName</strong><br />
                            <small style="color:var(--gray-500);">Applied: @s.ApplicationDate.ToString("dd MMM yyyy")</small>
                        </td>
                        <td>
                            <div><i class="fas fa-envelope" style="color:var(--gray-400);margin-right:4px;"></i>@s.Email</div>
                            <div><i class="fas fa-phone" style="color:var(--gray-400);margin-right:4px;"></i>@s.CellPhone</div>
                        </td>
                        <td>
                            <strong>@s.GradeApplyingFor</strong>
                            @if (!string.IsNullOrEmpty(s.StreamChoice))
                            {<br /><small style="color:var(--gray-500);">@(s.StreamChoice.Length>30?s.StreamChoice.Substring(0,27)+"...":s.StreamChoice)</small>}
                        </td>
                        <td><span class="badge @sc">@s.Status</span></td>
                        <td>
                            <button class="btn-sm btn-view" onclick="location.href='@Url.Action("ViewStudentDetails","Admin")?userId=@s.UserId'"><i class="fas fa-eye"></i></button>
                            <button class="btn-sm btn-reset" onclick="resetPass(@s.UserId,'@s.FullName','student')"><i class="fas fa-key"></i></button>
                            <button class="btn-sm btn-del" onclick="delUser(@s.UserId,'student')"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                }
                @if (!Model.Students.Any())
                {
                    <tr><td colspan="6" class="empty-row">No students found</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('teacherSearch').addEventListener('keyup', function() {
            var v = this.value.toLowerCase();
            document.querySelectorAll('#teachersTable tbody tr').forEach(r =>
                r.style.display = r.textContent.toLowerCase().includes(v) ? '' : 'none');
        });

        document.getElementById('studentSearch').addEventListener('keyup', function() {
            var v = this.value.toLowerCase();
            document.querySelectorAll('#studentsTable tbody tr').forEach(r =>
                r.style.display = r.textContent.toLowerCase().includes(v) ? '' : 'none');
        });

        function clearSearch(i, t) {
            document.getElementById(i).value = '';
            document.querySelectorAll('#' + t + ' tbody tr').forEach(r => r.style.display = '');
        }

        function resetPass(id, n, type) {
            if (!confirm('Reset password for ' + n + '?')) return;
            var t = document.querySelector('input[name="__RequestVerificationToken"]').value;
            fetch('@Url.Action("ResetUserPassword","Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: '__RequestVerificationToken=' + t + '&userId=' + id + '&userType=' + type
            }).then(r => r.json()).then(r =>
                alert(r.success ? 'Password sent to ' + r.email : 'Error: ' + r.message));
        }

        function delTeacher(id) {
            if (!confirm('Delete this teacher?')) return;
            var t = document.querySelector('input[name="__RequestVerificationToken"]').value;
            fetch('@Url.Action("DeleteTeacher","Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: '__RequestVerificationToken=' + t + '&id=' + id
            }).then(r => r.json()).then(r => {
                if (r.success) location.reload();
                else alert(r.message);
            });
        }

        function delUser(id, type) {
            if (!confirm('Delete this ' + type + '?')) return;
            var t = document.querySelector('input[name="__RequestVerificationToken"]').value;
            fetch('@Url.Action("DeleteUser","Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: '__RequestVerificationToken=' + t + '&userId=' + id + '&userType=' + type
            }).then(r => r.json()).then(r => {
                if (r.success) location.reload();
                else alert(r.message);
            });
        }
    </script>
}