@model List<ElevateED.ViewModels.AdminIssueViewModel>
@using ElevateED.Models

@{
    ViewBag.Title = "Issue Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var stats = ViewBag.Stats as ElevateED.ViewModels.IssueStatsViewModel;
}

@section SidebarNav {
    <div class="nav-section">Main</div>
    <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
    <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
    <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
    <div class="nav-section">Management</div>
    <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
    <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
    <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
    <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
    <a href="@Url.Action("Issues","Admin")" class="nav-item active"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
    <div class="nav-section">Extra</div>
    <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
    <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
    <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
    <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
}

@section Styles {
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 15px;
        }

            .page-header h1 {
                font-size: 26px;
                font-weight: 700;
                color: var(--gray-900);
            }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .stat-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            border: 1px solid var(--gray-200);
        }

            .stat-card.critical {
                border-top: 3px solid var(--danger);
            }

            .stat-card.pending {
                border-top: 3px solid var(--warning);
            }

            .stat-card.review {
                border-top: 3px solid var(--info);
            }

            .stat-card.resolved {
                border-top: 3px solid var(--success);
            }

        .stat-num {
            font-size: 30px;
            font-weight: 700;
        }

        .stat-lbl {
            font-size: 12px;
            color: var(--gray-500);
            text-transform: uppercase;
            margin-top: 4px;
        }

        .filter-bar {
            background: white;
            border-radius: 16px;
            padding: 20px;
            border: 1px solid var(--gray-200);
            margin-bottom: 20px;
        }

            .filter-bar select {
                padding: 9px 14px;
                border: 2px solid var(--gray-200);
                border-radius: 10px;
                font-size: 13px;
            }

        .btn-filter {
            background: var(--primary);
            color: white;
            padding: 9px 20px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-weight: 500;
        }

        .table-wrap {
            background: white;
            border-radius: 16px;
            border: 1px solid var(--gray-200);
            overflow: hidden;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th {
            background: var(--gray-800);
            color: white;
            padding: 12px 16px;
            text-align: left;
            font-weight: 500;
            font-size: 12px;
        }

        td {
            padding: 12px 16px;
            border-bottom: 1px solid var(--gray-100);
        }

        tr:hover td {
            background: var(--gray-50);
        }

        .badge {
            padding: 4px 10px;
            border-radius: 10px;
            font-size: 10px;
            font-weight: 600;
        }

        .badge-warning {
            background: #fef3c7;
            color: #92400e;
        }

        .badge-info {
            background: #dbeafe;
            color: #1e40af;
        }

        .badge-success {
            background: #d1fae5;
            color: #065f46;
        }

        .badge-secondary {
            background: var(--gray-200);
            color: var(--gray-600);
        }

        .badge-danger {
            background: #fee2e2;
            color: #991b1b;
        }

        .priority-select {
            padding: 6px 10px;
            border: 1px solid var(--gray-200);
            border-radius: 8px;
            font-size: 12px;
        }

        .btn-view {
            color: var(--primary);
            text-decoration: none;
            font-weight: 500;
            font-size: 12px;
        }

        .empty-state {
            text-align: center;
            padding: 60px;
            color: var(--gray-400);
        }

        @@media (max-width: 1024px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }
        }
    </style>
}

<div class="page-header">
    <div>
        <h1>
            <i class="fas fa-exclamation-triangle" style="color:var(--warning);"></i>
            Issue Management
        </h1>
        <p style="color:var(--gray-500);">Review and resolve student-reported issues</p>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card critical">
        <div class="stat-num" style="color:var(--danger);">@(stats?.CriticalIssues ?? 0)</div>
        <div class="stat-lbl">Critical</div>
    </div>
    <div class="stat-card pending">
        <div class="stat-num" style="color:var(--warning);">@(stats?.PendingIssues ?? 0)</div>
        <div class="stat-lbl">Pending</div>
    </div>
    <div class="stat-card review">
        <div class="stat-num" style="color:var(--info);">@(stats?.UnderReviewIssues ?? 0)</div>
        <div class="stat-lbl">Under Review</div>
    </div>
    <div class="stat-card resolved">
        <div class="stat-num" style="color:var(--success);">@(stats?.ResolvedIssues ?? 0)</div>
        <div class="stat-lbl">Resolved</div>
    </div>
</div>

<div class="filter-bar">
    <form method="get" style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
        <select name="status">
            <option value="">All Statuses</option>
            @if (ViewBag.Statuses != null)
            {
                foreach (var s in ViewBag.Statuses)
                {
                    <option value="@s" selected="@(Request.QueryString["status"]==s)">@s</option>
                }
            }
        </select>
        <select name="priority">
            <option value="">All Priorities</option>
            @if (ViewBag.Priorities != null)
            {
                foreach (var p in ViewBag.Priorities)
                {
                    <option value="@p" selected="@(Request.QueryString["priority"]==p)">@p</option>
                }
            }
        </select>
        <select name="category">
            <option value="">All Categories</option>
            @if (ViewBag.Categories != null)
            {
                foreach (var c in ViewBag.Categories)
                {
                    <option value="@c" selected="@(Request.QueryString["category"]==c)">@c</option>
                }
            }
        </select>
        <button type="submit" class="btn-filter">
            <i class="fas fa-filter"></i> Filter
        </button>
    </form>
</div>

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Category</th>
                <th>Student</th>
                <th>Date</th>
                <th>Priority</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var issue in Model)
                {
                    <tr>
                        <td>#@issue.Id</td>
                        <td>
                            <strong>@issue.Title</strong>
                            @if (issue.IsAnonymous)
                            {
                                <span class="badge badge-secondary" style="margin-left:6px;">
                                    <i class="fas fa-user-secret"></i>
                                </span>
                            }
                        </td>
                        <td>@issue.Category</td>
                        <td>
                            @if (issue.IsAnonymous)
                            {
                                <span style="color:var(--gray-500);">
                                    <i class="fas fa-user-secret"></i> Anonymous
                                </span>
                            }
                            else
                            {
                                <div>@issue.StudentName</div>
                                <small style="color:var(--gray-500);">@issue.Grade @issue.ClassName</small>
                            }
                        </td>
                        <td>@issue.CreatedAtFormatted</td>
                        <td>
                            <select class="priority-select" onchange="updatePriority(@issue.Id, this.value)">
                                @if (ViewBag.Priorities != null)
                                {
                                    foreach (var p in ViewBag.Priorities)
                                    {
                                        <option value="@p" selected="@(issue.Priority.ToString()==p)">@p</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <span class="badge @issue.StatusBadgeClass">@issue.Status</span>
                        </td>
                        <td>
                            <a href="@Url.Action("IssueDetails","Admin", new { id = issue.Id })" class="btn-view">
                                <i class="fas fa-eye"></i> View
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="empty-state">
                        <i class="fas fa-clipboard-check" style="font-size:40px;display:block;margin-bottom:10px;"></i>
                        No issues found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function updatePriority(id, p) {
            fetch('@Url.Action("UpdateIssuePriority","Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + id + '&priority=' + p
            }).then(r => r.json()).then(r => {
                alert(r.message);
            });
        }
    </script>
}