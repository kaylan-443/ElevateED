@model ElevateED.ViewModels.ApplicationEvaluationViewModel
@using ElevateED.Models

@{
    ViewBag.Title = "Evaluate Applications - Admin";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var gradeGroups = Model.GradeGroups ?? new List<IGrouping<string, ElevateED.Models.Applicant>>();
}

@section SidebarNav {
    <div class="nav-section">Main</div>
    <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="@Url.Action("PendingApplications","Admin")" class="nav-item active"><i class="fas fa-file-alt"></i><span>Applications</span></a>
    <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
    <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
    <div class="nav-section">Management</div>
    <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
    <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
    <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
    <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
    <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
    <div class="nav-section">Extra</div>
    <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
    <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
    <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
    <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
}

@section Styles {
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 15px;
        }

            .page-header h1 {
                font-size: 26px;
                font-weight: 700;
                color: var(--gray-900);
            }

        .btn-back {
            background: white;
            color: var(--gray-700);
            padding: 10px 20px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 500;
            border: 1px solid var(--gray-200);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-back:hover {
                background: var(--gray-100);
                text-decoration: none;
            }

        .info-banner {
            background: linear-gradient(135deg, var(--primary), #4338ca);
            color: white;
            padding: 20px 24px;
            border-radius: 16px;
            margin-bottom: 20px;
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
        }

        .stat-item {
            text-align: center;
        }

        .stat-val {
            font-size: 28px;
            font-weight: 700;
        }

        .stat-lbl {
            font-size: 12px;
            opacity: 0.9;
        }

        .filter-bar {
            background: white;
            border-radius: 16px;
            padding: 16px 20px;
            border: 1px solid var(--gray-200);
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
        }

        .btn-sm {
            padding: 8px 16px;
            border-radius: 10px;
            font-size: 12px;
            font-weight: 500;
            border: 1px solid var(--gray-200);
            background: white;
            color: var(--gray-700);
            cursor: pointer;
            margin-right: 6px;
        }

            .btn-sm:hover {
                background: var(--gray-100);
            }

        .btn-approve {
            background: var(--success);
            color: white;
            padding: 10px 20px;
            border-radius: 10px;
            border: none;
            font-weight: 500;
            cursor: pointer;
        }

        .btn-reject {
            background: var(--danger);
            color: white;
            padding: 10px 20px;
            border-radius: 10px;
            border: none;
            font-weight: 500;
            cursor: pointer;
            margin-left: 8px;
        }

        .grade-section {
            margin-bottom: 24px;
        }

        .grade-header {
            background: var(--gray-100);
            padding: 14px 20px;
            border-radius: 12px 12px 0 0;
            font-weight: 600;
            color: var(--gray-800);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .table-wrap {
            background: white;
            border-radius: 0 0 12px 12px;
            border: 1px solid var(--gray-200);
            border-top: none;
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th {
            background: var(--gray-800);
            color: white;
            padding: 10px 14px;
            text-align: left;
            font-weight: 500;
            font-size: 12px;
        }

        td {
            padding: 10px 14px;
            border-bottom: 1px solid var(--gray-100);
            vertical-align: middle;
        }

        tr:hover td {
            background: var(--gray-50);
        }

        .perf-high {
            background: #f0fdf4 !important;
        }

        .perf-med {
            background: #fefce8 !important;
        }

        .perf-low {
            background: #fef2f2 !important;
        }

        .avg-badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
        }

        .empty-state {
            text-align: center;
            padding: 60px;
            background: white;
            border-radius: 16px;
            border: 1px solid var(--gray-200);
        }

            .empty-state i {
                font-size: 40px;
                color: var(--gray-400);
                margin-bottom: 10px;
            }

        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 1050;
            align-items: center;
            justify-content: center;
        }

            .modal-overlay.show {
                display: flex;
            }

        .modal-box {
            background: white;
            border-radius: 16px;
            width: 90%;
            max-width: 500px;
        }

        .modal-header {
            padding: 20px 24px;
            background: var(--danger);
            color: white;
            border-radius: 16px 16px 0 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-body {
            padding: 24px;
        }

            .modal-body textarea {
                width: 100%;
                padding: 10px;
                border: 2px solid var(--gray-200);
                border-radius: 10px;
                min-height: 100px;
                font-size: 14px;
            }

        .modal-close {
            background: none;
            border: none;
            color: white;
            font-size: 22px;
            cursor: pointer;
        }

        .btn-cancel {
            padding: 8px 20px;
            border-radius: 10px;
            border: 1px solid var(--gray-200);
            background: white;
            cursor: pointer;
        }

        .btn-confirm {
            padding: 8px 20px;
            border-radius: 10px;
            border: none;
            background: var(--danger);
            color: white;
            cursor: pointer;
        }
    </style>
}

<div class="page-header">
    <div>
        <h1>
            <i class="fas fa-clipboard-check" style="color:var(--success);"></i>
            Evaluate Applications
        </h1>
        <p style="color:var(--gray-500);">@Model.Cycle.Name - @Model.Cycle.AcademicYear</p>
    </div>
    <a href="@Url.Action("ApplicationCycles","Admin")" class="btn-back">
        <i class="fas fa-arrow-left"></i> Back
    </a>
</div>

<div class="info-banner">
    <div class="stat-item">
        <div class="stat-val">@Model.Applicants.Count</div>
        <div class="stat-lbl">Total Pending</div>
    </div>
    <div class="stat-item">
        <div class="stat-val">@Model.Applicants.Count(a => a.AcademicAverage >= 70)</div>
        <div class="stat-lbl">Above 70%</div>
    </div>
    <div class="stat-item">
        <div class="stat-val">@Model.Applicants.Count(a => a.AcademicAverage >= 80)</div>
        <div class="stat-lbl">Above 80%</div>
    </div>
</div>

@if (!Model.Applicants.Any())
{
    <div class="empty-state">
        <i class="fas fa-inbox"></i>
        <h4>No Pending Applications</h4>
    </div>
}
else
{
    <div class="filter-bar">
        <div>
            <button class="btn-sm" onclick="selectTop(80)">
                <i class="fas fa-star"></i> Top 80%+
            </button>
            <button class="btn-sm" onclick="selectAll()">
                <i class="fas fa-check-square"></i> Select All
            </button>
            <button class="btn-sm" onclick="clearAll()">
                <i class="fas fa-square"></i> Clear
            </button>
        </div>
        <div style="display:flex;align-items:center;gap:10px;">
            <span id="selectedCount" style="font-weight:600;">0</span> selected
            <button class="btn-approve" onclick="bulkApprove()">
                <i class="fas fa-check-circle"></i> Approve
            </button>
            <button class="btn-reject" onclick="bulkReject()">
                <i class="fas fa-times-circle"></i> Reject
            </button>
        </div>
    </div>

    <form id="bulkForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="SelectedApplicantIds" id="SelectedApplicantIds" />
        <input type="hidden" name="RejectionReason" id="RejectionReason" />
    </form>

    foreach (var gg in gradeGroups.OrderBy(g => g.Key))
    {
        <div class="grade-section">
            <div class="grade-header">
                <span><i class="fas fa-graduation-cap"></i> @gg.Key</span>
                <button class="btn-sm" onclick="selectGrade('@gg.Key')">Select All in @gg.Key</button>
            </div>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th width="30"><input type="checkbox" onchange="toggleGrade(this,'@gg.Key')" /></th>
                            <th>#</th>
                            <th>Applicant</th>
                            <th>Student #</th>
                            <th>Average</th>
                            <th>Stream</th>
                            <th>Applied</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int r = 1;
                            foreach (var a in gg.OrderByDescending(x => x.AcademicAverage))
                            {
                                var pc = a.AcademicAverage >= 80 ? "perf-high" : a.AcademicAverage >= 60 ? "perf-med" : "perf-low";
                                var bg = a.AcademicAverage >= 80 ? "#d1fae5" : a.AcademicAverage >= 60 ? "#fef3c7" : "#fee2e2";
                                var fc = a.AcademicAverage >= 80 ? "#065f46" : a.AcademicAverage >= 60 ? "#92400e" : "#991b1b";

                                <tr class="@pc" data-grade="@gg.Key">
                                    <td>
                                        <input type="checkbox" class="app-cb" value="@a.Id"
                                               data-avg="@a.AcademicAverage" data-grade="@gg.Key" />
                                    </td>
                                    <td><strong>#@r</strong></td>
                                    <td>
                                        <strong>@a.FullName</strong><br />
                                        <small style="color:var(--gray-500);">@a.PreviousSchool</small>
                                    </td>
                                    <td>@(a.User?.StudentNumber ?? "—")</td>
                                    <td>
                                        <span class="avg-badge" style="background:@bg;color:@fc;">
                                            @(a.AcademicAverage?.ToString("0.0") ?? "—")%
                                        </span>
                                    </td>
                                    <td>@(a.StreamChoiceDisplay ?? "—")</td>
                                    <td>@a.ApplicationDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <a href="@Url.Action("ViewApplication",new{id=a.Id})"
                                           style="color:var(--info);text-decoration:none;">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                                r++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

<!-- Reject Modal -->
<div class="modal-overlay" id="rejectModal">
    <div class="modal-box">
        <div class="modal-header">
            <h4><i class="fas fa-times-circle"></i> Reject Applications</h4>
            <button class="modal-close" onclick="closeRejectModal()">&times;</button>
        </div>
        <div class="modal-body">
            <label style="font-weight:600;display:block;margin-bottom:6px;">Rejection Reason (Optional)</label>
            <textarea id="rejectionReasonText" placeholder="Reason for rejection..."></textarea>
            <small style="color:var(--gray-500);">This will be shared with applicants</small>
            <div style="display:flex;gap:10px;margin-top:16px;justify-content:flex-end;">
                <button class="btn-cancel" onclick="closeRejectModal()">Cancel</button>
                <button class="btn-confirm" onclick="confirmBulkReject()">Confirm Reject</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function closeRejectModal() {
            document.getElementById('rejectModal').classList.remove('show');
        }

        function updateCount() {
            document.getElementById('selectedCount').textContent =
                document.querySelectorAll('.app-cb:checked').length;
        }

        document.querySelectorAll('.app-cb').forEach(c =>
            c.addEventListener('change', updateCount));

        function toggleGrade(cb, g) {
            document.querySelectorAll('tr[data-grade="' + g + '"] .app-cb').forEach(c =>
                c.checked = cb.checked);
            updateCount();
        }

        function selectGrade(g) {
            document.querySelectorAll('tr[data-grade="' + g + '"] .app-cb').forEach(c =>
                c.checked = true);
            updateCount();
        }

        function selectTop(t) {
            document.querySelectorAll('.app-cb').forEach(c => {
                c.checked = parseFloat(c.dataset.avg || 0) >= t;
            });
            updateCount();
        }

        function selectAll() {
            document.querySelectorAll('.app-cb').forEach(c => c.checked = true);
            updateCount();
        }

        function clearAll() {
            document.querySelectorAll('.app-cb').forEach(c => c.checked = false);
            document.querySelectorAll('th input[type="checkbox"]').forEach(c => c.checked = false);
            updateCount();
        }

        function getIds() {
            var i = [];
            document.querySelectorAll('.app-cb:checked').forEach(c => i.push(c.value));
            return i.join(',');
        }

        function bulkApprove() {
            var ids = getIds();
            if (!ids) { alert('Select applicants'); return; }
            if (confirm('Approve selected?')) {
                document.getElementById('SelectedApplicantIds').value = ids;
                var f = document.getElementById('bulkForm');
                fetch('@Url.Action("BulkApprove","Admin")', {
                    method: 'POST',
                    body: new FormData(f)
                }).then(r => r.json()).then(r => {
                    alert(r.message);
                    location.reload();
                });
            }
        }

        function bulkReject() {
            var ids = getIds();
            if (!ids) { alert('Select applicants'); return; }
            document.getElementById('rejectModal').classList.add('show');
        }

        function confirmBulkReject() {
            var ids = getIds();
            document.getElementById('SelectedApplicantIds').value = ids;
            document.getElementById('RejectionReason').value =
                document.getElementById('rejectionReasonText').value;
            var f = document.getElementById('bulkForm');
            fetch('@Url.Action("BulkReject","Admin")', {
                method: 'POST',
                body: new FormData(f)
            }).then(r => r.json()).then(r => {
                alert(r.message);
                closeRejectModal();
                location.reload();
            });
        }
    </script>
}