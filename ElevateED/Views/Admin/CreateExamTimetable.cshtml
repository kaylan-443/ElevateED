@section Styles {
    <style>
        .form-card {
            background: white;
            border-radius: 16px;
            padding: 32px;
            border: 1px solid var(--gray-200);
            max-width: 800px;
            margin: 0 auto;
        }

        .form-header {
            text-align: center;
            margin-bottom: 28px;
            padding-bottom: 20px;
            border-bottom: 2px solid var(--gray-200);
        }

            .form-header h2 {
                font-size: 24px;
                font-weight: 700;
                color: var(--gray-900);
                margin-bottom: 8px;
            }

            .form-header i {
                color: var(--accent);
                font-size: 40px;
                margin-bottom: 12px;
            }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            font-weight: 600;
            font-size: 13px;
            color: var(--gray-700);
            margin-bottom: 6px;
            display: block;
        }

        .form-control {
            width: 100%;
            padding: 10px 14px;
            border: 2px solid var(--gray-200);
            border-radius: 10px;
            font-size: 14px;
        }

            .form-control:focus {
                border-color: var(--primary);
                outline: none;
            }

        .required::after {
            content: " *";
            color: var(--danger);
        }

        .info-box {
            background: #eef2ff;
            border-left: 4px solid var(--primary);
            padding: 16px 20px;
            border-radius: 10px;
            margin-bottom: 24px;
        }

            .info-box h5 {
                color: var(--primary);
                margin-bottom: 8px;
            }

            .info-box ul {
                padding-left: 20px;
                margin: 0;
            }

            .info-box li {
                margin-bottom: 4px;
                color: var(--gray-600);
                font-size: 14px;
            }

        .btn-submit {
            background: var(--success);
            color: white;
            padding: 14px 30px;
            border-radius: 12px;
            border: none;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            width: 100%;
        }

            .btn-submit:hover {
                background: #059669;
            }

        .btn-cancel {
            background: var(--gray-200);
            color: var(--gray-700);
            padding: 14px 30px;
            border-radius: 12px;
            border: none;
            font-size: 16px;
            font-weight: 500;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            width: 100%;
        }

            .btn-cancel:hover {
                background: var(--gray-300);
                color: var(--gray-900);
                text-decoration: none;
            }

        .validation-summary-errors {
            background: #fee2e2;
            color: #991b1b;
            padding: 14px;
            border-radius: 10px;
            margin-bottom: 20px;
        }
    </style>
}

<div class="app-container">
    <aside class="sidebar">
        <div class="sidebar-header"><div class="logo"><div class="logo-icon"><i class="fas fa-graduation-cap"></i></div><div class="logo-text">Elevate<span>ED</span></div></div></div>
        <nav class="sidebar-nav">
            <div class="nav-section">Main</div>
            <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
            <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
            <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
            <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
            <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
            <div class="nav-section">Management</div>
            <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
            <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item active"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
            <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
            <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
            <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
            <div class="nav-section">Extra</div>
            <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
            <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
            <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
            <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
        </nav>
    </aside>
    <main class="main-content">
        <header class="top-header">
            <div class="header-right">
                <button class="notification-btn"><i class="far fa-bell"></i><span class="notification-badge"></span></button>
                <div class="profile-container">
                    <button class="profile-trigger" onclick="toggleDropdown()"><div class="avatar">A</div><span class="profile-name">Admin</span><i class="fas fa-chevron-down dropdown-icon"></i></button>
                    <div class="dropdown-menu" id="profileDropdown">
                        <div class="dropdown-header"><div class="user-name">Administrator</div><div class="user-email">admin@mpiyakhehs.co.za</div></div>
                        <a href="@Url.Action("ManageUsers","Admin")" class="dropdown-item"><i class="fas fa-users"></i><span>Manage Users</span></a>
                        <div class="dropdown-divider"></div>
                        <form action="@Url.Action("LogOff","Account")" method="post" id="logoutForm">
                            @Html.AntiForgeryToken()
                            <button type="button" class="dropdown-item" onclick="confirmLogout(event)" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i><span>Logout</span></button>
                        </form>
                    </div>
                </div>
            </div>
        </header>
        <div class="dashboard-content">
            <div class="form-card">
                <div class="form-header">
                    <i class="fas fa-calendar-plus"></i>
                    <h2>Create Exam Cycle</h2>
                    <p style="color:var(--gray-500);">Set the window in which teachers may propose exam sessions.</p>
                </div>
                @using (Html.BeginForm("CreateExamTimetable", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    if (!ViewData.ModelState.IsValid)
                    {<div class="validation-summary-errors">@Html.ValidationSummary(true, "Please correct the following errors:", new { @class = "text-danger" })</div>}
                    <div class="info-box">
                        <h5><i class="fas fa-info-circle"></i> How this works</h5>
                        <ul>
                            <li>Pick the first and last day teachers may schedule exams for this cycle.</li>
                            <li>Teachers propose their own exam sessions (subject, paper, classes, time, venue).</li>
                            <li>The principal reviews and publishes the timetable.</li>
                            <li>Exams must fit between 07:30 and 14:30 and may not overlap break times.</li>
                        </ul>
                    </div>
                    <div class="form-group">
                        <label class="form-label required">Cycle Name</label>
                        @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "e.g. June Exams 2026" })
                        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        <label class="form-label required">Academic Year</label>
                        @Html.TextBoxFor(m => m.AcademicYear, new { @class = "form-control", type = "number", min = "2020", max = "2030" })
                        @Html.ValidationMessageFor(m => m.AcademicYear, "", new { @class = "text-danger" })
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                        <div class="form-group">
                            <label class="form-label required">Start Date</label>
                            @Html.TextBoxFor(m => m.StartDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                            @Html.ValidationMessageFor(m => m.StartDate, "", new { @class = "text-danger" })
                            <small style="color:var(--gray-500);">First day exams may be written.</small>
                        </div>
                        <div class="form-group">
                            <label class="form-label required">End Date</label>
                            @Html.TextBoxFor(m => m.EndDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                            @Html.ValidationMessageFor(m => m.EndDate, "", new { @class = "text-danger" })
                            <small style="color:var(--gray-500);">Last day exams may be written.</small>
                        </div>
                    </div>
                    <div style="display:flex;gap:14px;margin-top:24px;">
                        <a href="@Url.Action("ExamTimetables","Admin")" class="btn-cancel"><i class="fas fa-times"></i> Cancel</a>
                        <button type="submit" class="btn-submit"><i class="fas fa-arrow-right"></i> Create Cycle</button>
                    </div>
                }
            </div>
        </div>
    }
</div>