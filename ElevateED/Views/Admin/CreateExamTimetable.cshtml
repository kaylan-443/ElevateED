@model ElevateED.ViewModels.CreateExamTimetableViewModel

@{
    ViewBag.Title = "Create Exam Timetable - Admin";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section SidebarNav {
    <div class="nav-section">Main</div>
    <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
    <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
    <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
    <div class="nav-section">Management</div>
    <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
    <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item active"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
    <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
    <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
    <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
    <div class="nav-section">Extra</div>
    <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
    <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
    <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
    <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
}

@section Styles {
    <style>
        .form-card {
            background: white;
            border-radius: 16px;
            padding: 32px;
            border: 1px solid var(--gray-200);
            max-width: 800px;
            margin: 0 auto;
        }

        .form-header {
            text-align: center;
            margin-bottom: 28px;
            padding-bottom: 20px;
            border-bottom: 2px solid var(--gray-200);
        }

            .form-header h2 {
                font-size: 24px;
                font-weight: 700;
                color: var(--gray-900);
                margin-bottom: 8px;
            }

            .form-header i {
                color: var(--accent);
                font-size: 40px;
                margin-bottom: 12px;
            }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            font-weight: 600;
            font-size: 13px;
            color: var(--gray-700);
            margin-bottom: 6px;
            display: block;
        }

        .form-control {
            width: 100%;
            padding: 10px 14px;
            border: 2px solid var(--gray-200);
            border-radius: 10px;
            font-size: 14px;
        }

            .form-control:focus {
                border-color: var(--primary);
                outline: none;
            }

        .required::after {
            content: " *";
            color: var(--danger);
        }

        .info-box {
            background: #eef2ff;
            border-left: 4px solid var(--primary);
            padding: 16px 20px;
            border-radius: 10px;
            margin-bottom: 24px;
        }

            .info-box h5 {
                color: var(--primary);
                margin-bottom: 8px;
            }

            .info-box ul {
                padding-left: 20px;
                margin: 0;
            }

            .info-box li {
                margin-bottom: 4px;
                color: var(--gray-600);
                font-size: 14px;
            }

        .btn-submit {
            background: var(--success);
            color: white;
            padding: 14px 30px;
            border-radius: 12px;
            border: none;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            width: 100%;
        }

            .btn-submit:hover {
                background: #059669;
            }

        .btn-cancel {
            background: var(--gray-200);
            color: var(--gray-700);
            padding: 14px 30px;
            border-radius: 12px;
            border: none;
            font-size: 16px;
            font-weight: 500;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            width: 100%;
        }

            .btn-cancel:hover {
                background: var(--gray-300);
                color: var(--gray-900);
                text-decoration: none;
            }

        .validation-summary-errors {
            background: #fee2e2;
            color: #991b1b;
            padding: 14px;
            border-radius: 10px;
            margin-bottom: 20px;
        }
    </style>
}

<div class="form-card">
    <div class="form-header">
        <i class="fas fa-calendar-plus"></i>
        <h2>Create Exam Timetable</h2>
        <p style="color:var(--gray-500);">Set up a new examination timetable</p>
    </div>

    @using (Html.BeginForm("CreateExamTimetable", "Admin", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        if (!ViewData.ModelState.IsValid)
        {
            <div class="validation-summary-errors">
                @Html.ValidationSummary(true, "Please correct the following errors:", new { @class = "text-danger" })
            </div>
        }

        <div class="info-box">
            <h5><i class="fas fa-info-circle"></i> Important Information</h5>
            <ul>
                <li>Teachers will be notified to enter exam durations (1-3 hours per paper)</li>
                <li>Exams scheduled between 9:00 AM and 2:15 PM</li>
                <li>Each class writes one exam per day</li>
                <li>Total weeks determine exam duration</li>
            </ul>
        </div>

        <div class="form-group">
            <label class="form-label required">Timetable Name</label>
            @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "e.g., 2026 June Examinations" })
            @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div class="form-group">
                <label class="form-label required">Academic Year</label>
                @Html.TextBoxFor(m => m.AcademicYear, new { @class = "form-control", type = "number", min = "2020", max = "2030" })
                @Html.ValidationMessageFor(m => m.AcademicYear, "", new { @class = "text-danger" })
            </div>
            <div class="form-group">
                <label class="form-label required">Number of Weeks</label>
                @Html.TextBoxFor(m => m.NumberOfWeeks, new { @class = "form-control", type = "number", min = "1", max = "4" })
                @Html.ValidationMessageFor(m => m.NumberOfWeeks, "", new { @class = "text-danger" })
                <small style="color:var(--gray-500);">Between 1 and 4 weeks</small>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label required">Start Date</label>
            @Html.TextBoxFor(m => m.StartDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
            @Html.ValidationMessageFor(m => m.StartDate, "", new { @class = "text-danger" })
            <small style="color:var(--gray-500);">Exams run Monday-Friday only</small>
        </div>

        <div style="display:flex;gap:14px;margin-top:24px;">
            <a href="@Url.Action("ExamTimetables","Admin")" class="btn-cancel">
                <i class="fas fa-times"></i> Cancel
            </a>
            <button type="submit" class="btn-submit">
                <i class="fas fa-arrow-right"></i> Create & Notify Teachers
            </button>
        </div>
    }
</div>