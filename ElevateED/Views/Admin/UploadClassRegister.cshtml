@{
    ViewBag.Title = "Upload Class Register - Admin";
    var grade = ViewBag.Grade as string;
    var className = ViewBag.ClassName as string;
}

<style>
    .upload-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
    }

    .upload-card {
        background: white;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

    .upload-header {
        text-align: center;
        margin-bottom: 30px;
    }

        .upload-header h2 {
            color: #1e3c72;
            margin-bottom: 10px;
        }

    .class-badge {
        background: #28a745;
        color: white;
        padding: 10px 20px;
        border-radius: 25px;
        display: inline-block;
        margin: 10px 0;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        display: block;
    }

    .form-control {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 10px 15px;
        width: 100%;
    }

        .form-control:focus {
            border-color: #28a745;
            outline: none;
        }

    .file-drop-zone {
        border: 3px dashed #ddd;
        border-radius: 10px;
        padding: 30px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .file-drop-zone:hover {
            border-color: #28a745;
            background: #f0f8f0;
        }

    .btn-submit {
        background: #28a745;
        color: white;
        padding: 12px 30px;
        border-radius: 25px;
        border: none;
        font-size: 16px;
        font-weight: 600;
        width: 100%;
        cursor: pointer;
    }

        .btn-submit:hover {
            background: #218838;
        }

    .btn-cancel {
        background: #6c757d;
        color: white;
        padding: 12px 30px;
        border-radius: 25px;
        border: none;
        font-size: 16px;
        font-weight: 600;
        width: 100%;
        text-decoration: none;
        display: inline-block;
        text-align: center;
    }

        .btn-cancel:hover {
            background: #5a6268;
            color: white;
            text-decoration: none;
        }
</style>

<div class="container upload-container">
    <div class="upload-card">
        <div class="upload-header">
            <h2><i class="fas fa-upload"></i> Upload Class Register</h2>
            <div class="class-badge">@grade - @className</div>
            <p class="text-muted">Upload the class register for this class</p>
        </div>

        <form id="uploadForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Grade" value="@grade" />
            <input type="hidden" name="ClassName" value="@className" />

            <div class="form-group">
                <label class="form-label">Term *</label>
                <select name="Term" class="form-control" required>
                    <option value="">-- Select Term --</option>
                    <option value="Term 1">Term 1</option>
                    <option value="Term 2">Term 2</option>
                    <option value="Term 3">Term 3</option>
                    <option value="Term 4">Term 4</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Year *</label>
                <select name="Year" class="form-control" required>
                    <option value="">-- Select Year --</option>
                    @for (int i = DateTime.Now.Year; i >= DateTime.Now.Year - 5; i--)
                    {
                        <option value="@i">@i</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Description (Optional)</label>
                <textarea name="Description" class="form-control" rows="3" placeholder="Add any notes about this register..."></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">Register File (PDF/Excel) *</label>
                <div class="file-drop-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
                    <i class="fas fa-cloud-upload-alt fa-3x text-muted mb-3"></i>
                    <h5>Click to browse or drag & drop file here</h5>
                    <p class="text-muted">Supported: PDF, Excel, Word (Max 10MB)</p>
                    <div id="fileName" class="text-success mt-2"></div>
                </div>
                <input type="file" id="fileInput" name="RegisterFile" class="d-none" accept=".pdf,.xls,.xlsx,.doc,.docx" />
            </div>

            <div id="message" class="alert" style="display: none;"></div>

            <div class="row mt-4">
                <div class="col-md-6 mb-2">
                    <a href="@Url.Action("SelectClass", "Admin", new { grade = grade })" class="btn-cancel w-100">Cancel</a>
                </div>
                <div class="col-md-6">
                    <button type="button" class="btn-submit" onclick="submitUpload()">
                        <i class="fas fa-upload"></i> Upload Register
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<script>
    function handleFileSelect(input) {
        const fileName = document.getElementById('fileName');
        if (input.files && input.files[0]) {
            fileName.textContent = 'Selected: ' + input.files[0].name;
            document.getElementById('dropZone').style.borderColor = '#28a745';
        } else {
            fileName.textContent = '';
            document.getElementById('dropZone').style.borderColor = '#ddd';
        }
    }

    // Drag and drop
    const dropZone = document.getElementById('dropZone');
    dropZone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.style.borderColor = '#28a745';
        dropZone.style.background = '#e8f5e9';
    });
    dropZone.addEventListener('dragleave', (e) => {
        e.preventDefault();
        dropZone.style.borderColor = '#ddd';
        dropZone.style.background = 'white';
    });
    dropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        const files = e.dataTransfer.files;
        document.getElementById('fileInput').files = files;
        handleFileSelect(document.getElementById('fileInput'));
    });

    function submitUpload() {
        var formData = new FormData(document.getElementById('uploadForm'));
        var term = document.querySelector('select[name="Term"]').value;
        var year = document.querySelector('select[name="Year"]').value;
        var file = document.getElementById('fileInput').files[0];

        if (!term) { alert('Please select a term'); return; }
        if (!year) { alert('Please select a year'); return; }
        if (!file) { alert('Please select a file to upload'); return; }

        $.ajax({
            url: '@Url.Action("UploadClassRegister", "Admin")',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            beforeSend: function() {
                $('#message').hide();
            },
            success: function(response) {
                if (response.success) {
                    $('#message').removeClass('alert-danger').addClass('alert-success').html('<i class="fas fa-check-circle"></i> ' + response.message).show();
                    setTimeout(function() {
                        window.location.href = '@Url.Action("SelectClass", "Admin", new { grade = grade })';
                    }, 2000);
                } else {
                    $('#message').removeClass('alert-success').addClass('alert-danger').html('<i class="fas fa-exclamation-circle"></i> ' + response.message).show();
                }
            },
            error: function() {
                $('#message').removeClass('alert-success').addClass('alert-danger').html('<i class="fas fa-exclamation-circle"></i> An error occurred during upload').show();
            }
        });
    }
</script>