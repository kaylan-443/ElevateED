@model ElevateED.ViewModels.SendAnnouncementViewModel

@{
    ViewBag.Title = "Send Announcement - Admin";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --primary: #4f46e5;
        --primary-light: #6366f1;
        --primary-dark: #4338ca;
        --primary-bg: #f5f3ff;
        --primary-soft: #ede9fe;
        --primary-hover: #e0e7ff;
        --accent: #fbbf24;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --sidebar-width: 280px;
        --header-height: 70px;
    }

    body {
        font-family: 'Inter', -apple-system, sans-serif;
        background: var(--gray-50);
        overflow-x: hidden;
    }

    .app-container {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: var(--sidebar-width);
        background: linear-gradient(180deg, #1e1b4b 0%, #2e1065 100%);
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        transition: all 0.3s ease;
        z-index: 100;
        overflow-y: auto;
    }

    .sidebar-header {
        padding: 24px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .logo-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--accent), #f59e0b);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e1b4b;
        font-size: 20px;
    }

    .logo-text {
        font-size: 20px;
        font-weight: 700;
        color: white;
    }

        .logo-text span {
            color: var(--accent);
        }

    .sidebar-nav {
        flex: 1;
        padding: 24px 16px;
    }

    .nav-section {
        margin-top: 24px;
        margin-bottom: 12px;
        padding: 0 16px;
        font-size: 11px;
        font-weight: 600;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        margin-bottom: 8px;
        border-radius: 12px;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .nav-item:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        .nav-item.active {
            background: linear-gradient(135deg, var(--accent), #f59e0b);
            color: #1e1b4b;
        }

        .nav-item i {
            width: 20px;
            font-size: 18px;
        }

        .nav-item span {
            font-size: 14px;
            font-weight: 500;
        }

    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width);
        min-height: 100vh;
    }

    .top-header {
        height: var(--header-height);
        background: white;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: flex-end;
        align-items: center;
        padding: 0 32px;
        position: sticky;
        top: 0;
        z-index: 99;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .notification-btn {
        position: relative;
        background: none;
        border: none;
        font-size: 20px;
        color: var(--gray-500);
        cursor: pointer;
        padding: 8px;
        border-radius: 10px;
        transition: all 0.2s;
    }

        .notification-btn:hover {
            background: var(--gray-100);
        }

    .notification-badge {
        position: absolute;
        top: 2px;
        right: 2px;
        width: 8px;
        height: 8px;
        background: var(--danger);
        border-radius: 50%;
    }

    .profile-container {
        position: relative;
    }

    .profile-trigger {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 50px;
        transition: all 0.2s;
        background: none;
        border: none;
    }

        .profile-trigger:hover {
            background: var(--gray-100);
        }

    .avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 16px;
        text-transform: uppercase;
    }

    .profile-name {
        font-size: 14px;
        font-weight: 500;
        color: var(--gray-700);
    }

    .dropdown-icon {
        font-size: 12px;
        color: var(--gray-400);
    }

    .dropdown-menu {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        width: 240px;
        overflow: hidden;
        display: none;
        z-index: 1000;
    }

        .dropdown-menu.show {
            display: block;
            animation: fadeInDown 0.2s ease;
        }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .dropdown-header {
        padding: 16px;
        border-bottom: 1px solid var(--gray-200);
        background: linear-gradient(135deg, var(--primary-bg), var(--primary-soft));
    }

        .dropdown-header .user-name {
            font-weight: 600;
            color: var(--gray-900);
            margin-bottom: 4px;
        }

        .dropdown-header .user-email {
            font-size: 12px;
            color: var(--gray-500);
        }

    .dropdown-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        text-decoration: none;
        color: var(--gray-700);
        transition: all 0.2s;
        cursor: pointer;
        background: none;
        border: none;
        width: 100%;
        text-align: left;
    }

        .dropdown-item:hover {
            background: var(--primary-hover);
            color: var(--primary);
        }

        .dropdown-item i {
            width: 20px;
            font-size: 16px;
            color: var(--gray-500);
        }

    .dropdown-divider {
        height: 1px;
        background: var(--gray-200);
        margin: 8px 0;
    }

    .dashboard-content {
        padding: 32px;
        max-width: 900px;
        margin: 0 auto;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 15px;
    }

        .page-header h1 {
            font-size: 26px;
            font-weight: 700;
            color: var(--gray-900);
        }

    .btn-back {
        background: white;
        color: var(--gray-700);
        padding: 10px 20px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 500;
        border: 1px solid var(--gray-200);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-back:hover {
            background: var(--gray-100);
            text-decoration: none;
        }

    .form-card {
        background: white;
        border-radius: 16px;
        padding: 32px;
        border: 1px solid var(--gray-200);
    }

    .form-header {
        text-align: center;
        margin-bottom: 28px;
    }

        .form-header h2 {
            font-size: 24px;
            font-weight: 700;
            color: var(--gray-900);
        }

        .form-header p {
            color: var(--gray-500);
            margin-top: 6px;
        }

    .form-group {
        margin-bottom: 18px;
    }

    .form-label {
        font-weight: 600;
        font-size: 13px;
        color: var(--gray-700);
        margin-bottom: 5px;
        display: block;
    }

    .form-control {
        width: 100%;
        padding: 10px 14px;
        border: 2px solid var(--gray-200);
        border-radius: 10px;
        font-size: 14px;
        transition: all 0.2s;
    }

        .form-control:focus {
            border-color: var(--primary);
            outline: none;
            box-shadow: 0 0 0 3px rgba(79,70,229,0.1);
        }

    textarea.form-control {
        resize: vertical;
        min-height: 120px;
    }

    .required::after {
        content: " *";
        color: var(--danger);
    }

    .btn-submit {
        background: var(--accent);
        color: #1e1b4b;
        padding: 14px 30px;
        border-radius: 12px;
        border: none;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        width: 100%;
    }

        .btn-submit:hover {
            background: #f59e0b;
        }

    .btn-cancel {
        background: var(--gray-200);
        color: var(--gray-700);
        padding: 14px 30px;
        border-radius: 12px;
        border: none;
        font-size: 16px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        text-align: center;
        width: 100%;
    }

        .btn-cancel:hover {
            background: var(--gray-300);
            color: var(--gray-900);
            text-decoration: none;
        }

    .alert {
        padding: 12px 16px;
        border-radius: 10px;
        display: none;
        margin-top: 10px;
    }

    .alert-success {
        background: #d1fae5;
        color: #065f46;
    }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    @@media (max-width: 1024px) {
        .sidebar {
            transform: translateX(-100%);
        }

        .main-content {
            margin-left: 0;
        }
    }

    @@media (max-width: 768px) {
        .dashboard-content {
            padding: 20px;
        }
    }
</style>

<div class="app-container">
    <aside class="sidebar">
        <div class="sidebar-header"><div class="logo"><div class="logo-icon"><i class="fas fa-graduation-cap"></i></div><div class="logo-text">Elevate<span>ED</span></div></div></div>
        <nav class="sidebar-nav">
            <div class="nav-section">Main</div>
            <a href="@Url.Action("Dashboard","Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
            <a href="@Url.Action("PendingApplications","Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
            <a href="@Url.Action("ManageUsers","Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
            <a href="@Url.Action("ClassStructure","Admin")" class="nav-item"><i class="fas fa-school"></i><span>Classes</span></a>
            <a href="@Url.Action("RegisterTeacher","Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>
            <div class="nav-section">Management</div>
            <a href="@Url.Action("TimeTable","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
            <a href="@Url.Action("ExamTimetables","Admin")" class="nav-item"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
            <a href="@Url.Action("ClassRegister","Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
            <a href="@Url.Action("SendAnnouncement","Admin")" class="nav-item active"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
            <a href="@Url.Action("Issues","Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>
            <div class="nav-section">Extra</div>
            <a href="@Url.Action("Index","AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
            <a href="@Url.Action("EmergencyAlerts","AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
            <a href="@Url.Action("ApplicationCycles","Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
            <a href="@Url.Action("Index","Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
        </nav>
    </aside>
    <main class="main-content">
        <header class="top-header">
            <div class="header-right">
                <button class="notification-btn"><i class="far fa-bell"></i><span class="notification-badge"></span></button>
                <div class="profile-container">
                    <button class="profile-trigger" onclick="toggleDropdown()"><div class="avatar">A</div><span class="profile-name">Admin</span><i class="fas fa-chevron-down dropdown-icon"></i></button>
                    <div class="dropdown-menu" id="profileDropdown">
                        <div class="dropdown-header"><div class="user-name">Administrator</div><div class="user-email">admin@mpiyakhehs.co.za</div></div>
                        <a href="@Url.Action("ManageUsers","Admin")" class="dropdown-item"><i class="fas fa-users"></i><span>Manage Users</span></a>
                        <div class="dropdown-divider"></div>
                        <form action="@Url.Action("LogOff","Account")" method="post" id="logoutForm">
                            @Html.AntiForgeryToken()
                            <button type="button" class="dropdown-item" onclick="confirmLogout(event)" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i><span>Logout</span></button>
                        </form>
                    </div>
                </div>
            </div>
        </header>
        <div class="dashboard-content">
            <div class="page-header"><div><h1><i class="fas fa-bullhorn" style="color:var(--accent);"></i> Send Announcement</h1></div><a href="@Url.Action("Dashboard","Admin")" class="btn-back"><i class="fas fa-arrow-left"></i> Back</a></div>
            <div class="form-card">
                <div class="form-header"><h2><i class="fas fa-bullhorn"></i> Send Announcement</h2><p>Broadcast messages to students, teachers, or parents</p></div>
                <form id="announcementForm">
                    @Html.AntiForgeryToken()
                <div class="form-group"><label class="form-label required">Title</label><input type="text" name="Title" class="form-control" required placeholder="Enter announcement title" /></div>
                <div class="form-group"><label class="form-label required">Content / Message</label><textarea name="Content" class="form-control" rows="5" required placeholder="Write your announcement message here..."></textarea></div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                    <div class="form-group"><label class="form-label required">Target Audience</label><select name="TargetAudience" id="TargetAudience" class="form-control" required><option value="">-- Select --</option><option value="All Users">All Users</option><option value="Students Only">Students Only</option><option value="Teachers Only">Teachers Only</option><option value="Parents Only">Parents Only</option></select></div>
                    <div class="form-group"><label class="form-label">Type</label><select name="AnnouncementType" class="form-control"><option value="General">General</option><option value="Important">Important</option><option value="Urgent">Urgent</option><option value="Event">Event</option></select></div>
                    <div class="form-group"><label class="form-label">Filter by Grade</label><select name="TargetGrade" id="TargetGrade" class="form-control"><option value="">All Grades</option><option value="Grade 8">Grade 8</option><option value="Grade 9">Grade 9</option><option value="Grade 10">Grade 10</option><option value="Grade 11">Grade 11</option><option value="Grade 12">Grade 12</option></select></div>
                    <div class="form-group"><label class="form-label">Filter by Class</label><select name="TargetClass" id="TargetClass" class="form-control"><option value="">All Classes</option></select><small style="color:var(--gray-500);">Select grade first</small></div>
                    <div class="form-group"><label class="form-label">Expiry Date</label><input type="date" name="ExpiryDate" class="form-control" /></div>
                </div>
                <div id="message" class="alert"></div>
                <div style="display:flex;gap:14px;margin-top:24px;"><a href="@Url.Action("Dashboard","Admin")" class="btn-cancel"><i class="fas fa-times"></i> Cancel</a><button type="button" class="btn-submit" onclick="submitAnnouncement()"><i class="fas fa-paper-plane"></i> Send</button></div>
            </form>
        </div>
    </div>
</main>
</div>
<script>
    function toggleDropdown(){document.getElementById('profileDropdown').classList.toggle('show');}
    document.addEventListener('click',function(e){var c=document.querySelector('.profile-container');var d=document.getElementById('profileDropdown');if(c&&!c.contains(e.target))d.classList.remove('show');});
    function confirmLogout(e){e.preventDefault();if(confirm('Are you sure you want to logout?')){document.getElementById('logoutForm').submit();}}
    document.getElementById('TargetGrade').addEventListener('change',function(){var g=this.value,s=document.getElementById('TargetClass');if(g){fetch('@Url.Action("GetClassesForGrade","Admin")?grade='+g).then(r=>r.json()).then(r=>{s.innerHTML='<option value="">All Classes</option>';if(r.success&&r.classes)r.classes.forEach(c=>s.innerHTML+='<option value="'+c+'">'+c+'</option>');});}else{s.innerHTML='<option value="">All Classes</option>';}});
    function submitAnnouncement(){var f=document.getElementById('announcementForm');var t=f.querySelector('[name="Title"]').value,c=f.querySelector('[name="Content"]').value,a=f.querySelector('[name="TargetAudience"]').value;if(!t||!c||!a){alert('Fill all required fields');return;}var m=document.getElementById('message');m.style.display='none';var fd=new FormData(f);fetch('@Url.Action("SendAnnouncement","Admin")',{method:'POST',body:fd}).then(r=>r.json()).then(r=>{if(r.success){m.className='alert alert-success';m.innerHTML='<i class="fas fa-check-circle"></i> '+r.message;m.style.display='block';setTimeout(function(){location.href='@Url.Action("ViewAnnouncements","Admin")';},2000);}else{m.className='alert alert-danger';m.innerHTML='<i class="fas fa-exclamation-circle"></i> '+r.message;m.style.display='block';}});}
</script>