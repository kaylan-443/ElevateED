@section Styles {
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 2px solid #e0e0e0;
            flex-wrap: wrap;
            gap: 15px;
        }

        .page-title {
            margin: 0;
            color: #1e3c72;
            font-weight: 700;
        }

            .page-title i {
                color: #d4af37;
                margin-right: 10px;
            }

        .btn-back {
            background: #6c757d;
            color: white;
            padding: 8px 20px;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-back:hover {
                background: #5a6268;
                transform: translateY(-2px);
                color: white;
                text-decoration: none;
            }

        .info-banner {
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            color: white;
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 30px;
        }

            .info-banner h3 {
                margin: 0;
                font-size: 24px;
            }

            .info-banner p {
                margin: 5px 0 0 0;
                opacity: 0.9;
            }

        .subject-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.08);
            overflow: hidden;
            margin-bottom: 20px;
        }

        .subjects-header {
            background: #f8f9fa;
            padding: 15px 20px;
            border-bottom: 2px solid #e0e0e0;
            font-weight: 600;
            font-size: 18px;
            color: #1e3c72;
        }

            .subjects-header i {
                margin-right: 10px;
                color: #d4af37;
            }

        .subject-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
            border-bottom: 1px solid #e0e0e0;
            transition: background 0.3s ease;
        }

            .subject-row:hover {
                background: #f8f9fa;
            }

            .subject-row:last-child {
                border-bottom: none;
            }

        .subject-name {
            font-weight: 600;
            font-size: 16px;
            color: #333;
            flex: 1;
        }

            .subject-name i {
                color: #17a2b8;
                margin-right: 10px;
            }

        .teacher-assigned {
            display: flex;
            align-items: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        .teacher-badge {
            background: #e8f5e9;
            padding: 6px 15px;
            border-radius: 25px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: #28a745;
        }

        .btn-assign {
            background: #28a745;
            color: white;
            border: none;
            padding: 6px 18px;
            border-radius: 25px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
        }

            .btn-assign:hover {
                background: #218838;
            }

            .btn-assign:disabled {
                background: #6c757d;
                cursor: not-allowed;
                opacity: 0.6;
            }

        .btn-remove {
            background: #dc3545;
            color: white;
            border: none;
            padding: 6px 18px;
            border-radius: 25px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
        }

            .btn-remove:hover {
                background: #c82333;
            }

        select {
            padding: 6px 12px;
            border-radius: 8px;
            border: 1px solid #ddd;
            font-size: 13px;
            min-width: 280px;
        }

        .qualified-count {
            background: #17a2b8;
            color: white;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
            margin-left: 10px;
        }

        .no-teachers-notice {
            color: #ffc107;
            font-size: 13px;
            font-style: italic;
        }

        .alert-info {
            background: #d1ecf1;
            color: #0c5460;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .alert-warning {
            background: #fff3cd;
            color: #856404;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .alert-danger {
            background: #f8d7da;
            color: #721c24;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
    </style>
}

@Html.AntiForgeryToken()

<div class="page-header">
    <div class="header-left">
        <h2 class="page-title">
            <i class="fas fa-chalkboard"></i> Class Details
        </h2>
        <small class="text-muted">Assign qualified teachers to subjects for @(Model.Class?.FullName ?? "Unknown")</small>
    </div>
    <div class="header-right">
        <a href="@Url.Action("ClassStructure", "Admin")" class="btn-back">
            <i class="fas fa-arrow-left"></i> Back to Class Structure
        </a>
    </div>
</div>

@if (Model.Class == null)
{
    <div class="alert alert-danger">Class not found.</div>
}
else
{
    <div class="info-banner">
        <h3><i class="fas fa-users"></i> @Model.Class.FullName</h3>
        <p>Grade: @(Model.Class.Grade != null ? Model.Class.Grade.Name : "N/A") | Only qualified teachers shown</p>
    </div>

    <div class="alert alert-info">
        <strong><i class="fas fa-info-circle"></i> Summary:</strong> Teachers Available: @(Model.QualifiedTeachers?.Count ?? 0) | Subjects: @(Model.Subjects?.Count ?? 0)
    </div>

    if (Model.Subjects != null && Model.Subjects.Any())
    {
        var coreSubjects = Model.Subjects.Where(s => s.Category == SubjectCategory.Core).ToList();
        var electiveSubjects = Model.Subjects.Where(s => s.Category == SubjectCategory.Elective).ToList();
        var techSubjects = Model.Subjects.Where(s => s.Category == SubjectCategory.Technology).ToList();

        if (coreSubjects.Any())
        {
            <div class="subject-card">
                <div class="subjects-header"><i class="fas fa-star"></i> CORE SUBJECTS</div>
                @foreach (var subject in coreSubjects)
                {
                    var assignment = Model.CurrentAssignments?.FirstOrDefault(a => a.SubjectId == subject.Id);
                    var qualifiedTeachers = Model.QualifiedTeachers?
                        .Where(t => t.SubjectQualifications != null && t.SubjectQualifications.Any(sq => sq.SubjectId == subject.Id))
                        .Where(t => t.GradeAssignments != null && t.GradeAssignments.Any(ga => ga.GradeId == Model.Class.GradeId))
                        .ToList() ?? new List<Teacher>();

                    <div class="subject-row">
                        <div class="subject-name">
                            <i class="fas fa-book"></i> @subject.Name
                            @if (qualifiedTeachers.Any())
                            {
                                <span class="qualified-count">@qualifiedTeachers.Count qualified</span>
                            }
                        </div>
                        <div class="teacher-assigned">
                            @if (assignment != null)
                            {
                                <div class="teacher-badge">
                                    <i class="fas fa-user-tie"></i> @(assignment.Teacher?.FullName ?? "Unknown")
                                </div>
                                <button class="btn-remove" onclick="removeTeacher(@Model.Class.Id, @subject.Id)">
                                    <i class="fas fa-trash"></i> Remove
                                </button>
                            }
                            else
                            {
                                if (qualifiedTeachers.Any())
                                {
                                    <select id="teacherSelect_@subject.Id" class="teacher-select">
                                        <option value="">-- Select Teacher --</option>
                                        @foreach (var teacher in qualifiedTeachers.OrderBy(t => t.LastName))
                                        {
                                            <option value="@teacher.Id">@teacher.FullName (@teacher.User?.StudentNumber)</option>
                                        }
                                    </select>
                                    <button class="btn-assign" onclick="assignTeacher(@Model.Class.Id, @subject.Id)">
                                        <i class="fas fa-user-plus"></i> Assign
                                    </button>
                                }
                                else
                                {
                                    <span class="no-teachers-notice">No qualified teachers</span>
                                    <button class="btn-assign" disabled>No Teachers</button>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }

        if (electiveSubjects.Any())
        {
            <div class="subject-card">
                <div class="subjects-header"><i class="fas fa-chart-line"></i> ELECTIVE SUBJECTS</div>
                @foreach (var subject in electiveSubjects)
                {
                    var assignment = Model.CurrentAssignments?.FirstOrDefault(a => a.SubjectId == subject.Id);
                    var qualifiedTeachers = Model.QualifiedTeachers?
                        .Where(t => t.SubjectQualifications != null && t.SubjectQualifications.Any(sq => sq.SubjectId == subject.Id))
                        .Where(t => t.GradeAssignments != null && t.GradeAssignments.Any(ga => ga.GradeId == Model.Class.GradeId))
                        .ToList() ?? new List<Teacher>();

                    <div class="subject-row">
                        <div class="subject-name">
                            <i class="fas fa-book"></i> @subject.Name
                            @if (qualifiedTeachers.Any())
                            {
                                <span class="qualified-count">@qualifiedTeachers.Count qualified</span>
                            }
                        </div>
                        <div class="teacher-assigned">
                            @if (assignment != null)
                            {
                                <div class="teacher-badge">
                                    <i class="fas fa-user-tie"></i> @(assignment.Teacher?.FullName ?? "Unknown")
                                </div>
                                <button class="btn-remove" onclick="removeTeacher(@Model.Class.Id, @subject.Id)">
                                    <i class="fas fa-trash"></i> Remove
                                </button>
                            }
                            else
                            {
                                if (qualifiedTeachers.Any())
                                {
                                    <select id="teacherSelect_@subject.Id" class="teacher-select">
                                        <option value="">-- Select Teacher --</option>
                                        @foreach (var teacher in qualifiedTeachers.OrderBy(t => t.LastName))
                                        {
                                            <option value="@teacher.Id">@teacher.FullName (@teacher.User?.StudentNumber)</option>
                                        }
                                    </select>
                                    <button class="btn-assign" onclick="assignTeacher(@Model.Class.Id, @subject.Id)">
                                        <i class="fas fa-user-plus"></i> Assign
                                    </button>
                                }
                                else
                                {
                                    <span class="no-teachers-notice">No qualified teachers</span>
                                    <button class="btn-assign" disabled>No Teachers</button>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }

        if (techSubjects.Any())
        {
            <div class="subject-card">
                <div class="subjects-header"><i class="fas fa-laptop-code"></i> TECHNOLOGY SUBJECTS</div>
                @foreach (var subject in techSubjects)
                {
                    var assignment = Model.CurrentAssignments?.FirstOrDefault(a => a.SubjectId == subject.Id);
                    var qualifiedTeachers = Model.QualifiedTeachers?
                        .Where(t => t.SubjectQualifications != null && t.SubjectQualifications.Any(sq => sq.SubjectId == subject.Id))
                        .Where(t => t.GradeAssignments != null && t.GradeAssignments.Any(ga => ga.GradeId == Model.Class.GradeId))
                        .ToList() ?? new List<Teacher>();

                    <div class="subject-row">
                        <div class="subject-name">
                            <i class="fas fa-book"></i> @subject.Name
                            @if (qualifiedTeachers.Any())
                            {
                                <span class="qualified-count">@qualifiedTeachers.Count qualified</span>
                            }
                        </div>
                        <div class="teacher-assigned">
                            @if (assignment != null)
                            {
                                <div class="teacher-badge">
                                    <i class="fas fa-user-tie"></i> @(assignment.Teacher?.FullName ?? "Unknown")
                                </div>
                                <button class="btn-remove" onclick="removeTeacher(@Model.Class.Id, @subject.Id)">
                                    <i class="fas fa-trash"></i> Remove
                                </button>
                            }
                            else
                            {
                                if (qualifiedTeachers.Any())
                                {
                                    <select id="teacherSelect_@subject.Id" class="teacher-select">
                                        <option value="">-- Select Teacher --</option>
                                        @foreach (var teacher in qualifiedTeachers.OrderBy(t => t.LastName))
                                        {
                                            <option value="@teacher.Id">@teacher.FullName (@teacher.User?.StudentNumber)</option>
                                        }
                                    </select>
                                    <button class="btn-assign" onclick="assignTeacher(@Model.Class.Id, @subject.Id)">
                                        <i class="fas fa-user-plus"></i> Assign
                                    </button>
                                }
                                else
                                {
                                    <span class="no-teachers-notice">No qualified teachers</span>
                                    <button class="btn-assign" disabled>No Teachers</button>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i> No subjects found for this grade level.
        </div>
    }
}

@section Scripts {
    <script>
        function assignTeacher(classId, subjectId) {
            var select = document.getElementById('teacherSelect_' + subjectId);
            if (!select) { alert('Error: Select element not found'); return; }

            var teacherId = select.value;
            if (!teacherId) { alert('Please select a teacher first'); return; }

            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            if (!token) { alert('Security token not found. Refresh the page.'); return; }

            $.ajax({
                url: '@Url.Action("AssignSubjectTeacher", "Admin")',
                type: 'POST',
                data: {
                    __RequestVerificationToken: token,
                    classId: classId,
                    subjectId: subjectId,
                    teacherId: teacherId
                },
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        location.reload();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function() { alert('An error occurred'); }
            });
        }

        function removeTeacher(classId, subjectId) {
            if (!confirm('Remove teacher from this subject?')) return;

            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            if (!token) { alert('Security token not found. Refresh the page.'); return; }

            $.ajax({
                url: '@Url.Action("RemoveSubjectTeacher", "Admin")',
                type: 'POST',
                data: {
                    __RequestVerificationToken: token,
                    classId: classId,
                    subjectId: subjectId
                },
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        location.reload();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function() { alert('An error occurred'); }
            });
        }
    </script>
}