@{
    ViewBag.Title = "Class Details - Admin Dashboard";
    string grade = ViewBag.Grade as string;
    string className = ViewBag.ClassName as string;
    var subjects = ViewBag.Subjects as List<ElevateED.ViewModels.SubjectAssignmentViewModel>;
    var allTeachers = ViewBag.Teachers as List<ElevateED.ViewModels.TeacherViewModel>;

    // Initialize empty lists if null
    if (subjects == null) { subjects = new List<ElevateED.ViewModels.SubjectAssignmentViewModel>(); }
    if (allTeachers == null) { allTeachers = new List<ElevateED.ViewModels.TeacherViewModel>(); }
}

<style>
    :root {
        --primary-blue: #1e3c72;
        --secondary-blue: #2a5298;
        --accent-gold: #d4af37;
        --success-green: #28a745;
        --info-blue: #17a2b8;
        --warning-orange: #ffc107;
        --danger-red: #dc3545;
    }

    .class-details-container {
        padding: 20px 0 40px 0;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 15px;
        border-bottom: 2px solid #e0e0e0;
        flex-wrap: wrap;
        gap: 15px;
    }

    .page-title {
        margin: 0;
        color: var(--primary-blue);
        font-weight: 700;
    }

        .page-title i {
            color: var(--accent-gold);
            margin-right: 10px;
        }

    .class-info {
        background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%);
        color: white;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 30px;
    }

        .class-info h3 {
            margin: 0;
            font-size: 24px;
        }

        .class-info p {
            margin: 5px 0 0 0;
            opacity: 0.9;
        }

    .btn-back {
        background: #6c757d;
        color: white;
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-back:hover {
            background: #5a6268;
            transform: translateY(-2px);
            color: white;
            text-decoration: none;
        }

    .subjects-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.08);
        overflow: hidden;
        margin-bottom: 20px;
    }

    .subjects-header {
        background: #f8f9fa;
        padding: 15px 20px;
        border-bottom: 2px solid #e0e0e0;
        font-weight: 600;
        font-size: 18px;
        color: var(--primary-blue);
    }

        .subjects-header i {
            margin-right: 10px;
            color: var(--accent-gold);
        }

    .subject-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 20px;
        border-bottom: 1px solid #e0e0e0;
        transition: background 0.3s ease;
    }

        .subject-row:hover {
            background: #f8f9fa;
        }

        .subject-row:last-child {
            border-bottom: none;
        }

    .subject-name {
        font-weight: 600;
        font-size: 16px;
        color: #333;
        flex: 1;
    }

        .subject-name i {
            color: var(--info-blue);
            margin-right: 10px;
        }

    .teacher-assigned {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
    }

    .teacher-badge {
        background: #e8f5e9;
        padding: 6px 15px;
        border-radius: 25px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        color: var(--success-green);
    }

    .btn-assign {
        background: linear-gradient(135deg, var(--success-green) 0%, #20c997 100%);
        color: white;
        border: none;
        padding: 6px 18px;
        border-radius: 25px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-assign:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(40,167,69,0.3);
        }

        .btn-assign:disabled {
            background: #6c757d;
            cursor: not-allowed;
            opacity: 0.6;
        }

    .btn-remove {
        background: var(--danger-red);
        color: white;
        border: none;
        padding: 6px 18px;
        border-radius: 25px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-remove:hover {
            background: #c82333;
            transform: translateY(-2px);
        }

    select {
        padding: 6px 12px;
        border-radius: 8px;
        border: 1px solid #ddd;
        font-size: 13px;
        min-width: 280px;
    }

    .no-teachers-notice {
        color: var(--warning-orange);
        font-size: 13px;
        font-style: italic;
    }

    .qualified-count {
        background: var(--info-blue);
        color: white;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 11px;
        margin-left: 10px;
    }

    .dashboard-footer {
        text-align: center;
        margin-top: 40px;
        padding-top: 20px;
        border-top: 1px solid #e0e0e0;
        color: #999;
        font-size: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

    .footer-links {
        display: flex;
        gap: 20px;
    }

        .footer-links a {
            color: #999;
            text-decoration: none;
            transition: color 0.3s ease;
        }

            .footer-links a:hover {
                color: var(--primary-blue);
            }

    @@media (max-width: 768px) {
        .subject-row {
            flex-direction: column;
            gap: 15px;
            align-items: flex-start;
        }

        .teacher-assigned {
            width: 100%;
            justify-content: space-between;
        }

        select {
            min-width: 100%;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="container class-details-container">
    @Html.AntiForgeryToken()

    <!-- Header -->
    <div class="page-header">
        <div class="header-left">
            <h2 class="page-title">
                <i class="fas fa-chalkboard"></i> Class Details
            </h2>
            <small class="text-muted">Assign qualified teachers to subjects for @className</small>
        </div>
        <div class="header-right">
            <a href="@Url.Action("ClassStructure", "Admin")" class="btn-back">
                <i class="fas fa-arrow-left"></i> Back to Class Structure
            </a>
        </div>
    </div>

    <!-- Class Info -->
    <div class="class-info">
        <h3><i class="fas fa-users"></i> @className</h3>
        <p><i class="fas fa-filter"></i> Only teachers qualified for <strong>@grade</strong> and each specific subject are shown</p>
    </div>

    <!-- Debug Info -->
    <div class="alert alert-info mb-3">
        <strong>Total Teachers in Database:</strong> @allTeachers.Count<br>
        <strong>Subjects for @grade:</strong> @subjects.Count<br>
        <small>Teachers are filtered by their registered subjects and grades</small>
    </div>

    <!-- Subjects List -->
    @if (grade != null && (grade.Contains("8") || grade.Contains("9")))
    {
        <!-- Core Subjects for Grade 8 & 9 -->
        <div class="subjects-card">
            <div class="subjects-header">
                <i class="fas fa-star"></i> CORE SUBJECTS
            </div>

            @RenderSubjectRow(1, "English (First Additional Language)", subjects, grade, className)
            @RenderSubjectRow(2, "isiZulu (Home Language)", subjects, grade, className)
            @RenderSubjectRow(3, "Life Orientation", subjects, grade, className)
        </div>

        <!-- Other Subjects for Grade 8 & 9 -->
        <div class="subjects-card">
            <div class="subjects-header">
                <i class="fas fa-book-open"></i> OTHER SUBJECTS
            </div>

            @RenderSubjectRow(4, "Mathematics", subjects, grade, className)
            @RenderSubjectRow(5, "Natural Science", subjects, grade, className)
            @RenderSubjectRow(6, "Social Science", subjects, grade, className)
            @RenderSubjectRow(7, "Creative Arts", subjects, grade, className)
            @RenderSubjectRow(8, "Economic Management Science", subjects, grade, className)
            @RenderSubjectRow(9, "Technology", subjects, grade, className)
        </div>
    }
    else
    {
        <!-- Core Subjects for Grade 10-12 -->
        <div class="subjects-card">
            <div class="subjects-header">
                <i class="fas fa-star"></i> CORE SUBJECTS
            </div>

            @RenderSubjectRow(1, "English (First Additional Language)", subjects, grade, className)
            @RenderSubjectRow(2, "isiZulu (Home Language)", subjects, grade, className)
            @RenderSubjectRow(3, "Life Orientation", subjects, grade, className)
        </div>

        <!-- Elective Subjects for Grade 10-12 -->
        <div class="subjects-card">
            <div class="subjects-header">
                <i class="fas fa-chart-line"></i> ELECTIVE SUBJECTS
            </div>

            @RenderSubjectRow(4, "Mathematics", subjects, grade, className)
            @RenderSubjectRow(5, "Mathematical Literacy", subjects, grade, className)
            @RenderSubjectRow(6, "Physical Sciences", subjects, grade, className)
            @RenderSubjectRow(7, "Life Sciences", subjects, grade, className)
            @RenderSubjectRow(8, "History", subjects, grade, className)
            @RenderSubjectRow(9, "Geography", subjects, grade, className)
            @RenderSubjectRow(10, "Accounting", subjects, grade, className)
            @RenderSubjectRow(11, "Business Studies", subjects, grade, className)
            @RenderSubjectRow(12, "Economics", subjects, grade, className)
            @RenderSubjectRow(13, "Agricultural Sciences", subjects, grade, className)
            @RenderSubjectRow(14, "Computer Applications Technology", subjects, grade, className)
            @RenderSubjectRow(15, "Information Technology", subjects, grade, className)
        </div>
    }

    <!-- Footer -->
    <div class="dashboard-footer">
        <div>
            <i class="fas fa-info-circle mr-1"></i>
            ElevateED School Management System v1.0 | Mpiyakhe High School
        </div>
        <div class="footer-links">
            <a href="@Url.Action("Dashboard", "Admin")" class="text-muted">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
            <a href="@Url.Action("ClassStructure", "Admin")" class="text-muted">
                <i class="fas fa-school"></i> Class Structure
            </a>
            <a href="#" class="text-muted">
                <i class="fas fa-question-circle"></i> Help
            </a>
        </div>
    </div>
</div>

@helper RenderSubjectRow(int subjectId, string subjectName, List<ElevateED.ViewModels.SubjectAssignmentViewModel> subjects, string grade, string className)
{
    var subject = subjects.FirstOrDefault(s => s.Id == subjectId);
    var qualifiedTeachers = subject != null && subject.QualifiedTeachers != null ? subject.QualifiedTeachers : new List<ElevateED.ViewModels.TeacherViewModel>();
    var qualifiedCount = qualifiedTeachers.Count;

    <div class="subject-row" data-subject-id="@subjectId">
        <div class="subject-name">
            <i class="fas fa-book"></i> @subjectName
            @if (qualifiedCount > 0)
            {
                <span class="qualified-count">@qualifiedCount qualified</span>
            }
        </div>
        <div class="teacher-assigned" id="teacher-assign-@subjectId">
            @if (subject != null && subject.AssignedTeacherId.HasValue)
            {
                <div class="teacher-badge">
                    <i class="fas fa-user-tie"></i> @subject.AssignedTeacherName
                </div>
                <button class="btn-remove" onclick="removeTeacher(@subjectId, '@subjectName', '@grade', '@className')">
                    <i class="fas fa-trash"></i> Remove
                </button>
            }
            else
            {
                if (qualifiedCount > 0)
                {
                    <select id="teacherSelect_@subjectId" class="teacher-select">
                        <option value="">-- Select Qualified Teacher --</option>
                        @foreach (var teacher in qualifiedTeachers)
                        {
                            <option value="@teacher.Id">
                                @teacher.FullName (@teacher.StaffNumber) - @teacher.YearsOfExperience yrs
                            </option>
                        }
                    </select>
                    <button class="btn-assign" onclick="assignTeacher(@subjectId, '@subjectName', '@grade', '@className')">
                        <i class="fas fa-user-plus"></i> Assign
                    </button>
                }
                else
                {
                    <span class="no-teachers-notice">
                        <i class="fas fa-exclamation-triangle"></i>
                        No teachers qualified for @subjectName in @grade
                    </span>
                    <button class="btn-assign" disabled>
                        <i class="fas fa-user-plus"></i> No Teachers
                    </button>
                }
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        function assignTeacher(subjectId, subjectName, grade, className) {
            var select = document.getElementById('teacherSelect_' + subjectId);

            if (!select) {
                alert('Error: Could not find teacher select element for subject ' + subjectId);
                return;
            }

            var teacherId = select.value;

            if (!teacherId) {
                alert('Please select a teacher first');
                return;
            }

            var token = $('input[name="__RequestVerificationToken"]').val();
            if (!token) {
                alert('Error: Anti-forgery token not found. Please refresh the page.');
                return;
            }

            var confirmMessage = 'Assign this teacher to teach ' + subjectName + ' in ' + className + '?';

            if (confirm(confirmMessage)) {
                $.ajax({
                    url: '@Url.Action("AssignSubjectTeacher", "Admin")',
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: token,
                        grade: grade,
                        className: className,
                        subjectId: subjectId,
                        teacherId: teacherId
                    },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        var errorMessage = 'An error occurred while assigning the teacher.\n\n';
                        errorMessage += 'Status: ' + status + '\n';
                        errorMessage += 'Error: ' + error + '\n';

                        if (xhr.responseText) {
                            errorMessage += 'Response: ' + xhr.responseText.substring(0, 500);
                        }

                        alert(errorMessage);
                    }
                });
            }
        }

        function removeTeacher(subjectId, subjectName, grade, className) {
            var confirmMessage = 'Remove teacher from ' + subjectName + ' in ' + className + '?';

            if (confirm(confirmMessage)) {
                var token = $('input[name="__RequestVerificationToken"]').val();

                if (!token) {
                    alert('Error: Anti-forgery token not found. Please refresh the page.');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("RemoveSubjectTeacher", "Admin")',
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: token,
                        grade: grade,
                        className: className,
                        subjectId: subjectId
                    },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        alert('An error occurred while removing the teacher. Status: ' + status);
                    }
                });
            }
        }
    </script>
}