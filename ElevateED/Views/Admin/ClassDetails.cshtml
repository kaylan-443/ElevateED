@model ElevateED.ViewModels.ClassDetailsViewModel
@using ElevateED.Models

@{
    ViewBag.Title = "Class Details - " + (Model.Class?.FullName ?? "Unknown");
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --primary: #4f46e5;
        --primary-light: #6366f1;
        --primary-dark: #4338ca;
        --primary-bg: #f5f3ff;
        --primary-soft: #ede9fe;
        --primary-hover: #e0e7ff;
        --accent: #fbbf24;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --sidebar-width: 280px;
        --header-height: 70px;
    }

    body {
        font-family: 'Inter', -apple-system, sans-serif;
        background: var(--gray-50);
        overflow-x: hidden;
    }

    .app-container {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: var(--sidebar-width);
        background: linear-gradient(180deg, #1e1b4b 0%, #2e1065 100%);
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        transition: all 0.3s ease;
        z-index: 100;
        overflow-y: auto;
    }

    .sidebar-header {
        padding: 24px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .logo-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--accent), #f59e0b);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e1b4b;
        font-size: 20px;
    }

    .logo-text {
        font-size: 20px;
        font-weight: 700;
        color: white;
    }

        .logo-text span {
            color: var(--accent);
        }

    .sidebar-nav {
        flex: 1;
        padding: 24px 16px;
    }

    .nav-section {
        margin-top: 24px;
        margin-bottom: 12px;
        padding: 0 16px;
        font-size: 11px;
        font-weight: 600;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        margin-bottom: 8px;
        border-radius: 12px;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .nav-item:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        .nav-item.active {
            background: linear-gradient(135deg, var(--accent), #f59e0b);
            color: #1e1b4b;
        }

        .nav-item i {
            width: 20px;
            font-size: 18px;
        }

        .nav-item span {
            font-size: 14px;
            font-weight: 500;
        }

    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width);
        min-height: 100vh;
    }

    .top-header {
        height: var(--header-height);
        background: white;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: flex-end;
        align-items: center;
        padding: 0 32px;
        position: sticky;
        top: 0;
        z-index: 99;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .notification-btn {
        position: relative;
        background: none;
        border: none;
        font-size: 20px;
        color: var(--gray-500);
        cursor: pointer;
        padding: 8px;
        border-radius: 10px;
        transition: all 0.2s;
    }

        .notification-btn:hover {
            background: var(--gray-100);
        }

    .notification-badge {
        position: absolute;
        top: 2px;
        right: 2px;
        width: 8px;
        height: 8px;
        background: var(--danger);
        border-radius: 50%;
    }

    .profile-container {
        position: relative;
    }

    .profile-trigger {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 50px;
        transition: all 0.2s;
        background: none;
        border: none;
    }

        .profile-trigger:hover {
            background: var(--gray-100);
        }

    .avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 16px;
        text-transform: uppercase;
    }

    .profile-name {
        font-size: 14px;
        font-weight: 500;
        color: var(--gray-700);
    }

    .dropdown-icon {
        font-size: 12px;
        color: var(--gray-400);
    }

    .dropdown-menu {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        width: 240px;
        overflow: hidden;
        display: none;
        z-index: 1000;
    }

        .dropdown-menu.show {
            display: block;
            animation: fadeInDown 0.2s ease;
        }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .dropdown-header {
        padding: 16px;
        border-bottom: 1px solid var(--gray-200);
        background: linear-gradient(135deg, var(--primary-bg), var(--primary-soft));
    }

        .dropdown-header .user-name {
            font-weight: 600;
            color: var(--gray-900);
            margin-bottom: 4px;
        }

        .dropdown-header .user-email {
            font-size: 12px;
            color: var(--gray-500);
        }

    .dropdown-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        text-decoration: none;
        color: var(--gray-700);
        transition: all 0.2s;
        cursor: pointer;
        background: none;
        border: none;
        width: 100%;
        text-align: left;
    }

        .dropdown-item:hover {
            background: var(--primary-hover);
            color: var(--primary);
        }

        .dropdown-item i {
            width: 20px;
            font-size: 16px;
            color: var(--gray-500);
        }

    .dropdown-divider {
        height: 1px;
        background: var(--gray-200);
        margin: 8px 0;
    }

    .dashboard-content {
        padding: 32px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 15px;
        border-bottom: 2px solid #e0e0e0;
        flex-wrap: wrap;
        gap: 15px;
    }

    .page-title {
        margin: 0;
        color: #1e3c72;
        font-weight: 700;
    }

        .page-title i {
            color: #d4af37;
            margin-right: 10px;
        }

    .btn-back {
        background: #6c757d;
        color: white;
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-back:hover {
            background: #5a6268;
            transform: translateY(-2px);
            color: white;
            text-decoration: none;
        }

    .info-banner {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: white;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 30px;
    }

        .info-banner h3 {
            margin: 0;
            font-size: 24px;
        }

        .info-banner p {
            margin: 5px 0 0 0;
            opacity: 0.9;
        }

    .subject-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.08);
        overflow: hidden;
        margin-bottom: 20px;
    }

    .subjects-header {
        background: #f8f9fa;
        padding: 15px 20px;
        border-bottom: 2px solid #e0e0e0;
        font-weight: 600;
        font-size: 18px;
        color: #1e3c72;
    }

        .subjects-header i {
            margin-right: 10px;
            color: #d4af37;
        }

    .subject-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 20px;
        border-bottom: 1px solid #e0e0e0;
        transition: background 0.3s ease;
    }

        .subject-row:hover {
            background: #f8f9fa;
        }

        .subject-row:last-child {
            border-bottom: none;
        }

    .subject-name {
        font-weight: 600;
        font-size: 16px;
        color: #333;
        flex: 1;
    }

        .subject-name i {
            color: #17a2b8;
            margin-right: 10px;
        }

    .teacher-assigned {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
    }

    .teacher-badge {
        background: #e8f5e9;
        padding: 6px 15px;
        border-radius: 25px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        color: #28a745;
    }

    .btn-assign {
        background: #28a745;
        color: white;
        border: none;
        padding: 6px 18px;
        border-radius: 25px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

        .btn-assign:hover {
            background: #218838;
        }

        .btn-assign:disabled {
            background: #6c757d;
            cursor: not-allowed;
            opacity: 0.6;
        }

    .btn-remove {
        background: #dc3545;
        color: white;
        border: none;
        padding: 6px 18px;
        border-radius: 25px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

        .btn-remove:hover {
            background: #c82333;
        }

    select {
        padding: 6px 12px;
        border-radius: 8px;
        border: 1px solid #ddd;
        font-size: 13px;
        min-width: 280px;
    }

    .qualified-count {
        background: #17a2b8;
        color: white;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 11px;
        margin-left: 10px;
    }

    .no-teachers-notice {
        color: #ffc107;
        font-size: 13px;
        font-style: italic;
    }

    .alert-info {
        background: #d1ecf1;
        color: #0c5460;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    .alert-warning {
        background: #fff3cd;
        color: #856404;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    .alert-danger {
        background: #f8d7da;
        color: #721c24;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
    }
</style>

<div class="app-container">
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <div class="logo-icon"><i class="fas fa-graduation-cap"></i></div>
                <div class="logo-text">Elevate<span>ED</span></div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section">Main</div>
            <a href="@Url.Action("Dashboard", "Admin")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
            <a href="@Url.Action("PendingApplications", "Admin")" class="nav-item"><i class="fas fa-file-alt"></i><span>Applications</span></a>
            <a href="@Url.Action("ManageUsers", "Admin")" class="nav-item"><i class="fas fa-users"></i><span>Users</span></a>
            <a href="@Url.Action("ClassStructure", "Admin")" class="nav-item active"><i class="fas fa-school"></i><span>Classes</span></a>
            <a href="@Url.Action("RegisterTeacher", "Admin")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Teachers</span></a>

            <div class="nav-section">Management</div>
            <a href="@Url.Action("TimeTable", "Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>Timetable</span></a>
            <a href="@Url.Action("ExamTimetables", "Admin")" class="nav-item"><i class="fas fa-calendar-check"></i><span>Exam Management</span></a>
            <a href="@Url.Action("ClassRegister", "Admin")" class="nav-item"><i class="fas fa-clipboard-list"></i><span>Class Register</span></a>
            <a href="@Url.Action("SendAnnouncement", "Admin")" class="nav-item"><i class="fas fa-bullhorn"></i><span>Announcements</span></a>
            <a href="@Url.Action("Issues", "Admin")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Issues</span></a>

            <div class="nav-section">Extra</div>
            <a href="@Url.Action("Index", "AdminExtraClass")" class="nav-item"><i class="fas fa-chalkboard-teacher"></i><span>Extra Classes</span></a>
            <a href="@Url.Action("EmergencyAlerts", "AdminExtraClass")" class="nav-item"><i class="fas fa-exclamation-triangle"></i><span>Emergency Alerts</span></a>
            <a href="@Url.Action("ApplicationCycles", "Admin")" class="nav-item"><i class="fas fa-calendar-alt"></i><span>App Cycles</span></a>
            <a href="@Url.Action("Index", "Analytics")" class="nav-item"><i class="fas fa-chart-bar"></i><span>Analytics</span></a>
        </nav>
    </aside>

    <main class="main-content">
        <header class="top-header">
            <div class="header-right">
                <button class="notification-btn"><i class="far fa-bell"></i><span class="notification-badge"></span></button>
                <div class="profile-container">
                    <button class="profile-trigger" onclick="toggleDropdown()">
                        <div class="avatar">A</div>
                        <span class="profile-name">Admin</span>
                        <i class="fas fa-chevron-down dropdown-icon"></i>
                    </button>
                    <div class="dropdown-menu" id="profileDropdown">
                        <div class="dropdown-header">
                            <div class="user-name">Administrator</div>
                            <div class="user-email">admin@mpiyakhehs.co.za</div>
                        </div>
                        <a href="@Url.Action("ManageUsers", "Admin")" class="dropdown-item"><i class="fas fa-users"></i><span>Manage Users</span></a>
                        <div class="dropdown-divider"></div>
                        <form action="@Url.Action("LogOff", "Account")" method="post" id="logoutForm">
                            @Html.AntiForgeryToken()
                            <button type="button" class="dropdown-item" onclick="confirmLogout(event)" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i><span>Logout</span></button>
                        </form>
                    </div>
                </div>
            </div>
        </header>

        <div class="dashboard-content">
            @Html.AntiForgeryToken()

            <div class="page-header">
                <div class="header-left">
                    <h2 class="page-title">
                        <i class="fas fa-chalkboard"></i> Class Details
                    </h2>
                    <small class="text-muted">Assign qualified teachers to subjects for @(Model.Class?.FullName ?? "Unknown")</small>
                </div>
                <div class="header-right">
                    <a href="@Url.Action("ClassStructure", "Admin")" class="btn-back">
                        <i class="fas fa-arrow-left"></i> Back to Class Structure
                    </a>
                </div>
            </div>

            @if (Model.Class == null)
            {
                <div class="alert alert-danger">Class not found.</div>
            }
            else
            {
                <div class="info-banner">
                    <h3><i class="fas fa-users"></i> @Model.Class.FullName</h3>
                    <p>Grade: @(Model.Class.Grade != null ? Model.Class.Grade.Name : "N/A") | Only qualified teachers shown</p>
                </div>

                <div class="alert alert-info">
                    <strong><i class="fas fa-info-circle"></i> Summary:</strong> Teachers Available: @(Model.QualifiedTeachers?.Count ?? 0) | Subjects: @(Model.Subjects?.Count ?? 0)
                </div>

                if (Model.Subjects != null && Model.Subjects.Any())
                {
                    var coreSubjects = Model.Subjects.Where(s => s.Category == SubjectCategory.Core).ToList();
                    var electiveSubjects = Model.Subjects.Where(s => s.Category == SubjectCategory.Elective).ToList();
                    var techSubjects = Model.Subjects.Where(s => s.Category == SubjectCategory.Technology).ToList();

                    if (coreSubjects.Any())
                    {
                        <div class="subject-card">
                            <div class="subjects-header"><i class="fas fa-star"></i> CORE SUBJECTS</div>
                            @foreach (var subject in coreSubjects)
                            {
                                var assignment = Model.CurrentAssignments?.FirstOrDefault(a => a.SubjectId == subject.Id);
                                var qualifiedTeachers = Model.QualifiedTeachers?
                                    .Where(t => t.SubjectQualifications != null && t.SubjectQualifications.Any(sq => sq.SubjectId == subject.Id))
                                    .Where(t => t.GradeAssignments != null && t.GradeAssignments.Any(ga => ga.GradeId == Model.Class.GradeId))
                                    .ToList() ?? new List<Teacher>();

                                <div class="subject-row">
                                    <div class="subject-name">
                                        <i class="fas fa-book"></i> @subject.Name
                                        @if (qualifiedTeachers.Any())
                                        {
                                            <span class="qualified-count">@qualifiedTeachers.Count qualified</span>
                                        }
                                    </div>
                                    <div class="teacher-assigned">
                                        @if (assignment != null)
                                        {
                                            <div class="teacher-badge">
                                                <i class="fas fa-user-tie"></i> @(assignment.Teacher?.FullName ?? "Unknown")
                                            </div>
                                            <button class="btn-remove" onclick="removeTeacher(@Model.Class.Id, @subject.Id)">
                                                <i class="fas fa-trash"></i> Remove
                                            </button>
                                        }
                                        else
                                        {
                                            if (qualifiedTeachers.Any())
                                            {
                                                <select id="teacherSelect_@subject.Id" class="teacher-select">
                                                    <option value="">-- Select Teacher --</option>
                                                    @foreach (var teacher in qualifiedTeachers.OrderBy(t => t.LastName))
                                                    {
                                                        <option value="@teacher.Id">@teacher.FullName (@teacher.User?.StudentNumber)</option>
                                                    }
                                                </select>
                                                <button class="btn-assign" onclick="assignTeacher(@Model.Class.Id, @subject.Id)">
                                                    <i class="fas fa-user-plus"></i> Assign
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="no-teachers-notice">No qualified teachers</span>
                                                <button class="btn-assign" disabled>No Teachers</button>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    if (electiveSubjects.Any())
                    {
                        <div class="subject-card">
                            <div class="subjects-header"><i class="fas fa-chart-line"></i> ELECTIVE SUBJECTS</div>
                            @foreach (var subject in electiveSubjects)
                            {
                                var assignment = Model.CurrentAssignments?.FirstOrDefault(a => a.SubjectId == subject.Id);
                                var qualifiedTeachers = Model.QualifiedTeachers?
                                    .Where(t => t.SubjectQualifications != null && t.SubjectQualifications.Any(sq => sq.SubjectId == subject.Id))
                                    .Where(t => t.GradeAssignments != null && t.GradeAssignments.Any(ga => ga.GradeId == Model.Class.GradeId))
                                    .ToList() ?? new List<Teacher>();

                                <div class="subject-row">
                                    <div class="subject-name">
                                        <i class="fas fa-book"></i> @subject.Name
                                        @if (qualifiedTeachers.Any())
                                        {
                                            <span class="qualified-count">@qualifiedTeachers.Count qualified</span>
                                        }
                                    </div>
                                    <div class="teacher-assigned">
                                        @if (assignment != null)
                                        {
                                            <div class="teacher-badge">
                                                <i class="fas fa-user-tie"></i> @(assignment.Teacher?.FullName ?? "Unknown")
                                            </div>
                                            <button class="btn-remove" onclick="removeTeacher(@Model.Class.Id, @subject.Id)">
                                                <i class="fas fa-trash"></i> Remove
                                            </button>
                                        }
                                        else
                                        {
                                            if (qualifiedTeachers.Any())
                                            {
                                                <select id="teacherSelect_@subject.Id" class="teacher-select">
                                                    <option value="">-- Select Teacher --</option>
                                                    @foreach (var teacher in qualifiedTeachers.OrderBy(t => t.LastName))
                                                    {
                                                        <option value="@teacher.Id">@teacher.FullName (@teacher.User?.StudentNumber)</option>
                                                    }
                                                </select>
                                                <button class="btn-assign" onclick="assignTeacher(@Model.Class.Id, @subject.Id)">
                                                    <i class="fas fa-user-plus"></i> Assign
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="no-teachers-notice">No qualified teachers</span>
                                                <button class="btn-assign" disabled>No Teachers</button>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    if (techSubjects.Any())
                    {
                        <div class="subject-card">
                            <div class="subjects-header"><i class="fas fa-laptop-code"></i> TECHNOLOGY SUBJECTS</div>
                            @foreach (var subject in techSubjects)
                            {
                                var assignment = Model.CurrentAssignments?.FirstOrDefault(a => a.SubjectId == subject.Id);
                                var qualifiedTeachers = Model.QualifiedTeachers?
                                    .Where(t => t.SubjectQualifications != null && t.SubjectQualifications.Any(sq => sq.SubjectId == subject.Id))
                                    .Where(t => t.GradeAssignments != null && t.GradeAssignments.Any(ga => ga.GradeId == Model.Class.GradeId))
                                    .ToList() ?? new List<Teacher>();

                                <div class="subject-row">
                                    <div class="subject-name">
                                        <i class="fas fa-book"></i> @subject.Name
                                        @if (qualifiedTeachers.Any())
                                        {
                                            <span class="qualified-count">@qualifiedTeachers.Count qualified</span>
                                        }
                                    </div>
                                    <div class="teacher-assigned">
                                        @if (assignment != null)
                                        {
                                            <div class="teacher-badge">
                                                <i class="fas fa-user-tie"></i> @(assignment.Teacher?.FullName ?? "Unknown")
                                            </div>
                                            <button class="btn-remove" onclick="removeTeacher(@Model.Class.Id, @subject.Id)">
                                                <i class="fas fa-trash"></i> Remove
                                            </button>
                                        }
                                        else
                                        {
                                            if (qualifiedTeachers.Any())
                                            {
                                                <select id="teacherSelect_@subject.Id" class="teacher-select">
                                                    <option value="">-- Select Teacher --</option>
                                                    @foreach (var teacher in qualifiedTeachers.OrderBy(t => t.LastName))
                                                    {
                                                        <option value="@teacher.Id">@teacher.FullName (@teacher.User?.StudentNumber)</option>
                                                    }
                                                </select>
                                                <button class="btn-assign" onclick="assignTeacher(@Model.Class.Id, @subject.Id)">
                                                    <i class="fas fa-user-plus"></i> Assign
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="no-teachers-notice">No qualified teachers</span>
                                                <button class="btn-assign" disabled>No Teachers</button>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i> No subjects found for this grade level.
                    </div>
                }
            }
        </div>
    </main>
</div>

<script>
    function toggleDropdown() {
        document.getElementById('profileDropdown').classList.toggle('show');
    }

    document.addEventListener('click', function(e) {
        var container = document.querySelector('.profile-container');
        var dropdown = document.getElementById('profileDropdown');
        if (container && !container.contains(e.target)) {
            dropdown.classList.remove('show');
        }
    });

    function confirmLogout(e) {
        e.preventDefault();
        if (confirm('Are you sure you want to logout?')) {
            document.getElementById('logoutForm').submit();
        }
    }

    function assignTeacher(classId, subjectId) {
        var select = document.getElementById('teacherSelect_' + subjectId);
        if (!select) { alert('Error: Select element not found'); return; }

        var teacherId = select.value;
        if (!teacherId) { alert('Please select a teacher first'); return; }

        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        if (!token) { alert('Security token not found. Refresh the page.'); return; }

        $.ajax({
            url: '@Url.Action("AssignSubjectTeacher", "Admin")',
            type: 'POST',
            data: {
                __RequestVerificationToken: token,
                classId: classId,
                subjectId: subjectId,
                teacherId: teacherId
            },
            success: function(response) {
                if (response.success) {
                    alert(response.message);
                    location.reload();
                } else {
                    alert('Error: ' + response.message);
                }
            },
            error: function() { alert('An error occurred'); }
        });
    }

    function removeTeacher(classId, subjectId) {
        if (!confirm('Remove teacher from this subject?')) return;

        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        if (!token) { alert('Security token not found. Refresh the page.'); return; }

        $.ajax({
            url: '@Url.Action("RemoveSubjectTeacher", "Admin")',
            type: 'POST',
            data: {
                __RequestVerificationToken: token,
                classId: classId,
                subjectId: subjectId
            },
            success: function(response) {
                if (response.success) {
                    alert(response.message);
                    location.reload();
                } else {
                    alert('Error: ' + response.message);
                }
            },
            error: function() { alert('An error occurred'); }
        });
    }
</script>