@*
    Shared teacher sidebar. Pass the active page key as the model:
      @Html.Partial("_TeacherSidebar", "extraclasses")
    Recognised keys: dashboard, timetable, classregister, attendance,
    activesessions, homework, classwork, marks, classreports,
    extraclasses, sessionhistory, myproposals, proposeexam,
    examtimetable, pastpapers, studymaterials, quizbank,
    announcements, analytics
*@
@model string
@{
    var active = (Model ?? "").ToLowerInvariant();
    Func<string, string> cls = key => active == key ? "nav-item active" : "nav-item";
}

<aside class="sidebar">
    <div class="sidebar-header">
        <div class="logo">
            <div class="logo-icon"><i class="fas fa-graduation-cap"></i></div>
            <div class="logo-text">Elevate<span>ED</span></div>
        </div>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section">Main Menu</div>
        <a href="@Url.Action("Dashboard","Teacher")" class="@cls("dashboard")">
            <i class="fas fa-tachometer-alt"></i> <span>Dashboard</span>
        </a>
        <a href="@Url.Action("Timetable","Teacher")" class="@cls("timetable")">
            <i class="fas fa-calendar-alt"></i> <span>My Timetable</span>
        </a>
        <a href="@Url.Action("ClassRegister","Teacher")" class="@cls("classregister")">
            <i class="fas fa-clipboard-list"></i> <span>Class Register</span>
        </a>

        <div class="nav-section">Teaching</div>
        <a href="@Url.Action("StartSession","Attendance")" class="@cls("attendance")">
            <i class="fas fa-user-check"></i> <span>Take Attendance</span>
        </a>
        <a href="@Url.Action("ActiveSessions","Attendance")" class="@cls("activesessions")">
            <i class="fas fa-list-alt"></i> <span>Active Sessions</span>
        </a>
        <a href="@Url.Action("Homework","Teacher")" class="@cls("homework")">
            <i class="fas fa-home"></i> <span>Homework</span>
        </a>
        <a href="@Url.Action("Classwork","Teacher")" class="@cls("classwork")">
            <i class="fas fa-chalkboard"></i> <span>Classwork</span>
        </a>
        <a href="@Url.Action("Index","Marks")" class="@cls("marks")">
            <i class="fas fa-clipboard-check"></i> <span>Marks</span>
        </a>
        <a href="@Url.Action("ClassTeacherReports","Marks")" class="@cls("classreports")">
            <i class="fas fa-comment-dots"></i> <span>Class Reports</span>
        </a>

        <div class="nav-section">Extra Classes</div>
        <a href="@Url.Action("Index","TeacherExtraClass")" class="@cls("extraclasses")">
            <i class="fas fa-chalkboard-teacher"></i> <span>My Extra Classes</span>
        </a>
        <a href="@Url.Action("SessionHistory","TeacherExtraClass")" class="@cls("sessionhistory")">
            <i class="fas fa-history"></i> <span>Session History</span>
        </a>

        <div class="nav-section">Exams</div>
        <a href="@Url.Action("MyExamProposals","Teacher")" class="@cls("myproposals")">
            <i class="fas fa-calendar-check"></i> <span>My Exam Proposals</span>
        </a>
        <a href="@Url.Action("ProposeExam","Teacher")" class="@cls("proposeexam")">
            <i class="fas fa-calendar-plus"></i> <span>Propose Exam</span>
        </a>
        <a href="@Url.Action("ViewTeacherExamTimetable","Teacher")" class="@cls("examtimetable")">
            <i class="fas fa-calendar-week"></i> <span>My Exam Timetable</span>
        </a>

        <div class="nav-section">Resources</div>
        <a href="@Url.Action("PastPapers","Teacher")" class="@cls("pastpapers")">
            <i class="fas fa-archive"></i> <span>Past Papers</span>
        </a>
        <a href="@Url.Action("StudyMaterials","Teacher")" class="@cls("studymaterials")">
            <i class="fas fa-book"></i> <span>Study Materials</span>
        </a>
        <a href="@Url.Action("Index","TeacherQuiz")" class="@cls("quizbank")">
            <i class="fas fa-question-circle"></i> <span>Quiz Bank</span>
        </a>

        <div class="nav-section">Communication</div>
        <a href="@Url.Action("ViewAnnouncements","Teacher")" class="@cls("announcements")">
            <i class="fas fa-bullhorn"></i> <span>Announcements</span>
        </a>
        <a href="@Url.Action("Index","Analytics")" class="@cls("analytics")">
            <i class="fas fa-chart-bar"></i> <span>Analytics</span>
        </a>
    </nav>
    <div class="sidebar-footer">
        @{
            var displayName = User.Identity.Name ?? "Teacher";
            var initial = !string.IsNullOrEmpty(displayName) ? displayName.Substring(0, 1).ToUpper() : "T";
        }
        <div class="sidebar-user">
            <div class="sidebar-avatar">@initial</div>
            <div class="sidebar-user-info">
                <div class="sidebar-user-name">Teacher</div>
                <div class="sidebar-user-role">Educator</div>
            </div>
        </div>
        <form action="@Url.Action("LogOff","Account")" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="sidebar-logout">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </form>
    </div>
</aside>