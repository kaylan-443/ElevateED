@model List<ElevateED.Models.AIStudySession>
@{
    ViewBag.Title = "AI Study Assistant";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    ViewBag.ActiveSidebar = "aistudy";
}

@section Styles {
    <style>
        @@keyframes float {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        @@keyframes pulse-glow {
            0%, 100% {
                box-shadow: 0 0 20px rgba(99,102,241,0.4);
            }

            50% {
                box-shadow: 0 0 40px rgba(99,102,241,0.8), 0 0 80px rgba(139,92,246,0.4);
            }
        }

        @@keyframes circuit {
            0% {
                background-position: 0 0;
            }

            100% {
                background-position: 50px 50px;
            }
        }

        .ai-hero {
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 40%, #0f172a 100%);
            border-radius: 24px;
            padding: 40px;
            text-align: center;
            position: relative;
            overflow: hidden;
            margin-bottom: 28px;
            border: 1px solid rgba(99,102,241,0.3);
            box-shadow: 0 0 40px rgba(99,102,241,0.15);
        }

            .ai-hero::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%236366f1' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
                animation: circuit 8s linear infinite;
            }

            .ai-hero .hero-content {
                position: relative;
                z-index: 1;
            }

            .ai-hero h1 {
                font-size: 36px;
                font-weight: 800;
                color: white;
                margin-bottom: 8px;
                background: linear-gradient(135deg, #818cf8, #a78bfa, #818cf8);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-size: 200% 200%;
                animation: float 3s ease-in-out infinite;
            }

            .ai-hero p {
                color: #94a3b8;
                font-size: 16px;
            }

            .ai-hero .ai-badge {
                display: inline-block;
                background: rgba(99,102,241,0.2);
                color: #a5b4fc;
                padding: 6px 16px;
                border-radius: 20px;
                font-size: 12px;
                font-weight: 600;
                border: 1px solid rgba(99,102,241,0.3);
                margin-bottom: 16px;
                letter-spacing: 1px;
            }

        .main-card {
            background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);
            border-radius: 24px;
            overflow: hidden;
            border: 1px solid #e2e8f0;
            box-shadow: 0 4px 24px rgba(0,0,0,0.06);
            margin-bottom: 24px;
        }

            .main-card .card-header {
                background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
                color: white;
                padding: 24px 28px;
                border: none;
                border-bottom: 1px solid rgba(99,102,241,0.3);
                display: flex;
                align-items: center;
                gap: 12px;
            }

                .main-card .card-header .icon-box {
                    width: 40px;
                    height: 40px;
                    background: rgba(99,102,241,0.2);
                    border-radius: 12px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }

                .main-card .card-header h4 {
                    margin: 0;
                    font-weight: 700;
                    font-size: 16px;
                }

                .main-card .card-header small {
                    opacity: 0.7;
                    font-size: 12px;
                }

            .main-card .card-body {
                padding: 28px;
            }

        .upload-zone {
            border: 2px dashed #6366f1;
            border-radius: 16px;
            padding: 40px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            background: rgba(99,102,241,0.03);
        }

            .upload-zone:hover {
                background: rgba(99,102,241,0.08);
                border-color: #818cf8;
            }

            .upload-zone i {
                font-size: 40px;
                color: #6366f1;
                margin-bottom: 12px;
            }

            .upload-zone h5 {
                color: #475569;
                margin: 0;
            }

            .upload-zone p {
                color: #94a3b8;
                font-size: 12px;
                margin-top: 4px;
            }

        .ai-input {
            width: 100%;
            padding: 14px 18px;
            background: #f8fafc;
            border: 2px solid #e2e8f0;
            border-radius: 14px;
            font-size: 14px;
            color: #1e293b;
            transition: all 0.3s;
        }

            .ai-input:focus {
                border-color: #6366f1;
                background: white;
                outline: none;
                box-shadow: 0 0 0 4px rgba(99,102,241,0.1);
            }

        textarea.ai-input {
            resize: vertical;
            min-height: 120px;
        }

        .btn-ai {
            padding: 14px 32px;
            border-radius: 14px;
            border: none;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

            .btn-ai.primary {
                background: linear-gradient(135deg, #6366f1, #8b5cf6);
                color: white;
                box-shadow: 0 4px 20px rgba(99,102,241,0.4);
                width: 100%;
            }

                .btn-ai.primary:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 8px 30px rgba(99,102,241,0.6);
                }

        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 24px 0;
            color: #94a3b8;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #e2e8f0;
            }

        .session-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 16px;
            border-bottom: 1px solid #f1f5f9;
            border-radius: 12px;
            transition: all 0.2s;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
        }

            .session-item:hover {
                background: rgba(99,102,241,0.04);
                transform: translateX(4px);
            }

        .session-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            color: white;
            flex-shrink: 0;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
        }

        .session-info {
            flex: 1;
        }

            .session-info .s-title {
                font-weight: 600;
                font-size: 14px;
                color: #1e293b;
            }

            .session-info .s-meta {
                font-size: 12px;
                color: #94a3b8;
                margin-top: 2px;
            }

        .badge-ai {
            padding: 4px 12px;
            border-radius: 10px;
            font-size: 10px;
            font-weight: 700;
            background: #ede9fe;
            color: #6d28d9;
        }

        .arrow {
            color: #94a3b8;
            font-size: 18px;
        }

        .empty-state {
            text-align: center;
            padding: 50px;
            color: #94a3b8;
        }

            .empty-state i {
                font-size: 48px;
                color: #d1d5db;
                margin-bottom: 12px;
            }
    </style>
}

<div class="container-fluid py-2">
    <!-- Hero -->
    <div class="ai-hero">
        <div class="hero-content">
            <div class="ai-badge"><i class="fas fa-microchip"></i> AI POWERED</div>
            <h1>Study Assistant</h1>
            <p>Upload your notes and generate flashcards, quizzes, exam notes & more</p>
        </div>
    </div>

    <!-- Create Session Card -->
    <div class="main-card">
        <div class="card-header">
            <div class="icon-box"><i class="fas fa-cloud-upload-alt" style="color:#a5b4fc;"></i></div>
            <div>
                <h4>Create New Study Session</h4>
                <small>Upload notes or paste text to get started</small>
            </div>
        </div>
        <div class="card-body">
            <form action="@Url.Action("CreateSession", "AIStudy")" method="post" enctype="multipart/form-data">
                <div style="margin-bottom:12px;">
                    <input type="text" name="sessionTitle" class="ai-input" placeholder="Session name (optional)">
                </div>
                <div class="upload-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
                    <i class="fas fa-cloud-upload-alt"></i>
                    <h5>Click to upload or drag & drop</h5>
                    <p>PDF, TXT (max 20MB)</p>
                    <p id="fileNameDisplay" style="color:#6366f1;font-weight:500;margin-top:8px;"></p>
                </div>
                <input type="file" name="file" id="fileInput" accept=".pdf,.txt" style="display:none;" onchange="document.getElementById('fileNameDisplay').textContent='📎 '+this.files[0].name">
                <div class="divider">or paste text</div>
                <textarea name="pasteText" class="ai-input" placeholder="Paste your study notes here..."></textarea>
                <button type="submit" class="btn-ai primary" style="margin-top:16px;">
                    <i class="fas fa-magic"></i> Create Study Session
                </button>
            </form>
        </div>
    </div>

    <!-- Existing Sessions Card -->
    <div class="main-card">
        <div class="card-header">
            <div class="icon-box"><i class="fas fa-folder-open" style="color:#a5b4fc;"></i></div>
            <div>
                <h4>Your Study Sessions</h4>
                <small>@Model.Count session@(Model.Count != 1 ? "s" : "")</small>
            </div>
        </div>
        <div class="card-body" style="padding:12px 20px;">
            @if (Model.Any())
            {
                foreach (var s in Model)
                {
                    <a href="@Url.Action("Workspace", new { id = s.Id })" class="session-item">
                        <div class="session-icon"><i class="fas fa-file-alt"></i></div>
                        <div class="session-info">
                            <div class="s-title">@(s.SessionTitle ?? "Untitled Session")</div>
                            <div class="s-meta">@s.OutputCount outputs • @s.CreatedDate.ToString("dd MMM yyyy") • @s.TextPreview</div>
                        </div>
                        <span class="badge-ai">@s.OutputCount items</span>
                        <span class="arrow">→</span>
                    </a>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <h5 style="color:#64748b;">No study sessions yet</h5>
                    <p>Upload your notes above to create your first AI-powered study session!</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var dz = document.getElementById('dropZone');
        dz.addEventListener('dragover', function (e) {
            e.preventDefault();
            dz.style.borderColor = '#818cf8';
            dz.style.background = 'rgba(99,102,241,0.08)';
        });
        dz.addEventListener('dragleave', function () {
            dz.style.borderColor = '#6366f1';
            dz.style.background = 'rgba(99,102,241,0.03)';
        });
        dz.addEventListener('drop', function (e) {
            e.preventDefault();
            dz.style.borderColor = '#6366f1';
            dz.style.background = 'rgba(99,102,241,0.03)';
            var files = e.dataTransfer.files;
            if (files.length > 0) {
                document.getElementById('fileInput').files = files;
                document.getElementById('fileNameDisplay').textContent = '📎 ' + files[0].name;
            }
        });
    </script>
}