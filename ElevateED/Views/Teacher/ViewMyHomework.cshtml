@model List<ElevateED.ViewModels.HomeworkListViewModel>

@{
    ViewBag.Title = "My Uploaded Homework";
    var teacherName = ViewBag.TeacherName as string;
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --primary: #4f46e5;
        --accent: #fbbf24;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --purple: #8b5cf6;
        --orange: #f97316;
        --teal: #16a085;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --sidebar-width: 280px;
        --header-height: 70px;
    }

    body {
        font-family: 'Inter', -apple-system, sans-serif;
        background: var(--gray-50);
    }

    .app-container {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: var(--sidebar-width);
        background: linear-gradient(180deg, #1e1b4b 0%, #2e1065 100%);
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        z-index: 100;
        overflow-y: auto;
    }

    .sidebar-header {
        padding: 24px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .logo-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--accent), #f59e0b);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e1b4b;
        font-size: 20px;
    }

    .logo-text {
        font-size: 20px;
        font-weight: 700;
        color: white;
    }

        .logo-text span {
            color: var(--accent);
        }

    .sidebar-nav {
        flex: 1;
        padding: 24px 16px;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        margin-bottom: 8px;
        border-radius: 12px;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        transition: all 0.2s;
        font-size: 14px;
        font-weight: 500;
    }

        .nav-item:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        .nav-item.active {
            background: linear-gradient(135deg, var(--accent), #f59e0b);
            color: #1e1b4b;
        }

        .nav-item i {
            width: 20px;
            font-size: 18px;
        }

    .nav-section {
        margin-top: 24px;
        margin-bottom: 12px;
        padding: 0 16px;
        font-size: 11px;
        font-weight: 600;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width);
        min-height: 100vh;
    }

    .top-header {
        height: var(--header-height);
        background: white;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: flex-end;
        align-items: center;
        padding: 0 32px;
        position: sticky;
        top: 0;
        z-index: 99;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .profile-trigger {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 50px;
        transition: all 0.2s;
        background: none;
        border: none;
    }

        .profile-trigger:hover {
            background: var(--gray-100);
        }

    .avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--primary), #4338ca);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 16px;
        text-transform: uppercase;
    }

    .dropdown-menu {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        width: 220px;
        overflow: hidden;
        display: none;
        z-index: 1000;
    }

        .dropdown-menu.show {
            display: block;
        }

    .content-area {
        padding: 32px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 15px;
    }

        .page-header h1 {
            font-size: 26px;
            font-weight: 700;
            color: var(--gray-900);
        }

    .btn-back {
        background: white;
        color: var(--gray-700);
        padding: 10px 20px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 500;
        border: 1px solid var(--gray-200);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-back:hover {
            background: var(--gray-100);
            text-decoration: none;
        }

    .homework-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 16px;
        border: 1px solid var(--gray-200);
        transition: all 0.3s;
        border-left: 4px solid var(--teal);
    }

        .homework-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.06);
        }

    .homework-title {
        font-size: 17px;
        font-weight: 600;
        color: var(--gray-900);
        margin-bottom: 8px;
    }

    .subject-badge {
        display: inline-block;
        background: #e8f4fd;
        color: #17a2b8;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 10px;
        margin-right: 6px;
    }

    .homework-instructions {
        color: var(--gray-600);
        font-size: 14px;
        margin-bottom: 12px;
        line-height: 1.5;
    }

    .homework-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 14px;
        font-size: 13px;
        color: var(--gray-500);
    }

    .due-date {
        color: var(--danger);
        font-weight: 600;
    }

    .btn-sm {
        padding: 7px 14px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        margin-right: 6px;
    }

    .btn-dl {
        background: var(--teal);
        color: white;
    }

        .btn-dl:hover {
            background: #1abc9c;
            color: white;
            text-decoration: none;
        }

    .btn-grade {
        background: var(--orange);
        color: white;
    }

        .btn-grade:hover {
            background: #ea580c;
            color: white;
            text-decoration: none;
        }

    .btn-analytics {
        background: var(--purple);
        color: white;
    }

        .btn-analytics:hover {
            background: #7c3aed;
            color: white;
            text-decoration: none;
        }

    .btn-del {
        background: var(--danger);
        color: white;
    }

        .btn-del:hover {
            background: #dc2626;
        }

    .empty-state {
        text-align: center;
        padding: 60px;
        background: white;
        border-radius: 16px;
        border: 1px solid var(--gray-200);
    }

        .empty-state i {
            font-size: 48px;
            color: var(--gray-400);
            margin-bottom: 15px;
        }

    @@media (max-width: 1024px) {
        .sidebar {
            transform: translateX(-100%);
        }

        .main-content {
            margin-left: 0;
        }
    }
</style>

<div class="app-container">
    <aside class="sidebar">
        <div class="sidebar-header"><div class="logo"><div class="logo-icon"><i class="fas fa-graduation-cap"></i></div><div class="logo-text">Elevate<span>ED</span></div></div></div>
        <nav class="sidebar-nav">
            <div class="nav-section">Main</div>
            <a href="@Url.Action("Dashboard","Teacher")" class="nav-item"><i class="fas fa-home"></i><span>Dashboard</span></a>
            <div class="nav-section">Teaching</div>
            <a href="@Url.Action("Homework","Teacher")" class="nav-item active"><i class="fas fa-home"></i><span>Homework</span></a>
        </nav>
    </aside>
    <main class="main-content">
        <header class="top-header"><div class="header-right"><div class="profile-container" style="position:relative;"><button class="profile-trigger" onclick="toggleDropdown()"><div class="avatar">T</div></button></div></div></header>
        <div class="content-area">
            <div class="page-header"><div><h1><i class="fas fa-home" style="color:var(--teal);"></i> My Uploaded Homework</h1><p style="color:var(--gray-500);">View and manage homework you've assigned</p></div><a href="@Url.Action("Homework","Teacher")" class="btn-back"><i class="fas fa-arrow-left"></i> Back to Subjects</a></div>

            @if (Model == null || !Model.Any())
            {<div class="empty-state"><i class="fas fa-inbox"></i><h4>No Homework Uploaded</h4><a href="@Url.Action("Homework","Teacher")" class="btn-sm btn-dl" style="display:inline-flex;margin-top:12px;">Assign Homework</a></div>}
            else
            {
                foreach (var item in Model)
                {
                    bool isOverdue = item.DueDate < DateTime.Now;
                    <div class="homework-card" id="homework-@item.Id">
                        <div class="homework-title">@item.Title</div>
                        <div><span class="subject-badge">@item.Subject</span><span class="subject-badge">@item.ClassName</span></div>
                        <div class="homework-instructions">@item.Instructions</div>
                        <div class="homework-meta">
                            <span><i class="fas fa-calendar"></i> Posted: @item.UploadedAt.ToString("dd MMM yyyy")</span>
                            <span class="@(isOverdue?"due-date":"")"><i class="fas fa-hourglass-half"></i> Due: @item.DueDateFormatted</span>
                            <span><i class="fas fa-hdd"></i> @item.FileSizeFormatted</span>
                        </div>
                        <div style="display:flex;gap:8px;flex-wrap:wrap;">
                            <a href="@Url.Action("DownloadHomework","Teacher",new{id=item.Id})" class="btn-sm btn-dl"><i class="fas fa-download"></i> Download</a>
                            <a href="@Url.Action("GradeHomework","Teacher",new{id=item.Id})" class="btn-sm btn-grade"><i class="fas fa-check-circle"></i> Grade</a>
                            <a href="@Url.Action("SubmissionAnalytics","Teacher",new{id=item.Id,type="homework"})" class="btn-sm btn-analytics"><i class="fas fa-chart-line"></i> Analytics</a>
                            <button class="btn-sm btn-del" onclick="delHomework(@item.Id)"><i class="fas fa-trash"></i> Delete</button>
                        </div>
                    </div>}
            }
        </div>
    </main>
</div>
<script>
    function toggleDropdown(){document.getElementById('profileDropdown').classList.toggle('show');}
    document.addEventListener('click',function(e){var c=document.querySelector('.profile-container');var d=document.getElementById('profileDropdown');if(c&&!c.contains(e.target))d.classList.remove('show');});
    function delHomework(id){if(!confirm('Delete this homework?'))return;var t=document.querySelector('input[name="__RequestVerificationToken"]').value;fetch('@Url.Action("DeleteHomework","Teacher")',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'__RequestVerificationToken='+t+'&id='+id}).then(r=>r.json()).then(r=>{if(r.success){var c=document.getElementById('homework-'+id);if(c)c.style.display='none';if(!document.querySelectorAll('.homework-card:not([style*="display:none"])').length)location.reload();}else alert(r.message);});}
</script>