@{
    ViewBag.Title = "Select Class - " + ViewBag.Grade;
    var teacherName = ViewBag.TeacherName as string;
    var grade = ViewBag.Grade as string;
    var classes = ViewBag.Classes as List<string>;
}

<div class="container" style="padding: 40px 0;">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("ClassRegister", "Teacher")">Grades</a></li>
            <li class="breadcrumb-item active">@grade</li>
        </ol>
    </nav>

    <h2><i class="fas fa-users text-success"></i> Select a Class</h2>
    <p class="text-muted">Choose a class in @grade to view its register.</p>

    <div class="row mt-4">
        @foreach (var className in classes)
        {
            <div class="col-md-4 col-lg-3 mb-4">
                <div class="card text-center p-4 border-success" onclick="location.href='@Url.Action("ViewClassRegisters", "Teacher", new { grade = grade, className = className })'" style="cursor: pointer; transition: all 0.3s;">
                    <div class="mb-3">
                        <i class="fas fa-door-open fa-3x text-success"></i>
                    </div>
                    <h4>@className</h4>
                    <p class="text-muted mb-0">View register</p>
                </div>
            </div>
        }
    </div>
</div>