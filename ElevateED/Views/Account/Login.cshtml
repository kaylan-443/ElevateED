@model ElevateED.ViewModels.LoginViewModel

@{
    ViewBag.Title = "Login - ElevateED";
}

<style>
    :root {
        --primary-blue: #1e3c72;
        --secondary-blue: #2a5298;
        --accent-gold: #d4af37;
    }

    .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%);
        padding: 20px;
    }

    .login-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        overflow: hidden;
        width: 100%;
        max-width: 450px;
    }

    .login-header {
        background: linear-gradient(135deg, var(--accent-gold) 0%, #f4d03f 100%);
        padding: 30px;
        text-align: center;
        color: var(--primary-blue);
    }

        .login-header i {
            font-size: 50px;
            margin-bottom: 10px;
            display: block;
        }

        .login-header h2 {
            font-weight: 700;
            margin: 0;
            font-size: 24px;
        }

        .login-header p {
            margin: 5px 0 0 0;
            opacity: 0.9;
            font-size: 14px;
        }

    .login-body {
        padding: 30px;
    }

    .form-group label {
        font-weight: 600;
        color: #555;
        font-size: 14px;
    }

    .input-group-text {
        background: var(--primary-blue);
        color: white;
        border: none;
        width: 45px;
        justify-content: center;
    }

    .form-control {
        border: 2px solid #e0e0e0;
        padding: 12px 15px;
        height: auto;
    }

        .form-control:focus {
            border-color: var(--secondary-blue);
            box-shadow: 0 0 0 0.2rem rgba(42, 82, 152, 0.25);
        }

    .btn-login {
        background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%);
        color: white;
        padding: 15px;
        font-size: 16px;
        font-weight: 600;
        border: none;
        border-radius: 50px;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(30, 60, 114, 0.3);
            color: white;
        }

    .login-footer {
        text-align: center;
        padding: 20px;
        background: #f8f9fa;
        border-top: 1px solid #e0e0e0;
    }

    .hint-box {
        background: #e3f2fd;
        border-left: 4px solid var(--secondary-blue);
        padding: 15px;
        margin-bottom: 20px;
        border-radius: 5px;
        font-size: 13px;
    }

    .role-examples {
        display: flex;
        gap: 15px;
        justify-content: center;
        margin-top: 10px;
        font-size: 12px;
    }

    .role-badge {
        background: #e9ecef;
        padding: 5px 10px;
        border-radius: 15px;
        color: #555;
    }

        .role-badge code {
            background: #1e3c72;
            color: white;
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 11px;
        }
</style>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <i class="fas fa-graduation-cap"></i>
            <h2>ElevateED Portal</h2>
            <p>Mpiyakhe High School</p>
        </div>

        <div class="login-body">
            

            @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "login-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                <div class="form-group mb-3">
                    @Html.LabelFor(m => m.StudentNumber, "Staff ID / Learner ID")
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                        </div>
                        @Html.TextBoxFor(m => m.StudentNumber, new { @class = "form-control", placeholder = "Enter your ID number", autocomplete = "off" })
                    </div>
                    @Html.ValidationMessageFor(m => m.StudentNumber, "", new { @class = "text-danger small" })
                </div>

                <div class="form-group mb-3">
                    @Html.LabelFor(m => m.Password)
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                        </div>
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Enter your password", id = "password-input" })
                        <div class="input-group-append">
                            <span class="input-group-text" style="cursor: pointer; background: #e9ecef; color: #666;" onclick="togglePassword()">
                                <i class="fas fa-eye" id="toggleIcon"></i>
                            </span>
                        </div>
                    </div>
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                </div>

                <div class="form-group mb-4">
                    <div class="custom-control custom-checkbox">
                        @Html.CheckBoxFor(m => m.RememberMe, new { @class = "custom-control-input" })
                        @Html.LabelFor(m => m.RememberMe, new { @class = "custom-control-label" })
                    </div>
                </div>

                <button type="submit" class="btn btn-login">
                    <i class="fas fa-sign-in-alt mr-2"></i>Sign In
                </button>
            }
        </div>

        <div class="login-footer">
            <p class="mb-2">New Student? Apply for Enrolment</p>
            <a href="@Url.Action("Apply", "Application")" class="btn btn-outline-primary btn-sm">
                <i class="fas fa-edit mr-1"></i>Apply Now
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword() {
            var passwordInput = document.getElementById('password-input');
            var toggleIcon = document.getElementById('toggleIcon');

            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('fa-eye');
                toggleIcon.classList.add('fa-eye-slash');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('fa-eye-slash');
                toggleIcon.classList.add('fa-eye');
            }
        }

        // Auto-format input to uppercase
        document.getElementById('StudentNumber').addEventListener('input', function () {
            this.value = this.value.toUpperCase();
        });
    </script>
}