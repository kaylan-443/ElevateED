@{
    ViewBag.Title = "Change Password - ElevateED";
    bool isFirstLogin = ViewBag.FirstLogin ?? false;
}

<style>
    :root {
        --primary-blue: #1e3c72;
        --secondary-blue: #2a5298;
        --accent-gold: #d4af37;
        --success-green: #28a745;
    }

    .password-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%);
        padding: 20px;
    }

    .password-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        width: 100%;
        max-width: 500px;
        overflow: hidden;
    }

    .password-header {
        background: linear-gradient(135deg, var(--accent-gold) 0%, #f4d03f 100%);
        padding: 30px;
        text-align: center;
        color: var(--primary-blue);
    }

        .password-header i {
            font-size: 50px;
            margin-bottom: 15px;
            display: block;
        }

        .password-header h2 {
            font-weight: 700;
            margin: 0;
        }

    .password-body {
        padding: 40px;
    }

    .alert-first-login {
        background: #e3f2fd;
        border-left: 4px solid var(--secondary-blue);
        padding: 20px;
        margin-bottom: 25px;
        border-radius: 8px;
    }

        .alert-first-login i {
            color: var(--secondary-blue);
            font-size: 24px;
            margin-bottom: 10px;
        }

    .form-group label {
        font-weight: 600;
        color: #555;
        margin-bottom: 8px;
    }

    .form-control {
        border: 2px solid #e0e0e0;
        padding: 12px 15px;
        border-radius: 8px;
        height: auto;
    }

        .form-control:focus {
            border-color: var(--secondary-blue);
            box-shadow: 0 0 0 0.2rem rgba(42, 82, 152, 0.25);
        }

    .input-group-text {
        background: var(--primary-blue);
        color: white;
        border: none;
        cursor: pointer;
    }

    .btn-change-password {
        background: linear-gradient(135deg, var(--success-green) 0%, #20c997 100%);
        color: white;
        padding: 15px;
        font-size: 16px;
        font-weight: 600;
        border: none;
        border-radius: 50px;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
    }

        .btn-change-password:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(40, 167, 69, 0.3);
            color: white;
        }

    .password-requirements {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 8px;
        margin-top: 20px;
    }

        .password-requirements h6 {
            color: var(--primary-blue);
            margin-bottom: 10px;
        }

    .requirement {
        font-size: 13px;
        color: #666;
        margin-bottom: 5px;
    }

        .requirement i {
            color: #ccc;
            margin-right: 8px;
        }

        .requirement.met i {
            color: var(--success-green);
        }

    .validation-summary-errors {
        background: #f8d7da;
        color: #721c24;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
    }
</style>

<div class="password-container">
    <div class="password-card">
        <div class="password-header">
            <i class="fas fa-lock"></i>
            <h2>@(isFirstLogin ? "Welcome! Set Your Password" : "Change Password")</h2>
        </div>

        <div class="password-body">

            @if (isFirstLogin)
            {
                <div class="alert-first-login">
                    <i class="fas fa-shield-alt d-block text-center"></i>
                    <h5 class="text-center mb-2">Security First!</h5>
                    <p class="mb-0 text-center">
                        For your security, please change your temporary password to something you'll remember.
                        This is required before you can access your dashboard.
                    </p>
                </div>
            }

            @if (!string.IsNullOrEmpty(TempData["SuccessMessage"] as string))
            {
                <div class="alert alert-success">
                    @TempData["SuccessMessage"]
                </div>
            }

            @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

            @using (Html.BeginForm("ChangePassword", "Account", FormMethod.Post, new { id = "changePasswordForm" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="firstLogin" value="@(isFirstLogin ? "true" : "false")" />

                if (!isFirstLogin)
                {
                    <div class="form-group mb-3">
                        <label>Current Password</label>
                        <div class="input-group">
                            <input type="password" name="currentPassword" id="currentPassword" class="form-control" required />
                            <div class="input-group-append">
                                <span class="input-group-text" onclick="togglePassword('currentPassword')">
                                    <i class="fas fa-eye"></i>
                                </span>
                            </div>
                        </div>
                    </div>
                }

                <div class="form-group mb-3">
                    <label>New Password</label>
                    <div class="input-group">
                        <input type="password" name="newPassword" id="newPassword" class="form-control" required minlength="6" />
                        <div class="input-group-append">
                            <span class="input-group-text" onclick="togglePassword('newPassword')">
                                <i class="fas fa-eye"></i>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label>Confirm New Password</label>
                    <div class="input-group">
                        <input type="password" name="confirmPassword" id="confirmPassword" class="form-control" required />
                        <div class="input-group-append">
                            <span class="input-group-text" onclick="togglePassword('confirmPassword')">
                                <i class="fas fa-eye"></i>
                            </span>
                        </div>
                    </div>
                    <small id="passwordMatchError" class="text-danger" style="display: none;">
                        Passwords do not match
                    </small>
                </div>

                <button type="submit" class="btn btn-change-password" id="submitBtn">
                    <i class="fas fa-save mr-2"></i>@(isFirstLogin ? "Set Password & Continue" : "Change Password")
                </button>
            }

            <div class="password-requirements">
                <h6><i class="fas fa-info-circle mr-2"></i>Password Requirements</h6>
                <div class="requirement" id="req-length">
                    <i class="fas fa-circle"></i> At least 6 characters
                </div>
                <div class="requirement" id="req-match">
                    <i class="fas fa-circle"></i> Passwords must match
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>function togglePassword(fieldId) {
            var field = document.getElementById(fieldId);
            var icon = field.parentElement.querySelector('.input-group-text i');

            if (field.type === 'password') {
                field.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                field.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }

        // Real-time validation
        document.getElementById('newPassword').addEventListener('input', function() {
            var lengthReq = document.getElementById('req-length');
            if (this.value.length >= 6) {
                lengthReq.classList.add('met');
                lengthReq.querySelector('i').classList.remove('fa-circle');
                lengthReq.querySelector('i').classList.add('fa-check-circle');
            } else {
                lengthReq.classList.remove('met');
                lengthReq.querySelector('i').classList.remove('fa-check-circle');
                lengthReq.querySelector('i').classList.add('fa-circle');
            }
            checkMatch();
        });

        document.getElementById('confirmPassword').addEventListener('input', checkMatch);

        function checkMatch() {
            var newPass = document.getElementById('newPassword').value;
            var confirmPass = document.getElementById('confirmPassword').value;
            var matchReq = document.getElementById('req-match');
            var errorMsg = document.getElementById('passwordMatchError');

            if (confirmPass.length > 0) {
                if (newPass === confirmPass) {
                    matchReq.classList.add('met');
                    matchReq.querySelector('i').classList.remove('fa-circle');
                    matchReq.querySelector('i').classList.add('fa-check-circle');
                    errorMsg.style.display = 'none';
                } else {
                    matchReq.classList.remove('met');
                    matchReq.querySelector('i').classList.remove('fa-check-circle');
                    matchReq.querySelector('i').classList.add('fa-circle');
                    errorMsg.style.display = 'block';
                }
            }
        }

        // Form validation
        document.getElementById('changePasswordForm').addEventListener('submit', function(e) {
            var newPass = document.getElementById('newPassword').value;
            var confirmPass = document.getElementById('confirmPassword').value;

            if (newPass !== confirmPass) {
                e.preventDefault();
                alert('Passwords do not match!');
                return false;
            }

            if (newPass.length < 6) {
                e.preventDefault();
                alert('Password must be at least 6 characters!');
                return false;
            }
        });</script>
}